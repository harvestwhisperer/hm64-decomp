; Dialogue Bank
; Index Start: 0xE92800
; Bytecode Start: 0xE92640
; Segments: 43

; This bank hosts bytecode for several shops/menus. Each shop has its own
; entry segment invoked from C with initializeDialogueSession / showMessageBox
; (see game.c showDialogueTextBox, overlayScreens.c). Many segments here are
; independent entry points rather than links from segment_0.

; aliases for segment names

.define .lillia_menu 0
.define .lillia_season_branch 1
.define .lillia_grass_reply 2
.define .lillia_flowers_reply 3
