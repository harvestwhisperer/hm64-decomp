; Flower shop

; 0xE92640
.lillia_menu:
    ; choices from text 1: Vegetables / Grass / Flowers / Nothing
    SHOW_SELECTION_MENU 1, 4
    HANDLE_MENU_SELECTION_BRANCH 0, .lillia_season_branch
    HANDLE_MENU_SELECTION_BRANCH 1, .lillia_grass_reply
    HANDLE_MENU_SELECTION_BRANCH 2, .lillia_flowers_reply
    HANDLE_MENU_SELECTION_BRANCH 3, .lillia_exit_reply
    END_DIALOGUE

; 0xE92658
.lillia_season_branch:
    DIALOGUE_VARIABLE_BRANCH VAR_SEASON, 1, 1, NO_TEXT, .lillia_spring_veg_menu
    DIALOGUE_VARIABLE_BRANCH VAR_SEASON, 2, 2, NO_TEXT, .lillia_summer_veg_menu
    DIALOGUE_VARIABLE_BRANCH VAR_SEASON, 3, 3, NO_TEXT, .lillia_autumn_veg_info
    DIALOGUE_VARIABLE_BRANCH VAR_SEASON, 4, 4, NO_TEXT, .lillia_winter_veg_info
    END_DIALOGUE

; 0xE92684
.lillia_grass_reply:
    RANDOM_BRANCH 0, 49, 11, .lillia_menu
    SHOW_TEXT 12
    JUMP_TO_DIALOGUE .lillia_menu
    END_DIALOGUE

; 0xE92694
.lillia_flowers_reply:
    SHOW_TEXT 13
    JUMP_TO_DIALOGUE .lillia_menu
    END_DIALOGUE

; 0xE9269C
.lillia_exit_reply:
    SHOW_TEXT 151
    END_DIALOGUE

; 0xE926A0
.lillia_spring_veg_menu:
    SHOW_SELECTION_MENU 2, 4
    HANDLE_MENU_SELECTION_BRANCH 0, .lillia_turnip_info
    HANDLE_MENU_SELECTION_BRANCH 1, .lillia_potato_info
    HANDLE_MENU_SELECTION_BRANCH 2, .lillia_cabbage_info
    HANDLE_MENU_SELECTION_BRANCH 3, .lillia_menu
    END_DIALOGUE

; 0xE926B8
.lillia_summer_veg_menu:
    SHOW_SELECTION_MENU 3, 3
    HANDLE_MENU_SELECTION_BRANCH 0, .lillia_tomato_info
    HANDLE_MENU_SELECTION_BRANCH 1, .lillia_corn_info
    HANDLE_MENU_SELECTION_BRANCH 2, .lillia_menu
    END_DIALOGUE

; 0xE926CC
