; ==========================================================
; Cliff
; ==========================================================

.cliff_setup:
    SETUP_ENTITY 30, ENTITY_ASSET_CLIFF, 1
    SET_ENTITY_ANIMATIONS 30, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    RETURN_FROM_SUBROUTINE

.cliff_arm_callback_1:
    SET_CALLBACK_ROUTINE 0, 32768, .cliff_dispatch
    BRANCH_U16_VAR_WITHIN_RANGE 210, 210, gCutsceneIndex, .wait_until_hour_17
    BRANCH_U16_VAR_WITHIN_RANGE 212, 213, gCutsceneIndex, .wait_until_hour_18
    EXECUTE_SUBROUTINE .wait_until_hour_9

.cliff_walk_in_1:
    EXECUTE_SUBROUTINE .cliff_setup
    SET_ASSET_ROTATION 6
    SET_COORDINATES -590, 0, 152
    ENTITY_WALK 34, DIRECTION_E, 2
    EXECUTE_SUBROUTINE .show_doorstep_greeting_text_620
    ENTITY_WALK 90, DIRECTION_E, 2
    SET_ASSET_ROTATION 4
    EXECUTE_SUBROUTINE .cliff_arm_callback_1

.cliff_walk_in_2:
    EXECUTE_SUBROUTINE .cliff_setup
    UPDATE_RGBA 254, 254, 254, 254, 0
    SET_ASSET_ROTATION 4
    SET_COORDINATES -342, 0, 152
    BRANCH_U16_VAR_WITHIN_RANGE 214, 214, gCutsceneIndex, .idle
    WAIT_RGBA_FINISHED
    EXECUTE_SUBROUTINE .show_doorstep_greeting_text_620
    EXECUTE_SUBROUTINE .cliff_arm_callback_1

.cliff_walk_in_3:
    EXECUTE_SUBROUTINE .cliff_setup
    UPDATE_RGBA 254, 254, 254, 254, 0
    SET_COORDINATES -342, 0, 152
    SET_ENTITY_ANIMATION 24
    WAIT_RGBA_FINISHED

.cliff_arm_callback_2:
    SET_CALLBACK_ROUTINE 0, 32768, .cliff_feed_dispatch
    EXECUTE_SUBROUTINE .idle

.hawk_setup_slot31:
    SETUP_ENTITY 31, ENTITY_ASSET_HAWK, 1
    SET_ENTITY_ANIMATIONS 31, 0, 16, 24, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    RETURN_FROM_SUBROUTINE

.hawk_walk_in_1:
    EXECUTE_SUBROUTINE .hawk_setup_slot31
    UPDATE_RGBA 254, 254, 254, 254, 0
    SET_COORDINATES -430, 0, 70
    WAIT_RGBA_FINISHED
    SET_ASSET_ROTATION 7
    EXECUTE_SUBROUTINE .idle

.cliff_walk_over_say_text_632:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITY 30
    ENTITY_WALK 32, DIRECTION_W, 2
    SET_ASSET_ROTATION 6
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 632
    EXECUTE_SUBROUTINE .close_message_and_walk_off_northwest_98

.cliff_dispatch:
    BRANCH_U16_VAR_WITHIN_RANGE 210, 210, gCutsceneIndex, .cliff_cutscene_210
    EXECUTE_SUBROUTINE .lock_camera_and_face_player
    BRANCH_U16_VAR_WITHIN_RANGE 211, 211, gCutsceneIndex, .cliff_cutscene_211
    BRANCH_U16_VAR_WITHIN_RANGE 212, 212, gCutsceneIndex, .cutscene_cliff_leaving_default
    BRANCH_U16_VAR_WITHIN_RANGE 213, 213, gCutsceneIndex, .cliff_cutscene_213
    BRANCH_U16_VAR_WITHIN_RANGE 214, 214, gCutsceneIndex, .cliff_cutscene_214
    EXECUTE_SUBROUTINE .end_cutscene

.cliff_cutscene_210:
    BRANCH_ON_SPECIAL_BIT 28, dailyEventBits[2], .cliff_arm_callback_1
    BRANCH_U8_VAR_WITHIN_RANGE 0, 254, gItemBeingHeld, .cliff_arm_callback_1
    EXECUTE_SUBROUTINE .lock_camera_and_face_player
    BRANCH_U16_VAR_WITHIN_RANGE 210, 210, gCutsceneIndex, .cliff_cutscene_210_2
    EXECUTE_SUBROUTINE .end_cutscene

; Cliff feeding interaction: armed while he is lying on the ground
.cliff_feed_dispatch:
    PAUSE_ENTITY 0
    BRANCH_U8_VAR_WITHIN_RANGE 1, 255, gItemBeingHeld, .cliff_feed_check_item

; No item held -- play text 517 and wait for another interaction
.cliff_feed_no_item_held:
    EXECUTE_SUBROUTINE .set_msg_avatar_layout
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 517
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    EXECUTE_SUBROUTINE .set_msg_default_layout
    TOGGLE_PAUSE_ENTITY 0
    EXECUTE_SUBROUTINE .cliff_arm_callback_2

; Item held -- accept only specific item ID ranges
.cliff_feed_check_item:
    BRANCH_U8_VAR_WITHIN_RANGE 1, 12, gItemBeingHeld, .cliff_feed_accept_sequence
    BRANCH_U8_VAR_WITHIN_RANGE 15, 17, gItemBeingHeld, .cliff_feed_accept_sequence
    BRANCH_U8_VAR_WITHIN_RANGE 20, 35, gItemBeingHeld, .cliff_feed_accept_sequence
    EXECUTE_SUBROUTINE .cliff_feed_no_item_held

; Slot 0 helper: restore player control after the feeding sequence
.cliff_feed_restore_player_control:
    TOGGLE_PAUSE_ENTITY 0
    EXECUTE_SUBROUTINE .player_setup_slot0
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    FLIP_ENTITY_DIRECTION 30
    SET_WAIT_FRAMES 1
    SET_ENTITY_MAP_SPACE_INDEPENDENT FALSE
    PAUSE_ENTITY 0
    DEACTIVATE_SELF

; Accepted item path: affection bump, intro dialogue, Cain arrival
.cliff_feed_accept_sequence:
    SET_MAP_ROTATION 0, 255, 7
    WAIT_MAP_LOAD 0
    SET_U8_VALUE 0, gCameraRotationOffset
    UPDATE_U8_VALUE 5, 255, npcAffection[CLIFF]
    SET_SPECIAL_BIT 15, gCutsceneCompletionFlags
    EXECUTE_SUBROUTINE .set_msg_default_layout
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    FLIP_ENTITY_DIRECTION 0
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 518
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SPAWN_EXECUTOR 0, .cliff_feed_restore_player_control
    SET_WAIT_FRAMES 5
    SET_OTHER_EXECUTOR_PTR 2, .cliff_cain_arrives
    SET_ASSET_ROTATION 3
    SET_WAIT_FRAMES 30
    FLIP_ENTITY_DIRECTION 0
    SET_WAIT_FRAMES 20
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 520
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    ENTITY_WALK 144, DIRECTION_W, 2
    CLEAR_SPECIAL_BIT 15, gCutsceneCompletionFlags
    TOGGLE_PAUSE_ENTITY 0
    EXECUTE_SUBROUTINE .end_cutscene

; Slot 2 executor: walk Cain in with footstep SFX and show text 521
.cliff_cain_arrives:
    SET_ASSET_ROTATION 6
    SET_ENTITY_NON_COLLIDABLE
    SET_ENTITY_PHYSICS_FLAGS 0
    SET_WAIT_FRAMES 20
    SET_ENTITY_DIRECTIONAL_ANIMATION 8
    SET_SFX 76, 128
    SET_FRAME_DELTA 4, 1, 0, 16
    SET_SFX 76, 128
    SET_FRAME_DELTA 4, 2, 0, 16
    SET_SFX 76, 128
    ENTITY_WALK 32, DIRECTION_E, 4
    SET_SFX 76, 128
    ENTITY_RUN 64, DIRECTION_E, 4
    DEACTIVATE_SELF
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 521
    EXECUTE_SUBROUTINE .cliff_walk_over_say_text_632 

.cliff_cutscene_210_2:
    UPDATE_U8_VALUE 5, 255, gHappiness
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 521
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_ENTITY_DIRECTIONAL_ANIMATION 16
    WAIT_ENTITY_ANIMATION
    SPAWN_EXECUTOR 10, .static_item_walk_in_13
    SET_WAIT_FRAMES 30
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SPAWN_EXECUTOR 7, .player_walk_in_26
    EXECUTE_SUBROUTINE .idle

.cliff_show_msg_522:
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 522
    EXECUTE_SUBROUTINE .cliff_walk_over_say_text_632

.player_walk_in_26:
    EXECUTE_SUBROUTINE .player_setup_slot0
    EXECUTE_SUBROUTINE .player_receive_item_variant_a
    SET_OTHER_EXECUTOR_PTR 1, .cliff_show_msg_522
    DEACTIVATE_SELF

.cliff_cutscene_211:
    UPDATE_U8_VALUE 2, 255, gHappiness
    INIT_DIALOGUE_SESSION 0, DIALOGUE_FARM_VISITS, 23
    WAIT_FOR_DIALOGUE_INPUT 0
    BRANCH_ON_DIALOGUE 0, 0, .cliff_dialogue_23_yes
    BRANCH_ON_DIALOGUE 0, 1, .cliff_dialogue_23_no

.cliff_dialogue_23_yes:
    ; SPIRIT_FESTIVAL_INVITATION_ACCEPTED
    SET_SPECIAL_BIT 16, dailyEventBits[2]
    UPDATE_U8_VALUE 3, 255, npcAffection[CLIFF]
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 528
    EXECUTE_SUBROUTINE .cliff_walk_over_say_text_632

.cliff_dialogue_23_no:
    CLEAR_SPECIAL_BIT 16, dailyEventBits[2]
    UPDATE_U8_VALUE -5, 255, npcAffection[CLIFF]
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 529
    EXECUTE_SUBROUTINE .cliff_walk_over_say_text_632

.cutscene_cliff_leaving_default:
    UPDATE_U8_VALUE -20, 255, gHappiness
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 530
    EXECUTE_SUBROUTINE .close_message_and_walk_off_northwest_120

.cliff_cutscene_213:
    UPDATE_U8_VALUE -10, 255, gHappiness
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 531
    EXECUTE_SUBROUTINE .close_message_and_walk_off_northwest_120

.cliff_cutscene_214:
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 532
    EXECUTE_SUBROUTINE .cliff_walk_over_say_text_632


