    BRANCH_ON_DIALOGUE 0, 0, .gray_dialogue_21_yes
    BRANCH_ON_DIALOGUE 0, 1, .gray_dialogue_21_no

.gray_dialogue_21_yes:
    ; SPIRIT_FESTIVAL_INVITATION_ACCEPTED
