    BRANCH_U16_VAR_WITHIN_RANGE 204, 204, gCutsceneIndex, .harris_cutscene_204
    EXECUTE_SUBROUTINE .lock_camera_and_face_player
    BRANCH_U16_VAR_WITHIN_RANGE 202, 202, gCutsceneIndex, .harris_cutscene_202
    BRANCH_U16_VAR_WITHIN_RANGE 203, 203, gCutsceneIndex, .harris_cutscene_203
    EXECUTE_SUBROUTINE .end_cutscene

.harris_cutscene_204:
    BRANCH_ON_SPECIAL_BIT 28, dailyEventBits[2], .harris_arm_callback_1
    BRANCH_U8_VAR_WITHIN_RANGE 0, 254, gItemBeingHeld, .harris_arm_callback_1
    EXECUTE_SUBROUTINE .lock_camera_and_face_player
    BRANCH_U16_VAR_WITHIN_RANGE 204, 204, gCutsceneIndex, .harris_cutscene_204_2
    EXECUTE_SUBROUTINE .end_cutscene

