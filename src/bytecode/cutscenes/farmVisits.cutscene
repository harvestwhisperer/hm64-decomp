; ============================================
; Bank 7-8 - Farm Visits
; ============================================

#include "entities.h"
#include "texts.h"
#include "dialogues.h"
#include "maps.h"

#define MAIN_MAP_INDEX 0

#define MARIA 0
#define POPURI 1
#define ELLI 2
#define ANN 3
#define KAREN 4
#define BABY 5
#define HARRIS 6
#define JEFF 8
#define MAYOR 11
#define BASIL 14
#define DOUG 16
#define POTION_SHOP_DEALER 19
#define KENT 20
#define STU 21
#define RICK 24
#define PHOTOGRAPHER 39

#define HAVE_BABY 1

; pre-defined game variables
.array npcAffection, u8
.array dailyEventBits, u32
.array lifeEventBits, u32

.struct horseInfo, Horse


; ==========================================================
; Kent
; ==========================================================

; Shared Kent entity init at slot 30 (callbacks are armed separately).
.kent_setup:
    SETUP_ENTITY 30, ENTITY_ASSET_KENT, 1
    SET_ENTITY_ANIMATIONS 30, 0, 8, 16, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    RETURN_FROM_SUBROUTINE

.kent_arm_callback_1:
    SET_CALLBACK_ROUTINE 0, 32768, .kent_dispatch
    BRANCH_U16_VAR_WITHIN_RANGE 112, 112, gCutsceneIndex, .wait_until_hour_17
    EXECUTE_SUBROUTINE .wait_until_hour_9

; Pauses entities and plays farmVisits text 003 (Kent calling Yohooo Brother) then restores.
.kent_say_yohooo_brother:
    PAUSE_ENTITIES
    SET_MESSAGE_INTERPOLATION -4, 0, 0
    SET_MESSAGE_BOX_ASSETS 0, 1, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 0, -64, 352
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 3
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_MESSAGE_BOX_ASSETS 0, 0, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 24, -64, 352
    TOGGLE_PAUSE_ENTITIES
    RETURN_FROM_SUBROUTINE

; Kent enters from the west, plays the yohooo-brother message, then waits until 9:00.
.kent_walk_in_1:
    EXECUTE_SUBROUTINE .kent_setup
    SET_ASSET_ROTATION 6
    SET_COORDINATES -590, 0, 152
    ENTITY_WALK 34, DIRECTION_E, 2
    EXECUTE_SUBROUTINE .kent_say_yohooo_brother
    ENTITY_WALK 90, DIRECTION_E, 2
    SET_ASSET_ROTATION 4
    EXECUTE_SUBROUTINE .kent_arm_callback_1

; Kent fades in already near the player, plays the yohooo-brother message, then waits until 18:00.
.kent_walk_in_2:
    EXECUTE_SUBROUTINE .kent_setup
    UPDATE_RGBA 254, 254, 254, 254, 0
    SET_ASSET_ROTATION 4
    SET_COORDINATES -342, 0, 152
    WAIT_RGBA_FINISHED
    EXECUTE_SUBROUTINE .kent_say_yohooo_brother
    EXECUTE_SUBROUTINE .kent_arm_callback_1

; Kent enters with Stu trailing (spawns executor 2), plays the yohooo-brother message, then both walk further in.
.kent_walk_in_3:
    EXECUTE_SUBROUTINE .kent_setup
    SET_ASSET_ROTATION 6
    SET_COORDINATES -590, 0, 128
    SPAWN_EXECUTOR 2, .kent_stu_walk_in_behind
    ENTITY_WALK 34, DIRECTION_E, 2
    EXECUTE_SUBROUTINE .kent_say_yohooo_brother
    SET_OTHER_EXECUTOR_PTR 2, .kent_stu_walk_past_and_arm_callback
    ENTITY_WALK 90, DIRECTION_E, 2
    SET_ASSET_ROTATION 4
    SET_CALLBACK_ROUTINE 0, 32768, .kent_dispatch
    EXECUTE_SUBROUTINE .wait_until_hour_18

; Spawned as executor 2: Stu enters behind Kent and idles.
.kent_stu_walk_in_behind:
    SET_WAIT_FRAMES 8
    SETUP_ENTITY 31, ENTITY_ASSET_STU, 1
    SET_ENTITY_ANIMATIONS 31, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    SET_ASSET_ROTATION 6
    SET_COORDINATES -590, 0, 160
    ENTITY_WALK 30, DIRECTION_E, 2
    EXECUTE_SUBROUTINE .idle

; Stu walks past the player position, then arms callback to the Stu busy-check proxy.
.kent_stu_walk_past_and_arm_callback:
    ENTITY_WALK 94, DIRECTION_E, 2
    SET_ASSET_ROTATION 4
    SET_CALLBACK_ROUTINE 0, 32768, .stu_busy_check_then_kent_dispatch
    EXECUTE_SUBROUTINE .wait_until_hour_18

; Kent fades in, plays the yohooo-brother message, then arms callback and waits until 18:00.
.kent_walk_in_4:
    EXECUTE_SUBROUTINE .kent_setup
    UPDATE_RGBA 254, 254, 254, 254, 0
    SET_ASSET_ROTATION 4
    SET_COORDINATES -342, 0, 128
    WAIT_RGBA_FINISHED
    EXECUTE_SUBROUTINE .kent_say_yohooo_brother

.kent_arm_callback_2:
    SET_CALLBACK_ROUTINE 0, 32768, .kent_dispatch
    EXECUTE_SUBROUTINE .wait_until_hour_18

.stu_setup_slot31:
    SETUP_ENTITY 31, ENTITY_ASSET_STU, 1
    SET_ENTITY_ANIMATIONS 31, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    RETURN_FROM_SUBROUTINE

.stu_walk_in_1:
    EXECUTE_SUBROUTINE .stu_setup_slot31
    UPDATE_RGBA 254, 254, 254, 254, 0
    SET_COORDINATES -342, 0, 160
    SET_ASSET_ROTATION 4
    WAIT_RGBA_FINISHED

.kent_arm_callback_3:
    SET_CALLBACK_ROUTINE 0, 32768, .stu_busy_check_then_kent_dispatch
    EXECUTE_SUBROUTINE .wait_until_hour_18

.kent_walk_over_say_text_16:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITY 30
    ENTITY_WALK 32, DIRECTION_W, 2
    SET_ASSET_ROTATION 6
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 16
    EXECUTE_SUBROUTINE .close_message_and_walk_off_northwest_98

; Kent interact callback: picks per-gCutsceneIndex branch (101-113) or ends.
.kent_dispatch:
    BRANCH_U16_VAR_WITHIN_RANGE 112, 112, gCutsceneIndex, .kent_cutscene_112
    BRANCH_U16_VAR_WITHIN_RANGE 113, 113, gCutsceneIndex, .cutscene_kent_and_stu_farm_puppies
    EXECUTE_SUBROUTINE .lock_camera_and_face_player
    BRANCH_U16_VAR_WITHIN_RANGE 100, 100, gCutsceneIndex, .cutscene_kent_farm_sowing_fesitval
    BRANCH_U16_VAR_WITHIN_RANGE 101, 101, gCutsceneIndex, .kent_cutscene_101
    BRANCH_U16_VAR_WITHIN_RANGE 102, 102, gCutsceneIndex, .kent_cutscene_102
    BRANCH_U16_VAR_WITHIN_RANGE 103, 103, gCutsceneIndex, .cutscene_kent_farm_thanksgiving_festival
    BRANCH_U16_VAR_WITHIN_RANGE 104, 104, gCutsceneIndex, .kent_cutscene_104
    BRANCH_U16_VAR_WITHIN_RANGE 105, 105, gCutsceneIndex, .kent_cutscene_105
    BRANCH_U16_VAR_WITHIN_RANGE 106, 106, gCutsceneIndex, .kent_cutscene_106
    BRANCH_U16_VAR_WITHIN_RANGE 107, 107, gCutsceneIndex, .kent_cutscene_107
    BRANCH_U16_VAR_WITHIN_RANGE 108, 108, gCutsceneIndex, .kent_cutscene_108
    BRANCH_U16_VAR_WITHIN_RANGE 109, 109, gCutsceneIndex, .kent_cutscene_109
    BRANCH_U16_VAR_WITHIN_RANGE 110, 110, gCutsceneIndex, .kent_cutscene_110
    BRANCH_U16_VAR_WITHIN_RANGE 111, 111, gCutsceneIndex, .kent_cutscene_111
    EXECUTE_SUBROUTINE .end_cutscene

; Cutscene 112: guarded by daily bit 28 and not-holding-item, then plays the award scene.
.kent_cutscene_112:
    BRANCH_ON_SPECIAL_BIT 28, dailyEventBits[2], .kent_arm_callback_1
    BRANCH_U8_VAR_WITHIN_RANGE 0, 254, gItemBeingHeld, .kent_arm_callback_1
    EXECUTE_SUBROUTINE .lock_camera_and_face_player
    EXECUTE_SUBROUTINE .kent_award_and_msg_15

; Cutscene 113: Kent and Stu lead the player to the potion shop to see the new puppies.
.cutscene_kent_and_stu_farm_puppies:
    BRANCH_ON_SPECIAL_BIT 28, dailyEventBits[2], .kent_arm_callback_2
    BRANCH_U8_VAR_WITHIN_RANGE 0, 254, gItemBeingHeld, .kent_arm_callback_2
    EXECUTE_SUBROUTINE .lock_camera_and_face_player
    EXECUTE_SUBROUTINE .kent_puppies_scene

.cutscene_kent_farm_sowing_fesitval:
    UPDATE_U8_VALUE 2, 255, gHappiness
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 0
    EXECUTE_SUBROUTINE .kent_walk_over_say_text_16

.kent_cutscene_101:
    UPDATE_U8_VALUE 2, 255, gHappiness
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 1
    EXECUTE_SUBROUTINE .kent_walk_over_say_text_16

.kent_cutscene_102:
    UPDATE_U8_VALUE 2, 255, gHappiness
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 2
    EXECUTE_SUBROUTINE .kent_walk_over_say_text_16
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 4
    EXECUTE_SUBROUTINE .kent_walk_over_say_text_16

.cutscene_kent_farm_thanksgiving_festival:
    UPDATE_U8_VALUE 2, 255, gHappiness
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 5
    WAIT_MESSAGE_BOX_CLOSED 0
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 6
    EXECUTE_SUBROUTINE .kent_walk_over_say_text_16

.kent_cutscene_104:
    UPDATE_U8_VALUE 2, 255, gHappiness
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 5
    EXECUTE_SUBROUTINE .kent_walk_over_say_text_16

.kent_cutscene_105:
    UPDATE_U8_VALUE 2, 255, npcAffection[KENT]
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 7
    EXECUTE_SUBROUTINE .kent_walk_over_say_text_16

.kent_cutscene_106:
    UPDATE_U8_VALUE 3, 255, npcAffection[KENT]
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 9
    EXECUTE_SUBROUTINE .kent_walk_over_say_text_16

.kent_cutscene_107:
    UPDATE_U8_VALUE 5, 255, npcAffection[KENT]
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 10
    EXECUTE_SUBROUTINE .kent_walk_over_say_text_16

.kent_cutscene_108:
    UPDATE_U8_VALUE 5, 255, npcAffection[KENT]
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 10
    WAIT_MESSAGE_BOX_CLOSED 0
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 11
    EXECUTE_SUBROUTINE .kent_walk_over_say_text_16

.kent_cutscene_109:
    UPDATE_U8_VALUE 3, 255, npcAffection[KENT]
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 12
    WAIT_MESSAGE_BOX_CLOSED 0
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 13
    EXECUTE_SUBROUTINE .kent_walk_over_say_text_16

.kent_cutscene_110:
    UPDATE_U8_VALUE 3, 255, npcAffection[KENT]
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 14
    EXECUTE_SUBROUTINE .kent_walk_over_say_text_16

.kent_cutscene_111:
    UPDATE_U8_VALUE 2, 255, npcAffection[KENT]
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 8
    EXECUTE_SUBROUTINE .kent_walk_over_say_text_16

; Plays text 015, swaps Kent to a giving animation, spawns the item pickup, then re-plays greeting flow.
.kent_award_and_msg_15:
    UPDATE_U8_VALUE 5, 255, gHappiness
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 15
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_ENTITY_DIRECTIONAL_ANIMATION 28
    WAIT_ENTITY_ANIMATION
    SPAWN_EXECUTOR 10, .static_item_walk_in_2
    SET_ENTITY_DIRECTIONAL_ANIMATION 36
    WAIT_ENTITY_ANIMATION
    SET_WAIT_FRAMES 30
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SPAWN_EXECUTOR 7, .player_walk_in_1
    EXECUTE_SUBROUTINE .idle

.player_walk_in_1:
    EXECUTE_SUBROUTINE .player_setup_slot0
    EXECUTE_SUBROUTINE .player_receive_item_variant_a
    SET_OTHER_EXECUTOR_PTR 1, .kent_walk_over_say_text_16
    DEACTIVATE_SELF

; Awards affection/happiness, fades out, teleports player to potion shop, plays texts 024/026/028/029, fades out and ends.
.kent_puppies_scene:
    UPDATE_U8_VALUE 3, 255, npcAffection[KENT]
    UPDATE_U8_VALUE 3, 255, npcAffection[STU]
    UPDATE_U8_VALUE 3, 255, npcAffection[POTION_SHOP_DEALER]
    UPDATE_U8_VALUE 20, 255, gHappiness
    SET_OTHER_EXECUTOR_PTR 2, .flip_animation_and_idle
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 24
    WAIT_MESSAGE_BOX_CLOSED 0
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 25
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    SET_SPECIAL_BIT 29, gCutsceneCompletionFlags
    SET_SPECIAL_BIT 15, gCutsceneCompletionFlags
    SET_WAIT_FRAMES 1
    TOGGLE_PAUSE_ENTITIES
    SET_COORDINATES 32, 0, 16
    SET_ASSET_ROTATION 1
    SET_OTHER_EXECUTOR_PTR 2, .kent_stu_reposition_in_potion_shop
    SPAWN_EXECUTOR 3, .potion_shop_dealer_setup_slot29
    SPAWN_EXECUTOR 4, .player_dog_setup_slot1
    SPAWN_EXECUTOR 5, .dog_village_setup_slot14
    SPAWN_EXECUTOR 6, .dog_village_setup_slot15
    SPAWN_EXECUTOR 7, .player_walk_in_2
    SPAWN_EXECUTOR 8, .kent_load_potion_shop_map
    SET_WAIT_FRAMES 1
    UPDATE_GLOBAL_RGBA 255, 255, 255, 255, 8
    WAIT_RGBA_FINISHED
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 26
    WAIT_MESSAGE_BOX_CLOSED 0
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 28
    WAIT_MESSAGE_BOX_CLOSED 0
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 29
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_WAIT_FRAMES 30
    SET_AUDIO_SEQUENCE_VOLUME 0, 0, 8
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    STOP_SEQUENCE_WITH_FADE 0, 1
    DEACTIVATE_EXECUTOR 2
    DEACTIVATE_EXECUTOR 3
    DEACTIVATE_EXECUTOR 4
    DEACTIVATE_EXECUTOR 5
    DEACTIVATE_EXECUTOR 6
    DEACTIVATE_EXECUTOR 8
    IDLE_WHILE_SEQUENCE_PLAYING 0
    EXECUTE_SUBROUTINE .end_cutscene

.player_dog_setup_slot1:
    SETUP_ENTITY 1, ENTITY_ASSET_PLAYER_DOG, 1
    SET_ENTITY_ANIMATIONS 1, 0, 8, 16, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_PALETTE 2
    SET_ENTITY_NON_COLLIDABLE
    SET_ASSET_ROTATION 0
    SET_COORDINATES 0, 0, 56
    SET_ENTITY_ANIMATION 25
    EXECUTE_SUBROUTINE .idle

.dog_village_setup_slot14:
    SETUP_ENTITY 14, ENTITY_ASSET_DOG_VILLAGE, 1
    SET_ENTITY_ANIMATIONS 14, 0, 8, 16, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    SET_ASSET_ROTATION 2
    SET_COORDINATES 16, 0, 44
    SET_ENTITY_DIRECTIONAL_ANIMATION 88
    EXECUTE_SUBROUTINE .idle

.dog_village_setup_slot15:
    SETUP_ENTITY 15, ENTITY_ASSET_DOG_VILLAGE, 1
    SET_ENTITY_ANIMATIONS 15, 0, 8, 16, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    SET_ASSET_ROTATION 2
    SET_COORDINATES 16, 0, 36
    SET_WAIT_FRAMES 2
    SET_ENTITY_DIRECTIONAL_ANIMATION 88
    EXECUTE_SUBROUTINE .idle

.potion_shop_dealer_setup_slot29:
    SETUP_ENTITY 29, ENTITY_ASSET_POTION_SHOP_DEALER, 1
    SET_ENTITY_ANIMATIONS 29, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_COORDINATES -80, 0, 64
    SET_ASSET_ROTATION 6
    EXECUTE_SUBROUTINE .idle

; Executor 2 retarget during puppies scene: reposition Stu in the potion shop.
.kent_stu_reposition_in_potion_shop:
    SET_COORDINATES -32, 0, 64
    SET_ASSET_ROTATION 6
    EXECUTE_SUBROUTINE .idle

.player_walk_in_2:
    EXECUTE_SUBROUTINE .player_setup_slot0
    SET_ASSET_ROTATION 0
    SET_COORDINATES 0, 0, 12
    EXECUTE_SUBROUTINE .idle

; Executor 8 during puppies scene: swaps the active map to POTION_SHOP.
.kent_load_potion_shop_map:
    DEACTIVATE_MAP_OBJECTS 0
    LOAD_MAP MAIN_MAP_INDEX, POTION_SHOP
    SETUP_MAP_ASSET MAIN_MAP_INDEX
    SET_COORDINATES 0, 0, 0
    SET_ASSET_ROTATION 7
    EXECUTE_SUBROUTINE .idle

; Stu interact callback: if daily bit 28 set or holding item, arm Kent; otherwise retarget executor 1 (Kent) to kent_dispatch.
.stu_busy_check_then_kent_dispatch:
    BRANCH_ON_SPECIAL_BIT 28, dailyEventBits[2], .kent_arm_callback_3
    BRANCH_U8_VAR_WITHIN_RANGE 0, 254, gItemBeingHeld, .kent_arm_callback_3
    SET_OTHER_EXECUTOR_PTR 1, .kent_dispatch
    EXECUTE_SUBROUTINE .idle


; ==========================================================
; Stu
; ==========================================================

.stu_setup:
    SETUP_ENTITY 30, ENTITY_ASSET_STU, 1
    SET_ENTITY_ANIMATIONS 30, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    SET_ASSET_ROTATION 6
    RETURN_FROM_SUBROUTINE

.stu_arm_callback_1:
    SET_CALLBACK_ROUTINE 0, 32768, .stu_dispatch
    EXECUTE_SUBROUTINE .wait_until_hour_12

; Door-greeting helper for Stu: pause, show text 56 (Hey Brother), restore, return.
.stu_show_doorstep_greeting:
    PAUSE_ENTITIES
    SET_MESSAGE_INTERPOLATION -4, 0, 0
    SET_MESSAGE_BOX_ASSETS 0, 1, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 0, -64, 352
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 56
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_MESSAGE_BOX_ASSETS 0, 0, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 24, -64, 352
    TOGGLE_PAUSE_ENTITIES
    RETURN_FROM_SUBROUTINE

.stu_walk_in_2:
    EXECUTE_SUBROUTINE .stu_setup
    SET_COORDINATES -590, 0, 152
    ENTITY_WALK 34, DIRECTION_E, 2
    EXECUTE_SUBROUTINE .stu_show_doorstep_greeting
    ENTITY_WALK 90, DIRECTION_E, 2
    EXECUTE_SUBROUTINE .stu_arm_callback_1

.stu_walk_in_3:
    EXECUTE_SUBROUTINE .stu_setup
    UPDATE_RGBA 254, 254, 254, 254, 0
    SET_COORDINATES -342, 0, 152
    WAIT_RGBA_FINISHED
    EXECUTE_SUBROUTINE .stu_show_doorstep_greeting
    EXECUTE_SUBROUTINE .stu_arm_callback_1

.stu_walk_over_say_text_62:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITY 30
    ENTITY_WALK 32, DIRECTION_W, 2
    SET_ASSET_ROTATION 6
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 62
    EXECUTE_SUBROUTINE .close_message_and_walk_off_northwest_98

.stu_dispatch:
    BRANCH_U16_VAR_WITHIN_RANGE 116, 116, gCutsceneIndex, .stu_cutscene_116
    EXECUTE_SUBROUTINE .lock_camera_and_face_player
    BRANCH_U16_VAR_WITHIN_RANGE 114, 114, gCutsceneIndex, .stu_cutscene_114
    BRANCH_U16_VAR_WITHIN_RANGE 115, 115, gCutsceneIndex, .stu_cutscene_115
    EXECUTE_SUBROUTINE .end_cutscene

.stu_cutscene_116:
    BRANCH_ON_SPECIAL_BIT 28, dailyEventBits[2], .stu_arm_callback_1
    BRANCH_U8_VAR_WITHIN_RANGE 0, 254, gItemBeingHeld, .stu_arm_callback_1
    EXECUTE_SUBROUTINE .lock_camera_and_face_player
    BRANCH_U16_VAR_WITHIN_RANGE 116, 116, gCutsceneIndex, .stu_cutscene_116_2
    EXECUTE_SUBROUTINE .end_cutscene

.stu_cutscene_114:
    UPDATE_U8_VALUE 3, 255, npcAffection[STU]
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 57
    EXECUTE_SUBROUTINE .stu_walk_over_say_text_62

.stu_cutscene_115:
    UPDATE_U8_VALUE 3, 255, npcAffection[STU]
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 58
    EXECUTE_SUBROUTINE .stu_walk_over_say_text_62

.stu_cutscene_116_2:
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 59
    WAIT_MESSAGE_BOX_CLOSED 0
    SET_ENTITY_DIRECTIONAL_ANIMATION 16
    WAIT_ENTITY_ANIMATION
    SPAWN_EXECUTOR 10, .static_item_walk_in_14
    SET_ENTITY_DIRECTIONAL_ANIMATION 24
    WAIT_ENTITY_ANIMATION
    INIT_DIALOGUE_SESSION 0, DIALOGUE_FARM_VISITS, 0
    WAIT_FOR_DIALOGUE_INPUT 0
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    DEACTIVATE_EXECUTOR 10
    BRANCH_ON_DIALOGUE 0, 0, .stu_dialogue_0_yes
    BRANCH_ON_DIALOGUE 0, 1, .stu_dialogue_0_no

.stu_dialogue_0_yes:
    SET_SPECIAL_BIT 11, lifeEventBits[2]
    UPDATE_U8_VALUE 3, 255, npcAffection[STU]
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 60
    EXECUTE_SUBROUTINE .stu_walk_over_say_text_62

.stu_dialogue_0_no:
    UPDATE_U8_VALUE -5, 255, npcAffection[STU]
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 61
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITY 30
    ENTITY_WALK 114, DIRECTION_W, 2
    TOGGLE_PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .end_cutscene


; ==========================================================
; Mayor
; ==========================================================

.mayor_setup:
    SETUP_ENTITY 30, ENTITY_ASSET_MAYOR, 1
    SET_ENTITY_ANIMATIONS 30, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    RETURN_FROM_SUBROUTINE

; Shared door-greeting helper used by Mayor, Doug, Basil, potion shop dealer, master carpenter: pause entities, show text 620, restore, return.
.show_doorstep_greeting_text_620:
    PAUSE_ENTITIES
    SET_MESSAGE_INTERPOLATION -4, 0, 0
    SET_MESSAGE_BOX_ASSETS 0, 1, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 0, -64, 352
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 620
    WAIT_MESSAGE_BOX_CLOSED 0
