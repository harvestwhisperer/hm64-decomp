    UPDATE_RGBA 0, 0, 0, 0, 6
    WAIT_RGBA_FINISHED
    DEACTIVATE_SELF

; ---- Cutscenes 239-243: Fireworks festival with wife ----
.cutscene_239:
    EXECUTE_SUBROUTINE .maria_setup
    EXECUTE_SUBROUTINE .walk_in_from_north_southwest

.fireworks_maria_arm_callback:
    SET_CALLBACK_ROUTINE 0, 32768, .fireworks_maria_dialogue
    EXECUTE_SUBROUTINE .wait_until_hour_21_2

.wait_until_hour_21_2:
    SET_WAIT_FRAMES 1
    BRANCH_U8_VAR_WITHIN_RANGE 21, 21, gHour, .fireworks_wife_walk_off_northeast
    EXECUTE_SUBROUTINE .wait_until_hour_21_2

.fireworks_wife_walk_off_northeast:
    ENTITY_WALK 96, DIRECTION_N, 2
    EXECUTE_SUBROUTINE .end_cutscene

.cutscene_239_2:
    EXECUTE_SUBROUTINE .maria_setup
    SET_ASSET_ROTATION 4
    SET_COORDINATES -358, 0, 152
    EXECUTE_SUBROUTINE .fireworks_maria_arm_callback

.fireworks_maria_dialogue:
    EXECUTE_SUBROUTINE .lock_camera_and_face_player
    INIT_DIALOGUE_SESSION 0, DIALOGUE_FARM_VISITS, 33
    WAIT_FOR_DIALOGUE_INPUT 0
    BRANCH_ON_DIALOGUE 0, 0, .fireworks_maria_choice_yes
    BRANCH_ON_DIALOGUE 0, 1, .fireworks_maria_choice_no

.fireworks_fade_to_night:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    SET_COORDINATES -358, 0, 152
    SET_ASSET_ROTATION 0
    TOGGLE_PAUSE_ENTITIES
    SPAWN_EXECUTOR 1, .player_walk_in_29
    SET_WAIT_FRAMES 1
    UPDATE_GLOBAL_RGBA 80, 80, 80, 80, 3
    WAIT_RGBA_FINISHED
    SET_WAIT_FRAMES 10
    SET_ENTITY_ANIMATION 52
    WAIT_ENTITY_ANIMATION
    SET_OTHER_EXECUTOR_PTR 1, .fireworks_wife_anim_496_502_loop
    SET_ENTITY_ANIMATION 54
    SET_WAIT_FRAMES 10
    SET_AUDIO_SEQUENCE 1, _fireworksSfxSegmentRomStart, _fireworksSfxSegmentRomEnd
    SET_AUDIO_SEQUENCE_VOLUME 1, 128, 128
    SPAWN_EXECUTOR 40, .fireworks_dma_slot96
    SET_WAIT_FRAMES 120
    RETURN_FROM_SUBROUTINE

.fireworks_wait_msg_closed:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    IDLE_WHILE_SEQUENCE_PLAYING 1

.fireworks_end_and_turn:
    SET_OTHER_EXECUTOR_PTR 40, .fireworks_fade_out_self
    SET_WAIT_FRAMES 40
    SET_OTHER_EXECUTOR_PTR 1, .fireworks_wife_anim_496_face_change
    SET_ENTITY_ANIMATION 52
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    ENTITY_WALK 16, DIRECTION_S, 2
    SET_ASSET_ROTATION 6
    RETURN_FROM_SUBROUTINE

.fireworks_sfx_loop:
    SET_SFX 93, 128
    SET_WAIT_FRAMES 7
    EXECUTE_SUBROUTINE .fireworks_sfx_loop

.fireworks_maria_choice_yes:
    SET_SPECIAL_BIT 30, gCutsceneCompletionFlags
    UPDATE_U8_VALUE 5, 255, npcAffection[MARIA]
    UPDATE_U8_VALUE 5, 255, gHappiness
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 160
    EXECUTE_SUBROUTINE .fireworks_fade_to_night
    INIT_MESSAGE_BOX_TYPE2 0, 63, 162
    EXECUTE_SUBROUTINE .fireworks_wait_msg_closed
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 163
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_ENTITY_DIRECTIONAL_ANIMATION 100
    WAIT_ENTITY_ANIMATION
    SET_OTHER_EXECUTOR_PTR 1, .fireworks_wife_anim_439_447_spawn_slot32
    SET_ENTITY_DIRECTIONAL_ANIMATION 25
    SPAWN_EXECUTOR 33, .fireworks_spawn_slot43_track_wife
    SPAWN_EXECUTOR 34, .fireworks_sfx_loop
    SET_WAIT_FRAMES 60
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 164

.fireworks_finale_fade_out:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_WAIT_FRAMES 60
    DEACTIVATE_EXECUTOR 32
    DEACTIVATE_EXECUTOR 33
    DEACTIVATE_EXECUTOR 34
    SET_WAIT_FRAMES 30
    SET_AUDIO_SEQUENCE_VOLUME 0, 0, 4
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 4
    WAIT_RGBA_FINISHED
    STOP_SEQUENCE_WITH_FADE 0, 1
    DEACTIVATE_EXECUTOR 1
    IDLE_WHILE_SEQUENCE_PLAYING 0
    EXECUTE_SUBROUTINE .end_cutscene

