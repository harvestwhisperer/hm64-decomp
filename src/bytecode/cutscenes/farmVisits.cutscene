    EXECUTE_SUBROUTINE .lock_camera_and_face_player
    SET_ASSET_ROTATION 6
    BRANCH_U16_VAR_WITHIN_RANGE 228, 228, gCutsceneIndex, .tourist_couple_man_cutscene_228
    BRANCH_U16_VAR_WITHIN_RANGE 230, 230, gCutsceneIndex, .tourist_couple_man_cutscene_230
    BRANCH_U16_VAR_WITHIN_RANGE 231, 231, gCutsceneIndex, .tourist_couple_man_cutscene_231
    EXECUTE_SUBROUTINE .end_cutscene

.tourist_couple_man_cutscene_228:
    PAUSE_ENTITY 0
    SET_OTHER_EXECUTOR_PTR 2, .rearm_dispatch_and_idle
    SPAWN_EXECUTOR 3, .tourist_couple_man_award_and_msg_574
    EXECUTE_SUBROUTINE .idle

.tourist_couple_man_cutscene_230:
    PAUSE_ENTITY 0
    SET_OTHER_EXECUTOR_PTR 2, .rearm_dispatch_and_idle
    SPAWN_EXECUTOR 3, .tourist_couple_man_award_and_msg_582
    EXECUTE_SUBROUTINE .idle

.tourist_couple_man_cutscene_231:
    PAUSE_ENTITY 0
    SET_ASSET_ROTATION 4
    SET_OTHER_EXECUTOR_PTR 2, .rearm_dispatch_and_idle
    SPAWN_EXECUTOR 3, .tourist_couple_man_award_and_msg_586
    EXECUTE_SUBROUTINE .idle

; Flips entity anim and direction 0, then idles (callback target)
.flip_animation_and_idle:
    FLIP_ENTITY_ANIMATION
    FLIP_ENTITY_DIRECTION 0
    EXECUTE_SUBROUTINE .idle

; Toggles pause on slot 30 and walks the man 120 units NW, then self-deactivates
.tourist_couple_man_walk_off_northwest:
    TOGGLE_PAUSE_ENTITY 30
    ENTITY_WALK 120, DIRECTION_W, 2
    DEACTIVATE_SELF

.tourist_couple_woman_walk_in_2:
    EXECUTE_SUBROUTINE .tourist_couple_woman_setup_slot31
    TOGGLE_PAUSE_ENTITY 31
    SET_COORDINATES -342, 0, 160
    SET_ASSET_ROTATION 4
    SET_WAIT_FRAMES 30
    ENTITY_WALK 120, DIRECTION_W, 2
    TOGGLE_PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .end_cutscene

; After message box closes: reset avatar, reposition both speakers, hand off slot 1 to walk-off helper, deactivate slot 2
.tourist_couple_post_msg_reposition_and_walk_off:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_WAIT_FRAMES 10
    SET_OTHER_EXECUTOR_PTR 1, .slot1_face_southwest
    SET_OTHER_EXECUTOR_PTR 2, .slot2_face_northeast
    SET_WAIT_FRAMES 30
    SET_OTHER_EXECUTOR_PTR 1, .tourist_couple_man_spawn_bubble_and_walk_off
    DEACTIVATE_EXECUTOR 2
    DEACTIVATE_SELF

.expression_bubbles_setup_slot47:
    SETUP_ENTITY 47, ENTITY_ASSET_EXPRESSION_BUBBLES, 1
    SET_ENTITY_ANIMATIONS 47, 0, 0, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_TRACKING_TARGET 30, -4, 64, 0, 0
    SET_ENTITY_ANIMATION 3
    WAIT_ENTITY_ANIMATION
    DEACTIVATE_SELF

; Slot 1 post-message: unpause man, reposition, spawn expression bubble, play anim 16, spawn woman walk-in, then fall through to walk-off
.tourist_couple_man_spawn_bubble_and_walk_off:
    TOGGLE_PAUSE_ENTITY 30
    SET_COORDINATES -342, 0, 144
    SPAWN_EXECUTOR 3, .expression_bubbles_setup_slot47
    SET_ENTITY_ANIMATION 16
    SET_WAIT_FRAMES 60
    SPAWN_EXECUTOR 2, .tourist_couple_woman_walk_in_2
    SET_COORDINATES -342, 0, 128
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SET_ASSET_ROTATION 0
    SET_WAIT_FRAMES 30
    EXECUTE_SUBROUTINE .tourist_couple_man_walk_off_northwest

.tourist_couple_man_award_and_msg_574:
    UPDATE_U8_VALUE 10, 255, gHappiness
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 574
    WAIT_MESSAGE_BOX_CLOSED 0
    SET_OTHER_EXECUTOR_PTR 2, .slot2_face_northeast
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 575
    WAIT_MESSAGE_BOX_CLOSED 0
    SET_OTHER_EXECUTOR_PTR 1, .slot1_face_southwest
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 576
    WAIT_MESSAGE_BOX_CLOSED 0
    SET_OTHER_EXECUTOR_PTR 2, .slot1_face_southwest
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 577
    EXECUTE_SUBROUTINE .tourist_couple_post_msg_reposition_and_walk_off

.tourist_couple_man_award_and_msg_582:
    UPDATE_U8_VALUE 10, 255, gHappiness
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 582
    WAIT_MESSAGE_BOX_CLOSED 0
    SET_OTHER_EXECUTOR_PTR 2, .slot2_face_northeast
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 583
    WAIT_MESSAGE_BOX_CLOSED 0
    SET_OTHER_EXECUTOR_PTR 1, .slot1_face_southwest
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 584
    WAIT_MESSAGE_BOX_CLOSED 0
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 585
    EXECUTE_SUBROUTINE .tourist_couple_post_msg_reposition_and_walk_off

.tourist_couple_man_award_and_msg_586:
    UPDATE_U8_VALUE 10, 255, gHappiness
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 586
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SPAWN_EXECUTOR 0, .tourist_couple_player_anim_456_then_spawn_msg_587
    DEACTIVATE_SELF

.tourist_couple_man_show_msg_587_588:
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 587
    WAIT_MESSAGE_BOX_CLOSED 0
    SET_OTHER_EXECUTOR_PTR 2, .slot2_face_northeast
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 588
    WAIT_MESSAGE_BOX_CLOSED 0
    SET_OTHER_EXECUTOR_PTR 1, .slot1_face_southwest
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 589
    WAIT_MESSAGE_BOX_CLOSED 0
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 590
    EXECUTE_SUBROUTINE .tourist_couple_post_msg_reposition_and_walk_off

; Slot 0 player handler: unpause player, play animation 456, then spawn the 587-590 message sequence
.tourist_couple_player_anim_456_then_spawn_msg_587:
    TOGGLE_PAUSE_ENTITY 0
    EXECUTE_SUBROUTINE .player_setup_slot0
    SET_ENTITY_DIRECTIONAL_ANIMATION 456
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SPAWN_EXECUTOR 3, .tourist_couple_man_show_msg_587_588
    SET_WAIT_FRAMES 1
    SET_ENTITY_MAP_SPACE_INDEPENDENT FALSE
    PAUSE_ENTITY 0
    DEACTIVATE_SELF


