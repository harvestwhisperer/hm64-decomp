    WAIT_MESSAGE_BOX_CLOSED 0
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 636
    WAIT_MESSAGE_BOX_CLOSED 0
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 637
