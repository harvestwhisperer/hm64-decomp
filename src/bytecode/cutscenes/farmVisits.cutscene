; ---- Cutscene 251: Shooting-star wish with wife ----
.cutscene_251:
    SET_SPECIAL_BIT 31, gCutsceneCompletionFlags
    SPAWN_EXECUTOR 1, .wife_setup_for_cutscene_251
    BRANCH_ON_SPECIAL_BIT HAVE_BABY, lifeEventBits[0], .spawn_baby_if_present_1
    SPAWN_EXECUTOR 3, .static_item_walk_in_16
    SET_WAIT_FRAMES 1
    EXECUTE_SUBROUTINE .player_setup_slot0
    SET_COORDINATES -224, 0, -32
    SET_ASSET_ROTATION 2
    SET_HOLDING_ANIMATION_FLAG TRUE
    UPDATE_GLOBAL_RGBA 80, 80, 80, 80, 6
    WAIT_RGBA_FINISHED
    BRANCH_U8_VAR_WITHIN_RANGE MARIA, MARIA, gWife, .shooting_star_intro_msg_185_maria
    BRANCH_U8_VAR_WITHIN_RANGE POPURI, POPURI, gWife, .shooting_star_intro_msg_261_popuri
    BRANCH_U8_VAR_WITHIN_RANGE ELLI, ELLI, gWife, .shooting_star_intro_msg_337_elli
    BRANCH_U8_VAR_WITHIN_RANGE ANN, ANN, gWife, .shooting_star_intro_msg_390_ann
    BRANCH_U8_VAR_WITHIN_RANGE KAREN, KAREN, gWife, .shooting_star_intro_msg_460_karen
    WAIT_MESSAGE_BOX_CLOSED 0
    INIT_DIALOGUE_SESSION 0, DIALOGUE_FARM_VISITS, 28
    WAIT_FOR_DIALOGUE_INPUT 0
    BRANCH_ON_DIALOGUE 0, 0, .shooting_star_wish_choice_a
    BRANCH_ON_DIALOGUE 0, 1, .shooting_star_wish_choice_wife_affection
    BRANCH_ON_DIALOGUE 0, 2, .shooting_star_wish_choice_good_weather

.shooting_star_wish_choice_a:
    ; set SHOOTING_STAR_ANIMAL_WISH_DAILY
    SET_SPECIAL_BIT 10, dailyEventBits[1]
    EXECUTE_SUBROUTINE .shooting_star_finale

.shooting_star_wish_choice_wife_affection:
    BRANCH_U8_VAR_WITHIN_RANGE MARIA, MARIA, gWife, .shooting_star_bump_maria_affection
    BRANCH_U8_VAR_WITHIN_RANGE POPURI, POPURI, gWife, .shooting_star_bump_popuri_affection
    BRANCH_U8_VAR_WITHIN_RANGE ELLI, ELLI, gWife, .shooting_star_bump_elli_affection
    BRANCH_U8_VAR_WITHIN_RANGE ANN, ANN, gWife, .shooting_star_bump_ann_affection
    BRANCH_U8_VAR_WITHIN_RANGE KAREN, KAREN, gWife, .shooting_star_bump_karen_affection
    EXECUTE_SUBROUTINE .shooting_star_finale

.shooting_star_bump_maria_affection:
    UPDATE_U8_VALUE 5, 255, npcAffection[MARIA]

.shooting_star_bump_baby_affection_if_present:
    BRANCH_ON_SPECIAL_BIT HAVE_BABY, lifeEventBits[0], .shooting_star_apply_baby_affection
    EXECUTE_SUBROUTINE .shooting_star_finale

.shooting_star_apply_baby_affection:
    UPDATE_U8_VALUE 5, 255, npcAffection[BABY]
    EXECUTE_SUBROUTINE .shooting_star_finale

.shooting_star_bump_popuri_affection:
    UPDATE_U8_VALUE 5, 255, npcAffection[POPURI]
    EXECUTE_SUBROUTINE .shooting_star_bump_baby_affection_if_present

.shooting_star_bump_elli_affection:
    UPDATE_U8_VALUE 5, 255, npcAffection[ELLI]
    EXECUTE_SUBROUTINE .shooting_star_bump_baby_affection_if_present

.shooting_star_bump_ann_affection:
    UPDATE_U8_VALUE 5, 255, npcAffection[ANN]
    EXECUTE_SUBROUTINE .shooting_star_bump_baby_affection_if_present

.shooting_star_bump_karen_affection:
    UPDATE_U8_VALUE 5, 255, npcAffection[KAREN]
    EXECUTE_SUBROUTINE .shooting_star_bump_baby_affection_if_present

.shooting_star_wish_choice_good_weather:
    ; set WEATHER_WISH bit to get alternate forecast weights
    SET_SPECIAL_BIT 4, lifeEventBits[2]

.shooting_star_finale:
    SET_OTHER_EXECUTOR_PTR 3, .shooting_star_arc
    SET_ENTITY_DIRECTIONAL_ANIMATION 421
    WAIT_ENTITY_ANIMATION
    SET_OTHER_EXECUTOR_PTR 1, .slot1_face_west
    SET_OTHER_EXECUTOR_PTR 2, .slot1_face_west
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SET_ASSET_ROTATION 1
    SET_HOLDING_ANIMATION_FLAG FALSE
    SET_WAIT_FRAMES 40
    SET_OTHER_EXECUTOR_PTR 1, .slot1_face_southwest
    SET_OTHER_EXECUTOR_PTR 2, .slot1_face_southwest
    SET_ASSET_ROTATION 0
    SET_WAIT_FRAMES 40
    BRANCH_U8_VAR_WITHIN_RANGE 0, 0, gWife, .shooting_star_outro_msg_189_maria
    BRANCH_U8_VAR_WITHIN_RANGE 1, 1, gWife, .shooting_star_outro_msg_262_popuri
    BRANCH_U8_VAR_WITHIN_RANGE 2, 2, gWife, .shooting_star_outro_msg_338_elli
    BRANCH_U8_VAR_WITHIN_RANGE 3, 3, gWife, .shooting_star_outro_msg_391_ann
    BRANCH_U8_VAR_WITHIN_RANGE 4, 4, gWife, .shooting_star_outro_msg_461_karen
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_WAIT_FRAMES 20
    SET_AUDIO_SEQUENCE_VOLUME 0, 0, 4
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    STOP_SEQUENCE_WITH_FADE 0, 1
    DEACTIVATE_EXECUTOR 1
    DEACTIVATE_EXECUTOR 2
    DEACTIVATE_EXECUTOR 41
    IDLE_WHILE_SEQUENCE_PLAYING 0
    EXECUTE_SUBROUTINE .end_cutscene

.shooting_star_intro_msg_185_maria:
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 185
    RETURN_FROM_SUBROUTINE

.shooting_star_intro_msg_261_popuri:
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 261
    RETURN_FROM_SUBROUTINE

.shooting_star_intro_msg_337_elli:
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 337
    RETURN_FROM_SUBROUTINE

.shooting_star_intro_msg_390_ann:
