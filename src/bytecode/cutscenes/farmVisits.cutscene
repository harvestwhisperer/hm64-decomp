    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    SPAWN_EXECUTOR 2, .elli_post_date_player_setup
    SET_ASSET_ROTATION 6
    SET_WAIT_FRAMES 30
    UPDATE_GLOBAL_RGBA 224, 224, 224, 224, 8
    WAIT_RGBA_FINISHED
    EXECUTE_SUBROUTINE .elli_walk_off_msg_490

