; Shipper on farm during birth
; ============================================

.shipper_setup_2:
    SETUP_ENTITY 30, ENTITY_ASSET_SHIPPER, 1
    SET_ENTITY_ANIMATIONS 30, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_COORDINATES -560, 0, 144
.shipper_birth_idle:
    SET_ASSET_ROTATION 6
    SET_CALLBACK_ROUTINE 0, BUTTON_A, .shipper_birth_show_msg_19
    EXECUTE_SUBROUTINE .idle

.shipper_birth_show_msg_19:
    PAUSE_ENTITIES
    FLIP_ENTITY_DIRECTION 0
    EXECUTE_SUBROUTINE .set_msg_default_layout
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 19
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .shipper_birth_idle
