    SET_COORDINATES -342, 0, 152
    WAIT_RGBA_FINISHED
    EXECUTE_SUBROUTINE .shady_salesman_show_doorstep_greeting
    EXECUTE_SUBROUTINE .shady_salesman_arm_callback_1

.shady_salesman_dispatch:
    EXECUTE_SUBROUTINE .lock_camera_and_face_player
    BRANCH_U16_VAR_WITHIN_RANGE 224, 224, gCutsceneIndex, .shady_salesman_cutscene_224
    BRANCH_U16_VAR_WITHIN_RANGE 225, 225, gCutsceneIndex, .shady_salesman_cutscene_225_2
    EXECUTE_SUBROUTINE .end_cutscene

.shady_salesman_cutscene_224:
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 555
    WAIT_MESSAGE_BOX_CLOSED 0
    INIT_DIALOGUE_SESSION 0, DIALOGUE_FARM_VISITS, 25
    WAIT_FOR_DIALOGUE_INPUT 0
    BRANCH_ON_DIALOGUE 0, 0, .shady_salesman_dialogue_25_yes
    BRANCH_ON_DIALOGUE 0, 1, .shady_salesman_dialogue_25_no

.shady_salesman_dialogue_25_no:
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 557
    WAIT_MESSAGE_BOX_CLOSED 0
    INIT_DIALOGUE_SESSION 0, DIALOGUE_FARM_VISITS, 25
    WAIT_FOR_DIALOGUE_INPUT 0
    BRANCH_ON_DIALOGUE 0, 0, .shady_salesman_dialogue_25_yes
    BRANCH_ON_DIALOGUE 0, 1, .shady_salesman_dialogue_25_no_2

.shady_salesman_dialogue_25_no_2:
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 558
    WAIT_MESSAGE_BOX_CLOSED 0
    INIT_DIALOGUE_SESSION 0, DIALOGUE_FARM_VISITS, 25
    WAIT_FOR_DIALOGUE_INPUT 0
    BRANCH_ON_DIALOGUE 0, 0, .shady_salesman_dialogue_25_yes
    BRANCH_ON_DIALOGUE 0, 1, .shady_salesman_dialogue_25_no_3

.shady_salesman_dialogue_25_no_3:
    UPDATE_U8_VALUE -5, 255, gHappiness
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 559
    EXECUTE_SUBROUTINE .close_message_and_walk_off_northwest_120

.shady_salesman_dialogue_25_yes:
    BRANCH_U32_VAR_WITHIN_RANGE 0, 149, gGold, .shady_salesman_award_and_msg_560
    UPDATE_U32_VALUE 4294967146, 999999, gGold
    UPDATE_U8_VALUE 3, 255, gHappiness
    ; buy super high grade chicken feed
    SET_SPECIAL_BIT 9, lifeEventBits[2]
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 556

; Close message, walk salesman 120 steps NW, then branch to a follow-up text depending on cutscene index (224 -> text 17, 225 -> text 18).
.close_msg_walk_off_and_maybe_followup:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITY 30
    ENTITY_WALK 120, DIRECTION_W, 2
    BRANCH_U16_VAR_WITHIN_RANGE 224, 224, gCutsceneIndex, .shady_salesman_cutscene_224_2
    BRANCH_U16_VAR_WITHIN_RANGE 225, 225, gCutsceneIndex, .shady_salesman_cutscene_225
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .end_cutscene

.shady_salesman_cutscene_224_2:
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 17
    RETURN_FROM_SUBROUTINE

.shady_salesman_cutscene_225:
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 18
    RETURN_FROM_SUBROUTINE

.shady_salesman_award_and_msg_560:
    UPDATE_U8_VALUE -5, 255, gHappiness
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 560
    EXECUTE_SUBROUTINE .close_message_and_walk_off_northwest_120

.shady_salesman_cutscene_225_2:
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 561
    WAIT_MESSAGE_BOX_CLOSED 0
    INIT_DIALOGUE_SESSION 0, DIALOGUE_FARM_VISITS, 25
    WAIT_FOR_DIALOGUE_INPUT 0
    BRANCH_ON_DIALOGUE 0, 0, .shady_salesman_dialogue_25_yes_2
    BRANCH_ON_DIALOGUE 0, 1, .shady_salesman_dialogue_25_no_4

.shady_salesman_dialogue_25_yes_2:
    BRANCH_U32_VAR_WITHIN_RANGE 0, 349, gGold, .shady_salesman_award_and_msg_560
    UPDATE_U32_VALUE 4294966946, 999999, gGold
    UPDATE_U8_VALUE 3, 255, gHappiness
    SET_SPECIAL_BIT 10, lifeEventBits[2]
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 563
    EXECUTE_SUBROUTINE .close_msg_walk_off_and_maybe_followup

.shady_salesman_dialogue_25_no_4:
    UPDATE_U8_VALUE -5, 255, gHappiness
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 566
    EXECUTE_SUBROUTINE .close_message_and_walk_off_northwest_120

; Shared harvest-sprite entity-finalize helper: clear behavior flags, fade in (alpha 254), face NE, mark non-collidable.
.harvest_sprite_common_fade_in_setup:
    SET_BEHAVIOR_FLAGS 0
    UPDATE_RGBA 254, 254, 254, 254, 0
    SET_ASSET_ROTATION 4
    SET_ENTITY_NON_COLLIDABLE
    RETURN_FROM_SUBROUTINE

.harvest_sprite_setup_slot29:
    SETUP_ENTITY 29, ENTITY_ASSET_HARVEST_SPRITE, 1
    SET_ENTITY_ANIMATIONS 29, 0, 8, 0, 0, 0, 0
    EXECUTE_SUBROUTINE .harvest_sprite_common_fade_in_setup
    SET_COORDINATES -342, 0, 152
    WAIT_RGBA_FINISHED
    SET_CALLBACK_ROUTINE 0, 32768, .harvest_sprite_slot29_trigger
    EXECUTE_SUBROUTINE .wait_until_hour_9


; ==========================================================
; Harvest Sprites
; ==========================================================

.harvest_sprite_setup:
    SETUP_ENTITY 30, ENTITY_ASSET_HARVEST_SPRITE, 1
    SET_ENTITY_ANIMATIONS 30, 0, 8, 0, 0, 0, 0
    EXECUTE_SUBROUTINE .harvest_sprite_common_fade_in_setup
    SET_COORDINATES -364, 0, 152
    WAIT_RGBA_FINISHED
    SET_CALLBACK_ROUTINE 0, 32768, .harvest_sprite_slot30_trigger
    EXECUTE_SUBROUTINE .wait_until_hour_9

.harvest_sprite_setup_slot31:
    SETUP_ENTITY 31, ENTITY_ASSET_HARVEST_SPRITE, 1
    SET_ENTITY_ANIMATIONS 31, 0, 8, 0, 0, 0, 0
    EXECUTE_SUBROUTINE .harvest_sprite_common_fade_in_setup
    SET_COORDINATES -384, 0, 152
    WAIT_RGBA_FINISHED
    SET_CALLBACK_ROUTINE 0, 32768, .harvest_sprite_slot31_trigger
    EXECUTE_SUBROUTINE .wait_until_hour_9

; Callback fired when player enters proximity of Harvest Sprite in slot 29 (sets peer pointers on slots 2 and 3, spawns shared award routine).
.harvest_sprite_slot29_trigger:
    EXECUTE_SUBROUTINE .lock_camera_and_face_player
    SET_OTHER_EXECUTOR_PTR 2, .rearm_dispatch_and_idle
    SET_OTHER_EXECUTOR_PTR 3, .rearm_dispatch_and_idle
    SPAWN_EXECUTOR 4, .harvest_sprite_award_and_msg_571
    EXECUTE_SUBROUTINE .idle

; Callback fired when player enters proximity of Harvest Sprite in slot 30.
.harvest_sprite_slot30_trigger:
    EXECUTE_SUBROUTINE .lock_camera_and_face_player
    SET_OTHER_EXECUTOR_PTR 1, .rearm_dispatch_and_idle
    SET_OTHER_EXECUTOR_PTR 3, .rearm_dispatch_and_idle
    SPAWN_EXECUTOR 4, .harvest_sprite_award_and_msg_571
    EXECUTE_SUBROUTINE .idle

; Callback fired when player enters proximity of Harvest Sprite in slot 31.
.harvest_sprite_slot31_trigger:
    EXECUTE_SUBROUTINE .lock_camera_and_face_player
    SET_OTHER_EXECUTOR_PTR 1, .rearm_dispatch_and_idle
    SET_OTHER_EXECUTOR_PTR 2, .rearm_dispatch_and_idle
    SPAWN_EXECUTOR 4, .harvest_sprite_award_and_msg_571
    EXECUTE_SUBROUTINE .idle

; Shared routine spawned into executor slot 4: maxes gHappiness, shows texts 571/572/573, then hands all three peer slots to their walk-off executors.
.harvest_sprite_award_and_msg_571:
    UPDATE_U8_VALUE 2, 255, gHappiness
    SET_OTHER_EXECUTOR_PTR 1, .flip_animation_and_idle
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 571
    WAIT_MESSAGE_BOX_CLOSED 0
    SET_OTHER_EXECUTOR_PTR 2, .flip_animation_and_idle
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 572
    WAIT_MESSAGE_BOX_CLOSED 0
    SET_OTHER_EXECUTOR_PTR 3, .flip_animation_and_idle
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 573
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 1, .harvest_sprite_slot1_walkoff_and_end
    SET_OTHER_EXECUTOR_PTR 2, .harvest_sprite_slot30_walkoff
    SET_OTHER_EXECUTOR_PTR 3, .harvest_sprite_slot31_walkoff
    DEACTIVATE_SELF

.harvest_sprite_slot1_walkoff_and_end:
    TOGGLE_PAUSE_ENTITY 29
    ENTITY_WALK 130, DIRECTION_W, 2
    TOGGLE_PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .end_cutscene

.harvest_sprite_slot30_walkoff:
    TOGGLE_PAUSE_ENTITY 30
    ENTITY_WALK 120, DIRECTION_W, 2
    DEACTIVATE_SELF

.harvest_sprite_slot31_walkoff:
    TOGGLE_PAUSE_ENTITY 31
    ENTITY_WALK 110, DIRECTION_W, 2
    DEACTIVATE_SELF


