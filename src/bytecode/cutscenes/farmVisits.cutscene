; ==========================================================
; Ann
; ==========================================================

.ann_setup:
    SETUP_ENTITY 30, ENTITY_ASSET_ANN, 1
    SET_ENTITY_ANIMATIONS 30, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    RETURN_FROM_SUBROUTINE

; Shows arrival text 396 using a taller message box, then restores defaults.
.ann_show_msg_396_large_box:
    PAUSE_ENTITIES
    SET_MESSAGE_INTERPOLATION -4, 0, 0
    SET_MESSAGE_BOX_ASSETS 0, 1, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 0, -64, 352
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 396
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_MESSAGE_BOX_ASSETS 0, 0, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 24, -64, 352
    TOGGLE_PAUSE_ENTITIES
    RETURN_FROM_SUBROUTINE

; Picks a wait-until-hour helper based on gCutsceneIndex, then dispatches via .ann_dispatch.
.ann_arm_callback_1:
    SET_CALLBACK_ROUTINE 0, 32768, .ann_dispatch
    BRANCH_U16_VAR_WITHIN_RANGE 179, 179, gCutsceneIndex, .wait_until_hour_9
    BRANCH_U16_VAR_WITHIN_RANGE 180, 180, gCutsceneIndex, .wait_until_hours_9_11_13_15_17
    BRANCH_U16_VAR_WITHIN_RANGE 181, 181, gCutsceneIndex, .wait_until_hour_18
    BRANCH_U16_VAR_WITHIN_RANGE 182, 183, gCutsceneIndex, .wait_until_hours_9_11_13_15_17
    BRANCH_U16_VAR_WITHIN_RANGE 186, 187, gCutsceneIndex, .wait_until_hour_18
    BRANCH_U16_VAR_WITHIN_RANGE 188, 189, gCutsceneIndex, .wait_until_hour_12
    EXECUTE_SUBROUTINE .wait_until_hour_17

; Walk-in from the far west approach; uses .ann_walk_in_1_late for cutscenes 184-185.
.ann_walk_in_1:
    EXECUTE_SUBROUTINE .ann_setup
    SET_ASSET_ROTATION 6
    BRANCH_U16_VAR_WITHIN_RANGE 184, 185, gCutsceneIndex, .ann_walk_in_1_late
    SET_COORDINATES -590, 0, 152
    ENTITY_WALK 34, DIRECTION_E, 2
    EXECUTE_SUBROUTINE .ann_show_msg_396_large_box
    ENTITY_WALK 90, DIRECTION_E, 2
    SET_ASSET_ROTATION 4
    EXECUTE_SUBROUTINE .ann_arm_callback_1

; Walk-in starting at the door with a fade-in; branches to .ann_walk_in_2_late for 184-185.
.ann_walk_in_2:
    EXECUTE_SUBROUTINE .ann_setup
    UPDATE_RGBA 254, 254, 254, 254, 0
    SET_ASSET_ROTATION 4
    SET_COORDINATES -358, 0, 152
    BRANCH_U16_VAR_WITHIN_RANGE 184, 185, gCutsceneIndex, .ann_walk_in_2_late
    WAIT_RGBA_FINISHED
    EXECUTE_SUBROUTINE .ann_show_msg_396_large_box
    EXECUTE_SUBROUTINE .ann_arm_callback_1

.ann_walk_in_1_late:
    EXECUTE_SUBROUTINE .walk_in_from_north_southwest

.ann_walk_in_2_late:
    BRANCH_U16_VAR_WITHIN_RANGE 185, 185, gCutsceneIndex, .ann_cutscene_185
    SET_CALLBACK_ROUTINE 0, 32768, .ann_cutscene_184
    EXECUTE_SUBROUTINE .idle

.ann_cutscene_185:
    SET_CALLBACK_ROUTINE 0, 32768, .ann_cutscene_185_callback
    EXECUTE_SUBROUTINE .idle

; Shared close helper: walks Ann NW 32, turns SE, shows msg 491, then walks off NW 98.
.ann_show_msg_491_and_walk_off_northwest_98:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITY 30
    ENTITY_WALK 32, DIRECTION_W, 2
    SET_ASSET_ROTATION 6
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 491
    EXECUTE_SUBROUTINE .close_message_and_walk_off_northwest_98

; Main dispatch by gCutsceneIndex after camera/lock routines.
.ann_dispatch:
    BRANCH_U16_VAR_WITHIN_RANGE 177, 178, gCutsceneIndex, .cutscene_ann_thanksgiving_gift
    BRANCH_U16_VAR_WITHIN_RANGE 182, 182, gCutsceneIndex, .cutscene_ann_thanksgiving_gift
    BRANCH_U16_VAR_WITHIN_RANGE 186, 187, gCutsceneIndex, .cutscene_ann_thanksgiving_gift
    EXECUTE_SUBROUTINE .lock_camera_and_face_player
    BRANCH_U16_VAR_WITHIN_RANGE 179, 179, gCutsceneIndex, .ann_cutscene_179
    BRANCH_U16_VAR_WITHIN_RANGE 180, 180, gCutsceneIndex, .cutscene_ann_fireworks_invitation
    BRANCH_U16_VAR_WITHIN_RANGE 181, 181, gCutsceneIndex, .ann_cutscene_181
    BRANCH_U16_VAR_WITHIN_RANGE 183, 183, gCutsceneIndex, .ann_cutscene_183
    BRANCH_U16_VAR_WITHIN_RANGE 188, 188, gCutsceneIndex, .ann_cutscene_188
    BRANCH_U16_VAR_WITHIN_RANGE 189, 189, gCutsceneIndex, .ann_cutscene_189
    EXECUTE_SUBROUTINE .end_cutscene

