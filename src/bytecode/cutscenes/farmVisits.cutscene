; ---- Cutscene 255: Ann pika-bunny event ----
.cutscene_255:
    SET_SPECIAL_BIT 29, dailyEventBits[1]
    SPAWN_EXECUTOR 1, .ann_walk_in_3
    SPAWN_EXECUTOR 2, .mouse_setup_slot31
    SET_WAIT_FRAMES 1
    EXECUTE_SUBROUTINE .player_setup_slot0
    SET_COORDINATES 160, 0, 0
    SET_ASSET_ROTATION 4
    UPDATE_GLOBAL_RGBA 254, 254, 254, 254, 0
    WAIT_RGBA_FINISHED
    SET_BEHAVIOR_FLAGS 0
    SET_WAIT_FRAMES 10
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 367
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 1, .ann_pika_bunny_anim_103_25
    SET_ENTITY_DIRECTIONAL_ANIMATION 439
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 447
    SET_WAIT_FRAMES 10
    SPAWN_EXECUTOR 41, .ann_pika_bunny_camera_move
    EXECUTE_SUBROUTINE .idle

.ann_pika_bunny_camera_move:
    SETUP_MAP_ASSET MAIN_MAP_INDEX
    SET_ASSET_ROTATION 7
    SET_FRAME_DELTA 0, 0, -2, 96
    SET_FRAME_DELTA -2, 0, -2, 24
    SET_OTHER_EXECUTOR_PTR 2, .ann_pika_bunny_show_msg_369_370
    EXECUTE_SUBROUTINE .idle

.ann_walk_in_3:
    EXECUTE_SUBROUTINE .ann_setup
    SET_COORDINATES 192, 0, 0
    SET_ASSET_ROTATION 4
    EXECUTE_SUBROUTINE .idle

.ann_pika_bunny_anim_103_25:
    SET_ENTITY_DIRECTIONAL_ANIMATION 103
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 25
    EXECUTE_SUBROUTINE .idle

.mouse_setup_slot31:
    SETUP_ENTITY 31, ENTITY_ASSET_MOUSE, 1
    SET_ENTITY_ANIMATIONS 31, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    SET_COORDINATES 80, 0, -256
    SET_ASSET_ROTATION 1
    EXECUTE_SUBROUTINE .idle

.ann_pika_bunny_show_msg_369_370:
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 369
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    ENTITY_WALK 10, DIRECTION_SW, 2
    SET_WAIT_FRAMES 10
    ENTITY_WALK 24, DIRECTION_S, 2
    SET_ENTITY_ANIMATION 16
    SET_WAIT_FRAMES 30
    ENTITY_WALK 24, DIRECTION_E, 2
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 370
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    ENTITY_WALK 16, DIRECTION_S, 2
    SET_ENTITY_ANIMATION 16
    SET_WAIT_FRAMES 5
    SET_ENTITY_ANIMATION 17
    SET_WAIT_FRAMES 30
    SET_ENTITY_ANIMATION 16
    SET_WAIT_FRAMES 5
    ENTITY_WALK 112, DIRECTION_W, 2
    SET_OTHER_EXECUTOR_PTR 41, .ann_pika_bunny_camera_return
    DEACTIVATE_SELF

.ann_pika_bunny_camera_return:
    SET_FRAME_DELTA 2, 0, 2, 24
    SET_OTHER_EXECUTOR_PTR 0, .ann_pika_bunny_player_walk_off
    SET_OTHER_EXECUTOR_PTR 1, .ann_pika_bunny_ann_walk_off
    SET_FRAME_DELTA 0, 0, 2, 64
    SET_WAIT_FRAMES 20
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 371
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_WAIT_FRAMES 20
    SET_AUDIO_SEQUENCE_VOLUME 0, 0, 4
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    STOP_SEQUENCE_WITH_FADE 0, 1
    DEACTIVATE_EXECUTOR 0
    DEACTIVATE_EXECUTOR 1
    IDLE_WHILE_SEQUENCE_PLAYING 0
    EXECUTE_SUBROUTINE .end_cutscene

.ann_pika_bunny_player_walk_off:
    SET_ENTITY_DIRECTIONAL_ANIMATION 439
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    ENTITY_WALK 32, DIRECTION_N, 2
    SET_ASSET_ROTATION 6
    EXECUTE_SUBROUTINE .idle

.ann_pika_bunny_ann_walk_off:
    SET_ENTITY_DIRECTIONAL_ANIMATION 103
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    ENTITY_WALK 32, DIRECTION_N, 2
    SET_ASSET_ROTATION 2
    EXECUTE_SUBROUTINE .idle

.player_walk_in_29:
