; ==========================================================
; Karen
; ==========================================================

.karen_setup:
    SETUP_ENTITY 30, ENTITY_ASSET_KAREN, 1
    SET_ENTITY_ANIMATIONS 30, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    RETURN_FROM_SUBROUTINE

; Shared message-box helpers (avatar-enabled greeting + default reset)
.karen_say_hi_there:
    PAUSE_ENTITIES
    SET_MESSAGE_INTERPOLATION -4, 0, 0
    SET_MESSAGE_BOX_ASSETS 0, 1, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 0, -64, 352
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 464
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_MESSAGE_BOX_ASSETS 0, 0, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 24, -64, 352
    TOGGLE_PAUSE_ENTITIES
    RETURN_FROM_SUBROUTINE

.karen_arm_callback_1:
    SET_CALLBACK_ROUTINE 0, 32768, .karen_dispatch
    BRANCH_U16_VAR_WITHIN_RANGE 192, 192, gCutsceneIndex, .wait_until_hours_9_11_13_15_17
    BRANCH_U16_VAR_WITHIN_RANGE 193, 193, gCutsceneIndex, .wait_until_hour_0
    BRANCH_U16_VAR_WITHIN_RANGE 194, 194, gCutsceneIndex, .wait_until_hour_18
    BRANCH_U16_VAR_WITHIN_RANGE 195, 196, gCutsceneIndex, .wait_until_hours_9_11_13_15_17
    BRANCH_U16_VAR_WITHIN_RANGE 199, 200, gCutsceneIndex, .wait_until_hour_18
    EXECUTE_SUBROUTINE .wait_until_hour_17

.karen_walk_in_1:
    EXECUTE_SUBROUTINE .karen_setup
    SET_ASSET_ROTATION 6
    BRANCH_U16_VAR_WITHIN_RANGE 197, 198, gCutsceneIndex, .karen_festival_invite_setup
    SET_COORDINATES -590, 0, 152
    ENTITY_WALK 34, DIRECTION_E, 2
    EXECUTE_SUBROUTINE .karen_say_hi_there
    ENTITY_WALK 90, DIRECTION_E, 2
    SET_ASSET_ROTATION 4
    EXECUTE_SUBROUTINE .karen_arm_callback_1

.karen_walk_in_2:
    EXECUTE_SUBROUTINE .karen_setup
    UPDATE_RGBA 254, 254, 254, 254, 0
    SET_ASSET_ROTATION 4
    SET_COORDINATES -358, 0, 152
    BRANCH_U16_VAR_WITHIN_RANGE 197, 198, gCutsceneIndex, .karen_festival_invite_dispatch
    WAIT_RGBA_FINISHED
    EXECUTE_SUBROUTINE .karen_say_hi_there
    EXECUTE_SUBROUTINE .karen_arm_callback_1

.karen_festival_invite_setup:
    EXECUTE_SUBROUTINE .walk_in_from_north_southwest

.karen_festival_invite_dispatch:
    BRANCH_U16_VAR_WITHIN_RANGE 198, 198, gCutsceneIndex, .karen_cutscene_198
    SET_CALLBACK_ROUTINE 0, 32768, .karen_award_and_msg_457
    EXECUTE_SUBROUTINE .idle

.karen_cutscene_198:
    SET_CALLBACK_ROUTINE 0, 32768, .karen_award_and_msg_462
    EXECUTE_SUBROUTINE .idle

.karen_walk_over_say_text_492:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITY 30
    ENTITY_WALK 32, DIRECTION_W, 2
    SET_ASSET_ROTATION 6
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 492
    EXECUTE_SUBROUTINE .close_message_and_walk_off_northwest_98

; Dispatch table keyed on gCutsceneIndex -- routes to per-cutscene handlers
.karen_dispatch:
    BRANCH_U16_VAR_WITHIN_RANGE 190, 191, gCutsceneIndex, .karen_gift_dispatch
    BRANCH_U16_VAR_WITHIN_RANGE 194, 195, gCutsceneIndex, .karen_gift_dispatch
    BRANCH_U16_VAR_WITHIN_RANGE 199, 200, gCutsceneIndex, .karen_gift_dispatch
    EXECUTE_SUBROUTINE .lock_camera_and_face_player
    BRANCH_U16_VAR_WITHIN_RANGE 192, 192, gCutsceneIndex, .cutscene_karen_fireworks_invitation
    BRANCH_U16_VAR_WITHIN_RANGE 193, 193, gCutsceneIndex, .karen_cutscene_193
    BRANCH_U16_VAR_WITHIN_RANGE 196, 196, gCutsceneIndex, .karen_cutscene_196
    EXECUTE_SUBROUTINE .end_cutscene

.karen_gift_dispatch:
    BRANCH_ON_SPECIAL_BIT 28, dailyEventBits[2], .karen_arm_callback_1
    BRANCH_U8_VAR_WITHIN_RANGE 0, 254, gItemBeingHeld, .karen_arm_callback_1
    EXECUTE_SUBROUTINE .lock_camera_and_face_player
    BRANCH_U16_VAR_WITHIN_RANGE 190, 190, gCutsceneIndex, .karen_cutscene_190
    BRANCH_U16_VAR_WITHIN_RANGE 191, 191, gCutsceneIndex, .karen_cutscene_191
    BRANCH_U16_VAR_WITHIN_RANGE 194, 194, gCutsceneIndex, .karen_cutscene_194
    BRANCH_U16_VAR_WITHIN_RANGE 195, 195, gCutsceneIndex, .cutscene_karen_thanksgiving_gift
    BRANCH_U16_VAR_WITHIN_RANGE 199, 199, gCutsceneIndex, .karen_cutscene_199
    BRANCH_U16_VAR_WITHIN_RANGE 200, 200, gCutsceneIndex, .karen_cutscene_200
    EXECUTE_SUBROUTINE .end_cutscene

