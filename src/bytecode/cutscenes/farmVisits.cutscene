; ==========================================================
; Elli
; ==========================================================

.elli_setup:
    SETUP_ENTITY 30, ENTITY_ASSET_ELLI, 1
    SET_ENTITY_ANIMATIONS 30, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    RETURN_FROM_SUBROUTINE

; Open a narrow menu-style box and show text 341 (Hello), then restore default box layout.
.elli_show_greeting_msg_341:
    PAUSE_ENTITIES
    SET_MESSAGE_INTERPOLATION -4, 0, 0
    SET_MESSAGE_BOX_ASSETS 0, 1, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 0, -64, 352
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 341
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_MESSAGE_BOX_ASSETS 0, 0, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 24, -64, 352
    TOGGLE_PAUSE_ENTITIES
    RETURN_FROM_SUBROUTINE

.elli_arm_callback_1:
    SET_CALLBACK_ROUTINE 0, 32768, .elli_dispatch
    BRANCH_U16_VAR_WITHIN_RANGE 167, 167, gCutsceneIndex, .wait_until_hours_9_11_13_15_17
    BRANCH_U16_VAR_WITHIN_RANGE 168, 168, gCutsceneIndex, .wait_until_hour_9
    BRANCH_U16_VAR_WITHIN_RANGE 169, 169, gCutsceneIndex, .wait_until_hour_0
    BRANCH_U16_VAR_WITHIN_RANGE 170, 170, gCutsceneIndex, .wait_until_hour_12
    BRANCH_U16_VAR_WITHIN_RANGE 171, 172, gCutsceneIndex, .wait_until_hours_9_11_13_15_17
    BRANCH_U16_VAR_WITHIN_RANGE 175, 176, gCutsceneIndex, .wait_until_hour_18
    EXECUTE_SUBROUTINE .wait_until_hour_17

.elli_walk_in_1:
    EXECUTE_SUBROUTINE .elli_setup
    SET_ASSET_ROTATION 6
    BRANCH_U16_VAR_WITHIN_RANGE 173, 174, gCutsceneIndex, .elli_walk_in_1_reposition
    SET_COORDINATES -590, 0, 152
    ENTITY_WALK 34, DIRECTION_E, 2
    EXECUTE_SUBROUTINE .elli_show_greeting_msg_341
    ENTITY_WALK 90, DIRECTION_E, 2
    SET_ASSET_ROTATION 4
    EXECUTE_SUBROUTINE .elli_arm_callback_1

.elli_walk_in_2:
    EXECUTE_SUBROUTINE .elli_setup
    UPDATE_RGBA 254, 254, 254, 254, 0
    SET_ASSET_ROTATION 4
    SET_COORDINATES -358, 0, 152
    BRANCH_U16_VAR_WITHIN_RANGE 173, 174, gCutsceneIndex, .elli_walk_in_2_dispatch
    WAIT_RGBA_FINISHED
    EXECUTE_SUBROUTINE .elli_show_greeting_msg_341
    EXECUTE_SUBROUTINE .elli_arm_callback_1

; Cutscene 173 path: reposition Elli via walk-in-from-north helper before dispatching.
.elli_walk_in_1_reposition:
    EXECUTE_SUBROUTINE .walk_in_from_north_southwest

; Dispatch by cutscene index after walk-in: 174 -> msg 339 award, else msg 334 award.
.elli_walk_in_2_dispatch:
    BRANCH_U16_VAR_WITHIN_RANGE 174, 174, gCutsceneIndex, .elli_cutscene_174
    SET_CALLBACK_ROUTINE 0, 32768, .elli_award_and_msg_334
    EXECUTE_SUBROUTINE .idle

.elli_cutscene_174:
    SET_CALLBACK_ROUTINE 0, 32768, .elli_award_and_msg_339
    EXECUTE_SUBROUTINE .idle

; Shared Elli wrap-up: close box, walk NW 32 frames, show text 490 (Ill come by again), then walk off NW.
.elli_walk_off_msg_490:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITY 30
    ENTITY_WALK 32, DIRECTION_W, 2
    SET_ASSET_ROTATION 6
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 490
    EXECUTE_SUBROUTINE .close_message_and_walk_off_northwest_98

.elli_dispatch:
    BRANCH_U16_VAR_WITHIN_RANGE 165, 166, gCutsceneIndex, .cutscene_elli_thanksgiving_gift
    BRANCH_U16_VAR_WITHIN_RANGE 171, 171, gCutsceneIndex, .cutscene_elli_thanksgiving_gift
    BRANCH_U16_VAR_WITHIN_RANGE 175, 176, gCutsceneIndex, .cutscene_elli_thanksgiving_gift
    EXECUTE_SUBROUTINE .lock_camera_and_face_player
