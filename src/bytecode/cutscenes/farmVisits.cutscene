; ==========================================================
; Basil
; ==========================================================

; --- Setup and idle behavior ---
.basil_setup:
    SETUP_ENTITY 30, ENTITY_ASSET_BASIL, 1
    SET_ENTITY_ANIMATIONS 30, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    RETURN_FROM_SUBROUTINE

.basil_arm_callback_1:
    SET_CALLBACK_ROUTINE 0, 32768, .basil_dispatch
    BRANCH_U16_VAR_WITHIN_RANGE 139, 139, gCutsceneIndex, .wait_until_hour_21
    BRANCH_U16_VAR_WITHIN_RANGE 140, 143, gCutsceneIndex, .basil_idle_rotation_loop
    EXECUTE_SUBROUTINE .wait_until_hour_9

.basil_walk_in_1:
    EXECUTE_SUBROUTINE .basil_setup
    SET_ASSET_ROTATION 6
    SET_COORDINATES -590, 0, 152
    ENTITY_WALK 34, DIRECTION_E, 2
    EXECUTE_SUBROUTINE .show_doorstep_greeting_text_620
    ENTITY_WALK 90, DIRECTION_E, 2
    SET_ASSET_ROTATION 4
    EXECUTE_SUBROUTINE .basil_arm_callback_1

.basil_walk_in_2:
    EXECUTE_SUBROUTINE .basil_setup
    UPDATE_RGBA 254, 254, 254, 254, 0
    SET_ASSET_ROTATION 4
    SET_COORDINATES -342, 0, 152
    WAIT_RGBA_FINISHED
    EXECUTE_SUBROUTINE .show_doorstep_greeting_text_620
    EXECUTE_SUBROUTINE .basil_arm_callback_1

; --- Idle rotation: change facing each 10-minute tick ---
.basil_idle_rotation_loop:
    SET_WAIT_FRAMES 1
    BRANCH_U8_VAR_WITHIN_RANGE 17, 17, gHour, .rearm_dispatch_and_walk_off_northwest_116
    BRANCH_U8_VAR_WITHIN_RANGE 0, 0, gMinutes, .basil_face_northeast
    BRANCH_U8_VAR_WITHIN_RANGE 10, 10, gMinutes, .basil_face_east
    BRANCH_U8_VAR_WITHIN_RANGE 20, 20, gMinutes, .basil_face_southeast
    BRANCH_U8_VAR_WITHIN_RANGE 30, 30, gMinutes, .basil_face_south
    BRANCH_U8_VAR_WITHIN_RANGE 40, 40, gMinutes, .basil_face_southwest
    BRANCH_U8_VAR_WITHIN_RANGE 50, 50, gMinutes, .basil_face_southeast
    EXECUTE_SUBROUTINE .basil_idle_rotation_loop

.basil_face_northeast:
    SET_ASSET_ROTATION 4
    EXECUTE_SUBROUTINE .basil_idle_rotation_loop

.basil_face_east:
    SET_ASSET_ROTATION 5
    EXECUTE_SUBROUTINE .basil_idle_rotation_loop

.basil_face_southeast:
    SET_ASSET_ROTATION 6
    EXECUTE_SUBROUTINE .basil_idle_rotation_loop

.basil_face_south:
    SET_ASSET_ROTATION 7
    EXECUTE_SUBROUTINE .basil_idle_rotation_loop

.basil_face_southwest:
    SET_ASSET_ROTATION 0
    EXECUTE_SUBROUTINE .basil_idle_rotation_loop

; --- Farewell helpers ---
.basil_farewell:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITY 30
    ENTITY_WALK 32, DIRECTION_W, 2
    SET_ASSET_ROTATION 6
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 623
    EXECUTE_SUBROUTINE .close_message_and_walk_off_northwest_98

.basil_farewell_no_prior_msg:
    TOGGLE_PAUSE_ENTITY 30
    ENTITY_WALK 32, DIRECTION_W, 2
    SET_ASSET_ROTATION 6
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 623
    EXECUTE_SUBROUTINE .close_message_and_walk_off_northwest_98

; --- Dispatcher: choose scene by gCutsceneIndex ---
.basil_cutscene_139:
    BRANCH_ON_SPECIAL_BIT 28, dailyEventBits[2], .basil_arm_callback_1
    BRANCH_U8_VAR_WITHIN_RANGE 0, 254, gItemBeingHeld, .basil_arm_callback_1
    EXECUTE_SUBROUTINE .lock_camera_and_face_player
    EXECUTE_SUBROUTINE .cutscene_basil_farm_visit_offer_seeds

.basil_dispatch:
    BRANCH_U16_VAR_WITHIN_RANGE 139, 139, gCutsceneIndex, .basil_cutscene_139
    EXECUTE_SUBROUTINE .lock_camera_and_face_player
    BRANCH_U16_VAR_WITHIN_RANGE 137, 137, gCutsceneIndex, .cutscene_basil_farm_flower_festival
    BRANCH_U16_VAR_WITHIN_RANGE 138, 138, gCutsceneIndex, .cutscene_basil_farm_vegetable_festival
    BRANCH_U16_VAR_WITHIN_RANGE 140, 140, gCutsceneIndex, .cutscene_basil_intro
    BRANCH_U16_VAR_WITHIN_RANGE 141, 141, gCutsceneIndex, .cutscene_basil_power_nut_gift
    BRANCH_U16_VAR_WITHIN_RANGE 142, 142, gCutsceneIndex, .cutscene_basil_return
    BRANCH_U16_VAR_WITHIN_RANGE 143, 143, gCutsceneIndex, .cutscene_basil_leaving
    EXECUTE_SUBROUTINE .end_cutscene

