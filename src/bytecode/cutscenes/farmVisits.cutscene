    SET_WAIT_FRAMES 1
    EXECUTE_SUBROUTINE .player_setup_slot0
    SET_ENTITY_NON_COLLIDABLE
    SET_ENTITY_PHYSICS_FLAGS 1
    SET_WAIT_FRAMES 32
    ENTITY_WALK 56, DIRECTION_S, 2
    SET_OTHER_EXECUTOR_PTR 2, .doug_dispatch_slot_2
    EXECUTE_SUBROUTINE .idle

; 0x104AFC
.idle:
    SET_WAIT_FRAMES 1
    EXECUTE_SUBROUTINE .idle

; Hour-wait loops -- each spins until gHour matches, then arms callback 2
.wait_until_hour_0:
    SET_WAIT_FRAMES 1
    BRANCH_U8_VAR_WITHIN_RANGE 0, 0, gHour, .rearm_dispatch_and_walk_off_northwest_116
    EXECUTE_SUBROUTINE .wait_until_hour_0

.wait_until_hour_9:
    SET_WAIT_FRAMES 1
    BRANCH_U8_VAR_WITHIN_RANGE 9, 9, gHour, .rearm_dispatch_and_walk_off_northwest_116
    EXECUTE_SUBROUTINE .wait_until_hour_9

.wait_until_hour_12:
    SET_WAIT_FRAMES 1
    BRANCH_U8_VAR_WITHIN_RANGE 12, 12, gHour, .rearm_dispatch_and_walk_off_northwest_116
    EXECUTE_SUBROUTINE .wait_until_hour_12

.wait_until_hour_15:
    SET_WAIT_FRAMES 1
    BRANCH_U8_VAR_WITHIN_RANGE 15, 15, gHour, .rearm_dispatch_and_walk_off_northwest_116
    EXECUTE_SUBROUTINE .wait_until_hour_15

.wait_until_hour_17:
    SET_WAIT_FRAMES 1
    BRANCH_U8_VAR_WITHIN_RANGE 17, 17, gHour, .rearm_dispatch_and_walk_off_northwest_116
    EXECUTE_SUBROUTINE .wait_until_hour_17

.wait_until_hour_18:
    SET_WAIT_FRAMES 1
    BRANCH_U8_VAR_WITHIN_RANGE 18, 18, gHour, .rearm_dispatch_and_walk_off_northwest_116
    EXECUTE_SUBROUTINE .wait_until_hour_18

.wait_until_hour_21:
    SET_WAIT_FRAMES 1
    BRANCH_U8_VAR_WITHIN_RANGE 21, 21, gHour, .rearm_dispatch_and_walk_off_northwest_116
    EXECUTE_SUBROUTINE .wait_until_hour_21

.wait_until_hours_9_11_13_15_17:
    SET_WAIT_FRAMES 1
    BRANCH_U8_VAR_WITHIN_RANGE 9, 9, gHour, .rearm_dispatch_and_walk_off_northwest_116
    BRANCH_U8_VAR_WITHIN_RANGE 11, 11, gHour, .rearm_dispatch_and_walk_off_northwest_116
    BRANCH_U8_VAR_WITHIN_RANGE 13, 13, gHour, .rearm_dispatch_and_walk_off_northwest_116
    BRANCH_U8_VAR_WITHIN_RANGE 15, 15, gHour, .rearm_dispatch_and_walk_off_northwest_116
    BRANCH_U8_VAR_WITHIN_RANGE 17, 17, gHour, .rearm_dispatch_and_walk_off_northwest_116
    EXECUTE_SUBROUTINE .wait_until_hours_9_11_13_15_17

; Shared setup / teardown helpers used by award-and-msg handlers
.lock_camera_and_face_player:
    FLIP_ENTITY_DIRECTION 0
    PAUSE_ENTITY 0
    SET_MAP_ROTATION 0, 255, 7
    WAIT_MAP_LOAD 0
    SET_U8_VALUE 0, gCameraRotationOffset
    SET_MESSAGE_INTERPOLATION -4, 0, 0
    SET_MESSAGE_BOX_ASSETS 0, 0, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 24, -64, 352
    RETURN_FROM_SUBROUTINE

.close_message_and_walk_off_northwest_122:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITIES
    ENTITY_WALK 122, DIRECTION_W, 2
    EXECUTE_SUBROUTINE .end_cutscene

.close_message_and_walk_off_northwest_98:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    ENTITY_WALK 98, DIRECTION_W, 2
    TOGGLE_PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .end_cutscene

.rearm_dispatch_and_walk_off_northwest_116:
    SET_CALLBACK_ROUTINE 65535, 32768, .cutscene_kent_farm_sowing_fesitval
    ENTITY_WALK 116, DIRECTION_W, 2
    EXECUTE_SUBROUTINE .end_cutscene

.rearm_dispatch_and_idle:
    SET_CALLBACK_ROUTINE 65535, 32768, .cutscene_kent_farm_sowing_fesitval
    EXECUTE_SUBROUTINE .idle

.set_msg_default_layout:
    SET_MESSAGE_INTERPOLATION -4, 0, 0
    SET_MESSAGE_BOX_ASSETS 0, 0, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 24, -64, 352
    RETURN_FROM_SUBROUTINE

