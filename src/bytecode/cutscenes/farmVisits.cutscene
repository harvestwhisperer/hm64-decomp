.kai_setup:
    SETUP_ENTITY 30, ENTITY_ASSET_KAI, 1
    SET_ENTITY_ANIMATIONS 30, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    RETURN_FROM_SUBROUTINE

.kai_arm_callback_1:
    SET_CALLBACK_ROUTINE 0, 32768, .kai_dispatch
    BRANCH_U16_VAR_WITHIN_RANGE 215, 215, gCutsceneIndex, .wait_until_hour_18
    BRANCH_U16_VAR_WITHIN_RANGE 218, 219, gCutsceneIndex, .wait_until_hour_18
    EXECUTE_SUBROUTINE .wait_until_hour_9

