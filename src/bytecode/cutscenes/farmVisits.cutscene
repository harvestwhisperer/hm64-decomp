    SPAWN_EXECUTOR 41, .karen_fairy_scene_map_setup
    SET_WAIT_FRAMES 1
    SPAWN_EXECUTOR 1, .karen_walk_in_3
    EXECUTE_SUBROUTINE .player_setup_slot0
    SET_COORDINATES 72, 0, 0
    SET_ASSET_ROTATION 2
    SET_WAIT_FRAMES 1
    SET_BEHAVIOR_FLAGS 0
    SET_WAIT_FRAMES 1
    SET_OTHER_EXECUTOR_PTR 41, .karen_fairy_scene_map_reposition
    SPAWN_EXECUTOR 16, .karen_dma_slot128_1
    SET_WAIT_FRAMES 6
    SPAWN_EXECUTOR 17, .karen_dma_slot129_1
    SET_WAIT_FRAMES 6
    SPAWN_EXECUTOR 18, .karen_dma_slot130_1
    SET_WAIT_FRAMES 6
    SPAWN_EXECUTOR 19, .karen_dma_slot131_1
    SET_WAIT_FRAMES 6
