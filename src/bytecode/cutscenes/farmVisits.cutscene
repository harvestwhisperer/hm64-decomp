    BRANCH_ON_DIALOGUE 0, 0, .harris_dialogue_20_yes
    BRANCH_ON_DIALOGUE 0, 1, .harris_dialogue_20_no

.harris_dialogue_20_yes:
    ; SPIRIT_FESTIVAL_INVITATION_ACCEPTED
    SET_SPECIAL_BIT 16, dailyEventBits[2]
    UPDATE_U8_VALUE 3, 255, npcAffection[HARRIS]
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 502
