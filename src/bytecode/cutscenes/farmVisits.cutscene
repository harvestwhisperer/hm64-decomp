    WAIT_RGBA_FINISHED
    EXECUTE_SUBROUTINE .pause_and_show_centered_msg_147
    EXECUTE_SUBROUTINE .kai_arm_callback_1

; Shared helper -- wait for msg close, unpause Kai, walk him off to the northwest.
.kai_close_msg_walk_off_northwest:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITY 30
    ENTITY_WALK 32, DIRECTION_W, 2
    SET_ASSET_ROTATION 6
    RETURN_FROM_SUBROUTINE

; Close message and show Kai goodbye text 539 (See you later), then walk off.
.kai_close_msg_539:
    EXECUTE_SUBROUTINE .kai_close_msg_walk_off_northwest
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 539
    EXECUTE_SUBROUTINE .close_message_and_walk_off_northwest_98

; Close message and show Kai goodbye text 626 (Well see you later), then walk off.
.kai_close_msg_626:
    EXECUTE_SUBROUTINE .kai_close_msg_walk_off_northwest
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 626
    EXECUTE_SUBROUTINE .close_message_and_walk_off_northwest_98

.kai_dispatch:
    BRANCH_U16_VAR_WITHIN_RANGE 215, 215, gCutsceneIndex, .kai_cutscene_215_or_218_gate
    BRANCH_U16_VAR_WITHIN_RANGE 218, 218, gCutsceneIndex, .kai_cutscene_215_or_218_gate
    EXECUTE_SUBROUTINE .lock_camera_and_face_player
    BRANCH_U16_VAR_WITHIN_RANGE 216, 216, gCutsceneIndex, .kai_cutscene_216
    BRANCH_U16_VAR_WITHIN_RANGE 217, 217, gCutsceneIndex, .kai_cutscene_217
    BRANCH_U16_VAR_WITHIN_RANGE 219, 219, gCutsceneIndex, .kai_cutscene_219
    EXECUTE_SUBROUTINE .end_cutscene

; Cutscenes 215 and 218 only fire when daily bit 28 is clear and the player is holding no item.
.kai_cutscene_215_or_218_gate:
    BRANCH_ON_SPECIAL_BIT 28, dailyEventBits[2], .kai_arm_callback_1
    BRANCH_U8_VAR_WITHIN_RANGE 0, 254, gItemBeingHeld, .kai_arm_callback_1
    EXECUTE_SUBROUTINE .lock_camera_and_face_player
    BRANCH_U16_VAR_WITHIN_RANGE 215, 215, gCutsceneIndex, .kai_cutscene_215
    BRANCH_U16_VAR_WITHIN_RANGE 218, 218, gCutsceneIndex, .kai_cutscene_218
    EXECUTE_SUBROUTINE .end_cutscene

.kai_cutscene_215:
    UPDATE_U8_VALUE 3, 255, gHappiness
    UPDATE_U8_VALUE 1, 255, gAlcoholTolerance
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 533
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_ENTITY_DIRECTIONAL_ANIMATION 16
    WAIT_ENTITY_ANIMATION
    SPAWN_EXECUTOR 10, .static_item_walk_in_6
    SET_WAIT_FRAMES 30
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SPAWN_EXECUTOR 7, .player_walk_in_27
    EXECUTE_SUBROUTINE .idle

.player_walk_in_27:
    EXECUTE_SUBROUTINE .player_setup_slot0
    EXECUTE_SUBROUTINE .player_receive_item_variant_b
    SET_OTHER_EXECUTOR_PTR 1, .kai_show_msg_534
    DEACTIVATE_SELF

.kai_show_msg_534:
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 534
    EXECUTE_SUBROUTINE .kai_close_msg_539

.kai_cutscene_216:
    UPDATE_U8_VALUE 2, 255, gHappiness
    INIT_DIALOGUE_SESSION 0, DIALOGUE_FARM_VISITS, 24
    WAIT_FOR_DIALOGUE_INPUT 0
    BRANCH_ON_DIALOGUE 0, 0, .kai_dialogue_24_yes
    BRANCH_ON_DIALOGUE 0, 1, .kai_dialogue_24_no

.kai_dialogue_24_yes:
    ; SPIRIT_FESTIVAL_INVITATION_ACCEPTED
    SET_SPECIAL_BIT 16, dailyEventBits[2]
    UPDATE_U8_VALUE 3, 255, npcAffection[CLIFF]
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 536
    EXECUTE_SUBROUTINE .kai_close_msg_539

.kai_dialogue_24_no:
    CLEAR_SPECIAL_BIT 16, dailyEventBits[2]
    UPDATE_U8_VALUE -5, 255, npcAffection[CLIFF]
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 537
    EXECUTE_SUBROUTINE .kai_close_msg_539

.kai_cutscene_217:
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 538
    EXECUTE_SUBROUTINE .kai_close_msg_539

.kai_cutscene_218:
    UPDATE_U8_VALUE 5, 255, gHappiness
    UPDATE_U8_VALUE 1, 255, gAlcoholTolerance
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 624
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITY 30
    SET_ENTITY_DIRECTIONAL_ANIMATION 16
    WAIT_ENTITY_ANIMATION
    SPAWN_EXECUTOR 10, .static_item_walk_in_6
    SET_WAIT_FRAMES 30
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SPAWN_EXECUTOR 7, .player_walk_in_28
    EXECUTE_SUBROUTINE .idle

.player_walk_in_28:
    EXECUTE_SUBROUTINE .player_setup_slot0
    EXECUTE_SUBROUTINE .player_receive_item_variant_b
    SET_OTHER_EXECUTOR_PTR 1, .kai_show_msg_625
    DEACTIVATE_SELF

.kai_show_msg_625:
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 625
    EXECUTE_SUBROUTINE .kai_close_msg_626

.kai_cutscene_219:
    UPDATE_U8_VALUE -20, 255, gHappiness
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 627
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITY 30
    ENTITY_WALK 132, DIRECTION_W, 2
    TOGGLE_PAUSE_ENTITIES
    DEACTIVATE_SELF

; Cutscene 220 -- Rick demonstrates the Transporter
.rick_cutscene_220:
    SET_SPECIAL_BIT 15, gCutsceneCompletionFlags
    SPAWN_EXECUTOR 1, .rick_setup
    SPAWN_EXECUTOR 32, .static_item_setup_slot42
    SPAWN_EXECUTOR 33, .static_item_setup_slot43
    EXECUTE_SUBROUTINE .player_setup_slot0
    SET_ENTITY_PHYSICS_FLAGS 1
    SET_COORDINATES -352, 0, -16
    SET_ASSET_ROTATION 0
    SET_WAIT_FRAMES 32
    ENTITY_WALK 64, DIRECTION_S, 2
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 540
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_ENTITY_ANIMATION 490
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 541
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 1, .rick_cutscene_220_ask_experiment
    EXECUTE_SUBROUTINE .idle

.rick_cutscene_220_ask_experiment:
    ENTITY_WALK 32, DIRECTION_W, 2
    SET_OTHER_EXECUTOR_PTR 0, .slot1_face_west
    SET_ASSET_ROTATION 6
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 542
    WAIT_MESSAGE_BOX_CLOSED 0
    SPAWN_EXECUTOR 16, .expression_bubbles_walk_in_1
    INIT_DIALOGUE_SESSION 0, DIALOGUE_FARM_VISITS, 27
    WAIT_FOR_DIALOGUE_INPUT 0
    BRANCH_ON_DIALOGUE 0, 0, .rick_dialogue_27_yes
    BRANCH_ON_DIALOGUE 0, 1, .rick_dialogue_27_no

.rick_dialogue_27_yes:
    UPDATE_U8_VALUE 8, 255, npcAffection[RICK]
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 545
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    EXECUTE_SUBROUTINE .rick_cutscene_220_run_transporter

.rick_dialogue_27_no:
    UPDATE_U8_VALUE -5, 255, npcAffection[RICK]
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 546
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    EXECUTE_SUBROUTINE .rick_cutscene_220_run_transporter

; Runs the transporter sequence: slot 21 is the item placed on the pad, slot 32 drives the machine animation.
.rick_cutscene_220_run_transporter:
    SET_ASSET_ROTATION 0
    SET_ENTITY_DIRECTIONAL_ANIMATION 16
    WAIT_ENTITY_ANIMATION
    SPAWN_EXECUTOR 21, .static_item_walk_in_15
    SET_WAIT_FRAMES 15
    SET_OTHER_EXECUTOR_PTR 21, .transporter_item_idle_aloft
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SET_WAIT_FRAMES 15
    SET_OTHER_EXECUTOR_PTR 32, .transporter_machine_run_sequence
    EXECUTE_SUBROUTINE .idle

; Slot 21 reattaches to Kai, hovers at y=112 (on the transporter pad).
.transporter_item_idle_aloft:
    SET_ENTITY_TRACKING_TARGET 65535, 0, 0, 0, 255
    SET_BEHAVIOR_FLAGS 0
    SET_COORDINATES -416, 112, 184
    SET_ENTITY_PHYSICS_FLAGS 0
    SET_ENTITY_ANIMATION 15
    EXECUTE_SUBROUTINE .idle

; Slot 21 bounces between y=110 and y=112 with decreasing wait frames.
.transporter_item_bounce:
    SET_WAIT_FRAMES 16
    SET_COORDINATES -416, 110, 184
    SET_WAIT_FRAMES 6
    SET_COORDINATES -416, 112, 184
    SET_WAIT_FRAMES 5
    SET_COORDINATES -416, 110, 184
    SET_WAIT_FRAMES 5
    SET_COORDINATES -416, 112, 184
    SET_WAIT_FRAMES 4
    SET_COORDINATES -416, 110, 184
    SET_WAIT_FRAMES 4
    SET_COORDINATES -416, 112, 184
    SET_WAIT_FRAMES 3
    SET_COORDINATES -416, 110, 184
    SET_WAIT_FRAMES 3
    SET_COORDINATES -416, 112, 184
    SET_WAIT_FRAMES 2
    SET_COORDINATES -416, 110, 184
    SET_WAIT_FRAMES 2
    EXECUTE_SUBROUTINE .idle

.transporter_item_anim_121_122:
    SET_ENTITY_ANIMATION 121
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_ANIMATION 122
    EXECUTE_SUBROUTINE .idle

.transporter_item_move_to_destination:
    SET_COORDINATES -352, 112, 184
    EXECUTE_SUBROUTINE .idle

.transporter_item_anim_123:
    SET_ENTITY_ANIMATION 123
    EXECUTE_SUBROUTINE .idle

; Slot 32 plays the transporter machine animations and cues slot 21 state changes.
.transporter_machine_run_sequence:
    SET_AUDIO_SEQUENCE 1, _seq60SegmentRomStart, _seq60SegmentRomEnd
    SET_AUDIO_SEQUENCE_VOLUME 1, 128, 128
    SET_ENTITY_ANIMATION 118
    SET_OTHER_EXECUTOR_PTR 21, .transporter_item_bounce
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_ANIMATION 119
    SET_OTHER_EXECUTOR_PTR 21, .transporter_item_anim_121_122
    SET_WAIT_FRAMES 60
    SET_SFX 26, 128
    SET_OTHER_EXECUTOR_PTR 21, .transporter_item_move_to_destination
    SET_ENTITY_ANIMATION 120
    WAIT_ENTITY_ANIMATION
    SET_OTHER_EXECUTOR_PTR 0, .slot1_face_southwest
    SET_OTHER_EXECUTOR_PTR 1, .slot1_face_southeast
    SET_OTHER_EXECUTOR_PTR 21, .transporter_item_anim_123
    SET_ENTITY_ANIMATION 116
    SET_WAIT_FRAMES 20
    SET_OTHER_EXECUTOR_PTR 1, .rick_cutscene_220_inspect_and_teardown
    EXECUTE_SUBROUTINE .idle

; Rick inspects the transported item (text 547), tears down the scene, and ends the cutscene.
.rick_cutscene_220_inspect_and_teardown:
    ENTITY_WALK 32, DIRECTION_E, 2
    SET_ASSET_ROTATION 0
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 547
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    DEACTIVATE_EXECUTOR 21
    SET_WAIT_FRAMES 20
    DEACTIVATE_EXECUTOR 33
    SET_WAIT_FRAMES 20
    ENTITY_WALK 32, DIRECTION_W, 2
    SET_OTHER_EXECUTOR_PTR 0, .slot1_face_west
    SET_ASSET_ROTATION 0
    SET_WAIT_FRAMES 20
    DEACTIVATE_EXECUTOR 32
    SET_WAIT_FRAMES 20
    SET_ASSET_ROTATION 6
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 548
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    ENTITY_WALK 112, DIRECTION_W, 2
    SET_OTHER_EXECUTOR_PTR 0, .slot7_teardown
    EXECUTE_SUBROUTINE .end_cutscene

.static_item_setup_slot42:
    SETUP_ENTITY 42, ENTITY_ASSET_STATIC_ITEM, 1
    SET_ENTITY_ANIMATIONS 42, 0, 0, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_COORDINATES -416, 0, 184
    SET_ENTITY_ANIMATION 116
    EXECUTE_SUBROUTINE .idle

.static_item_setup_slot43:
    SETUP_ENTITY 43, ENTITY_ASSET_STATIC_ITEM, 1
    SET_ENTITY_ANIMATIONS 43, 0, 0, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_COORDINATES -352, 0, 184
    SET_ENTITY_ANIMATION 117
    EXECUTE_SUBROUTINE .idle


