    SET_OTHER_EXECUTOR_PTR 17, .karen_fairies_float_up
    SET_OTHER_EXECUTOR_PTR 18, .karen_fairies_float_up
    SET_OTHER_EXECUTOR_PTR 19, .karen_fairies_float_up
    SET_OTHER_EXECUTOR_PTR 20, .karen_fairies_float_up
    SET_OTHER_EXECUTOR_PTR 21, .karen_fairies_float_up
    SET_OTHER_EXECUTOR_PTR 41, .karen_msg_434_and_handoff
    EXECUTE_SUBROUTINE .idle

; Fairy cut-in sprite executors (slots 128-133) for cutscene 256 vineyard scene
.karen_fairies_float_up:
    SET_FRAME_DELTA -2, 2, 0, 132
    EXECUTE_SUBROUTINE .idle

.karen_fairies_float_down:
    SET_FRAME_DELTA 2, -2, 0, 96
    EXECUTE_SUBROUTINE .idle

.karen_msg_434_and_handoff:
    SET_FRAME_DELTA 2, 0, 0, 132
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 434
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 1, .karen_walk_and_grape_speech
    EXECUTE_SUBROUTINE .idle

.karen_map_scroll_back:
    SET_FRAME_DELTA -2, 0, 0, 96
    EXECUTE_SUBROUTINE .idle

.karen_walk_and_grape_speech:
    ENTITY_WALK 32, DIRECTION_W, 2
    SET_OTHER_EXECUTOR_PTR 0, .karen_player_follow_nw
    SET_OTHER_EXECUTOR_PTR 16, .karen_fairies_float_down
    SET_OTHER_EXECUTOR_PTR 17, .karen_fairies_float_down
    SET_OTHER_EXECUTOR_PTR 18, .karen_fairies_float_down
    SET_OTHER_EXECUTOR_PTR 19, .karen_fairies_float_down
    SET_OTHER_EXECUTOR_PTR 20, .karen_fairies_float_down
    SET_OTHER_EXECUTOR_PTR 21, .karen_fairies_float_down
    SET_OTHER_EXECUTOR_PTR 41, .karen_map_scroll_back
    ENTITY_WALK 56, DIRECTION_W, 2
    SET_WAIT_FRAMES 40
    SET_ASSET_ROTATION 7
    SET_OTHER_EXECUTOR_PTR 0, .karen_player_face_north
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 435
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_ENTITY_ANIMATION 70
    WAIT_ENTITY_ANIMATION
    SET_OTHER_EXECUTOR_PTR 16, .karen_fairies_fade_out
    SET_OTHER_EXECUTOR_PTR 17, .karen_fairies_fade_out
    SET_OTHER_EXECUTOR_PTR 18, .karen_fairies_fade_out
    SET_OTHER_EXECUTOR_PTR 19, .karen_fairies_fade_out
    SET_OTHER_EXECUTOR_PTR 20, .karen_fairies_fade_out
    SET_OTHER_EXECUTOR_PTR 21, .karen_fairies_fade_out
    SET_AUDIO_SEQUENCE_VOLUME 0, 0, 2
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 4
    WAIT_RGBA_FINISHED
    STOP_SEQUENCE_WITH_FADE 0, 1
    IDLE_WHILE_SEQUENCE_PLAYING 0
    DEACTIVATE_EXECUTOR 0
    DEACTIVATE_EXECUTOR 41
    EXECUTE_SUBROUTINE .end_cutscene

.karen_fairies_fade_out:
    UPDATE_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    DEACTIVATE_SELF

.karen_player_follow_nw:
