; --- Cutscene 138: farm vegetable festival invitation ---
.cutscene_basil_farm_vegetable_festival:
    UPDATE_U8_VALUE 2, 255, gHappiness
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 127
    EXECUTE_SUBROUTINE .basil_farewell

; --- Cutscene 139: farm visit, offer seeds ---
; Cutscene 139 body: Basil farm visit offer seeds (dialogue 9; yes sets completion bit 30 and fades out, no walks him off).
.cutscene_basil_farm_visit_offer_seeds:
    UPDATE_U8_VALUE 2, 255, gHappiness
    INIT_DIALOGUE_SESSION 0, DIALOGUE_FARM_VISITS, 9
    WAIT_FOR_DIALOGUE_INPUT 0
    BRANCH_ON_DIALOGUE 0, 0, .basil_dialogue_9_yes
    BRANCH_ON_DIALOGUE 0, 1, .basil_dialogue_9_no

.basil_dialogue_9_yes:
    SET_SPECIAL_BIT 30, gCutsceneCompletionFlags
    UPDATE_U8_VALUE 5, 255, npcAffection[BASIL]
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 131
    EXECUTE_SUBROUTINE .close_msg_fade_and_end_cutscene

.basil_dialogue_9_no:
    CLEAR_SPECIAL_BIT 30, gCutsceneCompletionFlags
    UPDATE_U8_VALUE -5, 255, npcAffection[BASIL]
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 132
    EXECUTE_SUBROUTINE .close_message_and_walk_off_northwest_120

; --- Cutscene 140: Basil introduction ---
.cutscene_basil_intro:
    UPDATE_U8_VALUE 5, 255, npcAffection[BASIL]
    UPDATE_U8_VALUE 2, 255, npcAffection[POPURI]
    UPDATE_U8_VALUE 2, 255, gHappiness
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 133
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SPAWN_EXECUTOR 2, .popuri_walk_in_1
    EXECUTE_SUBROUTINE .idle

.basil_intro_pick_player_walk_in:
    SET_ASSET_ROTATION 2
    BRANCH_ON_ENTITY_DIR 0, DIRECTION_E, .basil_intro_player_walk_in_from_southeast
    BRANCH_ON_ENTITY_DIR 0, DIRECTION_NE, .basil_intro_player_walk_in_from_east
    BRANCH_ON_ENTITY_DIR 0, DIRECTION_SE, .basil_intro_player_walk_in_from_south
    SET_WAIT_FRAMES 10
    EXECUTE_SUBROUTINE .basil_msg_135_and_136

.basil_intro_player_walk_in_from_southeast:
    SPAWN_EXECUTOR 7, .player_walk_in_4
    EXECUTE_SUBROUTINE .idle

.basil_intro_player_walk_in_from_south:
    SPAWN_EXECUTOR 7, .player_walk_in_5
    EXECUTE_SUBROUTINE .idle

.basil_intro_player_walk_in_from_east:
    SPAWN_EXECUTOR 7, .player_walk_in_3
    EXECUTE_SUBROUTINE .idle

.player_walk_in_3:
    EXECUTE_SUBROUTINE .player_setup_slot0
    TOGGLE_PAUSE_ENTITIES
    SET_OTHER_EXECUTOR_PTR 1, .basil_msg_135_and_136
    SET_WAIT_FRAMES 20
    SET_ASSET_ROTATION 2
    EXECUTE_SUBROUTINE .idle

.player_walk_in_4:
    EXECUTE_SUBROUTINE .player_setup_slot0
    TOGGLE_PAUSE_ENTITIES
    ENTITY_WALK 24, DIRECTION_N, 2
    SET_ASSET_ROTATION 0
    SET_OTHER_EXECUTOR_PTR 1, .basil_msg_135_and_136
    EXECUTE_SUBROUTINE .idle

.player_walk_in_5:
    EXECUTE_SUBROUTINE .player_setup_slot0
    TOGGLE_PAUSE_ENTITIES
    ENTITY_WALK 16, DIRECTION_N, 2
    SET_ASSET_ROTATION 0
    SET_OTHER_EXECUTOR_PTR 1, .basil_msg_135_and_136
    EXECUTE_SUBROUTINE .idle

.basil_msg_135_and_136:
    TOGGLE_PAUSE_ENTITY 30
    ENTITY_WALK 20, DIRECTION_W, 2
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 135
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    DEACTIVATE_EXECUTOR 2
    SET_ENTITY_ANIMATION 16
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_ANIMATION 18
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_ANIMATION 17
    WAIT_ENTITY_ANIMATION
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 136
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SET_ASSET_ROTATION 2
    SPAWN_EXECUTOR 2, .popuri_walk_in_2
    EXECUTE_SUBROUTINE .idle

.basil_walk_off_northwest_and_deactivate:
    ENTITY_WALK 132, DIRECTION_W, 2
    DEACTIVATE_SELF

; --- Popuri entity setup and walk-ins for intro scene ---
.popuri_setup_slot31:
    SETUP_ENTITY 31, ENTITY_ASSET_POPURI, 1
    SET_ENTITY_ANIMATIONS 31, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    RETURN_FROM_SUBROUTINE

.popuri_walk_in_1:
    EXECUTE_SUBROUTINE .popuri_setup_slot31
    SET_ASSET_ROTATION 6
    SET_COORDINATES -590, 0, 152
    TOGGLE_PAUSE_ENTITY 31
    ENTITY_WALK 92, DIRECTION_E, 2
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 134
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 1, .basil_intro_pick_player_walk_in
    EXECUTE_SUBROUTINE .idle

.popuri_walk_in_2:
    EXECUTE_SUBROUTINE .popuri_setup_slot31
    SET_ASSET_ROTATION 6
    SET_COORDINATES -414, 0, 152
    TOGGLE_PAUSE_ENTITY 31
    SET_WAIT_FRAMES 20
    SET_OTHER_EXECUTOR_PTR 1, .slot1_face_west
    ENTITY_WALK 16, DIRECTION_S, 2
    SET_OTHER_EXECUTOR_PTR 1, .slot1_face_southwest
    ENTITY_WALK 16, DIRECTION_E, 2
    SET_ASSET_ROTATION 4
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 137
    WAIT_MESSAGE_BOX_CLOSED 0
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 138
    WAIT_MESSAGE_BOX_CLOSED 0
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 139
    WAIT_MESSAGE_BOX_CLOSED 0
    SET_OTHER_EXECUTOR_PTR 1, .basil_walk_off_northwest_and_deactivate
    RESET_MESSAGE_BOX_AVATAR 0
    SET_WAIT_FRAMES 16
    ENTITY_WALK 24, DIRECTION_NW, 2
    SET_ASSET_ROTATION 6
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 140
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITY 31
    ENTITY_WALK 32, DIRECTION_W, 2
    SET_ASSET_ROTATION 6
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 489
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    ENTITY_WALK 82, DIRECTION_W, 2
    SET_OTHER_EXECUTOR_PTR 7, .slot7_teardown
    TOGGLE_PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .end_cutscene

; --- Cutscene 141: Basil gifts a Power Nut ---
.cutscene_basil_power_nut_gift:
    UPDATE_U8_VALUE 2, 255, gHappiness
    BRANCH_U8_VAR_WITHIN_RANGE 200, 255, npcAffection[BASIL], .basil_power_nut_first_time

.basil_award_and_msg_141:
    UPDATE_U8_VALUE 3, 255, npcAffection[BASIL]
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 141
    EXECUTE_SUBROUTINE .basil_farewell

.basil_power_nut_first_time:
    BRANCH_ON_SPECIAL_BIT 9, acquiredPowerNutBits, .basil_award_and_msg_141
    SET_SPECIAL_BIT 9, acquiredPowerNutBits
    UPDATE_U8_VALUE 15, 250, gMaximumStamina
    UPDATE_U8_VALUE 2, 255, gHappiness
    UPDATE_U8_VALUE 3, 255, npcAffection[BASIL]
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 123
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SPAWN_EXECUTOR 10, .static_item_walk_in_1
    SET_WAIT_FRAMES 30
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SPAWN_EXECUTOR 7, .player_walk_in_6
    EXECUTE_SUBROUTINE .idle

.player_walk_in_6:
    EXECUTE_SUBROUTINE .player_setup_slot0
    EXECUTE_SUBROUTINE .player_receive_item_variant_a
    SET_OTHER_EXECUTOR_PTR 1, .basil_farewell_no_prior_msg
    DEACTIVATE_SELF

; --- Cutscene 142: Basil returns from travels ---
.cutscene_basil_return:
    UPDATE_U8_VALUE 2, 255, gHappiness
    UPDATE_U8_VALUE 3, 255, npcAffection[BASIL]
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 142
    EXECUTE_SUBROUTINE .basil_farewell

; --- Cutscene 143: Basil leaves on a trip ---
.cutscene_basil_leaving:
    UPDATE_U8_VALUE 2, 255, gHappiness
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 143
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITY 30
    ENTITY_WALK 132, DIRECTION_W, 2
    TOGGLE_PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .end_cutscene


; ==========================================================
; Maria
; ==========================================================

.maria_setup:
    SETUP_ENTITY 30, ENTITY_ASSET_MARIA, 1
    SET_ENTITY_ANIMATIONS 30, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    RETURN_FROM_SUBROUTINE

; Shared helper: pause entities, show centered message 147 (naming screen), then restore.
.pause_and_show_centered_msg_147:
    PAUSE_ENTITIES
    SET_MESSAGE_INTERPOLATION -4, 0, 0
    SET_MESSAGE_BOX_ASSETS 0, 1, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 0, -64, 352
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 147
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_MESSAGE_BOX_ASSETS 0, 0, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 24, -64, 352
    TOGGLE_PAUSE_ENTITIES
    RETURN_FROM_SUBROUTINE

.maria_arm_callback_1:
    SET_CALLBACK_ROUTINE 0, 32768, .maria_dispatch
    BRANCH_U16_VAR_WITHIN_RANGE 146, 146, gCutsceneIndex, .wait_until_hours_9_11_13_15_17
    BRANCH_U16_VAR_WITHIN_RANGE 147, 147, gCutsceneIndex, .wait_until_hour_0
    BRANCH_U16_VAR_WITHIN_RANGE 148, 149, gCutsceneIndex, .wait_until_hours_9_11_13_15_17
    BRANCH_U16_VAR_WITHIN_RANGE 152, 153, gCutsceneIndex, .wait_until_hour_18
    EXECUTE_SUBROUTINE .wait_until_hour_17

.maria_walk_in_1:
    EXECUTE_SUBROUTINE .maria_setup
    SET_ASSET_ROTATION 6
    BRANCH_U16_VAR_WITHIN_RANGE 150, 151, gCutsceneIndex, .maria_walk_in_north_approach
    SET_COORDINATES -590, 0, 152
    ENTITY_WALK 34, DIRECTION_E, 2
    EXECUTE_SUBROUTINE .pause_and_show_centered_msg_147
    ENTITY_WALK 90, DIRECTION_E, 2
    SET_ASSET_ROTATION 4
    EXECUTE_SUBROUTINE .maria_arm_callback_1

.maria_walk_in_2:
    EXECUTE_SUBROUTINE .maria_setup
    SET_ASSET_ROTATION 4
    UPDATE_RGBA 254, 254, 254, 254, 8
    SET_COORDINATES -358, 0, 152
    BRANCH_U16_VAR_WITHIN_RANGE 150, 151, gCutsceneIndex, .maria_post_walk_in_dispatch
    WAIT_RGBA_FINISHED
    EXECUTE_SUBROUTINE .pause_and_show_centered_msg_147
    EXECUTE_SUBROUTINE .maria_arm_callback_1

; Shared helper: teleport to (-358, 0, -40), walk 96 units SOUTHWEST, face SOUTHEAST.
.walk_in_from_north_southwest:
    SET_COORDINATES -358, 0, -40
    ENTITY_WALK 96, DIRECTION_S, 2
    SET_ASSET_ROTATION 6
    RETURN_FROM_SUBROUTINE

; Cutscene 150/151 variant: skip the walk-in fade and do the overhead walk-in via .sub_101A88, then fall through.
.maria_walk_in_north_approach:
    EXECUTE_SUBROUTINE .walk_in_from_north_southwest

.maria_post_walk_in_dispatch:
    BRANCH_U16_VAR_WITHIN_RANGE 151, 151, gCutsceneIndex, .maria_cutscene_151
    SET_CALLBACK_ROUTINE 0, 32768, .maria_award_and_msg_182
    EXECUTE_SUBROUTINE .idle

.maria_cutscene_151:
    SET_CALLBACK_ROUTINE 0, 32768, .maria_award_and_msg_191
    EXECUTE_SUBROUTINE .idle

; Shared finisher: close message, unpause Maria, walk 32 units NORTHWEST, show message 488, then walk off.
.maria_close_msg_and_walk_off_northwest_32:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITY 30
    ENTITY_WALK 32, DIRECTION_W, 2
    SET_ASSET_ROTATION 6
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 488
    EXECUTE_SUBROUTINE .close_message_and_walk_off_northwest_98

.maria_dispatch:
    BRANCH_U16_VAR_WITHIN_RANGE 144, 145, gCutsceneIndex, .cutscene_maria_thanksgiving_gift
    BRANCH_U16_VAR_WITHIN_RANGE 148, 148, gCutsceneIndex, .cutscene_maria_thanksgiving_gift
    BRANCH_U16_VAR_WITHIN_RANGE 152, 153, gCutsceneIndex, .cutscene_maria_thanksgiving_gift
    EXECUTE_SUBROUTINE .lock_camera_and_face_player
    BRANCH_U16_VAR_WITHIN_RANGE 146, 146, gCutsceneIndex, .cutscene_maria_fireworks_invitation
    BRANCH_U16_VAR_WITHIN_RANGE 147, 147, gCutsceneIndex, .maria_cutscene_147
    BRANCH_U16_VAR_WITHIN_RANGE 149, 149, gCutsceneIndex, .maria_cutscene_149
    EXECUTE_SUBROUTINE .end_cutscene

.cutscene_maria_thanksgiving_gift:
    BRANCH_ON_SPECIAL_BIT 28, dailyEventBits[2], .maria_arm_callback_1
    BRANCH_U8_VAR_WITHIN_RANGE 0, 254, gItemBeingHeld, .maria_arm_callback_1
    EXECUTE_SUBROUTINE .lock_camera_and_face_player
    BRANCH_U16_VAR_WITHIN_RANGE 144, 144, gCutsceneIndex, .cutscene_maria_farm_gift_chocolate
    BRANCH_U16_VAR_WITHIN_RANGE 145, 145, gCutsceneIndex, .cutscene_maria_farm_gift_rice_balls
    BRANCH_U16_VAR_WITHIN_RANGE 148, 148, gCutsceneIndex, .cutscene_maria_thanksgiving_gift_2
    BRANCH_U16_VAR_WITHIN_RANGE 152, 152, gCutsceneIndex, .maria_cutscene_152
    BRANCH_U16_VAR_WITHIN_RANGE 153, 153, gCutsceneIndex, .maria_cutscene_153
    EXECUTE_SUBROUTINE .end_cutscene

.cutscene_maria_farm_gift_chocolate:
    UPDATE_U8_VALUE 5, 255, gHappiness
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 144
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_ENTITY_DIRECTIONAL_ANIMATION 16
    WAIT_ENTITY_ANIMATION
    SPAWN_EXECUTOR 10, .static_item_walk_in_3
    SET_WAIT_FRAMES 30
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SPAWN_EXECUTOR 7, .player_walk_in_7
    EXECUTE_SUBROUTINE .idle

.player_walk_in_7:
    EXECUTE_SUBROUTINE .player_setup_slot0
    EXECUTE_SUBROUTINE .player_receive_item_variant_a
    SET_OTHER_EXECUTOR_PTR 1, .maria_close_msg_and_walk_off_northwest_32
    DEACTIVATE_SELF

.cutscene_maria_farm_gift_rice_balls:
    UPDATE_U8_VALUE 5, 255, gHappiness
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 145
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_ENTITY_DIRECTIONAL_ANIMATION 16
    WAIT_ENTITY_ANIMATION
    SPAWN_EXECUTOR 10, .static_item_walk_in_4
    SET_WAIT_FRAMES 30
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SPAWN_EXECUTOR 7, .player_walk_in_7
    EXECUTE_SUBROUTINE .idle

.cutscene_maria_fireworks_invitation:
    UPDATE_U8_VALUE 2, 255, gHappiness
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 146
    EXECUTE_SUBROUTINE .maria_close_msg_and_walk_off_northwest_32

.maria_cutscene_147:
    UPDATE_U8_VALUE 2, 255, gHappiness
    INIT_DIALOGUE_SESSION 0, DIALOGUE_FARM_VISITS, 10
    WAIT_FOR_DIALOGUE_INPUT 0
    BRANCH_ON_DIALOGUE 0, 0, .maria_dialogue_10_yes
    BRANCH_ON_DIALOGUE 0, 1, .maria_dialogue_10_no

.maria_dialogue_10_yes:
    UPDATE_U8_VALUE 10, 255, npcAffection[MARIA]
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 151
    EXECUTE_SUBROUTINE .date_transition_fade_and_spawn_escorts
    UPDATE_GLOBAL_RGBA 80, 80, 80, 80, 6
    ENTITY_WALK 40, DIRECTION_W, 2
    WAIT_RGBA_FINISHED
    SET_ASSET_ROTATION 6
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 153
    EXECUTE_SUBROUTINE .close_msg_fade_and_end_date

; SPAWN_EXECUTOR 8 target: deactivate map objects and reload MAIN_MAP as MOUNTAIN_2 for the current season.
.load_mountain_2_seasonal_map:
    DEACTIVATE_MAP_OBJECTS 0
    BRANCH_U8_VAR_WITHIN_RANGE 1, 1, gSeason, .load_mountain_2_spring
    BRANCH_U8_VAR_WITHIN_RANGE 2, 2, gSeason, .load_mountain_2_summer
    BRANCH_U8_VAR_WITHIN_RANGE 3, 3, gSeason, .load_mountain_2_autumn
    BRANCH_U8_VAR_WITHIN_RANGE 4, 4, gSeason, .load_mountain_2_winter
    SETUP_MAP_ASSET MAIN_MAP_INDEX
    SET_ASSET_ROTATION 7
    EXECUTE_SUBROUTINE .idle

.load_mountain_2_spring:
    LOAD_MAP MAIN_MAP_INDEX, MOUNTAIN_2_SPRING
    RETURN_FROM_SUBROUTINE

.load_mountain_2_summer:
    LOAD_MAP MAIN_MAP_INDEX, MOUNTAIN_2_SUMMER
    RETURN_FROM_SUBROUTINE

.load_mountain_2_autumn:
    LOAD_MAP MAIN_MAP_INDEX, MOUNTAIN_2_AUTUMN
    RETURN_FROM_SUBROUTINE

.load_mountain_2_winter:
    LOAD_MAP MAIN_MAP_INDEX, MOUNTAIN_2_WINTER
    RETURN_FROM_SUBROUTINE

