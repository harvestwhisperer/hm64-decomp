; ==========================================================
; Popuri
; ==========================================================

.popuri_setup:
    SETUP_ENTITY 30, ENTITY_ASSET_POPURI, 1
    SET_ENTITY_ANIMATIONS 30, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    RETURN_FROM_SUBROUTINE

; Shared helper: show Popuri greeting popup (text 267, Hi-ho) with raised view.
.popuri_show_greeting_msg_267:
    PAUSE_ENTITIES
    SET_MESSAGE_INTERPOLATION -4, 0, 0
    SET_MESSAGE_BOX_ASSETS 0, 1, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 0, -64, 352
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 267
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_MESSAGE_BOX_ASSETS 0, 0, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 24, -64, 352
    TOGGLE_PAUSE_ENTITIES
    RETURN_FROM_SUBROUTINE

.popuri_arm_callback_1:
    SET_CALLBACK_ROUTINE 0, 32768, .popuri_dispatch
    BRANCH_U16_VAR_WITHIN_RANGE 156, 156, gCutsceneIndex, .wait_until_hour_9
    BRANCH_U16_VAR_WITHIN_RANGE 157, 157, gCutsceneIndex, .wait_until_hours_9_11_13_15_17
    BRANCH_U16_VAR_WITHIN_RANGE 158, 158, gCutsceneIndex, .wait_until_hour_18
    BRANCH_U16_VAR_WITHIN_RANGE 159, 160, gCutsceneIndex, .wait_until_hours_9_11_13_15_17
    BRANCH_U16_VAR_WITHIN_RANGE 163, 164, gCutsceneIndex, .wait_until_hour_18
    EXECUTE_SUBROUTINE .wait_until_hour_17

.popuri_walk_in_3:
    EXECUTE_SUBROUTINE .popuri_setup
    SET_ASSET_ROTATION 6
    BRANCH_U16_VAR_WITHIN_RANGE 161, 162, gCutsceneIndex, .popuri_reposition_then_birthday_dispatch
    SET_COORDINATES -590, 0, 152
    ENTITY_WALK 34, DIRECTION_E, 2
    EXECUTE_SUBROUTINE .popuri_show_greeting_msg_267
    ENTITY_WALK 90, DIRECTION_E, 2
    SET_ASSET_ROTATION 4
    EXECUTE_SUBROUTINE .popuri_arm_callback_1

.popuri_walk_in_4:
    EXECUTE_SUBROUTINE .popuri_setup
    UPDATE_RGBA 254, 254, 254, 254, 0
    SET_ASSET_ROTATION 4
    SET_COORDINATES -358, 0, 152
    BRANCH_U16_VAR_WITHIN_RANGE 161, 162, gCutsceneIndex, .popuri_birthday_dispatch_161_162
    WAIT_RGBA_FINISHED
    EXECUTE_SUBROUTINE .popuri_show_greeting_msg_267
    EXECUTE_SUBROUTINE .popuri_arm_callback_1

.popuri_reposition_then_birthday_dispatch:
    EXECUTE_SUBROUTINE .walk_in_from_north_southwest

.popuri_birthday_dispatch_161_162:
    BRANCH_U16_VAR_WITHIN_RANGE 162, 162, gCutsceneIndex, .popuri_cutscene_162
    SET_CALLBACK_ROUTINE 0, 32768, .popuri_award_and_msg_258
    EXECUTE_SUBROUTINE .idle

.popuri_cutscene_162:
    SET_CALLBACK_ROUTINE 0, 32768, .popuri_award_and_msg_264
    EXECUTE_SUBROUTINE .idle

.popuri_close_and_farewell_msg_489:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITY 30
    ENTITY_WALK 32, DIRECTION_W, 2
    SET_ASSET_ROTATION 6
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 489
    EXECUTE_SUBROUTINE .close_message_and_walk_off_northwest_98

; Popuri dispatcher (selected by .popuri_arm_callback_1 via callback routine).
.popuri_dispatch:
    BRANCH_U16_VAR_WITHIN_RANGE 154, 155, gCutsceneIndex, .cutscene_popuri_thanksgiving_gift
    BRANCH_U16_VAR_WITHIN_RANGE 159, 159, gCutsceneIndex, .cutscene_popuri_thanksgiving_gift
    BRANCH_U16_VAR_WITHIN_RANGE 163, 164, gCutsceneIndex, .cutscene_popuri_thanksgiving_gift
    EXECUTE_SUBROUTINE .lock_camera_and_face_player
    BRANCH_U16_VAR_WITHIN_RANGE 156, 156, gCutsceneIndex, .popuri_cutscene_156
    BRANCH_U16_VAR_WITHIN_RANGE 157, 157, gCutsceneIndex, .cutscene_popuri_fireworks_invitation
    BRANCH_U16_VAR_WITHIN_RANGE 158, 158, gCutsceneIndex, .popuri_cutscene_158
    BRANCH_U16_VAR_WITHIN_RANGE 160, 160, gCutsceneIndex, .popuri_cutscene_160
    EXECUTE_SUBROUTINE .end_cutscene

.cutscene_popuri_thanksgiving_gift:
    BRANCH_ON_SPECIAL_BIT 28, dailyEventBits[2], .popuri_arm_callback_1
    BRANCH_U8_VAR_WITHIN_RANGE 0, 254, gItemBeingHeld, .popuri_arm_callback_1
    EXECUTE_SUBROUTINE .lock_camera_and_face_player
    BRANCH_U16_VAR_WITHIN_RANGE 154, 154, gCutsceneIndex, .cutscene_popuri_farm_gift_tea
    BRANCH_U16_VAR_WITHIN_RANGE 155, 155, gCutsceneIndex, .cutscene_popuri_farm_gift_cookies
    BRANCH_U16_VAR_WITHIN_RANGE 159, 159, gCutsceneIndex, .cutscene_popuri_thanksgiving_gift_2
    BRANCH_U16_VAR_WITHIN_RANGE 163, 163, gCutsceneIndex, .popuri_cutscene_163
    BRANCH_U16_VAR_WITHIN_RANGE 164, 164, gCutsceneIndex, .popuri_cutscene_164
    EXECUTE_SUBROUTINE .end_cutscene

.cutscene_popuri_farm_gift_tea:
    UPDATE_U8_VALUE 5, 255, gHappiness
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 223
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_ENTITY_DIRECTIONAL_ANIMATION 16
    WAIT_ENTITY_ANIMATION
    SPAWN_EXECUTOR 10, .static_item_walk_in_5
    SET_WAIT_FRAMES 30
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SPAWN_EXECUTOR 7, .player_walk_in_9
    EXECUTE_SUBROUTINE .idle

.player_walk_in_9:
    EXECUTE_SUBROUTINE .player_setup_slot0
    EXECUTE_SUBROUTINE .player_receive_item_variant_b
    SET_OTHER_EXECUTOR_PTR 1, .popuri_close_and_farewell_msg_489
    DEACTIVATE_SELF

.cutscene_popuri_farm_gift_cookies:
    UPDATE_U8_VALUE 5, 255, gHappiness
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 224
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_ENTITY_DIRECTIONAL_ANIMATION 16
    WAIT_ENTITY_ANIMATION
    SPAWN_EXECUTOR 10, .static_item_walk_in_7
    SET_WAIT_FRAMES 30
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SPAWN_EXECUTOR 7, .player_walk_in_10
    EXECUTE_SUBROUTINE .idle

.executor_1_102290:
    SET_ENTITY_DIRECTIONAL_ANIMATION 16
    WAIT_ENTITY_ANIMATION
    SPAWN_EXECUTOR 10, .static_item_walk_in_5
    SET_WAIT_FRAMES 30
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SPAWN_EXECUTOR 7, .player_walk_in_9
    EXECUTE_SUBROUTINE .idle

.player_walk_in_10:
    EXECUTE_SUBROUTINE .player_setup_slot0
    EXECUTE_SUBROUTINE .player_receive_item_variant_a
    SET_OTHER_EXECUTOR_PTR 1, .executor_1_102290
    DEACTIVATE_SELF

.popuri_cutscene_156:
    UPDATE_U8_VALUE 2, 255, gHappiness
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 231
    EXECUTE_SUBROUTINE .popuri_close_and_farewell_msg_489

.cutscene_popuri_fireworks_invitation:
    UPDATE_U8_VALUE 2, 255, gHappiness
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 232
    EXECUTE_SUBROUTINE .popuri_close_and_farewell_msg_489

.popuri_cutscene_158:
    UPDATE_U8_VALUE 2, 255, gHappiness
    INIT_DIALOGUE_SESSION 0, DIALOGUE_FARM_VISITS, 13
    WAIT_FOR_DIALOGUE_INPUT 0
    BRANCH_ON_DIALOGUE 0, 0, .popuri_dialogue_13_yes
    BRANCH_ON_DIALOGUE 0, 1, .popuri_dialogue_13_no

; Shared date-start transition: used by cutscene 158 (bamboo float) and cutscene 181 (Ann fireworks via ann_cutscene_181_2).
.date_transition_fade_and_spawn_escorts:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    SET_SPECIAL_BIT 29, gCutsceneCompletionFlags
    TOGGLE_PAUSE_ENTITIES
    SPAWN_EXECUTOR 7, .player_walk_in_11
    SPAWN_EXECUTOR 8, .load_mountain_2_seasonal_map
    SET_WAIT_FRAMES 15
    SET_COORDINATES -160, 0, 232
    RETURN_FROM_SUBROUTINE

; Time-of-day + weather lighting tint selector; dispatches by gWeather then gHour.
.apply_time_of_day_tint:
    BRANCH_U8_VAR_WITHIN_RANGE 2, 2, gWeather, .tint_rain_dispatch
    BRANCH_U8_VAR_WITHIN_RANGE 0, 4, gHour, .tint_clear_night
    BRANCH_U8_VAR_WITHIN_RANGE 5, 5, gHour, .tint_clear_dawn_dusk
    BRANCH_U8_VAR_WITHIN_RANGE 6, 7, gHour, .tint_clear_early_morning
    BRANCH_U8_VAR_WITHIN_RANGE 8, 11, gHour, .tint_clear_morning
    BRANCH_U8_VAR_WITHIN_RANGE 12, 15, gHour, .tint_clear_midday
    BRANCH_U8_VAR_WITHIN_RANGE 16, 16, gHour, .tint_clear_hour_16
    BRANCH_U8_VAR_WITHIN_RANGE 17, 17, gHour, .tint_clear_hour_17
    BRANCH_U8_VAR_WITHIN_RANGE 18, 19, gHour, .tint_clear_dawn_dusk
    BRANCH_U8_VAR_WITHIN_RANGE 20, 23, gHour, .tint_clear_night

.tinted_dispatch_158_181:
    BRANCH_U16_VAR_WITHIN_RANGE 158, 158, gCutsceneIndex, .popuri_cutscene_158_2
    BRANCH_U16_VAR_WITHIN_RANGE 181, 181, gCutsceneIndex, .ann_cutscene_181_2
    EXECUTE_SUBROUTINE .end_cutscene

; -------- Clear/sunny tint variants (non-rain) --------
.tint_clear_night:
    UPDATE_GLOBAL_RGBA 80, 80, 80, 80, 8
    EXECUTE_SUBROUTINE .tinted_dispatch_158_181

.tint_clear_dawn_dusk:
    UPDATE_GLOBAL_RGBA 128, 128, 128, 128, 8
    EXECUTE_SUBROUTINE .tinted_dispatch_158_181

.tint_clear_early_morning:
    UPDATE_GLOBAL_RGBA 192, 192, 192, 192, 8
    EXECUTE_SUBROUTINE .tinted_dispatch_158_181

.tint_clear_morning:
    UPDATE_GLOBAL_RGBA 224, 224, 224, 224, 8
    EXECUTE_SUBROUTINE .tinted_dispatch_158_181

.tint_clear_midday:
    UPDATE_GLOBAL_RGBA 255, 255, 255, 255, 8
    EXECUTE_SUBROUTINE .tinted_dispatch_158_181

.tint_clear_hour_16:
    UPDATE_GLOBAL_RGBA 255, 224, 224, 224, 8
    EXECUTE_SUBROUTINE .tinted_dispatch_158_181

.tint_clear_hour_17:
    BRANCH_U8_VAR_WITHIN_RANGE 3, 3, gWeather, .tint_snow_hour_17
    UPDATE_GLOBAL_RGBA 255, 192, 192, 192, 8
    EXECUTE_SUBROUTINE .tinted_dispatch_158_181

.tint_snow_hour_17:
    UPDATE_GLOBAL_RGBA 192, 192, 192, 192, 8
    EXECUTE_SUBROUTINE .tinted_dispatch_158_181

; -------- Rain tint variants (gWeather == RAIN) --------
.tint_rain_dispatch:
    BRANCH_U8_VAR_WITHIN_RANGE 0, 4, gHour, .tint_rain_night
    BRANCH_U8_VAR_WITHIN_RANGE 5, 7, gHour, .tint_rain_dawn_dusk
    BRANCH_U8_VAR_WITHIN_RANGE 8, 11, gHour, .tint_rain_day
    BRANCH_U8_VAR_WITHIN_RANGE 12, 15, gHour, .tint_rain_midday
    BRANCH_U8_VAR_WITHIN_RANGE 16, 17, gHour, .tint_rain_day
    BRANCH_U8_VAR_WITHIN_RANGE 18, 19, gHour, .tint_rain_dawn_dusk
    BRANCH_U8_VAR_WITHIN_RANGE 20, 23, gHour, .tint_rain_night
    EXECUTE_SUBROUTINE .tinted_dispatch_158_181

.tint_rain_night:
    UPDATE_GLOBAL_RGBA 80, 80, 128, 80, 8
    EXECUTE_SUBROUTINE .tinted_dispatch_158_181

.tint_rain_dawn_dusk:
    UPDATE_GLOBAL_RGBA 112, 112, 192, 112, 8
    EXECUTE_SUBROUTINE .tinted_dispatch_158_181

.tint_rain_day:
    UPDATE_GLOBAL_RGBA 128, 128, 208, 128, 8
    EXECUTE_SUBROUTINE .tinted_dispatch_158_181

.tint_rain_midday:
    UPDATE_GLOBAL_RGBA 144, 144, 255, 144, 8
    EXECUTE_SUBROUTINE .tinted_dispatch_158_181

.popuri_dialogue_13_yes:
    UPDATE_U8_VALUE 10, 255, npcAffection[POPURI]
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 234
    EXECUTE_SUBROUTINE .date_transition_fade_and_spawn_escorts
    EXECUTE_SUBROUTINE .apply_time_of_day_tint

.popuri_cutscene_158_2:
    ENTITY_WALK 40, DIRECTION_W, 2
    WAIT_RGBA_FINISHED
    SET_ASSET_ROTATION 6
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 236

; Shared date-end helper: closes message, fades out, walks Popuri off, sets completion bit 1.
; Shared date-end helper: walks escort off, fade-out, sets gCutsceneCompletionFlags bit 1. Used by Maria, Elli, Popuri, Ann.
.close_msg_fade_and_end_date:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 7, .popuri_escort_walk_off_northwest
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    ENTITY_WALK 32, DIRECTION_W, 2
    WAIT_RGBA_FINISHED
    DEACTIVATE_EXECUTOR 7
    DEACTIVATE_EXECUTOR 8
    SET_SPECIAL_BIT 1, gCutsceneCompletionFlags
    EXECUTE_SUBROUTINE .end_cutscene

.popuri_escort_walk_off_northwest:
    ENTITY_WALK 32, DIRECTION_W, 2
    EXECUTE_SUBROUTINE .idle

.player_walk_in_11:
    EXECUTE_SUBROUTINE .player_setup_slot0
    SET_COORDINATES -112, 0, 232
    SET_WAIT_FRAMES 15
    ENTITY_WALK 40, DIRECTION_W, 2
    EXECUTE_SUBROUTINE .idle

