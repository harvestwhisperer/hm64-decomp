    UPDATE_U8_VALUE 3, 255, npcAffection[GRAY]
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 508
    EXECUTE_SUBROUTINE .gray_walk_over_say_text_630

