; ==========================================================
; Potion Shop Dealer
; ==========================================================

.potion_shop_dealer_setup:
    SETUP_ENTITY 30, ENTITY_ASSET_POTION_SHOP_DEALER, 1
    SET_ENTITY_ANIMATIONS 30, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    RETURN_FROM_SUBROUTINE

.potion_shop_dealer_walk_in_1:
    EXECUTE_SUBROUTINE .potion_shop_dealer_setup
    SET_ASSET_ROTATION 6
    SET_COORDINATES -590, 0, 152
    ENTITY_WALK 34, DIRECTION_E, 2
    EXECUTE_SUBROUTINE .show_doorstep_greeting_text_620
    ENTITY_WALK 90, DIRECTION_E, 2
    SET_ASSET_ROTATION 4
    SET_CALLBACK_ROUTINE 0, 32768, .potion_shop_dealer_dispatch
    EXECUTE_SUBROUTINE .wait_until_hour_9

.potion_shop_dealer_walk_in_2:
    EXECUTE_SUBROUTINE .potion_shop_dealer_setup
    UPDATE_RGBA 254, 254, 254, 254, 0
    SET_ASSET_ROTATION 4
    SET_COORDINATES -342, 0, 152
    WAIT_RGBA_FINISHED
    EXECUTE_SUBROUTINE .show_doorstep_greeting_text_620
    SET_CALLBACK_ROUTINE 0, 32768, .potion_shop_dealer_dispatch
    EXECUTE_SUBROUTINE .wait_until_hour_9

; Potion shop dealer dispatch (called by both walk_in_1 and walk_in_2 after wait-until-9): dialogue 19 yes/no branches.
.potion_shop_dealer_dispatch:
    UPDATE_U8_VALUE 2, 255, gHappiness
    EXECUTE_SUBROUTINE .lock_camera_and_face_player
    INIT_DIALOGUE_SESSION 0, DIALOGUE_FARM_VISITS, 19
    WAIT_FOR_DIALOGUE_INPUT 0
    BRANCH_ON_DIALOGUE 0, 0, .potion_shop_dealer_dialogue_19_yes
    BRANCH_ON_DIALOGUE 0, 1, .potion_shop_dealer_dialogue_19_no

.potion_shop_dealer_dialogue_19_yes:
    ; set SPIRIT_FESTIVAL_INVITATION_ACCEPTED
    SET_SPECIAL_BIT 16, dailyEventBits[2]
    UPDATE_U8_VALUE 3, 255, npcAffection[POTION_SHOP_DEALER]
    BRANCH_ON_SPECIAL_BIT 3, lifeEventBits[2], .potion_shop_dealer_show_msg_497
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 496
    EXECUTE_SUBROUTINE .close_message_and_walk_off_northwest_120

.potion_shop_dealer_show_msg_497:
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 497
    EXECUTE_SUBROUTINE .close_message_and_walk_off_northwest_120

.potion_shop_dealer_dialogue_19_no:
    CLEAR_SPECIAL_BIT 16, dailyEventBits[2]
    UPDATE_U8_VALUE -5, 255, npcAffection[POTION_SHOP_DEALER]
    INIT_MESSAGE_BOX_TYPE1 0, FARM_VISITS_TEXT_INDEX, 498
    EXECUTE_SUBROUTINE .close_message_and_walk_off_northwest_120


