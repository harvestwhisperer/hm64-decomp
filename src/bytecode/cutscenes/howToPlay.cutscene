    SET_ASSET_ROTATION NORTHEAST
    SET_OTHER_EXECUTOR_PTR 16, .c1611_slot16_1
    SET_WAIT_FRAMES 20
    SET_HOLDING_ANIMATION_FLAG FALSE
    SET_OTHER_EXECUTOR_PTR 30, .c1601_slot30_4
    SET_SFX 38, 128
    DEACTIVATE_EXECUTOR 4
    SET_SPECIAL_BIT 25, gCutsceneCompletionFlags
    SET_ENTITY_DIRECTIONAL_ANIMATION 421
    SET_WAIT_FRAMES 10
    SET_OTHER_EXECUTOR_PTR 30, .c1601_slot30_3
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SET_WAIT_FRAMES 20
    SET_ASSET_ROTATION SOUTH
    SET_WAIT_FRAMES 20
    EXECUTE_SUBROUTINE .finish_tutorial_step

; ---- cutscene 1611 private helpers (dog) ----
.c1611_slot16_1:
    SET_ENTITY_DIRECTIONAL_ANIMATION 48
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 40
    WAIT_ENTITY_ANIMATION
    SET_WAIT_FRAMES 20
    SET_ENTITY_DIRECTIONAL_ANIMATION 104
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 40
    SET_WAIT_FRAMES 30
    SET_ENTITY_DIRECTIONAL_ANIMATION 32
    WAIT_ENTITY_ANIMATION
    SET_WAIT_FRAMES 30
    SET_ENTITY_DIRECTIONAL_ANIMATION 24
    EXECUTE_SUBROUTINE .wait_loop

.c1611_slot4_1:
    EXECUTE_SUBROUTINE .setup_static_slot_39
    SET_ENTITY_ANIMATION 16
    SET_ENTITY_TRACKING_TARGET 0, 0, 14, 20, 255
    EXECUTE_SUBROUTINE .wait_loop

.c1611_slot4_2:
    EXECUTE_SUBROUTINE .setup_static_slot_39
    SET_ENTITY_DIRECTIONAL_ANIMATION 64
    SET_ENTITY_TRACKING_TARGET 0, 0, 10, 20, 254
    SET_WAIT_FRAMES 4
    SET_ENTITY_TRACKING_TARGET 0, 0, 14, 20, 254
    EXECUTE_SUBROUTINE .wait_loop

.c1611_slot16_2:
    ENTITY_RUN 24, NORTHWEST, 4
    EXECUTE_SUBROUTINE .wait_loop

.setup_dog_slot_1:
    SETUP_ENTITY 1, ENTITY_ASSET_PLAYER_DOG, 1
    SET_ENTITY_ANIMATIONS 1, 0, 8, 16, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    RETURN_FROM_SUBROUTINE

.c1611_slot16_3:
    EXECUTE_SUBROUTINE .setup_dog_slot_1
    SET_RGBA 0, 0, 0, 0
    SET_COORDINATES 64, 0, 0
    SET_ASSET_ROTATION NORTHWEST
    EXECUTE_SUBROUTINE .wait_loop

.c1611_slot16_4:
    EXECUTE_SUBROUTINE .setup_dog_slot_1
    SET_COORDINATES -448, 0, 160
    SET_ASSET_ROTATION SOUTHWEST
    EXECUTE_SUBROUTINE .wait_loop

