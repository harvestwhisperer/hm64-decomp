; ---------- Entity / item-impact setup helpers ----------
; One SETUP_ENTITY wrapper per executor slot so the cutscene body can
; spawn that slot with coordinates + animation in two cheap lines.
.setup_static_slot_39:
    SETUP_ENTITY 39, ENTITY_ASSET_STATIC_ITEM, 1
    SET_ENTITY_ANIMATIONS 39, 0, 0, 0, 0, 0, 0
