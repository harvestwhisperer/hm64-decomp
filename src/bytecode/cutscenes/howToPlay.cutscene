; ============================================================
; Bank 27 - How to Play
; ============================================================
; Scripted tutorial demo launched from the title-screen How to
; Play option. The demo is split across 12 cutscene indices that
; run back-to-back, each covering one gameplay topic on a fresh
; farm-field layout. The C dispatcher in src/game/cutscenes.c seeds
; gCutsceneIndex / gSeason / farmFieldTiles per topic and then
; transitions to the next segment (cases 1601..1611 loop back to
; 1600 on completion).
;
; Cutscene indices:
;   1600 = book / guidebook intro (title screen overlay)
;   1601 = rucksack and tool levels (summer farm)
;   1602 = clearing land, boulders, stumps, lumber (spring farm)
;   1603 = tilling the soil (spring farm)
;   1604 = sowing seeds (spring farm)
;   1605 = watering (spring farm)
;   1606 = harvesting and shipping (spring farm)
;   1607 = chickens (summer farm)
;   1608 = cows (summer farm)
;   1609 = sheep (summer farm, barn spawn)
;   1610 = horse (summer farm)
;   1611 = dog (summer farm)
;
; All message-box calls pull from HOW_TO_PLAY_TEXT_INDEX (bank 72).
; The guidebook narrator uses avatar PLAYER_ENGRAVING_LOGO_1.
; The Start-button exit is handled by executor slot 41 polling
; .poll_for_exit_button and branching into .perform_exit.

#include "entities.h"

#define MAIN_MAP_INDEX 0

.buffer 2

.local var0, u32, 0

.main:
    SET_SPECIAL_BIT 12, gCutsceneCompletionFlags
    SET_U8_VALUE 12, gHour
    SET_U8_VALUE 0, gMinutes
    EXECUTE_SUBROUTINE .init_message_box_standard
    BRANCH_U16_VAR_WITHIN_RANGE 1600, 1600, gCutsceneIndex, .cutscene_1600_book_intro
    BRANCH_U16_VAR_WITHIN_RANGE 1601, 1601, gCutsceneIndex, .cutscene_1601_rucksack_and_tools
    BRANCH_U16_VAR_WITHIN_RANGE 1602, 1602, gCutsceneIndex, .cutscene_1602_clearing_land
    BRANCH_U16_VAR_WITHIN_RANGE 1603, 1603, gCutsceneIndex, .cutscene_1603_tilling
    BRANCH_U16_VAR_WITHIN_RANGE 1604, 1604, gCutsceneIndex, .cutscene_1604_seeds
    BRANCH_U16_VAR_WITHIN_RANGE 1605, 1605, gCutsceneIndex, .cutscene_1605_watering
    BRANCH_U16_VAR_WITHIN_RANGE 1606, 1606, gCutsceneIndex, .cutscene_1606_harvest_and_ship
    BRANCH_U16_VAR_WITHIN_RANGE 1607, 1607, gCutsceneIndex, .cutscene_1607_chickens
    BRANCH_U16_VAR_WITHIN_RANGE 1608, 1608, gCutsceneIndex, .cutscene_1608_cows
    BRANCH_U16_VAR_WITHIN_RANGE 1609, 1609, gCutsceneIndex, .cutscene_1609_sheep
    BRANCH_U16_VAR_WITHIN_RANGE 1610, 1610, gCutsceneIndex, .cutscene_1610_horse
    BRANCH_U16_VAR_WITHIN_RANGE 1611, 1611, gCutsceneIndex, .cutscene_1611_dog

; ============================================================
; SHARED HELPERS
; ============================================================

.finish_cutscene:
    SET_SPECIAL_BIT 0, gCutsceneCompletionFlags
    DEACTIVATE_SELF

.wait_loop:
    SET_WAIT_FRAMES 1
    EXECUTE_SUBROUTINE .wait_loop

.init_message_box_standard:
    SET_MESSAGE_INTERPOLATION -4, 0, 0
    SET_MESSAGE_BOX_ASSETS 0, 0, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 24, -64, 352
    RETURN_FROM_SUBROUTINE

.init_message_box_alt:
    SET_MESSAGE_INTERPOLATION -4, 0, 0
    SET_MESSAGE_BOX_ASSETS 0, 1, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 0, -64, 352
    RETURN_FROM_SUBROUTINE

.setup_player:
    SETUP_ENTITY 0, ENTITY_ASSET_PLAYER, 1
    SET_ENTITY_ANIMATIONS 0, 0, 8, 16, 24, 32, 40
    SET_BEHAVIOR_FLAGS CUTSCENE_ASSET_BEHAVIOR_TRACK_ENTITY
    RETURN_FROM_SUBROUTINE

; ============================================================
; Cutscene 1600 - guidebook intro overlay
; ============================================================
; Opens with the title-screen theme and a checkerboard background.
; The player sprite, an open book, and three guidebook panes fade
; in one at a time, cycling through texts 0..11 (rucksack hint,
; tool-change hints, tool-level explanation).
.cutscene_1600_book_intro:
    SET_AUDIO_SEQUENCE 0, _titleSegmentRomStart, _titleSegmentRomEnd
    SET_AUDIO_SEQUENCE_VOLUME 0, 128, 8
    SPAWN_EXECUTOR 1, .c1600_slot1_1
    SPAWN_EXECUTOR 2, .c1600_slot2_1
    SET_WAIT_FRAMES 1
    SPAWN_EXECUTOR 1, .c1600_slot1_2
    SPAWN_EXECUTOR 2, .c1600_slot2_2
    SPAWN_EXECUTOR 3, .c1600_slot3_1
    SPAWN_EXECUTOR 4, .c1600_slot4_1
    SPAWN_EXECUTOR 16, .c1600_slot16_1
    SPAWN_EXECUTOR 32, .c1600_slot32
    DMA_SPRITE 80, 0, _checkerboardBackgroundTextureSegmentRomStart, _checkerboardBackgroundTextureSegmentRomEnd, _checkerboardBackgroundAssetsIndexSegmentRomStart, _checkerboardBackgroundAssetsIndexSegmentRomEnd, 0, 0, 0x8026F000, 0, 0x8027E200, 0x8027E700, 0x8027EB00, 0x00000000
    SET_ANIM_DATA_PTR_WITH_FLAG .c1600_anim_a0_fFE
    SET_COORDINATES 0, 0, 0
    SET_SPRITE_SCALE 2, 2, 0

.fade_in_then_wait:
    SET_RGBA 0, 0, 0, 0
    UPDATE_RGBA 255, 255, 255, 255, 8
    WAIT_RGBA_FINISHED
    EXECUTE_SUBROUTINE .wait_loop

.c1600_slot1_1:
    EXECUTE_SUBROUTINE .setup_player
    DEACTIVATE_SELF

.c1600_slot2_1:
    SETUP_MAP_ASSET MAIN_MAP_INDEX
    DEACTIVATE_SELF

.c1600_slot1_2:
    DMA_SPRITE 81, 0, _bookTextureSegmentRomStart, _bookTextureSegmentRomEnd, _bookAssetsIndexSegmentRomStart, _bookAssetsIndexSegmentRomEnd, 0, 0, 0x80289900, 0, 0x8028EF00, 0x8028F000, 0x8028F100, 0x00000000
    SET_ANIM_DATA_PTR_WITH_FLAG .c1600_anim_a0_fFE
    SET_COORDINATES 0, 0, 10
    EXECUTE_SUBROUTINE .fade_in_then_wait

