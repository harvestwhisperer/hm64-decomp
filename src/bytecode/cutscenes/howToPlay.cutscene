; ---------- Tutorial step cleanup (shared by 1601-1611) ----------
; Fades out audio + HUD executors, raises completion bit 1, and 
; hands off to .finish_cutscene so the next step of the sequence runs.
.finish_tutorial_step:
    SET_WAIT_FRAMES 20
    SET_AUDIO_SEQUENCE_VOLUME 0, 0, 4
    EXECUTE_SUBROUTINE .cleanup_controller_hud
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    STOP_SEQUENCE_WITH_FADE 0, 1
    IDLE_WHILE_SEQUENCE_PLAYING 0
    DEACTIVATE_EXECUTOR 16
    DEACTIVATE_EXECUTOR 17
    DEACTIVATE_EXECUTOR 18
    DEACTIVATE_EXECUTOR 19
    DEACTIVATE_EXECUTOR 39
    DEACTIVATE_EXECUTOR 41
    SET_SPECIAL_BIT 1, gCutsceneCompletionFlags
    EXECUTE_SUBROUTINE .finish_cutscene

; ---------- Player tool animation helpers ----------
; Each pair below plays a 'wind-up' animation then a 'strike' animation
; with an associated SFX. They are reused across tutorial steps; anim IDs
; and SFX numbers are preserved in the label names.
.play_3stage_windup_80_88_96:
    SET_OTHER_EXECUTOR_PTR 31, .c1601_slot31_4
    SET_ENTITY_DIRECTIONAL_ANIMATION 80
    SET_WAIT_FRAMES 20
    SET_ENTITY_DIRECTIONAL_ANIMATION 88
    SET_WAIT_FRAMES 20
    SET_ENTITY_DIRECTIONAL_ANIMATION 96
    SET_WAIT_FRAMES 20
    RETURN_FROM_SUBROUTINE

