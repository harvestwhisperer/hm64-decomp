; ---------- Status HUD open / close orchestration ----------
; Called between tutorial steps to fade the inventory/time/money HUD in
; (open_status_hud) and fade it back out (close_status_hud) while cursor
; executors on slot 27 highlight the relevant inventory cell.
.open_status_hud:
    SET_OTHER_EXECUTOR_PTR 32, .c1601_slot32_3
    SET_WAIT_FRAMES 30
    SET_OTHER_EXECUTOR_PTR 32, .c1601_slot32_4
    SET_OTHER_EXECUTOR_PTR 32, .c1601_slot32_4
    SET_SFX 0, 128
    SPAWN_EXECUTOR 1, .c1601_slot1_13
    SET_WAIT_FRAMES 2
    DEACTIVATE_EXECUTOR 16
    DEACTIVATE_EXECUTOR 17
    DEACTIVATE_EXECUTOR 18
    DEACTIVATE_EXECUTOR 19
    DEACTIVATE_EXECUTOR 20
    SET_WAIT_FRAMES 3
    SPAWN_EXECUTOR 2, .c1601_slot2_4
    SPAWN_EXECUTOR 3, .c1601_slot3_2
    SPAWN_EXECUTOR 4, .c1601_slot4_2
    SPAWN_EXECUTOR 5, .c1601_slot5_2
    SPAWN_EXECUTOR 6, .c1601_slot6_2
    SPAWN_EXECUTOR 7, .c1601_slot7_2
    SPAWN_EXECUTOR 8, .c1601_slot8_2
    SPAWN_EXECUTOR 9, .c1601_slot9_2
    SPAWN_EXECUTOR 10, .c1601_slot10
    SPAWN_EXECUTOR 11, .c1601_slot11
    SPAWN_EXECUTOR 12, .c1601_slot12
    SPAWN_EXECUTOR 13, .c1601_slot13
    SPAWN_EXECUTOR 14, .c1601_slot14
    SPAWN_EXECUTOR 15, .c1601_slot15
    SPAWN_EXECUTOR 16, .c1601_slot16
    SPAWN_EXECUTOR 17, .c1601_slot17
    SPAWN_EXECUTOR 40, .c1600_slot2_1
    RETURN_FROM_SUBROUTINE

