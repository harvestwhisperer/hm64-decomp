; ============================================
; Bank 25 - Cow Festival
; ============================================

#include "entities.h"
#include "texts.h"
#include "dialogues.h"

.buffer 2

#define MAIN_MAP_INDEX 0
#define MARRIED 0

; NPC indices for npcAffection array (non-built-in)
#define NPC_MAYOR 0xB
#define NPC_DOUG 0x10
#define NPC_POTION_SHOP_DEALER 0x13
#define NPC_KENT 0x14
#define NPC_RICK 0x18
#define NPC_GOURMET_JUDGE 0x28

; Local variables
.local var0, u32, 0
.local var1, u32, 0

.array npcAffection, u8
.array lifeEventBits, u32
.array dailyEventBits, u32

.entry
    SET_SPECIAL_BIT 31, gCutsceneCompletionFlags
    SET_SPECIAL_BIT 9, gCutsceneCompletionFlags
    SET_SPECIAL_BIT 12, gCutsceneCompletionFlags
    SET_SPECIAL_BIT 13, gCutsceneCompletionFlags
    SET_SPECIAL_BIT 14, gCutsceneCompletionFlags
    SET_SPECIAL_BIT 15, gCutsceneCompletionFlags
    SET_SPECIAL_BIT 13, dailyEventBits[1]
    PAUSE_ENTITIES
    STOP_SEQUENCE_WITH_FADE 0, 8
    IDLE_WHILE_SEQUENCE_PLAYING 0
    SET_AUDIO_SEQUENCE 0, _festivalThemeSegmentRomStart, _festivalThemeSegmentRomEnd
    SET_AUDIO_SEQUENCE_VOLUME 0, 128, 8
    TOGGLE_PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .setup_message_box
    BRANCH_U16_VAR_WITHIN_RANGE 1150, 1150, gCutsceneIndex, .festival_setup

.exit:
    CLEAR_SPECIAL_BIT 0, var0
    SET_SPECIAL_BIT 0, gCutsceneCompletionFlags
    DEACTIVATE_SELF

.wait_loop:
    SET_WAIT_FRAMES 1
    EXECUTE_SUBROUTINE .wait_loop

.setup_message_box:
    SET_MESSAGE_INTERPOLATION -4, 0, 0
    SET_MESSAGE_BOX_ASSETS 0, 0, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 24, -64, 352
    RETURN_FROM_SUBROUTINE

.setup_player:
    SETUP_ENTITY 0, ENTITY_ASSET_PLAYER, 1
    SET_ENTITY_ANIMATIONS 0, 0, 8, 16, 24, 32, 40
    SET_BEHAVIOR_FLAGS CUTSCENE_ASSET_BEHAVIOR_TRACK_ENTITY
    RETURN_FROM_SUBROUTINE

.deactivate_self:
    SET_ENTITY_MAP_SPACE_INDEPENDENT FALSE
    DEACTIVATE_SELF

.executor_trophy_1:
    SETUP_ENTITY 22, ENTITY_ASSET_STATIC_ITEM, 1
    SET_ENTITY_ANIMATIONS 22, 0, 0, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_COORDINATES 160, 0, 160
    SET_ENTITY_ANIMATION 21
    EXECUTE_SUBROUTINE .wait_loop

.executor_trophy_2:
    SETUP_ENTITY 23, ENTITY_ASSET_STATIC_ITEM, 1
    SET_ENTITY_ANIMATIONS 23, 0, 0, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_COORDINATES 160, 0, 192
    SET_ENTITY_ANIMATION 22
    EXECUTE_SUBROUTINE .wait_loop

.executor_trophy_3:
    SETUP_ENTITY 24, ENTITY_ASSET_STATIC_ITEM, 1
    SET_ENTITY_ANIMATIONS 24, 0, 0, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_COORDINATES 160, 0, 224
    SET_ENTITY_ANIMATION 21
    EXECUTE_SUBROUTINE .wait_loop

.festival_setup:
    INIT_MAP_ADDITION 3, 0
    SPAWN_EXECUTOR 21, .executor_cow_1
    SPAWN_EXECUTOR 22, .executor_cow_2
    SPAWN_EXECUTOR 23, .executor_cow_3
    SPAWN_EXECUTOR 24, .executor_cow_4
    SPAWN_EXECUTOR 25, .executor_cow_5
    SPAWN_EXECUTOR 1, .executor_mayor
    SPAWN_EXECUTOR 2, .executor_doug
    SPAWN_EXECUTOR 3, .executor_gray
    SPAWN_EXECUTOR 4, .executor_ann
    SPAWN_EXECUTOR 5, .executor_elli
    SPAWN_EXECUTOR 6, .executor_gourmet_judge
    SPAWN_EXECUTOR 7, .executor_potion_shop_dealer
    SPAWN_EXECUTOR 8, .executor_rick
    SPAWN_EXECUTOR 9, .executor_maria
    SPAWN_EXECUTOR 10, .executor_kent
    SPAWN_EXECUTOR 11, .executor_harris
    SPAWN_EXECUTOR 12, .executor_jeff
    BRANCH_ON_SPECIAL_BIT 13, lifeEventBits[1], .skip_cliff_spawn
    SPAWN_EXECUTOR 13, .executor_cliff

.skip_cliff_spawn:
    BRANCH_ON_SPECIAL_BIT 14, lifeEventBits[1], .skip_kai_spawn
    SPAWN_EXECUTOR 14, .executor_kai

.skip_kai_spawn:
    SPAWN_EXECUTOR 15, .executor_popuri
    BRANCH_ON_SPECIAL_BIT 15, lifeEventBits[1], .spawn_items_and_player
    SPAWN_EXECUTOR 16, .executor_karen

.spawn_items_and_player:
    SPAWN_EXECUTOR 32, .executor_trophy_1
    SPAWN_EXECUTOR 33, .executor_trophy_2
    SPAWN_EXECUTOR 34, .executor_trophy_3
    EXECUTE_SUBROUTINE .setup_player
    SET_COORDINATES 120, 0, 192
    SET_ASSET_ROTATION 6
    SET_WAIT_FRAMES 1
    UPDATE_GLOBAL_RGBA 255, 255, 255, 255, 8
    WAIT_RGBA_FINISHED
    INIT_MESSAGE_BOX_TYPE1 0, COW_FESTIVAL_TEXT_INDEX, 0
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_ENTITY_MAP_SPACE_INDEPENDENT FALSE
    SET_U16_VALUE 0, D_80189824
    SPAWN_EXECUTOR 41, .interaction_loop
    DEACTIVATE_SELF

.executor_cow_1:
    SETUP_ENTITY 1, ENTITY_ASSET_COW, 1
    SET_ENTITY_ANIMATIONS 1, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_COORDINATES 0, 0, 96
    SET_ASSET_ROTATION 6
    EXECUTE_SUBROUTINE .cow_animation_48

.cow_idle_animation:
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SET_WAIT_FRAMES 30
    EXECUTE_SUBROUTINE .cow_animation_48

.executor_cow_2:
    SETUP_ENTITY 2, ENTITY_ASSET_COW, 1
    SET_ENTITY_ANIMATIONS 2, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_COORDINATES -160, 0, 64
    SET_ASSET_ROTATION 5
    EXECUTE_SUBROUTINE .cow_idle_animation

.executor_cow_3:
    SETUP_ENTITY 3, ENTITY_ASSET_COW, 1
    SET_ENTITY_ANIMATIONS 3, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_COORDINATES -256, 0, 192
    SET_ASSET_ROTATION 4
    EXECUTE_SUBROUTINE .cow_animation_48

.executor_cow_4:
    SETUP_ENTITY 4, ENTITY_ASSET_COW, 1
    SET_ENTITY_ANIMATIONS 4, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_COORDINATES 0, 0, 256
    SET_ASSET_ROTATION 2
    EXECUTE_SUBROUTINE .cow_idle_animation

.executor_cow_5:
    SETUP_ENTITY 5, ENTITY_ASSET_COW, 1
    SET_ENTITY_ANIMATIONS 5, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_COORDINATES -112, 0, 288
    SET_ASSET_ROTATION 0
    EXECUTE_SUBROUTINE .cow_animation_48

.cow_animation_48:
    SET_ENTITY_DIRECTIONAL_ANIMATION 48
    WAIT_ENTITY_ANIMATION
    EXECUTE_SUBROUTINE .cow_idle_animation

.executor_mayor:
    SETUP_ENTITY 6, ENTITY_ASSET_MAYOR, 1
    SET_ENTITY_ANIMATIONS 6, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_COORDINATES 192, 0, 192
    SET_ASSET_ROTATION 2

.mayor_wait:
    SET_CALLBACK_ROUTINE 0, 32768, .mayor_on_interact
    EXECUTE_SUBROUTINE .wait_loop

.mayor_on_interact:
    BRANCH_ON_SPECIAL_BIT 15, var0, .mayor_wait
    EXECUTE_SUBROUTINE .setup_message_box
    BRANCH_ON_SPECIAL_BIT 0, var1, .mayor_talk_festival_purpose
    UPDATE_U8_VALUE 2, 255, npcAffection[NPC_MAYOR]
    SET_SPECIAL_BIT 0, var1

.mayor_talk_festival_purpose:
    PAUSE_ENTITIES
    FLIP_ENTITY_DIRECTION 0
    SET_SPECIAL_BIT 0, var0
    INIT_MESSAGE_BOX_TYPE1 0, COW_FESTIVAL_TEXT_INDEX, 40
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITIES
    CLEAR_SPECIAL_BIT 0, var0
    EXECUTE_SUBROUTINE .mayor_wait

.executor_doug:
    SETUP_ENTITY 7, ENTITY_ASSET_DOUG, 1
    SET_ENTITY_ANIMATIONS 7, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_COORDINATES -64, 0, 96
    SET_ASSET_ROTATION 6

.doug_wait:
    SET_CALLBACK_ROUTINE 0, 32768, .doug_on_interact
    EXECUTE_SUBROUTINE .wait_loop

.doug_on_interact:
    BRANCH_ON_SPECIAL_BIT 15, var0, .doug_wait
    EXECUTE_SUBROUTINE .setup_message_box
    BRANCH_ON_SPECIAL_BIT 1, var1, .doug_talk_checking_coat
    UPDATE_U8_VALUE 2, 255, npcAffection[NPC_DOUG]
    SET_SPECIAL_BIT 1, var1

.doug_talk_checking_coat:
    PAUSE_ENTITIES
    FLIP_ENTITY_DIRECTION 0
    SET_SPECIAL_BIT 0, var0
    INIT_MESSAGE_BOX_TYPE1 0, COW_FESTIVAL_TEXT_INDEX, 4
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITIES
    CLEAR_SPECIAL_BIT 0, var0
    EXECUTE_SUBROUTINE .doug_wait

.executor_gray:
    SETUP_ENTITY 8, ENTITY_ASSET_GRAY, 1
    SET_ENTITY_ANIMATIONS 8, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_COORDINATES -160, 0, 288
    SET_ASSET_ROTATION 6

