    UPDATE_U8_VALUE 3, 255, npcAffection[KAI]

.skip_kai_bonus:
    UPDATE_U8_VALUE 3, 255, npcAffection[POPURI]
    BRANCH_ON_SPECIAL_BIT 15, lifeEventBits[1], .first_prize_rewards
    UPDATE_U8_VALUE 3, 255, npcAffection[KAREN]

.first_prize_rewards:
    UPDATE_U8_VALUE 5, 255, gHappiness
    ; COW_FESTIVAL_FIRST_PRIZE 48
    SET_SPECIAL_BIT 16, lifeEventBits[1]
    SET_SPECIAL_BIT 17, lifeEventBits[4]
    INIT_MESSAGE_BOX_TYPE1 0, COW_FESTIVAL_TEXT_INDEX, 2
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_SFX 84, 128
    SET_WAIT_FRAMES 60
    INIT_MESSAGE_BOX_TYPE1 0, COW_FESTIVAL_TEXT_INDEX, 42
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_SFX 84, 128
    SET_WAIT_FRAMES 60
    INIT_MESSAGE_BOX_TYPE1 0, COW_FESTIVAL_TEXT_INDEX, 45
    EXECUTE_SUBROUTINE .end_festival
