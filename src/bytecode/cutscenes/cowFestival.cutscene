    SET_WAIT_FRAMES 1
    BRANCH_ON_SPECIAL_BIT 0, var0, .interaction_loop
    UPDATE_U16_VALUE 1, 9999, D_80189824
    BRANCH_U16_VAR_WITHIN_RANGE 1000, 1000, D_80189824, .judging_phase
    BRANCH_U8_VAR_WITHIN_RANGE 32, 32, cutsceneLevelInteractionIndex, .try_leave_festival
