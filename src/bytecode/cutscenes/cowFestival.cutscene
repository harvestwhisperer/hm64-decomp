    EXECUTE_SUBROUTINE .setup_message_box
    BRANCH_ON_SPECIAL_BIT 2, var1, .gray_talk
    UPDATE_U8_VALUE 2, 255, npcAffection[GRAY]
    SET_SPECIAL_BIT 2, var1

.gray_talk:
    PAUSE_ENTITIES
    FLIP_ENTITY_DIRECTION 0
    SET_SPECIAL_BIT 0, var0
    BRANCH_ON_SPECIAL_BIT 9, dailyEventBits[2], .gray_has_cow
    INIT_MESSAGE_BOX_TYPE1 0, COW_FESTIVAL_TEXT_INDEX, 20

.gray_talk_done:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITIES
    CLEAR_SPECIAL_BIT 0, var0
    EXECUTE_SUBROUTINE .gray_wait

.gray_has_cow:
    BRANCH_U16_VAR_WITHIN_RANGE 0, 50, D_801886D2, .gray_talk_bummer
    BRANCH_U16_VAR_WITHIN_RANGE 51, 159, D_801886D2, .gray_talk_still_a_ways
    BRANCH_U16_VAR_WITHIN_RANGE 160, 244, D_801886D2, .gray_talk_not_bad
    BRANCH_U16_VAR_WITHIN_RANGE 245, 255, D_801886D2, .gray_talk_good_job
    EXECUTE_SUBROUTINE .gray_talk_still_a_ways

.gray_talk_bummer:
    INIT_MESSAGE_BOX_TYPE1 0, COW_FESTIVAL_TEXT_INDEX, 22
    EXECUTE_SUBROUTINE .gray_talk_done

.gray_talk_still_a_ways:
    INIT_MESSAGE_BOX_TYPE1 0, COW_FESTIVAL_TEXT_INDEX, 19
    EXECUTE_SUBROUTINE .gray_talk_done

.gray_talk_not_bad:
    INIT_MESSAGE_BOX_TYPE1 0, COW_FESTIVAL_TEXT_INDEX, 20
    EXECUTE_SUBROUTINE .gray_talk_done

.gray_talk_good_job:
    INIT_MESSAGE_BOX_TYPE1 0, COW_FESTIVAL_TEXT_INDEX, 21
    EXECUTE_SUBROUTINE .gray_talk_done

