; ----- Cutscene 433 - Popuri pie/cake/tea (bakery) -----
; Triggered on entering BAKERY from VILLAGE_1 with Jeff
; affection >= 150 and 5 AM - 6 PM, when Elli-Jeff are not
; married and player is not married to Elli (cutscenes.c:3143).
; Chosen when gSpawnPointIndex == BAKERY_SPAWN_POINT_1 (0x59);
; cutscene 434 runs for any other entry spawn (same scene,
; different camera intro/exit angle).
;
; Cast:
;   slot 1 - Elli (behind counter, delivers pie later)
;   slot 2 - Jeff (tea delivery, scripted walker)
;   slot 3 - Popuri (customer, orders food)
;   slot 5 - static item on table (anim 7, spawned late)
;   slot 41 - scene driver
;
; Texts: village1Cutscenes 115-118 (order + Elli comment),
; 119-123 (tea, pie-with-ice-cream delivery), 124-126
; (post-scene NPC interact messages).

.cutscene_433_popuri_pie_cake_tea:
    SPAWN_EXECUTOR 1, .bakery_elli_counter_setup
    SPAWN_EXECUTOR 2, .executor_1_11E2C4
    SPAWN_EXECUTOR 3, .bakery_popuri_setup
    EXECUTE_SUBROUTINE .setup_player
    SET_WAIT_FRAMES 1
    BRANCH_U8_VAR_WITHIN_RANGE 0, 254, gItemBeingHeld, .branch_11B878
    UPDATE_GLOBAL_RGBA 254, 254, 254, 254, 0
    WAIT_RGBA_FINISHED
    SET_BEHAVIOR_FLAGS 0
    SET_WAIT_FRAMES 1
    SPAWN_EXECUTOR 41, .c433_bakery_intro_and_script
    EXECUTE_SUBROUTINE .wait_loop

.c433_bakery_intro_and_script:
    SETUP_MAP_ASSET MAIN_MAP_INDEX
    SET_FRAME_DELTA 0, 0, -2, 80
    INIT_MESSAGE_BOX_TYPE1 0, VILLAGE1_CUTSCENES_TEXT_INDEX, 115
    WAIT_MESSAGE_BOX_CLOSED 0
    INIT_MESSAGE_BOX_TYPE1 0, VILLAGE1_CUTSCENES_TEXT_INDEX, 116
    WAIT_MESSAGE_BOX_CLOSED 0
    INIT_MESSAGE_BOX_TYPE1 0, VILLAGE1_CUTSCENES_TEXT_INDEX, 117
    WAIT_MESSAGE_BOX_CLOSED 0
    SET_OTHER_EXECUTOR_PTR 2, .face_northeast_idle
    INIT_MESSAGE_BOX_TYPE1 0, VILLAGE1_CUTSCENES_TEXT_INDEX, 118
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 2, .bakery_jeff_delivers_tea
    SET_OTHER_EXECUTOR_PTR 1, .bakery_elli_walks_to_kitchen
    EXECUTE_SUBROUTINE .wait_loop

.bakery_scene_exit_dispatch:
    BRANCH_U16_VAR_WITHIN_RANGE 434, 434, gCutsceneIndex, .c434_bakery_exit_frame_delta
    SET_FRAME_DELTA 0, 0, 2, 80

.bakery_scene_exit:
    SET_OTHER_EXECUTOR_PTR 0, .enable_tracking_deactivate
    SET_SPECIAL_BIT 0, gCutsceneCompletionFlags
    EXECUTE_SUBROUTINE .wait_loop

.c434_bakery_exit_frame_delta:
    SET_FRAME_DELTA 1, 0, 2, 64
    EXECUTE_SUBROUTINE .bakery_scene_exit

.bakery_elli_counter_setup:
    EXECUTE_SUBROUTINE .sub_11C280
    SET_COORDINATES 32, 0, -64
    SET_ASSET_ROTATION NORTHEAST
    EXECUTE_SUBROUTINE .wait_loop

.bakery_elli_walks_to_kitchen:
    ENTITY_WALK 16, NORTHWEST, 2
    ENTITY_WALK 16, NORTHEAST, 2
    ENTITY_WALK 96, NORTHWEST, 2
    DEACTIVATE_SELF

