; ------------------------------------------------------------
; Cutscene handlers (400-445)
; ------------------------------------------------------------
; Each cutscene below is the BRANCH_U16_VAR_WITHIN_RANGE target
; from the dispatch table. Spawns its own executors and then
; deactivates the dispatcher slot.

; ----- Cutscene 400 - MARIA_WEDDING -----
; Player weds Maria. Ends with END_OF_DAY_1 main-loop
; callback (cutscenes.c:4453).

.cutscene_400_wedding_maria:
    SET_SPECIAL_BIT 31, gCutsceneCompletionFlags
    STOP_SEQUENCE_WITH_FADE 0, 8
    IDLE_WHILE_SEQUENCE_PLAYING 0
    SET_AUDIO_SEQUENCE 0, _weddingSegmentRomStart, _weddingSegmentRomEnd
    SET_AUDIO_SEQUENCE_VOLUME 0, 128, 128
    UPDATE_U8_VALUE 30, 255, gHappiness
    SET_SPECIAL_BIT 15, gCutsceneCompletionFlags
    SET_SPECIAL_BIT 12, gCutsceneCompletionFlags
    SPAWN_EXECUTOR 1, .c400_maria_bride_script
    SPAWN_EXECUTOR 7, .wedding_groom_setup_player
    SPAWN_EXECUTOR 2, .wedding_mayor_setup
    SPAWN_EXECUTOR 3, .wedding_pastor_setup
    SPAWN_EXECUTOR 4, .wedding_kent_setup
    SPAWN_EXECUTOR 5, .wedding_stu_setup
    SPAWN_EXECUTOR 6, .wedding_may_setup
    SPAWN_EXECUTOR 8, .wedding_photographer_setup
    SPAWN_EXECUTOR 9, .executor_9_11A03C
    SPAWN_EXECUTOR 10, .executor_10_11A068
    SPAWN_EXECUTOR 11, .executor_11_11A094
    SPAWN_EXECUTOR 12, .executor_12_11A0C0
    SPAWN_EXECUTOR 13, .executor_13_11A0EC
    SPAWN_EXECUTOR 14, .wedding_camera_setup
    DEACTIVATE_SELF

.maria_bride_setup:
    SETUP_ENTITY 22, ENTITY_ASSET_MARIA, 1
    SET_ENTITY_ANIMATIONS 22, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    RETURN_FROM_SUBROUTINE

.c400_maria_bride_script:
    EXECUTE_SUBROUTINE .maria_bride_setup
    SET_ENTITY_PHYSICS_FLAGS 0
    SET_COORDINATES -64, 96, -136
    SET_ASSET_ROTATION SOUTHWEST
    SET_ENTITY_ANIMATION 63
    SET_WAIT_FRAMES 1
    UPDATE_GLOBAL_RGBA 255, 255, 255, 255, 8
    WAIT_RGBA_FINISHED
    SET_WAIT_FRAMES 120
    SET_OTHER_EXECUTOR_PTR 7, .wedding_groom_anim_step1
    SET_OTHER_EXECUTOR_PTR 14, .wedding_camera_pan_guests
    SET_ENTITY_ANIMATION 65
    SET_FRAME_DELTA 0, 0, 1, 64
    SET_ENTITY_ANIMATION 63
    SET_WAIT_FRAMES 30
    SET_ENTITY_ANIMATION 64
    SET_WAIT_FRAMES 30
    SET_OTHER_EXECUTOR_PTR 7, .wedding_groom_anim_step2
    SET_ENTITY_ANIMATION 66

