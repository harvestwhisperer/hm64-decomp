#define PASTOR 25
#define DUKE 28
#define RICK 24

#define MARRIED 0
#define HAVE_BABY 1

; ------------------------------------------------------------
; Cutscene dispatch table (indices 400-445)
; ------------------------------------------------------------
; 400-404 weddings, 422 ANN_AND_RICK, 425 KAREN_KAI_TAVERN,
; 428 STARRY_NIGHT_FESTIVAL, 435 CHURCH_NEW_YEARS,
; 436 TAVERN_NEW_YEARS, 441 POPURI_SICK.

.dispatch:
    TOGGLE_PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .setup_message_box_window0
