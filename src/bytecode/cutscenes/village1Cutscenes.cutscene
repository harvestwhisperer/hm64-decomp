; ----- Cutscene 425 - KAREN_KAI_TAVERN -----
; Plays scripted scene in the tavern: Karen is slumped (text 50),
; Kai asks if she is OK (text 51), Karen rebuffs (text 52),
; then player walks NW and back SE while Kai resolves with
; text 53. Afterward, Kai (slot 2) and Duke (slot 3) remain
; interactive via DIALOGUE_KAI / DIALOGUE_DUKE on-interact
; handlers until the player leaves.

.cutscene_425_karen_kai_tavern:
    SET_SPECIAL_BIT 18, specialDialogueBits[3]
    SPAWN_EXECUTOR 1, .c425_karen_setup
    SPAWN_EXECUTOR 2, .c425_kai_setup
    SPAWN_EXECUTOR 3, .c425_duke_setup
    EXECUTE_SUBROUTINE .setup_player
    SET_ASSET_ROTATION NORTHEAST
    SET_WAIT_FRAMES 1
    UPDATE_GLOBAL_RGBA 254, 254, 254, 254, 0
    WAIT_RGBA_FINISHED
    SET_BEHAVIOR_FLAGS 0
    SET_WAIT_FRAMES 1
    SPAWN_EXECUTOR 41, .c425_scene_intro_karen_yawn
    EXECUTE_SUBROUTINE .wait_loop

.c425_scene_intro_karen_yawn:
    SETUP_MAP_ASSET MAIN_MAP_INDEX
    SET_FRAME_DELTA 0, 0, -2, 56
    INIT_MESSAGE_BOX_TYPE1 0, VILLAGE1_CUTSCENES_TEXT_INDEX, 50
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 2, .c425_kai_asks_if_karen_ok
    EXECUTE_SUBROUTINE .wait_loop

.c425_scene_exit:
    SET_FRAME_DELTA 0, 0, 2, 56
    SET_OTHER_EXECUTOR_PTR 0, .enable_tracking_deactivate
    SPAWN_EXECUTOR 16, .exit_cleanup
    EXECUTE_SUBROUTINE .wait_loop

.setup_karen_entity:
    SETUP_ENTITY 37, ENTITY_ASSET_KAREN, 1
    SET_ENTITY_ANIMATIONS 37, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    RETURN_FROM_SUBROUTINE

.c425_karen_setup:
    EXECUTE_SUBROUTINE .setup_karen_entity
    SET_COORDINATES -24, 0, 0
    SET_ASSET_ROTATION SOUTHEAST
    SET_ENTITY_ANIMATION 32
    EXECUTE_SUBROUTINE .wait_loop

.c425_kai_setup:
    SETUP_ENTITY 36, ENTITY_ASSET_KAI, 1
    SET_ENTITY_ANIMATIONS 36, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_COORDINATES -24, 0, -32
    SET_ASSET_ROTATION SOUTHWEST
    EXECUTE_SUBROUTINE .wait_loop

.c425_kai_asks_if_karen_ok:
    SET_ENTITY_DIRECTIONAL_ANIMATION 16
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    INIT_MESSAGE_BOX_TYPE1 0, VILLAGE1_CUTSCENES_TEXT_INDEX, 51
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 1, .c425_karen_rebuff_kai
    EXECUTE_SUBROUTINE .wait_loop

.c425_karen_rebuff_kai:
    SET_ENTITY_DIRECTIONAL_ANIMATION 94
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SET_WAIT_FRAMES 15
    SET_ASSET_ROTATION NORTHEAST
    INIT_MESSAGE_BOX_TYPE1 0, VILLAGE1_CUTSCENES_TEXT_INDEX, 52
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 0, .c425_player_step_nw
    ENTITY_WALK 64, SOUTHWEST, 2
    SET_OTHER_EXECUTOR_PTR 0, .c425_kai_ill_try_hard
