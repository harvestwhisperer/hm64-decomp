#define MAIN_MAP_INDEX 0

.buffer 2

; Local variables
.local var0, u32, 0
.local var1, u32, 0
.local var2, u8, 255

.array npcAffection, u8
.array lifeEventBits, u32
.array specialDialogueBits, u32

#define MAYOR 11
#define MAYOR_WIFE 12
#define KENT 20
