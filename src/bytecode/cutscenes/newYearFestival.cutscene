; Plain toast encounter; also relays neighbor walk nudges via
; SET_OTHER_EXECUTOR_PTR from Ann and Karen.

.executor_13_shipper:
    SETUP_ENTITY 13, ENTITY_ASSET_SHIPPER, 1
    SET_ENTITY_ANIMATIONS 13, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
