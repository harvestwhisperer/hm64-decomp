; ============================================================
; Bank 23 - New Year Festival
; ============================================================
; Cutscene index 1400: the New Year Festival, triggered on
; Spring day 1 between 6:00 and 17:59 (see cutscenes.c).
; Every townsperson NPC is spawned in a circle. Each one is a
; miniature toast encounter -- the player interacts, the NPC
; talks and clinks glasses, a drink-glass overlay is shown,
; and the player sprite plays a toast-drink animation. Each
; toast decrements gAlcoholTolerance by 1; when it reaches 0
; the player plays a pass-out animation and the festival ends.
; The Assistant Carpenter also offers a Yes/No prompt to leave
; early.
;
; Cutscene indices:
;   1400 - New Year Festival main scene
;
; Executor slots:
;   0       - player drink reaction (toast anim or pass-out)
;   1..13   - always-present townspeople in the festival circle:
;             Mayor, Mayor wife, Maria, Rick, Potion Shop
;             Dealer, Midwife, Popuri, Lillia, Elli, Ann, Karen,
;             Assistant Carpenter, Shipper
;   14..18  - conditional attendees spawned only at high
;             affection (and for bachelors, only if not yet
;             married to them): Harris, Gray, Jeff, Cliff, Kai
;   19      - player-side drink-glass static item (one-off)
;   20      - NPC-side drink-glass static item (sustained,
;             re-spawned per NPC toast)
;
; var0 bit layout:
;   bit 0 - Assistant Carpenter affection already bumped this run
;   bit 1 - Shipper affection already bumped this run
;
; Gating bits on lifeEventBits[1]:
;   bit 13 - skips the Cliff affection check
;   bit 14 - skips the Kai affection check
;   bit 15 - skips spawning Karen

#include "entities.h"
#include "texts.h"
#include "dialogues.h"

.buffer 2

; Local variables
.local var0, u32, 0

.array npcAffection, u8
.array lifeEventBits, u32

.main:
    SET_SPECIAL_BIT 31, gCutsceneCompletionFlags
    SET_SPECIAL_BIT 12, gCutsceneCompletionFlags
    SET_SPECIAL_BIT 13, gCutsceneCompletionFlags
    SET_SPECIAL_BIT 14, gCutsceneCompletionFlags
    SET_SPECIAL_BIT 15, gCutsceneCompletionFlags
    PAUSE_ENTITIES
    STOP_SEQUENCE_WITH_FADE 0, 8
    IDLE_WHILE_SEQUENCE_PLAYING 0
    SET_AUDIO_SEQUENCE 0, _dogRaceThemeSegmentRomStart, _dogRaceThemeSegmentRomEnd
    SET_AUDIO_SEQUENCE_VOLUME 0, 128, 8
    UPDATE_U8_VALUE 3, 255, gHappiness
    TOGGLE_PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .setup_message_box
    BRANCH_U16_VAR_WITHIN_RANGE 1400, 1400, gCutsceneIndex, .spawn_attendees
    ; fall through -- index outside range, exit cleanly

.end_festival:
    SET_SPECIAL_BIT 0, gCutsceneCompletionFlags
    DEACTIVATE_SELF

.wait_loop:
    SET_WAIT_FRAMES 1
    EXECUTE_SUBROUTINE .wait_loop

.setup_message_box:
    SET_MESSAGE_INTERPOLATION -4, 0, 0
    SET_MESSAGE_BOX_ASSETS 0, 0, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 24, -64, 352
    RETURN_FROM_SUBROUTINE

.setup_player:
    SETUP_ENTITY 0, ENTITY_ASSET_PLAYER, 1
    SET_ENTITY_ANIMATIONS 0, 0, 8, 16, 24, 32, 40
    SET_BEHAVIOR_FLAGS CUTSCENE_ASSET_BEHAVIOR_TRACK_ENTITY
    RETURN_FROM_SUBROUTINE

; ============================================================
; Spawn the festival attendees
; ============================================================

.spawn_attendees:
    SPAWN_EXECUTOR 1, .executor_1_mayor
    SPAWN_EXECUTOR 2, .executor_2_mayor_wife
    SPAWN_EXECUTOR 3, .executor_3_maria
    SPAWN_EXECUTOR 4, .executor_4_rick
    SPAWN_EXECUTOR 5, .executor_5_potion_shop_dealer
    SPAWN_EXECUTOR 6, .executor_6_midwife
    SPAWN_EXECUTOR 7, .executor_7_popuri
    SPAWN_EXECUTOR 8, .executor_8_lillia
    SPAWN_EXECUTOR 9, .executor_9_elli
    SPAWN_EXECUTOR 10, .executor_10_ann
    BRANCH_ON_SPECIAL_BIT 15, lifeEventBits + 0x4, .spawn_support_npcs
    SPAWN_EXECUTOR 11, .executor_11_karen

.spawn_support_npcs:
    SPAWN_EXECUTOR 12, .executor_12_assistant_carpenter
    SPAWN_EXECUTOR 13, .executor_13_shipper
    BRANCH_U8_VAR_WITHIN_RANGE 100, 255, npcAffection[HARRIS], .spawn_harris
    BRANCH_U8_VAR_WITHIN_RANGE 100, 255, npcAffection[GRAY], .spawn_gray
    BRANCH_U8_VAR_WITHIN_RANGE 100, 255, npcAffection[JEFF], .spawn_jeff
    BRANCH_ON_SPECIAL_BIT 13, lifeEventBits + 0x4, .check_kai
    BRANCH_U8_VAR_WITHIN_RANGE 100, 255, npcAffection[CLIFF], .spawn_cliff

.check_kai:
    BRANCH_ON_SPECIAL_BIT 14, lifeEventBits + 0x4, .no_optional_attendee
    BRANCH_U8_VAR_WITHIN_RANGE 100, 255, npcAffection[KAI], .spawn_kai

.no_optional_attendee:
    EXECUTE_SUBROUTINE .setup_player
    SET_COORDINATES 160, 0, -32
    SET_WAIT_FRAMES 1
    UPDATE_GLOBAL_RGBA 255, 255, 255, 255, 8
    SET_WAIT_FRAMES 32
    SET_ENTITY_MAP_SPACE_INDEPENDENT FALSE
    DEACTIVATE_SELF

.spawn_harris:
    SPAWN_EXECUTOR 14, .executor_14_harris
    RETURN_FROM_SUBROUTINE

.spawn_gray:
    SPAWN_EXECUTOR 15, .executor_15_gray
    RETURN_FROM_SUBROUTINE

.spawn_jeff:
    SPAWN_EXECUTOR 16, .executor_16_jeff
    RETURN_FROM_SUBROUTINE

.spawn_cliff:
    SPAWN_EXECUTOR 17, .executor_17_cliff
    RETURN_FROM_SUBROUTINE

.spawn_kai:
    SPAWN_EXECUTOR 18, .executor_18_kai
    RETURN_FROM_SUBROUTINE

; ============================================================
; SHARED HELPERS -- drink-glass overlays
; ============================================================

; Player-side drink glass (one-off, deactivates after 16 frames)
.setup_player_drink_glass:
    SETUP_ENTITY 22, ENTITY_ASSET_STATIC_ITEM, 1
    SET_ENTITY_ANIMATIONS 22, 0, 0, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_ANIMATION 109
    RETURN_FROM_SUBROUTINE

; NPC-side drink glass (sustained, one per NPC toast)
.setup_npc_drink_glass:
    SETUP_ENTITY 23, ENTITY_ASSET_STATIC_ITEM, 1
    SET_ENTITY_ANIMATIONS 23, 0, 0, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_ANIMATION 109
    RETURN_FROM_SUBROUTINE

.executor_19_player_glass:
    EXECUTE_SUBROUTINE .setup_player_drink_glass
    SET_ENTITY_TRACKING_TARGET 0, 0, 14, 20, 255
    SET_WAIT_FRAMES 16
    DEACTIVATE_SELF

; ----- Per-NPC tracking overlays (executor slot 20, re-spawned per toast) -----

.executor_20_mayor_glass:
    EXECUTE_SUBROUTINE .setup_npc_drink_glass
    SET_ENTITY_TRACKING_TARGET 1, 0, 14, 8, 6
    EXECUTE_SUBROUTINE .wait_loop

.executor_20_mayor_wife_glass:
    EXECUTE_SUBROUTINE .setup_npc_drink_glass
    SET_ENTITY_TRACKING_TARGET 2, 0, 14, 8, 6
    EXECUTE_SUBROUTINE .wait_loop

.executor_20_maria_glass:
    EXECUTE_SUBROUTINE .setup_npc_drink_glass
    SET_ENTITY_TRACKING_TARGET 3, 0, 14, 8, 6
    SET_WAIT_FRAMES 3
    SET_ENTITY_TRACKING_TARGET 3, 0, 16, 8, 6
    EXECUTE_SUBROUTINE .wait_loop

.executor_20_rick_glass:
    EXECUTE_SUBROUTINE .setup_npc_drink_glass
    SET_ENTITY_TRACKING_TARGET 4, 0, 14, 8, 6
    EXECUTE_SUBROUTINE .wait_loop

.executor_20_potion_shop_glass:
    EXECUTE_SUBROUTINE .setup_npc_drink_glass
    SET_ENTITY_TRACKING_TARGET 5, 0, 14, 8, 6
    EXECUTE_SUBROUTINE .wait_loop

.executor_20_midwife_glass:
    EXECUTE_SUBROUTINE .setup_npc_drink_glass
    SET_ENTITY_TRACKING_TARGET 6, 0, 14, 8, 6
    EXECUTE_SUBROUTINE .wait_loop

.executor_20_popuri_glass:
    EXECUTE_SUBROUTINE .setup_npc_drink_glass
    SET_ENTITY_TRACKING_TARGET 7, 0, 14, 8, 6
    SET_WAIT_FRAMES 3
    SET_ENTITY_TRACKING_TARGET 7, 0, 16, 8, 6
    EXECUTE_SUBROUTINE .wait_loop

.executor_20_lillia_glass:
    EXECUTE_SUBROUTINE .setup_npc_drink_glass
    SET_ENTITY_TRACKING_TARGET 8, 0, 14, 8, 6
    EXECUTE_SUBROUTINE .wait_loop

.executor_20_elli_glass:
    EXECUTE_SUBROUTINE .setup_npc_drink_glass
    SET_ENTITY_TRACKING_TARGET 9, 0, 14, 8, 6
    SET_WAIT_FRAMES 3
    SET_ENTITY_TRACKING_TARGET 9, 0, 16, 8, 6
    EXECUTE_SUBROUTINE .wait_loop

.executor_20_ann_glass:
    EXECUTE_SUBROUTINE .setup_npc_drink_glass
    SET_ENTITY_TRACKING_TARGET 10, 0, 14, 8, 6
    EXECUTE_SUBROUTINE .wait_loop

.executor_20_karen_glass:
    EXECUTE_SUBROUTINE .setup_npc_drink_glass
    SET_ENTITY_TRACKING_TARGET 11, 0, 14, 8, 6
    EXECUTE_SUBROUTINE .wait_loop

.executor_20_harris_glass:
    EXECUTE_SUBROUTINE .setup_npc_drink_glass
    SET_ENTITY_TRACKING_TARGET 14, 0, 14, 8, 6
    EXECUTE_SUBROUTINE .wait_loop

.executor_20_gray_glass:
    EXECUTE_SUBROUTINE .setup_npc_drink_glass
    SET_ENTITY_TRACKING_TARGET 15, -8, 14, 20, 3
    EXECUTE_SUBROUTINE .wait_loop

.executor_20_jeff_glass:
    EXECUTE_SUBROUTINE .setup_npc_drink_glass
    SET_ENTITY_TRACKING_TARGET 16, 0, 14, 8, 6
    EXECUTE_SUBROUTINE .wait_loop

.executor_20_cliff_glass:
    EXECUTE_SUBROUTINE .setup_npc_drink_glass
    SET_ENTITY_TRACKING_TARGET 17, 0, 14, 8, 6
    EXECUTE_SUBROUTINE .wait_loop

.executor_20_kai_glass:
    EXECUTE_SUBROUTINE .setup_npc_drink_glass
    SET_ENTITY_TRACKING_TARGET 18, 0, 14, 8, 6
    EXECUTE_SUBROUTINE .wait_loop

; ============================================================
; Executor 0 -- player drink reaction / pass-out
; ============================================================
; Plays anim 438 if gAlcoholTolerance > 0 (and decrements it);
; otherwise plays anim 691, fades to black, tears down every
; attendee executor, shows the pass-out message, and ends the
; cutscene.

.executor_0_player_drink:
    EXECUTE_SUBROUTINE .setup_player
    SET_ASSET_ROTATION 0
    SPAWN_EXECUTOR 19, .executor_19_player_glass
    SET_ENTITY_DIRECTIONAL_ANIMATION 24
    SET_WAIT_FRAMES 16
    BRANCH_U8_VAR_WITHIN_RANGE 0, 0, gAlcoholTolerance, .player_passed_out
    SET_ENTITY_ANIMATION 438
    WAIT_ENTITY_ANIMATION
    SET_WAIT_FRAMES 10
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    UPDATE_U8_VALUE -1, 255, gAlcoholTolerance
    SET_ENTITY_MAP_SPACE_INDEPENDENT FALSE
    DEACTIVATE_SELF

.player_passed_out:
    SET_ENTITY_ANIMATION 691
    WAIT_ENTITY_ANIMATION
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    SET_WAIT_FRAMES 10
    DEACTIVATE_EXECUTOR 1
    DEACTIVATE_EXECUTOR 2
    DEACTIVATE_EXECUTOR 3
    DEACTIVATE_EXECUTOR 4
    DEACTIVATE_EXECUTOR 5
    DEACTIVATE_EXECUTOR 6
    DEACTIVATE_EXECUTOR 7
    DEACTIVATE_EXECUTOR 8
    DEACTIVATE_EXECUTOR 9
    DEACTIVATE_EXECUTOR 10
    DEACTIVATE_EXECUTOR 11
    DEACTIVATE_EXECUTOR 12
    DEACTIVATE_EXECUTOR 13
    DEACTIVATE_EXECUTOR 14
    DEACTIVATE_EXECUTOR 15
    DEACTIVATE_EXECUTOR 16
    DEACTIVATE_EXECUTOR 17
    DEACTIVATE_EXECUTOR 18
    INIT_MESSAGE_BOX_TYPE1 0, NEW_YEAR_FESTIVAL_TEXT_INDEX, 46
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_AUDIO_SEQUENCE_VOLUME 0, 0, 4
    SET_WAIT_FRAMES 32
    STOP_SEQUENCE_WITH_FADE 0, 1
    IDLE_WHILE_SEQUENCE_PLAYING 0
    EXECUTE_SUBROUTINE .end_festival

; ============================================================
; Executor 1 -- Mayor
; ============================================================

.executor_1_mayor:
    SETUP_ENTITY 1, ENTITY_ASSET_MAYOR, 1
    SET_ENTITY_ANIMATIONS 1, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    SET_COORDINATES -176, 0, -32
    SET_ASSET_ROTATION 6
    SET_CALLBACK_ROUTINE 0, 32768, .mayor_talk_happy_new_year
    EXECUTE_SUBROUTINE .wait_loop

.mayor_toast_anim:
    UPDATE_U8_VALUE 2, 255, npcAffection[NPC_MAYOR]
    SPAWN_EXECUTOR 0, .executor_0_player_drink
    SPAWN_EXECUTOR 20, .executor_20_mayor_glass
    SET_ENTITY_ANIMATION 22
    WAIT_ENTITY_ANIMATION
    SET_WAIT_FRAMES 30
    DEACTIVATE_EXECUTOR 20
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    RETURN_FROM_SUBROUTINE

.mayor_talk_happy_new_year:
    PAUSE_ENTITY 0
    FLIP_ENTITY_DIRECTION 0
    EXECUTE_SUBROUTINE .setup_message_box
    INIT_MESSAGE_BOX_TYPE1 0, NEW_YEAR_FESTIVAL_TEXT_INDEX, 0
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    EXECUTE_SUBROUTINE .mayor_toast_anim
    SET_CALLBACK_ROUTINE 0, 32768, .mayor_talk_mayor_duty
    TOGGLE_PAUSE_ENTITY 0
    EXECUTE_SUBROUTINE .wait_loop

.mayor_talk_mayor_duty:
    PAUSE_ENTITY 0
    FLIP_ENTITY_DIRECTION 0
    EXECUTE_SUBROUTINE .setup_message_box
    INIT_MESSAGE_BOX_TYPE1 0, NEW_YEAR_FESTIVAL_TEXT_INDEX, 1
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    EXECUTE_SUBROUTINE .mayor_toast_anim
    SET_CALLBACK_ROUTINE 0, 32768, .mayor_talk_cant_drink
    TOGGLE_PAUSE_ENTITY 0
    EXECUTE_SUBROUTINE .wait_loop

.mayor_talk_cant_drink:
    UPDATE_U8_VALUE 2, 255, npcAffection[NPC_MAYOR]
    PAUSE_ENTITY 0
    FLIP_ENTITY_DIRECTION 0
    EXECUTE_SUBROUTINE .setup_message_box
    INIT_MESSAGE_BOX_TYPE1 0, NEW_YEAR_FESTIVAL_TEXT_INDEX, 2
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    EXECUTE_SUBROUTINE .mayor_walk_off

.mayor_walk_off:
    ENTITY_WALK 130, DIRECTION_E, 2
    TOGGLE_PAUSE_ENTITY 0
    DEACTIVATE_SELF

; ============================================================
