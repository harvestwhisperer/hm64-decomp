    SETUP_ENTITY 6, ENTITY_ASSET_MIDWIFE, 1
    SET_ENTITY_ANIMATIONS 6, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    SET_ASSET_ROTATION 3
    SET_COORDINATES 64, 0, -224
    SET_CALLBACK_ROUTINE 0, 32768, .midwife_talk_young_adults
