; ============================================================
; Executor 12 -- Assistant Carpenter (goodbye prompt)
; ============================================================
; Runs a Yes/No dialogue (session DIALOGUE_NEW_YEAR_FESTIVAL):
;   Yes -> shows text 50, fades out, tears down every attendee,
;          stops the music, and ends the festival.
;   No  -> shows text 51 ("drink up") and returns to the wait
;          state so the player can keep toasting.
; The slot-12 entity is also driven by SET_OTHER_EXECUTOR_PTR
; from neighboring NPCs via .assistant_carpenter_walk_west /
; .assistant_carpenter_walk_east below, which briefly move him
; out and back.

.executor_12_assistant_carpenter:
    SETUP_ENTITY 12, ENTITY_ASSET_ASSISTANT_CARPENTER, 1
    SET_ENTITY_ANIMATIONS 12, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    SET_ENTITY_NON_COLLIDABLE
    SET_COORDINATES 192, 0, -144

.assistant_carpenter_wait:
    SET_ASSET_ROTATION 2
    SET_CALLBACK_ROUTINE 0, 32768, .assistant_carpenter_on_interact
    EXECUTE_SUBROUTINE .wait_loop

.assistant_carpenter_walk_west:
    ENTITY_WALK 32, DIRECTION_SW, 2
    SET_ASSET_ROTATION 4
    EXECUTE_SUBROUTINE .wait_loop

.assistant_carpenter_walk_east:
    ENTITY_WALK 32, DIRECTION_NE, 2
    SET_ASSET_ROTATION 2
    TOGGLE_PAUSE_ENTITY 0
    EXECUTE_SUBROUTINE .wait_loop

.assistant_carpenter_on_interact:
    EXECUTE_SUBROUTINE .setup_message_box
    BRANCH_ON_SPECIAL_BIT 0, var0, .assistant_carpenter_talk
    UPDATE_U8_VALUE 2, 255, npcAffection[NPC_CARPENTER_1]
    SET_SPECIAL_BIT 0, var0

.assistant_carpenter_talk:
    PAUSE_ENTITY 0
    FLIP_ENTITY_DIRECTION 0
    INIT_DIALOGUE_SESSION 0, DIALOGUE_NEW_YEAR_FESTIVAL, 0
    WAIT_FOR_DIALOGUE_INPUT 0
    BRANCH_ON_DIALOGUE 0, 0, .assistant_carpenter_goodbye
    BRANCH_ON_DIALOGUE 0, 1, .assistant_carpenter_drink_up

.assistant_carpenter_goodbye:
    INIT_MESSAGE_BOX_TYPE1 0, NEW_YEAR_FESTIVAL_TEXT_INDEX, 50
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_AUDIO_SEQUENCE_VOLUME 0, 0, 2
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    DEACTIVATE_EXECUTOR 1
    DEACTIVATE_EXECUTOR 2
    DEACTIVATE_EXECUTOR 3
    DEACTIVATE_EXECUTOR 4
    DEACTIVATE_EXECUTOR 5
    DEACTIVATE_EXECUTOR 6
    DEACTIVATE_EXECUTOR 7
    DEACTIVATE_EXECUTOR 8
    DEACTIVATE_EXECUTOR 9
    DEACTIVATE_EXECUTOR 10
    DEACTIVATE_EXECUTOR 11
    DEACTIVATE_EXECUTOR 13
    DEACTIVATE_EXECUTOR 14
    DEACTIVATE_EXECUTOR 15
    DEACTIVATE_EXECUTOR 16
    DEACTIVATE_EXECUTOR 17
    DEACTIVATE_EXECUTOR 18
    STOP_SEQUENCE_WITH_FADE 0, 1
    IDLE_WHILE_SEQUENCE_PLAYING 0
    EXECUTE_SUBROUTINE .end_festival

.assistant_carpenter_drink_up:
    INIT_MESSAGE_BOX_TYPE1 0, NEW_YEAR_FESTIVAL_TEXT_INDEX, 51
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITY 0
    EXECUTE_SUBROUTINE .assistant_carpenter_wait

; ============================================================
; Executor 13 -- Shipper
