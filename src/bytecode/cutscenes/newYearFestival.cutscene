    SET_ENTITY_ANIMATIONS 2, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    SET_COORDINATES -112, 0, 48
    SET_ASSET_ROTATION 7
    SET_CALLBACK_ROUTINE 0, 32768, .mayor_wife_talk_ho_ho
