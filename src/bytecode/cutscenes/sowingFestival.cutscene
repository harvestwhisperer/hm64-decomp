    BRANCH_ON_SPECIAL_BIT 16, var1, .cs851_cliff_dialogue
    UPDATE_U8_VALUE 2, 255, npcAffection[CLIFF]
    SET_SPECIAL_BIT 16, var1

.cs851_cliff_dialogue:
    PAUSE_ENTITY 0
    FLIP_ENTITY_DIRECTION 0
    INIT_DIALOGUE_SESSION 0, DIALOGUE_TEXT_55, 11
    WAIT_FOR_DIALOGUE_INPUT 0
    BRANCH_ON_DIALOGUE 0, 0, .cs851_cliff_accept
    BRANCH_ON_DIALOGUE 0, 1, .cs851_cliff_decline

.cs851_cliff_accept:
    SET_SPECIAL_BIT 8, var0
    INIT_MESSAGE_BOX_TYPE1 0, SOWING_FESTIVAL_TEXT_INDEX, 73
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    UPDATE_U8_VALUE 8, 255, npcAffection[CLIFF]
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    DEACTIVATE_EXECUTOR 37
    SET_WAIT_FRAMES 1
    SPAWN_EXECUTOR 37, .cs851_cliff_in_balloon
    DEACTIVATE_SELF

.cs851_cliff_decline:
    TOGGLE_PAUSE_ENTITY 0
    EXECUTE_SUBROUTINE .cs851_cliff_wait

.cs851_cliff_in_balloon:
    SET_WAIT_FRAMES 1
    SET_SHADOW_FLAGS 10, 255
    EXECUTE_SUBROUTINE .setup_cliff
    EXECUTE_SUBROUTINE .cs851_ascent_start

.cs851_kai:
    EXECUTE_SUBROUTINE .setup_kai
    SET_ENTITY_NON_COLLIDABLE
    SET_COORDINATES 96, 0, -224

.cs851_kai_wait:
