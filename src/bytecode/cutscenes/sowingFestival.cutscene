; ============================================
; Bank 18 - Sowing Festival
; ============================================
;
; Cutscene indices (dispatched by gCutsceneIndex):
;   850 (SOWING_FESTIVAL_POTION_SHOP_DEALER) -> .cs_potion_shop_king
;        King is the Potion Shop Dealer, asks Kent to be assistant.
;   851 (SOWING_FESTIVAL_PLAYER)             -> .cs_player_king
;        Player is the King and must pick an assistant via
;        yes/no dialogue on each eligible NPC.
;   852 (SOWING_FESTIVAL_BACHELOR)             -> .cs_bachelor_king
;        King is a bachelor (Harris/Gray/Jeff/Cliff/Kai, selected
;        via gHarvestKing 1..5). Can ask player to be assistant.
;
; gHarvestKing values (source: src/game/cutscenes.c):
;   0 = PLAYER, 1 = HARRIS, 2 = GRAY, 3 = JEFF, 4 = CLIFF, 5 = KAI
;   other (including default in cs 850) = Potion Shop Dealer
;
; var0 bits (cs 851 tracks which NPC accepted, drives balloon
;            ascent dispatch at .king_balloon_anchor):
;   0  - Maria accepted
;   1  - Popuri accepted
;   2  - Elli accepted
;   3  - Ann accepted
;   4  - Karen accepted
;   5  - Harris accepted
;   6  - Gray accepted
;   7  - Jeff accepted
;   8  - Cliff accepted
;   9  - Kai accepted
;   10 - Stu accepted
;   11 - May accepted
;
; var1 bits: per-NPC "affection already bumped this festival"
;            flags (set after the first interaction so repeat
;            talks do not keep adding affection).
;
; Executor slot usage:
;   0      - player
;   1..20  - villager NPCs (slot layout varies per cutscene
;            variant; see the SPAWN_EXECUTOR lists at each
;            .cs_* entry point)
;   21     - "King" avatar / balloon-lift controller
;   22..40 - balloon / sparkle / misc static items
;   41     - sequence-timing controller (announcer, fade-out)

#include "entities.h"
#include "texts.h"
#include "dialogues.h"

#define MAIN_MAP_INDEX 0
#define MARRIED 0

; gHarvestKing values (see cutscenes.c)
#define KING_PLAYER 0
#define KING_HARRIS 1
#define KING_GRAY 2
#define KING_JEFF 3
#define KING_CLIFF 4
#define KING_KAI 5

.buffer 2

; Local variables
.var var0, u32
.var var1, u32

.array npcAffection, u8
.array lifeEventBits, u32
.array dailyEventBits, u32

.dispatch:
    SET_SPECIAL_BIT 31, gCutsceneCompletionFlags
    SET_SPECIAL_BIT 12, gCutsceneCompletionFlags
    SET_SPECIAL_BIT 13, gCutsceneCompletionFlags
    SET_SPECIAL_BIT 14, gCutsceneCompletionFlags
    SET_SPECIAL_BIT 15, gCutsceneCompletionFlags
    PAUSE_ENTITIES
    STOP_SEQUENCE_WITH_FADE 0, 8
    IDLE_WHILE_SEQUENCE_PLAYING 0
    SET_AUDIO_SEQUENCE 0, _namingScreenSegmentRomStart, _namingScreenSegmentRomEnd
    SET_AUDIO_SEQUENCE_VOLUME 0, 128, 8
    UPDATE_U8_VALUE 5, 255, gHappiness
    TOGGLE_PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .setup_message_box
    INIT_MAP_ADDITION 1, 0
    INIT_MAP_ADDITION 2, 0
    BRANCH_U16_VAR_WITHIN_RANGE 850, 850, gCutsceneIndex, .cs_potion_shop_king
    BRANCH_U16_VAR_WITHIN_RANGE 851, 851, gCutsceneIndex, .cs_player_king
    BRANCH_U16_VAR_WITHIN_RANGE 852, 852, gCutsceneIndex, .cs_bachelor_king

; ============================================================
; SHARED HELPERS
; ============================================================

.exit_cutscene:
    SET_U32_VALUE 0, var0
    SET_SPECIAL_BIT 0, gCutsceneCompletionFlags
    DEACTIVATE_SELF

.wait_loop:
    SET_WAIT_FRAMES 1
    EXECUTE_SUBROUTINE .wait_loop

.setup_message_box:
    SET_MESSAGE_INTERPOLATION -4, 0, 0
    SET_MESSAGE_BOX_ASSETS 0, 0, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 24, -64, 352
    RETURN_FROM_SUBROUTINE

.setup_player:
    SETUP_ENTITY 0, ENTITY_ASSET_PLAYER, 1
    SET_ENTITY_ANIMATIONS 0, 0, 8, 16, 24, 32, 40
    SET_BEHAVIOR_FLAGS CUTSCENE_ASSET_BEHAVIOR_TRACK_ENTITY
    RETURN_FROM_SUBROUTINE

.track_entity_done:
    SET_BEHAVIOR_FLAGS CUTSCENE_ASSET_BEHAVIOR_TRACK_ENTITY
    SET_WAIT_FRAMES 1
    SET_ENTITY_MAP_SPACE_INDEPENDENT FALSE
    DEACTIVATE_SELF

.face_northwest:
    SET_ASSET_ROTATION 2
    EXECUTE_SUBROUTINE .wait_loop

.face_southwest:
    SET_ASSET_ROTATION 0
    EXECUTE_SUBROUTINE .wait_loop

.face_southeast:
    SET_ASSET_ROTATION 6
    EXECUTE_SUBROUTINE .wait_loop

.face_west:
    SET_ASSET_ROTATION 1
    EXECUTE_SUBROUTINE .wait_loop

.face_south:
    SET_ASSET_ROTATION 7
    EXECUTE_SUBROUTINE .wait_loop

.face_north:
    SET_ASSET_ROTATION 3
    EXECUTE_SUBROUTINE .wait_loop

.face_east:
    SET_ASSET_ROTATION 5
    EXECUTE_SUBROUTINE .wait_loop

; ============================================================
; Cutscene 850 - SOWING_FESTIVAL_POTION_SHOP_DEALER
; King is the Potion Shop Dealer. He hands the task to Kent,
; villagers gather and watch the balloons go up.
; ============================================================

.cs_potion_shop_king:
    SPAWN_EXECUTOR 1, .cs850_mayor
    SPAWN_EXECUTOR 2, .cs850_mayor_wife
    SPAWN_EXECUTOR 3, .cs850_ann
    SPAWN_EXECUTOR 4, .cs850_maria
    SPAWN_EXECUTOR 5, .cs850_lillia
    SPAWN_EXECUTOR 6, .cs850_potion_shop_dealer
    SPAWN_EXECUTOR 7, .cs850_kent
    SPAWN_EXECUTOR 8, .cs850_stu
    SPAWN_EXECUTOR 9, .cs850_may
    SPAWN_EXECUTOR 10, .cs850_popuri
    SPAWN_EXECUTOR 11, .cs850_elli
    SPAWN_EXECUTOR 12, .cs850_rick
    SPAWN_EXECUTOR 13, .cs850_pastor
    BRANCH_ON_SPECIAL_BIT 13, lifeEventBits[1], .cs850_spawn_festival_items
    BRANCH_U8_VAR_WITHIN_RANGE 100, 255, npcAffection[CLIFF], .spawn_cliff_assistant

; ----- Post-dispatch: festival items + king + player -----
; Reached when either lifeEventBits[1].13 is set OR Cliff is low-affection
; (cs850 only). Otherwise `.spawn_cliff_assistant` short-circuits and
; returns before executor 21 (the King) is ever spawned.

.cs850_spawn_festival_items:
    SPAWN_EXECUTOR 22, .sparkle_static_22
    SPAWN_EXECUTOR 23, .sparkle_static_23
    SPAWN_EXECUTOR 24, .sparkle_static_24
    SPAWN_EXECUTOR 27, .sparkle_static_27
    SPAWN_EXECUTOR 29, .sparkle_static_29
    SPAWN_EXECUTOR 30, .sparkle_static_30
    SPAWN_EXECUTOR 31, .sparkle_static_31
    SPAWN_EXECUTOR 32, .sparkle_static_32
    SPAWN_EXECUTOR 33, .sparkle_static_33
    SPAWN_EXECUTOR 35, .festival_item_overlay
    SPAWN_EXECUTOR 36, .king_balloon_sprite
    SPAWN_EXECUTOR 21, .cs850_king_intro
    EXECUTE_SUBROUTINE .spawn_player_as_kingr

; ----- Conditional assistant-spawn helpers (cs850 + cs852 shared) -----
; Called when an NPC with affection >= 100 is eligible to be the King
; helper. The second SPAWN_EXECUTOR attaches a tracked sparkle to the
; NPC. Shared between the potion-shop-king dispatch, the bachelor-king
; dispatch, and the King runtime `.cs850_king_dispatch_assistant`.

.spawn_harris_assistant:
    SPAWN_EXECUTOR 14, .cs850_harris
    SET_WAIT_FRAMES 1
    SPAWN_EXECUTOR 34, .sparkle_static_34
    RETURN_FROM_SUBROUTINE

.spawn_gray_assistant:
    SPAWN_EXECUTOR 15, .cs850_gray
    SET_WAIT_FRAMES 1
    SPAWN_EXECUTOR 35, .sparkle_static_35
    RETURN_FROM_SUBROUTINE

.spawn_jeff_assistant:
    SPAWN_EXECUTOR 16, .cs850_jeff
    SET_WAIT_FRAMES 1
    SPAWN_EXECUTOR 36, .sparkle_static_36
    RETURN_FROM_SUBROUTINE

.spawn_cliff_assistant:
    SPAWN_EXECUTOR 17, .cs850_cliff
    SPAWN_EXECUTOR 37, .sparkle_static_37
    RETURN_FROM_SUBROUTINE

.spawn_kai_assistant:
    SPAWN_EXECUTOR 18, .cs850_kai
    SET_WAIT_FRAMES 1
    SPAWN_EXECUTOR 38, .sparkle_static_38
    RETURN_FROM_SUBROUTINE

.spawn_karen_assistant:
    SPAWN_EXECUTOR 19, .cs850_karen
    SET_WAIT_FRAMES 1
    SPAWN_EXECUTOR 39, .sparkle_static_39
    RETURN_FROM_SUBROUTINE

.spawn_basil_assistant:
    SPAWN_EXECUTOR 20, .cs850_basil
    SET_WAIT_FRAMES 1
    RETURN_FROM_SUBROUTINE

; ----- cs850 King (executor slot 21) -----
; Potion Shop Dealer opens with texts 0..5, hands the job to Kent
; (FLIP executors 6/8 to walk-west + helper spawns), then kicks off the
; balloon lift. After lift, `.cs850_king_dispatch_assistant` runs its
; affection fan-out to pick an NPC to ride along.

.cs850_king_intro:
    SETUP_MAP_ASSET MAIN_MAP_INDEX
    SET_ASSET_ROTATION 7
    SET_COORDINATES -72, 96, -16
    SET_WAIT_FRAMES 1
    UPDATE_GLOBAL_RGBA 255, 255, 255, 255, 8
    WAIT_RGBA_FINISHED
    SET_WAIT_FRAMES 15
    INIT_MESSAGE_BOX_TYPE1 0, SOWING_FESTIVAL_TEXT_INDEX, 0
    WAIT_MESSAGE_BOX_CLOSED 0
    SET_OTHER_EXECUTOR_PTR 6, .face_northwest
    INIT_MESSAGE_BOX_TYPE1 0, SOWING_FESTIVAL_TEXT_INDEX, 1
    WAIT_MESSAGE_BOX_CLOSED 0
    INIT_MESSAGE_BOX_TYPE1 0, SOWING_FESTIVAL_TEXT_INDEX, 2
    WAIT_MESSAGE_BOX_CLOSED 0
    INIT_MESSAGE_BOX_TYPE1 0, SOWING_FESTIVAL_TEXT_INDEX, 3
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 0, .face_north
    SET_OTHER_EXECUTOR_PTR 6, .face_east
    SET_WAIT_FRAMES 30
    SET_OTHER_EXECUTOR_PTR 8, .face_north
    INIT_MESSAGE_BOX_TYPE1 0, SOWING_FESTIVAL_TEXT_INDEX, 4
    WAIT_MESSAGE_BOX_CLOSED 0
    SET_OTHER_EXECUTOR_PTR 7, .face_south
    INIT_MESSAGE_BOX_TYPE1 0, SOWING_FESTIVAL_TEXT_INDEX, 5
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 0, .face_west
    SET_OTHER_EXECUTOR_PTR 7, .face_southwest
    SET_OTHER_EXECUTOR_PTR 6, .cs850_kent_walk_west
    SET_OTHER_EXECUTOR_PTR 8, .cs850_stu_walk_west
    SET_FRAME_DELTA -1, 0, 1, 56
    EXECUTE_SUBROUTINE .wait_loop

.cs850_king_dispatch_assistant:
    SET_WAIT_FRAMES 2
    BRANCH_U8_VAR_WITHIN_RANGE 100, 255, npcAffection[HARRIS], .spawn_harris_assistant
    BRANCH_U8_VAR_WITHIN_RANGE 100, 255, npcAffection[GRAY], .spawn_gray_assistant
    BRANCH_U8_VAR_WITHIN_RANGE 100, 255, npcAffection[JEFF], .spawn_jeff_assistant
    BRANCH_ON_SPECIAL_BIT 14, lifeEventBits[1], .cs850_king_check_karen
    BRANCH_U8_VAR_WITHIN_RANGE 100, 255, npcAffection[KAI], .spawn_kai_assistant

.cs850_king_check_karen:
    BRANCH_ON_SPECIAL_BIT 15, lifeEventBits[1], .cs850_king_check_basil
    BRANCH_U8_VAR_WITHIN_RANGE 100, 255, npcAffection[KAREN], .spawn_karen_assistant

.cs850_king_check_basil:
    BRANCH_ON_SPECIAL_BIT 12, lifeEventBits[1], .cs850_king_no_assistant
    BRANCH_U8_VAR_WITHIN_RANGE 100, 255, npcAffection[NPC_BASIL], .spawn_basil_assistant

.cs850_king_no_assistant:
    SET_WAIT_FRAMES 2
    SET_FRAME_DELTA 1, 0, -1, 48
    SET_FRAME_DELTA 1, 0, 0, 48
    SET_OTHER_EXECUTOR_PTR 0, .track_entity_done
    EXECUTE_SUBROUTINE .wait_loop

.cs850_kent_walk_west:
    SET_ENTITY_PHYSICS_FLAGS 0
    ENTITY_WALK 56, DIRECTION_SW, 2
    SPAWN_EXECUTOR 18, .cs850_entity18_helper_spawn
    DEACTIVATE_SELF

.cs850_entity18_helper_spawn:
    SET_SHADOW_FLAGS 20, 255
    SETUP_ENTITY 18, 20, 1
    SET_ENTITY_ANIMATIONS 18, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_PHYSICS_FLAGS 0
    SET_ASSET_ROTATION 0
    SET_COORDINATES -176, 96, 48
    SET_OTHER_EXECUTOR_PTR 1, .face_southwest
    SET_WAIT_FRAMES 30
    SET_ASSET_ROTATION 5
    SET_WAIT_FRAMES 30
    SET_OTHER_EXECUTOR_PTR 19, .face_west
    SET_WAIT_FRAMES 30
    SET_ASSET_ROTATION 0
    SET_WAIT_FRAMES 30
    SET_OTHER_EXECUTOR_PTR 19, .face_southeast
    SET_WAIT_FRAMES 30
    INIT_MESSAGE_BOX_TYPE1 0, SOWING_FESTIVAL_TEXT_INDEX, 6
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_WAIT_FRAMES 30
    SET_OTHER_EXECUTOR_PTR 19, .cs850_king_trigger_lift
    SET_OTHER_EXECUTOR_PTR 35, .cs850_helper_rise_delta
    SET_OTHER_EXECUTOR_PTR 36, .cs850_helper_rise_delta
    EXECUTE_SUBROUTINE .cs850_helper_rise_delta

.cs850_stu_walk_west:
    SET_ENTITY_PHYSICS_FLAGS 0
    ENTITY_WALK 68, DIRECTION_SW, 2
    SPAWN_EXECUTOR 19, .cs850_entity19_helper_spawn
    DEACTIVATE_SELF

.cs850_entity19_helper_spawn:
    SET_SHADOW_FLAGS 22, 255
    SETUP_ENTITY 19, 22, 1
    SET_ENTITY_ANIMATIONS 19, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_PHYSICS_FLAGS 0
    SET_COORDINATES -160, 96, 32
    SET_ASSET_ROTATION 6
    EXECUTE_SUBROUTINE .wait_loop

.cs850_helper_rise_delta:
    SET_FRAME_DELTA 0, 1, 1, 40
    SET_FRAME_DELTA 0, 2, 1, 200
    DEACTIVATE_SELF

.cs850_king_trigger_lift:
    SET_FRAME_DELTA 0, 1, 1, 40
    SET_ENTITY_ANIMATION 35
    SET_OTHER_EXECUTOR_PTR 0, .cs850_player_lift_anim
    SET_OTHER_EXECUTOR_PTR 7, .cs850_kent_lift_anim
    SET_FRAME_DELTA 0, 2, 1, 22
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SET_FRAME_DELTA 0, 2, 1, 1
    SET_ENTITY_ANIMATION 35
    SET_FRAME_DELTA 0, 2, 1, 177
    SET_OTHER_EXECUTOR_PTR 21, .cs850_king_dispatch_assistant
    DEACTIVATE_SELF

.cs850_player_lift_anim:
    SET_ASSET_ROTATION 0
    SET_ENTITY_DIRECTIONAL_ANIMATION 456
    SET_WAIT_FRAMES 32
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    EXECUTE_SUBROUTINE .wait_loop

.cs850_kent_lift_anim:
    SET_ENTITY_ANIMATION 24
    SET_WAIT_FRAMES 40
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    EXECUTE_SUBROUTINE .wait_loop

.spawn_player_as_kingr:
    EXECUTE_SUBROUTINE .setup_player
    SET_BEHAVIOR_FLAGS 0
    SET_COORDINATES -32, 0, -8
    SET_ASSET_ROTATION 2
    EXECUTE_SUBROUTINE .wait_loop

; ----- cs850 Villagers (executor slots 1..20) -----
; Each villager executor follows the same shape:
;   `<npc>_wait`          - idle + callback registration
;   `<npc>_on_interact`   - paused message box + affection bump
; NPCs whose bytecode has a dialogue branch (Ann, Maria, Popuri, Elli,
; Karen) get additional `_married_guard` / `_spouse_talk` labels for
; the post-marriage spouse-specific line.

.setup_mayor:
    SETUP_ENTITY 1, ENTITY_ASSET_MAYOR, 1
    SET_ENTITY_ANIMATIONS 1, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    RETURN_FROM_SUBROUTINE

.cs850_mayor:
    EXECUTE_SUBROUTINE .setup_mayor
    SET_COORDINATES -144, 0, -48

.cs850_mayor_wait:
    SET_ASSET_ROTATION 7
    SET_CALLBACK_ROUTINE 0, 32768, .cs850_mayor_on_interact
    EXECUTE_SUBROUTINE .wait_loop

.cs850_mayor_on_interact:
    EXECUTE_SUBROUTINE .setup_message_box
    PAUSE_ENTITY 0
    FLIP_ENTITY_DIRECTION 0
    INIT_MESSAGE_BOX_TYPE1 0, SOWING_FESTIVAL_TEXT_INDEX, 7
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITY 0
    BRANCH_ON_SPECIAL_BIT 0, var1, .cs850_mayor_wait
    UPDATE_U8_VALUE 2, 255, npcAffection[NPC_MAYOR]
    SET_SPECIAL_BIT 0, var1
    EXECUTE_SUBROUTINE .cs850_mayor_wait

.setup_mayor_wife:
    SETUP_ENTITY 2, ENTITY_ASSET_MAYOR_WIFE, 1
    SET_ENTITY_ANIMATIONS 2, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    RETURN_FROM_SUBROUTINE

.cs850_mayor_wife:
    EXECUTE_SUBROUTINE .setup_mayor_wife
    SET_COORDINATES -192, 0, -128

.cs850_mayor_wife_wait:
    SET_ASSET_ROTATION 0
    SET_CALLBACK_ROUTINE 0, 32768, .cs850_mayor_wife_on_interact
    EXECUTE_SUBROUTINE .wait_loop

.cs850_mayor_wife_on_interact:
    EXECUTE_SUBROUTINE .setup_message_box
    PAUSE_ENTITY 0
    FLIP_ENTITY_DIRECTION 0
    INIT_MESSAGE_BOX_TYPE1 0, SOWING_FESTIVAL_TEXT_INDEX, 10
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITY 0
    BRANCH_ON_SPECIAL_BIT 1, var1, .cs850_mayor_wife_wait
    UPDATE_U8_VALUE 2, 255, npcAffection[NPC_MAYOR_WIFE]
    SET_SPECIAL_BIT 1, var1
    EXECUTE_SUBROUTINE .cs850_mayor_wife_wait

.setup_ann:
    SETUP_ENTITY 3, ENTITY_ASSET_ANN, 1
    SET_ENTITY_ANIMATIONS 3, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    RETURN_FROM_SUBROUTINE

.cs850_ann:
    EXECUTE_SUBROUTINE .setup_ann
    SET_COORDINATES -96, 0, -160

.cs850_ann_wait:
    SET_ASSET_ROTATION 0
    SET_CALLBACK_ROUTINE 0, 32768, .cs850_ann_on_interact
    EXECUTE_SUBROUTINE .wait_loop

.cs850_ann_on_interact:
    EXECUTE_SUBROUTINE .setup_message_box
    PAUSE_ENTITY 0
    FLIP_ENTITY_DIRECTION 0
    BRANCH_ON_SPECIAL_BIT MARRIED, lifeEventBits[0], .cs850_ann_married_guard
    INIT_DIALOGUE_SESSION 0, DIALOGUE_TEXT_55, 1
    WAIT_FOR_DIALOGUE_INPUT 0

.cs850_ann_talk_end:
    TOGGLE_PAUSE_ENTITY 0
    BRANCH_ON_SPECIAL_BIT 2, var1, .cs850_ann_wait
    UPDATE_U8_VALUE 2, 255, npcAffection[ANN]
    SET_SPECIAL_BIT 2, var1
    EXECUTE_SUBROUTINE .cs850_ann_wait

.cs850_ann_married_guard:
    BRANCH_U8_VAR_WITHIN_RANGE 3, 3, gWife, .cs850_ann_spouse_talk
    RETURN_FROM_SUBROUTINE

.cs850_ann_spouse_talk:
    INIT_MESSAGE_BOX_TYPE1 0, SOWING_FESTIVAL_TEXT_INDEX, 47
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    EXECUTE_SUBROUTINE .cs850_ann_talk_end

.setup_maria:
    SETUP_ENTITY 4, ENTITY_ASSET_MARIA, 1
    SET_ENTITY_ANIMATIONS 4, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    RETURN_FROM_SUBROUTINE

.cs850_maria:
    EXECUTE_SUBROUTINE .setup_maria
    SET_COORDINATES -64, 0, -128

.cs850_maria_wait:
    SET_ASSET_ROTATION 0
    SET_CALLBACK_ROUTINE 0, 32768, .cs850_maria_on_interact
    EXECUTE_SUBROUTINE .wait_loop

.cs850_maria_on_interact:
    EXECUTE_SUBROUTINE .setup_message_box
    PAUSE_ENTITY 0
    FLIP_ENTITY_DIRECTION 0
    BRANCH_ON_SPECIAL_BIT MARRIED, lifeEventBits[0], .cs850_maria_married_guard
    INIT_MESSAGE_BOX_TYPE1 0, SOWING_FESTIVAL_TEXT_INDEX, 31
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0

.cs850_maria_talk_end:
    TOGGLE_PAUSE_ENTITY 0
    BRANCH_ON_SPECIAL_BIT 3, var1, .cs850_maria_wait
    UPDATE_U8_VALUE 2, 255, npcAffection[MARIA]
    SET_SPECIAL_BIT 3, var1
    EXECUTE_SUBROUTINE .cs850_maria_wait

.cs850_maria_married_guard:
    BRANCH_U8_VAR_WITHIN_RANGE 0, 0, gWife, .cs850_maria_spouse_talk
    RETURN_FROM_SUBROUTINE

.cs850_maria_spouse_talk:
    INIT_MESSAGE_BOX_TYPE1 0, SOWING_FESTIVAL_TEXT_INDEX, 33
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    EXECUTE_SUBROUTINE .cs850_maria_talk_end

.setup_lillia:
    SETUP_ENTITY 5, ENTITY_ASSET_LILLIA, 1
    SET_ENTITY_ANIMATIONS 5, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    RETURN_FROM_SUBROUTINE

.cs850_lillia:
    EXECUTE_SUBROUTINE .setup_lillia
    SET_COORDINATES -96, 0, -288

.cs850_lillia_wait:
    SET_ASSET_ROTATION 0
    SET_CALLBACK_ROUTINE 0, 32768, .cs850_lillia_on_interact
    EXECUTE_SUBROUTINE .wait_loop

.cs850_lillia_on_interact:
    EXECUTE_SUBROUTINE .setup_message_box
    BRANCH_ON_SPECIAL_BIT 4, var1, .cs850_lillia_dialogue
    UPDATE_U8_VALUE 2, 255, npcAffection[NPC_LILLIA]
    SET_SPECIAL_BIT 4, var1

.cs850_lillia_dialogue:
    PAUSE_ENTITY 0
    FLIP_ENTITY_DIRECTION 0
    INIT_DIALOGUE_SESSION 0, DIALOGUE_TEXT_55, 2
    WAIT_FOR_DIALOGUE_INPUT 0
    BRANCH_ON_DIALOGUE 0, 0, .cs850_lillia_accept_start_cutscene
    BRANCH_ON_DIALOGUE 0, 1, .cs850_lillia_decline

.cs850_lillia_accept_start_cutscene:
    DEACTIVATE_EXECUTOR 12
    DEACTIVATE_EXECUTOR 13
    DEACTIVATE_EXECUTOR 15
    DEACTIVATE_EXECUTOR 16
    DEACTIVATE_EXECUTOR 17
    DEACTIVATE_EXECUTOR 32
    DEACTIVATE_EXECUTOR 33
    DEACTIVATE_EXECUTOR 35
    DEACTIVATE_EXECUTOR 36
    DEACTIVATE_EXECUTOR 37
    SET_WAIT_FRAMES 1
    SPAWN_EXECUTOR 0, .cs850_player_ascent_start
    EXECUTE_SUBROUTINE .wait_loop

.cs850_lillia_decline:
    INIT_MESSAGE_BOX_TYPE1 0, SOWING_FESTIVAL_TEXT_INDEX, 53
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITY 0
    EXECUTE_SUBROUTINE .cs850_lillia_wait

.setup_potion_shop_dealer:
    SETUP_ENTITY 6, ENTITY_ASSET_POTION_SHOP_DEALER, 1
    SET_ENTITY_ANIMATIONS 6, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    RETURN_FROM_SUBROUTINE

.cs850_potion_shop_dealer:
    EXECUTE_SUBROUTINE .setup_potion_shop_dealer
    SET_ASSET_ROTATION 1
    SET_COORDINATES -96, 0, -32
    EXECUTE_SUBROUTINE .wait_loop

.setup_kent:
