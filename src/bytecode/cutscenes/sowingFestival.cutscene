; ----- cs850 Balloon ascent (main sequence) -----
; Spawned when Lillia accepts (.cs850_lillia_accept_start_cutscene)
; or when the King dispatch finds no assistant. Fades to black,
; deactivates all villager / sparkle executors, then spawns the
; in-balloon sprites (asc_bg_plate + asc_sprite_a..h) and exits.

.cs850_player_ascent_start:
    EXECUTE_SUBROUTINE .setup_player
    TOGGLE_PAUSE_ENTITY 0
    SET_WAIT_FRAMES 15
    SET_ENTITY_DIRECTIONAL_ANIMATION 24
    SET_WAIT_FRAMES 15
    SPAWN_EXECUTOR 32, .cs850_king_side_tracker
    SET_WAIT_FRAMES 15
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SET_WAIT_FRAMES 30
    SET_ASSET_ROTATION 0
    SET_OTHER_EXECUTOR_PTR 5, .face_southwest
    INIT_MESSAGE_BOX_TYPE1 0, SOWING_FESTIVAL_TEXT_INDEX, 52
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 3, .cs850_villager_cheer_anim
    SET_OTHER_EXECUTOR_PTR 4, .cs850_villager_cheer_anim
    SET_OTHER_EXECUTOR_PTR 10, .cs850_villager_cheer_anim
    SET_OTHER_EXECUTOR_PTR 11, .cs850_villager_cheer_anim
    SET_OTHER_EXECUTOR_PTR 19, .cs850_villager_cheer_anim
    SET_OTHER_EXECUTOR_PTR 22, .cs850_rise_fast
    SET_OTHER_EXECUTOR_PTR 23, .cs850_rise_mixed
    SET_OTHER_EXECUTOR_PTR 24, .cs850_rise_medium
    SET_OTHER_EXECUTOR_PTR 27, .cs850_rise_mixed
    SET_OTHER_EXECUTOR_PTR 29, .cs850_rise_medium
    SET_OTHER_EXECUTOR_PTR 30, .cs850_rise_fast
    SET_OTHER_EXECUTOR_PTR 31, .cs850_rise_mixed
    SET_OTHER_EXECUTOR_PTR 34, .cs850_rise_mixed
    SET_OTHER_EXECUTOR_PTR 38, .cs850_rise_medium
    SET_OTHER_EXECUTOR_PTR 39, .cs850_rise_fast
    SET_OTHER_EXECUTOR_PTR 32, .cs850_rise_slow
    SET_ENTITY_DIRECTIONAL_ANIMATION 456
    WAIT_ENTITY_ANIMATION
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    DEACTIVATE_EXECUTOR 1
    DEACTIVATE_EXECUTOR 2
    DEACTIVATE_EXECUTOR 3
    DEACTIVATE_EXECUTOR 4
    DEACTIVATE_EXECUTOR 5
    DEACTIVATE_EXECUTOR 6
    DEACTIVATE_EXECUTOR 7
    DEACTIVATE_EXECUTOR 8
    DEACTIVATE_EXECUTOR 9
    DEACTIVATE_EXECUTOR 10
    DEACTIVATE_EXECUTOR 11
    DEACTIVATE_EXECUTOR 12
    DEACTIVATE_EXECUTOR 13
    DEACTIVATE_EXECUTOR 14
    DEACTIVATE_EXECUTOR 15
    DEACTIVATE_EXECUTOR 16
    DEACTIVATE_EXECUTOR 17
    DEACTIVATE_EXECUTOR 18
    DEACTIVATE_EXECUTOR 19
    DEACTIVATE_EXECUTOR 20
    DEACTIVATE_EXECUTOR 21
    DEACTIVATE_EXECUTOR 22
    DEACTIVATE_EXECUTOR 23
    DEACTIVATE_EXECUTOR 24
    DEACTIVATE_EXECUTOR 25
    DEACTIVATE_EXECUTOR 26
    DEACTIVATE_EXECUTOR 27
    DEACTIVATE_EXECUTOR 28
    DEACTIVATE_EXECUTOR 29
    DEACTIVATE_EXECUTOR 30
    DEACTIVATE_EXECUTOR 31
    DEACTIVATE_EXECUTOR 32
    DEACTIVATE_EXECUTOR 33
    DEACTIVATE_EXECUTOR 34
    DEACTIVATE_EXECUTOR 35
    DEACTIVATE_EXECUTOR 36
    DEACTIVATE_EXECUTOR 37
    DEACTIVATE_EXECUTOR 38
    DEACTIVATE_EXECUTOR 39
    DEACTIVATE_EXECUTOR 40
    DEACTIVATE_EXECUTOR 41
    SET_WAIT_FRAMES 1
    SPAWN_EXECUTOR 1, .asc_bg_plate
    SPAWN_EXECUTOR 2, .asc_sprite_a
    SPAWN_EXECUTOR 3, .asc_sprite_b
    SPAWN_EXECUTOR 4, .asc_sprite_c
    SPAWN_EXECUTOR 5, .asc_sprite_d
    SPAWN_EXECUTOR 6, .asc_sprite_e
    SPAWN_EXECUTOR 7, .asc_sprite_f
    SPAWN_EXECUTOR 8, .asc_sprite_g
    SET_WAIT_FRAMES 92
    SPAWN_EXECUTOR 9, .asc_sprite_h
    SET_WAIT_FRAMES 120
    SET_AUDIO_SEQUENCE_VOLUME 0, 0, 2
    SET_WAIT_FRAMES 40
    STOP_SEQUENCE_WITH_FADE 0, 1
    IDLE_WHILE_SEQUENCE_PLAYING 0
    EXECUTE_SUBROUTINE .exit_cutscene

.cs850_villager_cheer_anim:
    SET_ENTITY_ANIMATION 35
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_ANIMATION 39
    EXECUTE_SUBROUTINE .wait_loop

.cs850_rise_slow:
    SET_ENTITY_TRACKING_TARGET 65535, -16, 64, 4, 255
    SET_ENTITY_PHYSICS_FLAGS 0
    SET_FRAME_DELTA 0, 1, 0, 1
    SET_FRAME_DELTA -1, 1, 1, 3
    SET_FRAME_DELTA 0, 1, 0, 1
    SET_FRAME_DELTA -1, 1, 1, 3
    SET_FRAME_DELTA 0, 1, 0, 1
    SET_FRAME_DELTA -1, 2, 1, 80
    DEACTIVATE_SELF

.cs850_rise_medium:
    SET_ENTITY_TRACKING_TARGET 65535, -16, 64, 4, 255
    SET_ENTITY_PHYSICS_FLAGS 0
    SET_FRAME_DELTA 0, 1, 0, 1
    SET_FRAME_DELTA -1, 1, 1, 3
    SET_FRAME_DELTA 0, 1, 0, 1
    SET_FRAME_DELTA -1, 1, 1, 3
    SET_FRAME_DELTA 0, 1, 0, 1
    SET_FRAME_DELTA -1, 1, 1, 3
    SET_FRAME_DELTA 0, 1, 0, 1
    SET_FRAME_DELTA -1, 2, 1, 80
    DEACTIVATE_SELF

.cs850_rise_fast:
    SET_ENTITY_TRACKING_TARGET 65535, -16, 64, 4, 255
    SET_ENTITY_PHYSICS_FLAGS 0
    SET_FRAME_DELTA 0, 1, 0, 16
    SET_FRAME_DELTA -1, 2, 0, 96
    DEACTIVATE_SELF

.cs850_rise_mixed:
    SET_ENTITY_TRACKING_TARGET 65535, -16, 64, 4, 255
    SET_ENTITY_PHYSICS_FLAGS 0
    SET_FRAME_DELTA 0, 1, 0, 16
    SET_FRAME_DELTA -1, 1, 1, 3
    SET_FRAME_DELTA 0, 1, 0, 1
    SET_FRAME_DELTA -1, 2, 1, 40
    SET_FRAME_DELTA -1, 2, 0, 46
    DEACTIVATE_SELF

.cs850_king_side_tracker:
    SET_SHADOW_FLAGS 93, 255
    SETUP_ENTITY 22, ENTITY_ASSET_STATIC_ITEM, 1
    SET_ENTITY_ANIMATIONS 22, 0, 0, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_PALETTE 99
    SET_ENTITY_ANIMATION 108
    SET_ENTITY_TRACKING_TARGET 0, 16, 64, 4, 255
    EXECUTE_SUBROUTINE .wait_loop
    SET_SHADOW_FLAGS 93, 255
    SETUP_ENTITY 23, ENTITY_ASSET_STATIC_ITEM, 1
    SET_ENTITY_ANIMATIONS 23, 0, 0, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_PALETTE 99
    SET_ENTITY_ANIMATION 108
    SET_ENTITY_TRACKING_TARGET 1, -16, 64, 4, 255
    EXECUTE_SUBROUTINE .wait_loop

; ----- Shared sparkle / static items (slots 22..39) -----
; Each sets up a STATIC_ITEM entity with palette 99..103 and anim 108,
; tracking one of the villager entities via SET_ENTITY_TRACKING_TARGET.
; Spawned by both cs850 and cs851. Executor slot != entity index; the
; entity index is the first operand of SETUP_ENTITY.

.sparkle_static_22:
    SET_SHADOW_FLAGS 93, 255
    SETUP_ENTITY 24, ENTITY_ASSET_STATIC_ITEM, 1
    SET_ENTITY_ANIMATIONS 24, 0, 0, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_PALETTE 100
    SET_ENTITY_ANIMATION 108
    SET_ENTITY_TRACKING_TARGET 2, -16, 64, 4, 255
