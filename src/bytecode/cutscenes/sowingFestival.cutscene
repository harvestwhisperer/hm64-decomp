; ============================================================
; Cutscene 852 - SOWING_FESTIVAL_BACHELOR (and other bachelors)
; A bachelor (gHarvestKing 1..5 -> Harris/Gray/Jeff/Cliff/Kai)
; is the King. Executor 14..18 is re-bound to the bachelor
; king role (see .cs852_king_is_harris..D38 fan-out). He may ask the
; player or a high-affection village woman to ride along, then
; the balloon sequence plays.
; ============================================================

; ----- cs852 Dispatch -----
; Reuses cs850 villager executors for slots 1..5, 9..13 (ground scene
; is identical apart from the King). Slot 6 (potion-shop-dealer), 7
; (Kent), and 8 (Stu) get their own cs852 executors with different
; positions and dialogue. `gHarvestKing` (1..5) selects which bachelor
; occupies slot 14..18 and runs `.cs852_bachelor_king_main`.

.cs_bachelor_king:
    SPAWN_EXECUTOR 1, .cs850_mayor
    SPAWN_EXECUTOR 2, .cs850_mayor_wife
    SPAWN_EXECUTOR 3, .cs850_ann
    SPAWN_EXECUTOR 4, .cs850_maria
    SPAWN_EXECUTOR 5, .cs850_lillia
    SPAWN_EXECUTOR 6, .cs852_potion_shop_dealer
    SPAWN_EXECUTOR 7, .cs852_kent
    SPAWN_EXECUTOR 8, .cs852_stu
    SPAWN_EXECUTOR 9, .cs850_may
    SPAWN_EXECUTOR 10, .cs850_popuri
    SPAWN_EXECUTOR 11, .cs850_elli
    SPAWN_EXECUTOR 12, .cs850_rick
    SPAWN_EXECUTOR 13, .cs850_pastor
    SPAWN_EXECUTOR 22, .sparkle_static_22
    SPAWN_EXECUTOR 23, .sparkle_static_23
    SPAWN_EXECUTOR 24, .sparkle_static_24
    SPAWN_EXECUTOR 26, .sparkle_static_26
    SPAWN_EXECUTOR 27, .sparkle_static_27
    SPAWN_EXECUTOR 28, .sparkle_static_28
    SPAWN_EXECUTOR 29, .sparkle_static_29
    SPAWN_EXECUTOR 30, .sparkle_static_30
    SPAWN_EXECUTOR 31, .sparkle_static_31
    SPAWN_EXECUTOR 32, .sparkle_static_32
    SPAWN_EXECUTOR 33, .sparkle_static_33
    SPAWN_EXECUTOR 35, .festival_item_overlay
    SPAWN_EXECUTOR 36, .king_balloon_sprite
    BRANCH_U8_VAR_WITHIN_RANGE 1, 1, gHarvestKing, .cs852_king_is_harris
    BRANCH_U8_VAR_WITHIN_RANGE 2, 2, gHarvestKing, .cs852_king_is_gray
    BRANCH_U8_VAR_WITHIN_RANGE 3, 3, gHarvestKing, .cs852_king_is_jeff
    BRANCH_U8_VAR_WITHIN_RANGE 4, 4, gHarvestKing, .cs852_king_is_cliff
    BRANCH_U8_VAR_WITHIN_RANGE 100, 255, npcAffection[CLIFF], .spawn_cliff_assistant

.cs852_king_post_select:
    BRANCH_U8_VAR_WITHIN_RANGE 5, 5, gHarvestKing, .cs852_king_is_kai
    BRANCH_ON_SPECIAL_BIT 15, lifeEventBits[1], .cs852_king_player_as_assistant
    BRANCH_U8_VAR_WITHIN_RANGE 100, 255, npcAffection[KAREN], .cs852_spawn_karen_assistant

.cs852_king_player_as_assistant:
    SPAWN_EXECUTOR 21, .cs852_king_intro
    EXECUTE_SUBROUTINE .spawn_player_as_kingr

.cs852_kent:
    EXECUTE_SUBROUTINE .setup_kent
    SET_COORDINATES -88, 0, -96

.cs852_kent_wait:
    SET_ASSET_ROTATION 0
    SET_CALLBACK_ROUTINE 0, 32768, .cs852_kent_on_interact
    EXECUTE_SUBROUTINE .wait_loop

.cs852_kent_on_interact:
    EXECUTE_SUBROUTINE .setup_message_box
    PAUSE_ENTITY 0
    FLIP_ENTITY_DIRECTION 0
    INIT_MESSAGE_BOX_TYPE1 0, SOWING_FESTIVAL_TEXT_INDEX, 21
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITY 0
    BRANCH_ON_SPECIAL_BIT 5, var1, .cs852_kent_wait
    UPDATE_U8_VALUE 2, 255, npcAffection[NPC_KENT]
    SET_SPECIAL_BIT 5, var1
    EXECUTE_SUBROUTINE .cs852_kent_wait

.cs852_king_intro:
    SETUP_MAP_ASSET MAIN_MAP_INDEX
    SET_ASSET_ROTATION 7
    SET_COORDINATES -72, 96, -16
    EXECUTE_SUBROUTINE .wait_loop

.cs852_king_ascent_pos:
    SET_COORDINATES -160, 96, 40
    EXECUTE_SUBROUTINE .wait_loop

.cs852_king_wife_pos:
    SET_COORDINATES -128, 96, 40
    EXECUTE_SUBROUTINE .wait_loop

.cs852_king_dispatch_assistant:
    SET_WAIT_FRAMES 2
    BRANCH_U8_VAR_WITHIN_RANGE 1, 1, gHarvestKing, .cs852_king_check_gray
    BRANCH_U8_VAR_WITHIN_RANGE 100, 255, npcAffection[HARRIS], .spawn_harris_assistant

.cs852_king_check_gray:
    BRANCH_U8_VAR_WITHIN_RANGE 2, 2, gHarvestKing, .cs852_king_check_jeff
    BRANCH_U8_VAR_WITHIN_RANGE 100, 255, npcAffection[GRAY], .spawn_gray_assistant

.cs852_king_check_jeff:
    BRANCH_U8_VAR_WITHIN_RANGE 3, 3, gHarvestKing, .cs852_king_check_kai
    BRANCH_U8_VAR_WITHIN_RANGE 100, 255, npcAffection[JEFF], .spawn_jeff_assistant

.cs852_king_check_kai:
    BRANCH_U8_VAR_WITHIN_RANGE 5, 5, gHarvestKing, .cs852_king_check_basil
    BRANCH_ON_SPECIAL_BIT 14, lifeEventBits[1], .cs852_king_check_basil
    BRANCH_U8_VAR_WITHIN_RANGE 100, 255, npcAffection[KAI], .spawn_kai_assistant

.cs852_king_check_basil:
    BRANCH_ON_SPECIAL_BIT 12, lifeEventBits[1], .cs852_king_no_assistant
    BRANCH_U8_VAR_WITHIN_RANGE 100, 255, npcAffection[NPC_BASIL], .spawn_basil_assistant

.cs852_king_no_assistant:
    SET_WAIT_FRAMES 2
    SET_FRAME_DELTA 1, 0, -1, 48
    SET_FRAME_DELTA 1, 0, 0, 48
    SET_OTHER_EXECUTOR_PTR 0, .track_entity_done
    EXECUTE_SUBROUTINE .wait_loop

.cs852_spawn_karen_assistant:
    SPAWN_EXECUTOR 19, .cs850_karen
    SET_WAIT_FRAMES 1
    SPAWN_EXECUTOR 39, .sparkle_static_39
    RETURN_FROM_SUBROUTINE

.cs852_king_is_harris:
    SPAWN_EXECUTOR 14, .cs852_king_harris_setup
    RETURN_FROM_SUBROUTINE

.cs852_king_is_gray:
    SPAWN_EXECUTOR 15, .cs852_king_gray_setup
    RETURN_FROM_SUBROUTINE

.cs852_king_is_jeff:
    SPAWN_EXECUTOR 16, .cs852_king_jeff_setup
    RETURN_FROM_SUBROUTINE

.cs852_king_is_cliff:
    SPAWN_EXECUTOR 17, .cs852_king_cliff_setup
    EXECUTE_SUBROUTINE .cs852_king_post_select

.cs852_king_is_kai:
    SPAWN_EXECUTOR 18, .cs852_king_kai_setup
    RETURN_FROM_SUBROUTINE

.cs852_king_harris_setup:
    EXECUTE_SUBROUTINE .setup_harris
    EXECUTE_SUBROUTINE .cs852_bachelor_king_main

.cs852_king_gray_setup:
    EXECUTE_SUBROUTINE .setup_gray
    EXECUTE_SUBROUTINE .cs852_bachelor_king_main

.cs852_king_jeff_setup:
    EXECUTE_SUBROUTINE .setup_jeff
    EXECUTE_SUBROUTINE .cs852_bachelor_king_main

.cs852_king_cliff_setup:
    EXECUTE_SUBROUTINE .setup_cliff
    EXECUTE_SUBROUTINE .cs852_bachelor_king_main

.cs852_king_kai_setup:
    EXECUTE_SUBROUTINE .setup_kai
    EXECUTE_SUBROUTINE .cs852_bachelor_king_main

; ----- cs852 Bachelor-king main body (shared by all 5 bachelors) -----
; Rotates through six facing directions as a warm-up, then dispatches
; on gHarvestKing. Each `cs852_<bachelor>_open` branch leads to:
;   - `<bachelor>_ask_player`         if high affection on the bachelor
;   - `<bachelor>_if_<wife>_wife`     if the player is married to the
;                                     canonical wife candidate
;   - `<bachelor>_player_declines`    fallback (bachelor + wife in balloon)
; The yes/no choice in `_ask_player` picks between:
;   - `_player_accepts`  -> bachelor rides with player (setup + .cs852_ascent_with_player)
;   - `_player_declines` -> bachelor rides with canonical wife (.cs852_ascent_with_wife)

.cs852_bachelor_king_main:
    SET_ASSET_ROTATION 1
    SET_COORDINATES -96, 0, -32
    SET_WAIT_FRAMES 1
    UPDATE_GLOBAL_RGBA 255, 255, 255, 255, 8
    WAIT_RGBA_FINISHED
    SET_WAIT_FRAMES 15
    SET_OTHER_EXECUTOR_PTR 1, .face_southeast
    SET_ASSET_ROTATION 2
    INIT_MESSAGE_BOX_TYPE1 0, SOWING_FESTIVAL_TEXT_INDEX, 8
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_WAIT_FRAMES 15
    SET_ASSET_ROTATION 1
    SET_WAIT_FRAMES 30
    SET_ASSET_ROTATION 0
    SET_WAIT_FRAMES 30
    SET_ASSET_ROTATION 6
    SET_WAIT_FRAMES 30
    SET_ASSET_ROTATION 5
    SET_WAIT_FRAMES 30
    SET_ASSET_ROTATION 4
    SET_WAIT_FRAMES 30
    BRANCH_U8_VAR_WITHIN_RANGE 1, 1, gHarvestKing, .cs852_harris_open
    BRANCH_U8_VAR_WITHIN_RANGE 2, 2, gHarvestKing, .cs852_gray_open
    BRANCH_U8_VAR_WITHIN_RANGE 3, 3, gHarvestKing, .cs852_jeff_open
    BRANCH_U8_VAR_WITHIN_RANGE 4, 4, gHarvestKing, .cs852_cliff_open
    BRANCH_U8_VAR_WITHIN_RANGE 5, 5, gHarvestKing, .cs852_kai_open
    EXECUTE_SUBROUTINE .wait_loop

.cs852_harris_open:
    BRANCH_ON_SPECIAL_BIT MARRIED, lifeEventBits[0], .cs852_harris_if_maria_wife
    BRANCH_U8_VAR_WITHIN_RANGE 100, 255, npcAffection[HARRIS], .cs852_harris_ask_player
    EXECUTE_SUBROUTINE .cs852_harris_player_declines

.cs852_harris_if_maria_wife:
    BRANCH_U8_VAR_WITHIN_RANGE 0, 0, gWife, .cs852_harris_ask_player
    RETURN_FROM_SUBROUTINE

.cs852_gray_open:
    BRANCH_ON_SPECIAL_BIT MARRIED, lifeEventBits[0], .cs852_gray_if_popuri_wife
    BRANCH_U8_VAR_WITHIN_RANGE 100, 255, npcAffection[GRAY], .cs852_gray_ask_player
    EXECUTE_SUBROUTINE .cs852_gray_player_declines

.cs852_gray_if_popuri_wife:
    BRANCH_U8_VAR_WITHIN_RANGE 1, 1, gWife, .cs852_gray_ask_player
    RETURN_FROM_SUBROUTINE

.cs852_jeff_open:
    BRANCH_ON_SPECIAL_BIT MARRIED, lifeEventBits[0], .cs852_jeff_if_elli_wife
    BRANCH_U8_VAR_WITHIN_RANGE 100, 255, npcAffection[JEFF], .cs852_jeff_ask_player
    EXECUTE_SUBROUTINE .cs852_jeff_player_declines

.cs852_jeff_if_elli_wife:
    BRANCH_U8_VAR_WITHIN_RANGE 2, 2, gWife, .cs852_jeff_ask_player
    RETURN_FROM_SUBROUTINE

.cs852_cliff_open:
    BRANCH_ON_SPECIAL_BIT MARRIED, lifeEventBits[0], .cs852_cliff_if_ann_wife
    BRANCH_U8_VAR_WITHIN_RANGE 100, 255, npcAffection[CLIFF], .cs852_cliff_ask_player
    EXECUTE_SUBROUTINE .cs852_cliff_player_declines

.cs852_cliff_if_ann_wife:
    BRANCH_U8_VAR_WITHIN_RANGE 3, 3, gWife, .cs852_cliff_ask_player
    RETURN_FROM_SUBROUTINE

.cs852_kai_open:
    BRANCH_ON_SPECIAL_BIT MARRIED, lifeEventBits[0], .cs852_kai_if_karen_wife
    BRANCH_U8_VAR_WITHIN_RANGE 100, 255, npcAffection[KAI], .cs852_kai_ask_player
    EXECUTE_SUBROUTINE .cs852_kai_player_declines

.cs852_kai_if_karen_wife:
    BRANCH_U8_VAR_WITHIN_RANGE 4, 4, gWife, .cs852_kai_ask_player
    RETURN_FROM_SUBROUTINE

.cs852_harris_ask_player:
    SET_ASSET_ROTATION 6
    SET_WAIT_FRAMES 15
    INIT_MESSAGE_BOX_TYPE1 0, SOWING_FESTIVAL_TEXT_INDEX, 62
    WAIT_MESSAGE_BOX_CLOSED 0
    BRANCH_ON_SPECIAL_BIT MARRIED, lifeEventBits[0], .cs852_harris_married_wife_check
    INIT_DIALOGUE_SESSION 0, DIALOGUE_TEXT_55, 12
    WAIT_FOR_DIALOGUE_INPUT 0
    BRANCH_ON_DIALOGUE 0, 0, .cs852_harris_player_accepts
    BRANCH_ON_DIALOGUE 0, 1, .cs852_harris_player_declines

.cs852_harris_player_accepts:
    RESET_MESSAGE_BOX_AVATAR 0
    SET_WAIT_FRAMES 15
    UPDATE_U8_VALUE 8, 255, npcAffection[HARRIS]
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    SPAWN_EXECUTOR 25, .cs852_harris_balloon_with_player
    DEACTIVATE_SELF

.cs852_harris_married_wife_check:
    BRANCH_U8_VAR_WITHIN_RANGE 0, 0, gWife, .cs852_harris_player_accepts
    RETURN_FROM_SUBROUTINE

.cs852_harris_balloon_with_player:
    SET_WAIT_FRAMES 1
    SET_SHADOW_FLAGS 7, 255
    EXECUTE_SUBROUTINE .setup_harris
    EXECUTE_SUBROUTINE .cs852_ascent_with_player

.cs852_harris_player_declines:
    SET_WAIT_FRAMES 15
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    DEACTIVATE_EXECUTOR 4
    DEACTIVATE_EXECUTOR 24
    SPAWN_EXECUTOR 25, .cs852_harris_balloon_with_maria
    DEACTIVATE_SELF

.cs852_harris_balloon_with_maria:
    SET_WAIT_FRAMES 1
    SPAWN_EXECUTOR 40, .cs852_maria_balloon_passenger
    SET_SHADOW_FLAGS 7, 255
    EXECUTE_SUBROUTINE .setup_harris
    EXECUTE_SUBROUTINE .cs852_ascent_with_wife

.cs852_maria_balloon_passenger:
    SET_SHADOW_FLAGS 1, 255
    EXECUTE_SUBROUTINE .setup_maria
    EXECUTE_SUBROUTINE .cs852_balloon_rest_pos

.cs852_gray_ask_player:
    SET_ASSET_ROTATION 6
    SET_WAIT_FRAMES 15
    INIT_MESSAGE_BOX_TYPE1 0, SOWING_FESTIVAL_TEXT_INDEX, 66
    WAIT_MESSAGE_BOX_CLOSED 0
    BRANCH_ON_SPECIAL_BIT MARRIED, lifeEventBits[0], .cs852_gray_married_wife_check
    INIT_DIALOGUE_SESSION 0, DIALOGUE_TEXT_55, 12
    WAIT_FOR_DIALOGUE_INPUT 0
    BRANCH_ON_DIALOGUE 0, 0, .cs852_gray_player_accepts
    BRANCH_ON_DIALOGUE 0, 1, .cs852_gray_player_declines

.cs852_gray_player_accepts:
    RESET_MESSAGE_BOX_AVATAR 0
    SET_WAIT_FRAMES 15
    UPDATE_U8_VALUE 8, 255, npcAffection[GRAY]
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    SPAWN_EXECUTOR 25, .cs852_gray_balloon_with_player
    DEACTIVATE_SELF

.cs852_gray_married_wife_check:
    BRANCH_U8_VAR_WITHIN_RANGE 1, 1, gWife, .cs852_gray_player_accepts
    RETURN_FROM_SUBROUTINE

.cs852_gray_balloon_with_player:
    SET_WAIT_FRAMES 1
    SET_SHADOW_FLAGS 8, 255
    EXECUTE_SUBROUTINE .setup_gray
    EXECUTE_SUBROUTINE .cs852_ascent_with_player

.cs852_gray_player_declines:
    SET_WAIT_FRAMES 15
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    DEACTIVATE_EXECUTOR 10
    DEACTIVATE_EXECUTOR 30
    SPAWN_EXECUTOR 25, .cs852_gray_balloon_with_popuri
    DEACTIVATE_SELF

.cs852_gray_balloon_with_popuri:
    SET_WAIT_FRAMES 1
    SPAWN_EXECUTOR 40, .cs852_popuri_balloon_passenger
    SET_SHADOW_FLAGS 8, 255
    EXECUTE_SUBROUTINE .setup_gray
    EXECUTE_SUBROUTINE .cs852_ascent_with_wife

.cs852_popuri_balloon_passenger:
    SET_SHADOW_FLAGS 2, 255
    EXECUTE_SUBROUTINE .setup_popuri
    EXECUTE_SUBROUTINE .cs852_balloon_rest_pos

.cs852_jeff_ask_player:
    SET_ASSET_ROTATION 6
    SET_WAIT_FRAMES 15
    INIT_MESSAGE_BOX_TYPE1 0, SOWING_FESTIVAL_TEXT_INDEX, 70
    WAIT_MESSAGE_BOX_CLOSED 0
    BRANCH_ON_SPECIAL_BIT MARRIED, lifeEventBits[0], .cs852_jeff_married_wife_check
    INIT_DIALOGUE_SESSION 0, DIALOGUE_TEXT_55, 12
    WAIT_FOR_DIALOGUE_INPUT 0
    BRANCH_ON_DIALOGUE 0, 0, .cs852_jeff_player_accepts
    BRANCH_ON_DIALOGUE 0, 1, .cs852_jeff_player_declines

.cs852_jeff_player_accepts:
    RESET_MESSAGE_BOX_AVATAR 0
    SET_WAIT_FRAMES 15
    UPDATE_U8_VALUE 8, 255, npcAffection[JEFF]
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    SPAWN_EXECUTOR 25, .cs852_jeff_balloon_with_player
    DEACTIVATE_SELF

.cs852_jeff_married_wife_check:
    BRANCH_U8_VAR_WITHIN_RANGE 2, 2, gWife, .cs852_jeff_player_accepts
    RETURN_FROM_SUBROUTINE

.cs852_jeff_balloon_with_player:
    SET_WAIT_FRAMES 1
    SET_SHADOW_FLAGS 9, 255
    EXECUTE_SUBROUTINE .setup_jeff
    EXECUTE_SUBROUTINE .cs852_ascent_with_player

.cs852_jeff_player_declines:
    SET_WAIT_FRAMES 15
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    DEACTIVATE_EXECUTOR 11
    DEACTIVATE_EXECUTOR 31
    SPAWN_EXECUTOR 25, .cs852_jeff_balloon_with_elli
    DEACTIVATE_SELF

.cs852_jeff_balloon_with_elli:
    SET_WAIT_FRAMES 1
    SPAWN_EXECUTOR 40, .cs852_elli_balloon_passenger
    SET_SHADOW_FLAGS 9, 255
    EXECUTE_SUBROUTINE .setup_jeff
    EXECUTE_SUBROUTINE .cs852_ascent_with_wife

.cs852_elli_balloon_passenger:
    SET_SHADOW_FLAGS 3, 255
    EXECUTE_SUBROUTINE .setup_elli
    EXECUTE_SUBROUTINE .cs852_balloon_rest_pos

.cs852_cliff_ask_player:
    SET_ASSET_ROTATION 6
    SET_WAIT_FRAMES 15
    INIT_MESSAGE_BOX_TYPE1 0, SOWING_FESTIVAL_TEXT_INDEX, 74
    WAIT_MESSAGE_BOX_CLOSED 0
    BRANCH_ON_SPECIAL_BIT MARRIED, lifeEventBits[0], .cs852_cliff_married_wife_check
    INIT_DIALOGUE_SESSION 0, DIALOGUE_TEXT_55, 12
    WAIT_FOR_DIALOGUE_INPUT 0
    BRANCH_ON_DIALOGUE 0, 0, .cs852_cliff_player_accepts
    BRANCH_ON_DIALOGUE 0, 1, .cs852_cliff_player_declines

.cs852_cliff_player_accepts:
    RESET_MESSAGE_BOX_AVATAR 0
    SET_WAIT_FRAMES 15
    UPDATE_U8_VALUE 8, 255, npcAffection[CLIFF]
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    SPAWN_EXECUTOR 25, .cs852_cliff_balloon_with_player
    DEACTIVATE_SELF

.cs852_cliff_married_wife_check:
    BRANCH_U8_VAR_WITHIN_RANGE 3, 3, gWife, .cs852_cliff_player_accepts
    RETURN_FROM_SUBROUTINE

.cs852_cliff_balloon_with_player:
    SET_WAIT_FRAMES 1
    SET_SHADOW_FLAGS 10, 255
    EXECUTE_SUBROUTINE .setup_cliff
    EXECUTE_SUBROUTINE .cs852_ascent_with_player

.cs852_cliff_player_declines:
    SET_WAIT_FRAMES 15
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    DEACTIVATE_EXECUTOR 3
    DEACTIVATE_EXECUTOR 23
    SPAWN_EXECUTOR 25, .cs852_cliff_balloon_with_ann
    DEACTIVATE_SELF

.cs852_cliff_balloon_with_ann:
    SET_WAIT_FRAMES 1
    SPAWN_EXECUTOR 40, .cs852_ann_balloon_passenger
    SET_SHADOW_FLAGS 10, 255
    EXECUTE_SUBROUTINE .setup_cliff
    EXECUTE_SUBROUTINE .cs852_ascent_with_wife

.cs852_ann_balloon_passenger:
    SET_SHADOW_FLAGS 4, 255
    EXECUTE_SUBROUTINE .setup_ann
    EXECUTE_SUBROUTINE .cs852_balloon_rest_pos

.cs852_kai_ask_player:
    SET_ASSET_ROTATION 6
    SET_WAIT_FRAMES 15
    INIT_MESSAGE_BOX_TYPE1 0, SOWING_FESTIVAL_TEXT_INDEX, 78
    WAIT_MESSAGE_BOX_CLOSED 0
    BRANCH_ON_SPECIAL_BIT MARRIED, lifeEventBits[0], .cs852_kai_married_wife_check
    INIT_DIALOGUE_SESSION 0, DIALOGUE_TEXT_55, 12
    WAIT_FOR_DIALOGUE_INPUT 0
    BRANCH_ON_DIALOGUE 0, 0, .cs852_kai_player_accepts
    BRANCH_ON_DIALOGUE 0, 1, .cs852_kai_player_declines

.cs852_kai_player_accepts:
    RESET_MESSAGE_BOX_AVATAR 0
    SET_WAIT_FRAMES 15
    UPDATE_U8_VALUE 8, 255, npcAffection[KAI]
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    SPAWN_EXECUTOR 25, .cs852_kai_balloon_with_player
    DEACTIVATE_SELF

.cs852_kai_married_wife_check:
    BRANCH_U8_VAR_WITHIN_RANGE 4, 4, gWife, .cs852_kai_player_accepts
    RETURN_FROM_SUBROUTINE

.cs852_kai_balloon_with_player:
    SET_WAIT_FRAMES 1
    SET_SHADOW_FLAGS 11, 255
    EXECUTE_SUBROUTINE .setup_kai
    EXECUTE_SUBROUTINE .cs852_ascent_with_player

.cs852_kai_player_declines:
    SET_WAIT_FRAMES 15
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    DEACTIVATE_EXECUTOR 19
    DEACTIVATE_EXECUTOR 39
    SPAWN_EXECUTOR 25, .cs852_kai_balloon_with_karen
    DEACTIVATE_SELF

.cs852_kai_balloon_with_karen:
    SET_WAIT_FRAMES 1
    SPAWN_EXECUTOR 40, .cs852_karen_balloon_passenger
    SET_SHADOW_FLAGS 11, 255
    EXECUTE_SUBROUTINE .setup_kai
    EXECUTE_SUBROUTINE .cs852_ascent_with_wife

.cs852_karen_balloon_passenger:
    SET_SHADOW_FLAGS 5, 255
    EXECUTE_SUBROUTINE .setup_karen
    EXECUTE_SUBROUTINE .cs852_balloon_rest_pos

.cs852_player_balloon_pos:
    SET_SHADOW_FLAGS 0, 255
    EXECUTE_SUBROUTINE .setup_player
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_PHYSICS_FLAGS 0
    TOGGLE_PAUSE_ENTITY 0
    SET_ASSET_ROTATION 6
    SET_COORDINATES -160, 96, 32
    EXECUTE_SUBROUTINE .wait_loop

.cs852_potion_shop_dealer:
    EXECUTE_SUBROUTINE .setup_potion_shop_dealer
    SET_COORDINATES 64, 0, 32

.cs852_potion_shop_dealer_wait:
    SET_ASSET_ROTATION 2
    SET_CALLBACK_ROUTINE 0, 32768, .cs852_potion_shop_dealer_on_interact
    EXECUTE_SUBROUTINE .wait_loop

.cs852_potion_shop_dealer_on_interact:
    EXECUTE_SUBROUTINE .setup_message_box
    PAUSE_ENTITY 0
    FLIP_ENTITY_DIRECTION 0
    INIT_MESSAGE_BOX_TYPE1 0, SOWING_FESTIVAL_TEXT_INDEX, 83
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITY 0
    BRANCH_ON_SPECIAL_BIT 20, var1, .cs852_potion_shop_dealer_wait
    UPDATE_U8_VALUE 2, 255, npcAffection[NPC_POTION_SHOP_DEALER]
    SET_SPECIAL_BIT 20, var1
    EXECUTE_SUBROUTINE .cs852_potion_shop_dealer_wait

.cs852_stu:
    EXECUTE_SUBROUTINE .setup_stu
    SET_COORDINATES 32, 0, -32

.cs852_stu_wait:
    SET_ASSET_ROTATION 1
    SET_CALLBACK_ROUTINE 0, 32768, .cs852_stu_on_interact
    EXECUTE_SUBROUTINE .wait_loop

.cs852_stu_on_interact:
    EXECUTE_SUBROUTINE .setup_message_box
    PAUSE_ENTITY 0
    FLIP_ENTITY_DIRECTION 0
    INIT_DIALOGUE_SESSION 0, DIALOGUE_TEXT_55, 5
    WAIT_FOR_DIALOGUE_INPUT 0
    TOGGLE_PAUSE_ENTITY 0
    BRANCH_ON_SPECIAL_BIT 21, var1, .cs852_stu_wait
    UPDATE_U8_VALUE 2, 255, npcAffection[NPC_STU]
    SET_SPECIAL_BIT 21, var1
    EXECUTE_SUBROUTINE .cs852_stu_wait

; ----- cs852 Ascent transitions and balloon-scene controller -----
; `.cs852_ascent_with_player` - called when the bachelor rides with the
;                               player (player_accepts paths). Reuses
;                               the cs851 balloon-scene sprites.
; `.cs852_ascent_with_wife`   - called when the bachelor rides with his
;                               canonical wife (player_declines paths).
; `.cs852_balloon_announcer`   - analogous to cs851 announcer but keyed
;                               off gHarvestKing (1..5 -> harris..kai).

.cs852_ascent_with_player:
    DEACTIVATE_EXECUTOR 0
    SET_WAIT_FRAMES 1
    SPAWN_EXECUTOR 0, .cs852_player_balloon_pos
    SET_OTHER_EXECUTOR_PTR 1, .face_southwest
    SET_OTHER_EXECUTOR_PTR 21, .cs852_king_ascent_pos
    SET_ENTITY_PHYSICS_FLAGS 0
    SET_COORDINATES -176, 96, 48
    SET_ASSET_ROTATION 0
    UPDATE_U8_VALUE 10, 255, gHappiness
    SET_WAIT_FRAMES 1
    UPDATE_GLOBAL_RGBA 255, 255, 255, 255, 8
    WAIT_RGBA_FINISHED
    SET_WAIT_FRAMES 15
    INIT_MESSAGE_BOX_TYPE1 0, SOWING_FESTIVAL_TEXT_INDEX, 9
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 0, .cs851_balloon_drift_delta
    SET_WAIT_FRAMES 1
    SET_OTHER_EXECUTOR_PTR 35, .cs851_balloon_drift_delta
    SET_OTHER_EXECUTOR_PTR 36, .cs851_balloon_drift_delta
    SET_FRAME_DELTA 0, 1, 1, 40
    SET_FRAME_DELTA 0, 2, 1, 200
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    DEACTIVATE_EXECUTOR 1
    DEACTIVATE_EXECUTOR 2
    DEACTIVATE_EXECUTOR 3
    DEACTIVATE_EXECUTOR 4
    DEACTIVATE_EXECUTOR 5
    DEACTIVATE_EXECUTOR 6
    DEACTIVATE_EXECUTOR 7
    DEACTIVATE_EXECUTOR 8
    DEACTIVATE_EXECUTOR 9
    DEACTIVATE_EXECUTOR 10
    DEACTIVATE_EXECUTOR 11
    DEACTIVATE_EXECUTOR 12
    DEACTIVATE_EXECUTOR 13
    DEACTIVATE_EXECUTOR 14
    DEACTIVATE_EXECUTOR 15
    DEACTIVATE_EXECUTOR 16
    DEACTIVATE_EXECUTOR 17
    DEACTIVATE_EXECUTOR 18
    DEACTIVATE_EXECUTOR 19
    DEACTIVATE_EXECUTOR 20
    DEACTIVATE_EXECUTOR 21
    DEACTIVATE_EXECUTOR 22
    DEACTIVATE_EXECUTOR 23
    DEACTIVATE_EXECUTOR 24
    DEACTIVATE_EXECUTOR 26
    DEACTIVATE_EXECUTOR 27
    DEACTIVATE_EXECUTOR 28
    DEACTIVATE_EXECUTOR 29
    DEACTIVATE_EXECUTOR 30
    DEACTIVATE_EXECUTOR 31
    DEACTIVATE_EXECUTOR 32
    DEACTIVATE_EXECUTOR 33
    DEACTIVATE_EXECUTOR 34
    DEACTIVATE_EXECUTOR 35
    DEACTIVATE_EXECUTOR 36
    DEACTIVATE_EXECUTOR 37
    DEACTIVATE_EXECUTOR 38
    DEACTIVATE_EXECUTOR 39
    DEACTIVATE_EXECUTOR 40
    DEACTIVATE_EXECUTOR 41
    SET_WAIT_FRAMES 1
    SET_OTHER_EXECUTOR_PTR 0, .cs852_balloon_rest_pos
    SPAWN_EXECUTOR 1, .cs851_bg_left_scroll
    SPAWN_EXECUTOR 2, .cs851_bg_right_scroll
    SPAWN_EXECUTOR 3, .festival_item_overlay
    SPAWN_EXECUTOR 4, .king_balloon_sprite
    SPAWN_EXECUTOR 41, .cs852_balloon_announcer
    SET_COORDINATES -176, 96, 48
    SET_WAIT_FRAMES 1
    UPDATE_GLOBAL_RGBA 255, 255, 255, 255, 8
    SET_OTHER_EXECUTOR_PTR 0, .cs851_balloon_bob_loop
    SET_OTHER_EXECUTOR_PTR 3, .cs851_balloon_bob_loop
    SET_OTHER_EXECUTOR_PTR 4, .cs851_balloon_bob_loop
    SET_WAIT_FRAMES 1
    EXECUTE_SUBROUTINE .cs851_balloon_bob_loop

.cs852_balloon_rest_pos:
    SET_ENTITY_PHYSICS_FLAGS 0
    SET_ASSET_ROTATION 6
    SET_COORDINATES -160, 96, 32
    EXECUTE_SUBROUTINE .wait_loop

.cs852_balloon_announcer:
    SET_WAIT_FRAMES 120
    BRANCH_U8_VAR_WITHIN_RANGE 1, 1, gHarvestKing, .cs851_announce_harris
    BRANCH_U8_VAR_WITHIN_RANGE 2, 2, gHarvestKing, .cs851_announce_gray
    BRANCH_U8_VAR_WITHIN_RANGE 3, 3, gHarvestKing, .cs851_announce_jeff
    BRANCH_U8_VAR_WITHIN_RANGE 4, 4, gHarvestKing, .cs851_announce_cliff
    BRANCH_U8_VAR_WITHIN_RANGE 5, 5, gHarvestKing, .cs851_announce_kai
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_WAIT_FRAMES 30
    SPAWN_EXECUTOR 5, .cs851_asc_sprite_5
    SPAWN_EXECUTOR 6, .cs851_asc_sprite_6
    SPAWN_EXECUTOR 7, .cs851_asc_sprite_7
    SPAWN_EXECUTOR 8, .cs851_asc_sprite_8
    SPAWN_EXECUTOR 9, .cs851_asc_sprite_9
    SPAWN_EXECUTOR 10, .cs851_asc_sprite_10
    SPAWN_EXECUTOR 11, .cs851_asc_sprite_11
    SPAWN_EXECUTOR 12, .cs851_asc_sprite_12
    SET_WAIT_FRAMES 211
    SET_OTHER_EXECUTOR_PTR 1, .cs851_bg_left_fade_out
    SET_OTHER_EXECUTOR_PTR 2, .cs851_bg_right_fade_out
    SET_WAIT_FRAMES 1
    SET_AUDIO_SEQUENCE_VOLUME 0, 0, 2
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    SET_WAIT_FRAMES 40
    STOP_SEQUENCE_WITH_FADE 0, 1
    DEACTIVATE_EXECUTOR 25
    DEACTIVATE_EXECUTOR 0
    DEACTIVATE_EXECUTOR 1
    DEACTIVATE_EXECUTOR 2
    DEACTIVATE_EXECUTOR 3
    DEACTIVATE_EXECUTOR 4
    IDLE_WHILE_SEQUENCE_PLAYING 0
    EXECUTE_SUBROUTINE .exit_cutscene

.cs852_ascent_with_wife:
    SET_OTHER_EXECUTOR_PTR 0, .face_west
    SET_OTHER_EXECUTOR_PTR 1, .face_southwest
    SET_OTHER_EXECUTOR_PTR 21, .cs852_king_wife_pos
    SET_ENTITY_PHYSICS_FLAGS 0
    SET_COORDINATES -176, 96, 48
    SET_ASSET_ROTATION 0
    SET_WAIT_FRAMES 1
    UPDATE_GLOBAL_RGBA 255, 255, 255, 255, 8
    WAIT_RGBA_FINISHED
    SET_WAIT_FRAMES 15
    INIT_MESSAGE_BOX_TYPE1 0, SOWING_FESTIVAL_TEXT_INDEX, 9
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 35, .cs850_helper_rise_delta
    SET_OTHER_EXECUTOR_PTR 36, .cs850_helper_rise_delta
    SET_OTHER_EXECUTOR_PTR 40, .cs850_helper_rise_delta
    SET_FRAME_DELTA 0, 1, 1, 40
    SET_FRAME_DELTA 0, 2, 1, 200
    SET_OTHER_EXECUTOR_PTR 21, .cs852_king_dispatch_assistant
    DEACTIVATE_SELF
