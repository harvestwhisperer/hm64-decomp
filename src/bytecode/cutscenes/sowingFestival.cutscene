; ============================================================
; Cutscene 851 - SOWING_FESTIVAL_PLAYER
; Player is the King and must choose an assistant. Each NPC
; gets a yes/no dialogue; pick-0 accepts, pick-1 re-enters
; the wait loop. Once an NPC accepts, var0 bit is set and the
; balloon-ascent sequence (executor_41_126ABC) dispatches the
; matching overlay line.
; ============================================================

; ----- Dispatch and conditional-spawn branches -----
; Same affection / lifeEventBits gating as cs850 but each NPC is its
; own cs851 executor (positions and dialogue lines differ from cs850).

.cs_player_king:
    UPDATE_U8_VALUE 10, 255, gHappiness
    SPAWN_EXECUTOR 1, .cs851_mayor
    SPAWN_EXECUTOR 2, .cs851_mayor_wife
    SPAWN_EXECUTOR 3, .cs851_ann
    SPAWN_EXECUTOR 4, .cs851_maria
    SPAWN_EXECUTOR 5, .cs851_lillia
    SPAWN_EXECUTOR 6, .cs851_potion_shop_dealer
    SPAWN_EXECUTOR 7, .cs851_kent
    SPAWN_EXECUTOR 8, .cs851_stu
    SPAWN_EXECUTOR 9, .cs851_may
    SPAWN_EXECUTOR 10, .cs851_popuri
    SPAWN_EXECUTOR 11, .cs851_elli
    SPAWN_EXECUTOR 12, .cs851_rick
    SPAWN_EXECUTOR 13, .cs851_pastor
    BRANCH_ON_SPECIAL_BIT 13, lifeEventBits[1], .cs851_spawn_festival_items
    BRANCH_U8_VAR_WITHIN_RANGE 100, 255, npcAffection[CLIFF], .cs851_spawn_cliff_pair

.cs851_spawn_festival_items:
    SPAWN_EXECUTOR 22, .sparkle_static_22
    SPAWN_EXECUTOR 23, .sparkle_static_23
    SPAWN_EXECUTOR 24, .sparkle_static_24
    SPAWN_EXECUTOR 26, .sparkle_static_26
    SPAWN_EXECUTOR 27, .sparkle_static_27
    SPAWN_EXECUTOR 28, .sparkle_static_28
    SPAWN_EXECUTOR 29, .sparkle_static_29
    SPAWN_EXECUTOR 30, .sparkle_static_30
    SPAWN_EXECUTOR 31, .sparkle_static_31
    SPAWN_EXECUTOR 32, .sparkle_static_32
    SPAWN_EXECUTOR 33, .sparkle_static_33
    SPAWN_EXECUTOR 40, .festival_item_overlay
    SPAWN_EXECUTOR 41, .king_balloon_anchor
    EXECUTE_SUBROUTINE .cs851_player_king_dispatch

.cs851_spawn_harris_pair:
    SPAWN_EXECUTOR 14, .cs851_harris
    SPAWN_EXECUTOR 34, .sparkle_static_34
    RETURN_FROM_SUBROUTINE

.cs851_spawn_gray_pair:
    SPAWN_EXECUTOR 15, .cs851_gray
    SPAWN_EXECUTOR 35, .sparkle_static_35
    RETURN_FROM_SUBROUTINE

.cs851_spawn_jeff_pair:
    SPAWN_EXECUTOR 16, .cs851_jeff
    SPAWN_EXECUTOR 36, .sparkle_static_36
    RETURN_FROM_SUBROUTINE

.cs851_spawn_cliff_pair:
    SPAWN_EXECUTOR 17, .cs851_cliff
    SPAWN_EXECUTOR 37, .sparkle_static_37
    RETURN_FROM_SUBROUTINE

.cs851_spawn_kai_pair:
    SPAWN_EXECUTOR 18, .cs851_kai
    SPAWN_EXECUTOR 38, .sparkle_static_38
    RETURN_FROM_SUBROUTINE

.cs851_spawn_karen_pair:
    SPAWN_EXECUTOR 19, .cs851_karen
    SET_WAIT_FRAMES 1
    SPAWN_EXECUTOR 39, .sparkle_static_39
    RETURN_FROM_SUBROUTINE

.cs851_spawn_basil_solo:
    SPAWN_EXECUTOR 20, .cs851_basil
    RETURN_FROM_SUBROUTINE

.cs851_player_king_dispatch:
    EXECUTE_SUBROUTINE .setup_player
    SET_COORDINATES -80, 0, -32
    SET_ASSET_ROTATION 2
    SET_WAIT_FRAMES 5
    BRANCH_U8_VAR_WITHIN_RANGE 100, 255, npcAffection[HARRIS], .cs851_spawn_harris_pair
    BRANCH_U8_VAR_WITHIN_RANGE 100, 255, npcAffection[GRAY], .cs851_spawn_gray_pair
    BRANCH_U8_VAR_WITHIN_RANGE 100, 255, npcAffection[JEFF], .cs851_spawn_jeff_pair
    BRANCH_ON_SPECIAL_BIT 14, lifeEventBits[1], .cs851_check_karen
    BRANCH_U8_VAR_WITHIN_RANGE 100, 255, npcAffection[KAI], .cs851_spawn_kai_pair

.cs851_check_karen:
    BRANCH_ON_SPECIAL_BIT 15, lifeEventBits[1], .cs851_check_basil
    BRANCH_U8_VAR_WITHIN_RANGE 100, 255, npcAffection[KAREN], .cs851_spawn_karen_pair

.cs851_check_basil:
    BRANCH_ON_SPECIAL_BIT 12, lifeEventBits[1], .cs851_no_assistant_ending
    BRANCH_U8_VAR_WITHIN_RANGE 100, 255, npcAffection[NPC_BASIL], .cs851_spawn_basil_solo

.cs851_no_assistant_ending:
    SET_WAIT_FRAMES 5
    UPDATE_GLOBAL_RGBA 255, 255, 255, 255, 8
    SET_WAIT_FRAMES 32
    INIT_MESSAGE_BOX_TYPE1 0, SOWING_FESTIVAL_TEXT_INDEX, 8
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    WAIT_RGBA_FINISHED
    SET_ENTITY_MAP_SPACE_INDEPENDENT FALSE
    DEACTIVATE_SELF

; ----- cs851 Villager Executors (slots 1..20) -----
; NPCs eligible to be asked as assistant use a 3-state dialogue shape:
;   `<npc>_wait`          - idle
;   `<npc>_on_interact`   - affection bump (guarded by var1 bit)
;   `<npc>_dialogue`      - yes/no prompt
;   `<npc>_accept`        - yes path: set var0 bit N, fade, respawn
;                           the NPC as `<npc>_in_balloon` (slot 23..39)
;   `<npc>_decline`       - no path: return to wait state
; NPCs without an accept option (Mayor, Mayor-wife, Lillia, Potion
; Shop Dealer, Stu, Rick, Pastor, Basil) keep just `_wait` / `_on_interact`.

.cs851_mayor:
    EXECUTE_SUBROUTINE .setup_mayor
    SET_COORDINATES -144, 0, -48

.cs851_mayor_wait:
    SET_ASSET_ROTATION 6
    SET_CALLBACK_ROUTINE 0, 32768, .cs851_mayor_on_interact
    EXECUTE_SUBROUTINE .wait_loop

.cs851_mayor_on_interact:
    EXECUTE_SUBROUTINE .setup_message_box
    PAUSE_ENTITY 0
    FLIP_ENTITY_DIRECTION 0
    INIT_MESSAGE_BOX_TYPE1 0, SOWING_FESTIVAL_TEXT_INDEX, 86
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITY 0
    BRANCH_ON_SPECIAL_BIT 0, var1, .cs851_mayor_wait
    UPDATE_U8_VALUE 2, 255, npcAffection[NPC_MAYOR]
    SET_SPECIAL_BIT 0, var1
    EXECUTE_SUBROUTINE .cs851_mayor_wait

.cs851_mayor_wife:
    EXECUTE_SUBROUTINE .setup_mayor_wife
    SET_COORDINATES -192, 0, -128

.cs851_mayor_wife_wait:
    SET_ASSET_ROTATION 0
    SET_CALLBACK_ROUTINE 0, 32768, .cs851_mayor_wife_on_interact
    EXECUTE_SUBROUTINE .wait_loop

.cs851_mayor_wife_on_interact:
    EXECUTE_SUBROUTINE .setup_message_box
    PAUSE_ENTITY 0
    FLIP_ENTITY_DIRECTION 0
    INIT_MESSAGE_BOX_TYPE1 0, SOWING_FESTIVAL_TEXT_INDEX, 11
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITY 0
    BRANCH_ON_SPECIAL_BIT 1, var1, .cs851_mayor_wife_wait
    UPDATE_U8_VALUE 2, 255, npcAffection[NPC_MAYOR_WIFE]
    SET_SPECIAL_BIT 1, var1
    EXECUTE_SUBROUTINE .cs851_mayor_wife_wait

.cs851_ann:
    EXECUTE_SUBROUTINE .setup_ann
    SET_COORDINATES -96, 0, -160

.cs851_ann_wait:
    SET_ASSET_ROTATION 0
    SET_CALLBACK_ROUTINE 0, 32768, .cs851_ann_on_interact
    EXECUTE_SUBROUTINE .wait_loop

.cs851_ann_on_interact:
    EXECUTE_SUBROUTINE .setup_message_box
    BRANCH_ON_SPECIAL_BIT 2, var1, .cs851_ann_dialogue
    UPDATE_U8_VALUE 2, 255, npcAffection[ANN]
    SET_SPECIAL_BIT 2, var1

.cs851_ann_dialogue:
    PAUSE_ENTITY 0
    FLIP_ENTITY_DIRECTION 0
    INIT_DIALOGUE_SESSION 0, DIALOGUE_TEXT_55, 11
    WAIT_FOR_DIALOGUE_INPUT 0
    BRANCH_ON_DIALOGUE 0, 0, .cs851_ann_accept
    BRANCH_ON_DIALOGUE 0, 1, .cs851_ann_decline

.cs851_ann_accept:
    SET_SPECIAL_BIT 3, var0
    INIT_MESSAGE_BOX_TYPE1 0, SOWING_FESTIVAL_TEXT_INDEX, 48
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    UPDATE_U8_VALUE 8, 255, npcAffection[ANN]
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    DEACTIVATE_EXECUTOR 23
    SET_WAIT_FRAMES 1
    SPAWN_EXECUTOR 23, .cs851_ann_in_balloon
    DEACTIVATE_SELF

.cs851_ann_decline:
    TOGGLE_PAUSE_ENTITY 0
    EXECUTE_SUBROUTINE .cs851_ann_wait

.cs851_ann_in_balloon:
    SET_WAIT_FRAMES 1
    SET_SHADOW_FLAGS 4, 255
    EXECUTE_SUBROUTINE .setup_ann
    EXECUTE_SUBROUTINE .cs851_ascent_start

