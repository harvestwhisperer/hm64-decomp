.cs851_player_reattach:
    EXECUTE_SUBROUTINE .setup_player
    TOGGLE_PAUSE_ENTITY 0
    DEACTIVATE_SELF

.cs851_player_balloon_pos:
    SET_SHADOW_FLAGS 0, 255
    EXECUTE_SUBROUTINE .setup_player
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_PHYSICS_FLAGS 0
    TOGGLE_PAUSE_ENTITY 0
    SET_ASSET_ROTATION 0
    SET_COORDINATES -176, 96, 48
    EXECUTE_SUBROUTINE .wait_loop

; ----- cs851 Ascent transition -----
; Called by every NPC accept-path. Deactivates the ground-scene
; executors, fades, then keeps only the accepting-NPC in-balloon
; executor alive via the `.cs851_keep_*_in` chain (one per var0 bit).
; Finally spawns the balloon scene (`.cs851_balloon_scene_begin`).

.cs851_ascent_start:
    DEACTIVATE_EXECUTOR 20
    DEACTIVATE_EXECUTOR 41
    SET_WAIT_FRAMES 1
    SPAWN_EXECUTOR 41, .king_balloon_sprite
    SPAWN_EXECUTOR 0, .cs851_player_reattach
    SET_WAIT_FRAMES 1
    SPAWN_EXECUTOR 0, .cs851_player_balloon_pos
    SET_OTHER_EXECUTOR_PTR 1, .face_southwest
    SPAWN_EXECUTOR 20, .cs851_balloon_map_anchor
    SET_ENTITY_PHYSICS_FLAGS 0
    SET_COORDINATES -160, 96, 32
    SET_ASSET_ROTATION 6
    SET_WAIT_FRAMES 1
    UPDATE_GLOBAL_RGBA 255, 255, 255, 255, 8
    WAIT_RGBA_FINISHED
    SET_WAIT_FRAMES 15
    INIT_MESSAGE_BOX_TYPE1 0, SOWING_FESTIVAL_TEXT_INDEX, 9
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 0, .cs851_balloon_drift_delta
    SET_WAIT_FRAMES 1
    SET_OTHER_EXECUTOR_PTR 40, .cs851_balloon_drift_delta
    SET_OTHER_EXECUTOR_PTR 41, .cs851_balloon_drift_delta
    SET_FRAME_DELTA 0, 1, 1, 40
    SET_FRAME_DELTA 0, 2, 1, 200
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    DEACTIVATE_EXECUTOR 1
    DEACTIVATE_EXECUTOR 2
    DEACTIVATE_EXECUTOR 3
    DEACTIVATE_EXECUTOR 4
    DEACTIVATE_EXECUTOR 5
    DEACTIVATE_EXECUTOR 6
    DEACTIVATE_EXECUTOR 7
    DEACTIVATE_EXECUTOR 8
    DEACTIVATE_EXECUTOR 9
    DEACTIVATE_EXECUTOR 10
    DEACTIVATE_EXECUTOR 11
    DEACTIVATE_EXECUTOR 12
    DEACTIVATE_EXECUTOR 13
    DEACTIVATE_EXECUTOR 14
    DEACTIVATE_EXECUTOR 15
    DEACTIVATE_EXECUTOR 16
    DEACTIVATE_EXECUTOR 17
    DEACTIVATE_EXECUTOR 18
    DEACTIVATE_EXECUTOR 19
    DEACTIVATE_EXECUTOR 20
    DEACTIVATE_EXECUTOR 21
    DEACTIVATE_EXECUTOR 22
    BRANCH_ON_SPECIAL_BIT 3, var0, .cs851_keep_ann_in
    DEACTIVATE_EXECUTOR 23

.cs851_keep_ann_in:
    BRANCH_ON_SPECIAL_BIT 0, var0, .cs851_keep_maria_in
    DEACTIVATE_EXECUTOR 24

.cs851_keep_maria_in:
    DEACTIVATE_EXECUTOR 25
    DEACTIVATE_EXECUTOR 26
    BRANCH_ON_SPECIAL_BIT 10, var0, .cs851_keep_kent_in
    DEACTIVATE_EXECUTOR 27

.cs851_keep_kent_in:
    DEACTIVATE_EXECUTOR 28
    BRANCH_ON_SPECIAL_BIT 11, var0, .cs851_keep_popuri_in
    DEACTIVATE_EXECUTOR 29

.cs851_keep_popuri_in:
    BRANCH_ON_SPECIAL_BIT 1, var0, .cs851_keep_elli_in
    DEACTIVATE_EXECUTOR 30

.cs851_keep_elli_in:
    BRANCH_ON_SPECIAL_BIT 2, var0, .cs851_keep_harris_in
    DEACTIVATE_EXECUTOR 31

.cs851_keep_harris_in:
    DEACTIVATE_EXECUTOR 32
    DEACTIVATE_EXECUTOR 33
    BRANCH_ON_SPECIAL_BIT 5, var0, .cs851_keep_gray_in
    DEACTIVATE_EXECUTOR 34

.cs851_keep_gray_in:
    BRANCH_ON_SPECIAL_BIT 6, var0, .cs851_keep_jeff_in
    DEACTIVATE_EXECUTOR 35

.cs851_keep_jeff_in:
    BRANCH_ON_SPECIAL_BIT 7, var0, .cs851_keep_cliff_in
    DEACTIVATE_EXECUTOR 36

.cs851_keep_cliff_in:
    BRANCH_ON_SPECIAL_BIT 8, var0, .cs851_keep_kai_in
    DEACTIVATE_EXECUTOR 37

.cs851_keep_kai_in:
    BRANCH_ON_SPECIAL_BIT 9, var0, .cs851_keep_karen_in
    DEACTIVATE_EXECUTOR 38

.cs851_keep_karen_in:
    BRANCH_ON_SPECIAL_BIT 4, var0, .cs851_balloon_scene_begin
    DEACTIVATE_EXECUTOR 39

.cs851_balloon_scene_begin:
    DEACTIVATE_EXECUTOR 40
    DEACTIVATE_EXECUTOR 41
    SET_WAIT_FRAMES 1
    SET_OTHER_EXECUTOR_PTR 0, .cs851_player_reposition
    SPAWN_EXECUTOR 1, .cs851_bg_left_scroll
    SPAWN_EXECUTOR 2, .cs851_bg_right_scroll
    SPAWN_EXECUTOR 3, .festival_item_overlay
    SPAWN_EXECUTOR 4, .king_balloon_sprite
    SPAWN_EXECUTOR 41, .cs851_balloon_announcer
    SET_SPECIAL_BIT 20, dailyEventBits[1]
    SET_COORDINATES -160, 96, 32
    SET_WAIT_FRAMES 1
    UPDATE_GLOBAL_RGBA 255, 255, 255, 255, 8
    SET_OTHER_EXECUTOR_PTR 0, .cs851_balloon_bob_loop
    SET_OTHER_EXECUTOR_PTR 3, .cs851_balloon_bob_loop
    SET_OTHER_EXECUTOR_PTR 4, .cs851_balloon_bob_loop
    SET_WAIT_FRAMES 1
    EXECUTE_SUBROUTINE .cs851_balloon_bob_loop

.cs851_balloon_drift_delta:
    SET_FRAME_DELTA 0, 1, 1, 40
    SET_FRAME_DELTA 0, 2, 1, 200
    EXECUTE_SUBROUTINE .wait_loop

.cs851_balloon_map_anchor:
    SETUP_MAP_ASSET MAIN_MAP_INDEX
    SET_ASSET_ROTATION 7
    SET_COORDINATES -160, 96, 40
    EXECUTE_SUBROUTINE .wait_loop

.cs851_player_reposition:
    SET_COORDINATES -176, 96, 48
    EXECUTE_SUBROUTINE .wait_loop

.cs851_balloon_bob_loop:
    SET_FRAME_DELTA 1, 0, 1, 1
    SET_WAIT_FRAMES 2
    SET_FRAME_DELTA 1, 0, 1, 1
    SET_WAIT_FRAMES 2
    SET_FRAME_DELTA 1, 0, 1, 1
    SET_WAIT_FRAMES 2
    SET_FRAME_DELTA 1, 0, 1, 1
    SET_WAIT_FRAMES 2
    SET_FRAME_DELTA 1, 0, 1, 1
    SET_WAIT_FRAMES 2
    SET_FRAME_DELTA 1, 0, 1, 1
    SET_WAIT_FRAMES 15
    SET_FRAME_DELTA -1, 0, -1, 1
    SET_WAIT_FRAMES 2
    SET_FRAME_DELTA -1, 0, -1, 1
    SET_WAIT_FRAMES 2
    SET_FRAME_DELTA -1, 0, -1, 1
    SET_WAIT_FRAMES 2
    SET_FRAME_DELTA -1, 0, -1, 1
    SET_WAIT_FRAMES 2
    SET_FRAME_DELTA -1, 0, -1, 1
    SET_WAIT_FRAMES 2
    SET_FRAME_DELTA -1, 0, -1, 1
    SET_WAIT_FRAMES 15
    EXECUTE_SUBROUTINE .cs851_balloon_bob_loop

; ----- cs851 Balloon-scene announcer (executor slot 41) -----
; Inspects var0 bits to emit the NPC-specific "in the balloon" overlay
; line. Exactly one bit is set (whichever NPC accepted earlier), so the
; fan-out always falls through to one announce branch. After the line,
; spawns the holdableItems sprites, scrolls the backgrounds, fades,
; and exits the cutscene.

.cs851_balloon_announcer:
    SET_WAIT_FRAMES 120
    BRANCH_ON_SPECIAL_BIT 0, var0, .cs851_announce_maria
    BRANCH_ON_SPECIAL_BIT 1, var0, .cs851_announce_popuri
    BRANCH_ON_SPECIAL_BIT 2, var0, .cs851_announce_elli
    BRANCH_ON_SPECIAL_BIT 3, var0, .cs851_announce_ann
    BRANCH_ON_SPECIAL_BIT 4, var0, .cs851_announce_karen
    BRANCH_ON_SPECIAL_BIT 5, var0, .cs851_announce_harris
    BRANCH_ON_SPECIAL_BIT 6, var0, .cs851_announce_gray
    BRANCH_ON_SPECIAL_BIT 7, var0, .cs851_announce_jeff
    BRANCH_ON_SPECIAL_BIT 8, var0, .cs851_announce_cliff
    BRANCH_ON_SPECIAL_BIT 9, var0, .cs851_announce_kai
    BRANCH_ON_SPECIAL_BIT 10, var0, .cs851_announce_kent
    BRANCH_ON_SPECIAL_BIT 11, var0, .cs851_announce_may
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_WAIT_FRAMES 30
    SPAWN_EXECUTOR 5, .cs851_asc_sprite_5
    SPAWN_EXECUTOR 6, .cs851_asc_sprite_6
    SPAWN_EXECUTOR 7, .cs851_asc_sprite_7
    SPAWN_EXECUTOR 8, .cs851_asc_sprite_8
    SPAWN_EXECUTOR 9, .cs851_asc_sprite_9
    SPAWN_EXECUTOR 10, .cs851_asc_sprite_10
    SPAWN_EXECUTOR 11, .cs851_asc_sprite_11
    SPAWN_EXECUTOR 12, .cs851_asc_sprite_12
    SET_WAIT_FRAMES 211
    SET_OTHER_EXECUTOR_PTR 1, .cs851_bg_left_fade_out
    SET_OTHER_EXECUTOR_PTR 2, .cs851_bg_right_fade_out
    SET_WAIT_FRAMES 1
    SET_AUDIO_SEQUENCE_VOLUME 0, 0, 2
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    SET_WAIT_FRAMES 40
    STOP_SEQUENCE_WITH_FADE 0, 1
    DEACTIVATE_EXECUTOR 1
    DEACTIVATE_EXECUTOR 2
    DEACTIVATE_EXECUTOR 3
    DEACTIVATE_EXECUTOR 4
    DEACTIVATE_EXECUTOR 5
    DEACTIVATE_EXECUTOR 6
    DEACTIVATE_EXECUTOR 7
    DEACTIVATE_EXECUTOR 8
    DEACTIVATE_EXECUTOR 9
    DEACTIVATE_EXECUTOR 10
    DEACTIVATE_EXECUTOR 11
    DEACTIVATE_EXECUTOR 12
    DEACTIVATE_EXECUTOR 23
    DEACTIVATE_EXECUTOR 24
    DEACTIVATE_EXECUTOR 27
    DEACTIVATE_EXECUTOR 29
    DEACTIVATE_EXECUTOR 30
    DEACTIVATE_EXECUTOR 31
    DEACTIVATE_EXECUTOR 34
    DEACTIVATE_EXECUTOR 35
    DEACTIVATE_EXECUTOR 36
    DEACTIVATE_EXECUTOR 37
    DEACTIVATE_EXECUTOR 38
    DEACTIVATE_EXECUTOR 39
    DEACTIVATE_EXECUTOR 0
    IDLE_WHILE_SEQUENCE_PLAYING 0
    EXECUTE_SUBROUTINE .exit_cutscene

.cs851_announce_maria:
    CLEAR_SPECIAL_BIT 0, var0
    INIT_MESSAGE_BOX_TYPE2 0, SOWING_FESTIVAL_TEXT_INDEX, 34
    RETURN_FROM_SUBROUTINE

.cs851_announce_popuri:
    CLEAR_SPECIAL_BIT 1, var0
    INIT_MESSAGE_BOX_TYPE2 0, SOWING_FESTIVAL_TEXT_INDEX, 39
    RETURN_FROM_SUBROUTINE

.cs851_announce_elli:
    CLEAR_SPECIAL_BIT 2, var0
    INIT_MESSAGE_BOX_TYPE2 0, SOWING_FESTIVAL_TEXT_INDEX, 44
    RETURN_FROM_SUBROUTINE

.cs851_announce_ann:
    CLEAR_SPECIAL_BIT 3, var0
    INIT_MESSAGE_BOX_TYPE2 0, SOWING_FESTIVAL_TEXT_INDEX, 49
    RETURN_FROM_SUBROUTINE

.cs851_announce_karen:
    CLEAR_SPECIAL_BIT 4, var0
    INIT_MESSAGE_BOX_TYPE2 0, SOWING_FESTIVAL_TEXT_INDEX, 59
    RETURN_FROM_SUBROUTINE

.cs851_announce_harris:
    CLEAR_SPECIAL_BIT 5, var0
    INIT_MESSAGE_BOX_TYPE2 0, SOWING_FESTIVAL_TEXT_INDEX, 63
    RETURN_FROM_SUBROUTINE

.cs851_announce_gray:
    CLEAR_SPECIAL_BIT 6, var0
    INIT_MESSAGE_BOX_TYPE2 0, SOWING_FESTIVAL_TEXT_INDEX, 67
    RETURN_FROM_SUBROUTINE

.cs851_announce_jeff:
    CLEAR_SPECIAL_BIT 7, var0
    INIT_MESSAGE_BOX_TYPE2 0, SOWING_FESTIVAL_TEXT_INDEX, 71
    RETURN_FROM_SUBROUTINE

.cs851_announce_cliff:
    CLEAR_SPECIAL_BIT 8, var0
    INIT_MESSAGE_BOX_TYPE2 0, SOWING_FESTIVAL_TEXT_INDEX, 75
    RETURN_FROM_SUBROUTINE

.cs851_announce_kai:
    CLEAR_SPECIAL_BIT 9, var0
    INIT_MESSAGE_BOX_TYPE2 0, SOWING_FESTIVAL_TEXT_INDEX, 79
    RETURN_FROM_SUBROUTINE

.cs851_announce_kent:
    CLEAR_SPECIAL_BIT 10, var0
    INIT_MESSAGE_BOX_TYPE2 0, SOWING_FESTIVAL_TEXT_INDEX, 23
    RETURN_FROM_SUBROUTINE

.cs851_announce_may:
    CLEAR_SPECIAL_BIT 11, var0
    INIT_MESSAGE_BOX_TYPE2 0, SOWING_FESTIVAL_TEXT_INDEX, 30
    RETURN_FROM_SUBROUTINE

.cs851_bg_left_fade_out:
    UPDATE_RGBA 0, 0, 0, 0, 8
    EXECUTE_SUBROUTINE .cs851_bg_left_scroll_step_b

.cs851_bg_right_fade_out:
    UPDATE_RGBA 0, 0, 0, 0, 8
    EXECUTE_SUBROUTINE .cs851_bg_right_scroll_step_b

.cs851_bg_left_scroll:
    DMA_SPRITE 150, 0, _moonMountainBackgroundTextureSegmentRomStart, _moonMountainBackgroundTextureSegmentRomEnd, _moonMountainBackgroundAssetsIndexSegmentRomStart, _moonMountainBackgroundAssetsIndexSegmentRomEnd, 0, 0, 0x80261000, 0, 0x80266000, 0x80266100, 0x80266300, 0x80266400
    SET_ANIM_DATA_PTR_WITH_FLAG .anim_126F48
    SET_COORDINATES 160, -120, -15
    SET_SPRITE_SCALE 2, 2, 0
    SET_RGBA 0, 0, 0, 0
    SET_WAIT_FRAMES 1
    UPDATE_RGBA 255, 255, 255, 255, 8
    SET_U16_VALUE 0, D_80189824

.cs851_bg_left_scroll_step_a:
    SET_FRAME_DELTA 1, 0, 0, 1
    SET_WAIT_FRAMES 2
    UPDATE_U16_VALUE 1, 9999, D_80189824
    BRANCH_U16_VAR_WITHIN_RANGE 160, 160, D_80189824, .cs851_bg_left_wrap
    EXECUTE_SUBROUTINE .cs851_bg_left_scroll_step_a

.cs851_bg_left_wrap:
    SET_COORDINATES -320, -120, -15
    SET_U16_VALUE 0, D_80189824

.cs851_bg_left_scroll_step_b:
    SET_FRAME_DELTA 1, 0, 0, 1
    SET_WAIT_FRAMES 2
    UPDATE_U16_VALUE 1, 9999, D_80189824
    BRANCH_U16_VAR_WITHIN_RANGE 640, 640, D_80189824, .cs851_bg_left_wrap
    EXECUTE_SUBROUTINE .cs851_bg_left_scroll_step_b

.cs851_bg_right_scroll:
    DMA_SPRITE 151, 0, _moonMountainBackgroundTextureSegmentRomStart, _moonMountainBackgroundTextureSegmentRomEnd, _moonMountainBackgroundAssetsIndexSegmentRomStart, _moonMountainBackgroundAssetsIndexSegmentRomEnd, 0, 0, 0x80261000, 0, 0x80266000, 0x80266100, 0x80266300, 0x80266400
    SET_ANIM_DATA_PTR_WITH_FLAG .anim_126F48
    SET_COORDINATES -160, -120, -15
    SET_SPRITE_SCALE 2, 2, 0
    SET_RGBA 0, 0, 0, 0
    SET_WAIT_FRAMES 1
    UPDATE_RGBA 255, 255, 255, 255, 8
    SET_U16_VALUE 0, D_801886D2

.cs851_bg_right_scroll_step_a:
    SET_FRAME_DELTA 1, 0, 0, 1
    SET_WAIT_FRAMES 2
    UPDATE_U16_VALUE 1, 9999, D_801886D2
    BRANCH_U16_VAR_WITHIN_RANGE 480, 480, D_801886D2, .cs851_bg_right_wrap
    EXECUTE_SUBROUTINE .cs851_bg_right_scroll_step_a

.cs851_bg_right_wrap:
    SET_COORDINATES -320, -120, -15
    SET_U16_VALUE 0, D_801886D2

.cs851_bg_right_scroll_step_b:
    SET_FRAME_DELTA 1, 0, 0, 1
    SET_WAIT_FRAMES 2
    UPDATE_U16_VALUE 1, 9999, D_801886D2
    BRANCH_U16_VAR_WITHIN_RANGE 640, 640, D_801886D2, .cs851_bg_right_wrap
    EXECUTE_SUBROUTINE .cs851_bg_right_scroll_step_b

.cs851_asc_sprite_5:
    DMA_SPRITE 157, 1, _holdableItemsTextureSegmentRomStart, _holdableItemsTextureSegmentRomEnd, _holdableItemsAssetsIndexSegmentRomStart, _holdableItemsAssetsIndexSegmentRomEnd, _holdableItemsSpritesheetIndexSegmentRomStart, _holdableItemsSpritesheetIndexSegmentRomEnd, 0x802BBE50, 0x802BC250, 0x802C8650, 0x802CAE50, 0x802CE350, 0x802CE550
    SET_ANIM_DATA_PTR_WITH_FLAG .anim_126F54
    SET_COORDINATES 250, -250, 255
    SET_SPRITE_PALETTE 102
    SET_RGBA 255, 255, 255, 255
    SET_FRAME_DELTA -1, 1, 0, 212
    UPDATE_RGBA 0, 0, 0, 0, 8
    SET_FRAME_DELTA -1, 1, 0, 32
    EXECUTE_SUBROUTINE .wait_loop

.cs851_asc_sprite_6:
    DMA_SPRITE 158, 1, _holdableItemsTextureSegmentRomStart, _holdableItemsTextureSegmentRomEnd, _holdableItemsAssetsIndexSegmentRomStart, _holdableItemsAssetsIndexSegmentRomEnd, _holdableItemsSpritesheetIndexSegmentRomStart, _holdableItemsSpritesheetIndexSegmentRomEnd, 0x802BC650, 0x802BCA50, 0x802C8650, 0x802CAE50, 0x802CE350, 0x802CE550
