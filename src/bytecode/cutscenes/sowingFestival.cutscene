    SET_WAIT_FRAMES 1
    SPAWN_EXECUTOR 36, .cs851_jeff_in_balloon
    DEACTIVATE_SELF

.cs851_jeff_decline:
    TOGGLE_PAUSE_ENTITY 0
    EXECUTE_SUBROUTINE .cs851_jeff_wait

.cs851_jeff_in_balloon:
    SET_WAIT_FRAMES 1
    SET_SHADOW_FLAGS 9, 255
    EXECUTE_SUBROUTINE .setup_jeff
    EXECUTE_SUBROUTINE .cs851_ascent_start

.cs851_cliff:
    EXECUTE_SUBROUTINE .setup_cliff
    SET_COORDINATES -96, 0, 256

.cs851_cliff_wait:
