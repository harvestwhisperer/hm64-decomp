; ----- Festival / King-balloon props -----
; Three fixed-position props: the festival-items overlay (entity 44),
; a static item anchored near the king at anim 107, and the same anim
; spawned in slot 41 for cs850 lift tracking.

.festival_item_overlay:
    SET_SHADOW_FLAGS 92, 1
    SETUP_ENTITY 44, ENTITY_ASSET_EXTRA_FESTIVAL_ITEMS, 1
    SET_ENTITY_ANIMATIONS 44, 0, 0, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_PHYSICS_FLAGS 0
    SET_COORDINATES -160, 192, 48
    SET_ENTITY_ANIMATION 0
    EXECUTE_SUBROUTINE .wait_loop

.king_balloon_sprite:
    SET_SHADOW_FLAGS 93, 255
    SETUP_ENTITY 43, ENTITY_ASSET_STATIC_ITEM, 1
    SET_ENTITY_ANIMATIONS 43, 0, 0, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_PHYSICS_FLAGS 0
    SET_COORDINATES -168, 85, 40
    SET_ENTITY_ANIMATION 107
    EXECUTE_SUBROUTINE .wait_loop

.king_balloon_anchor:
    SETUP_ENTITY 43, ENTITY_ASSET_STATIC_ITEM, 1
    SET_ENTITY_ANIMATIONS 43, 0, 0, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_COORDINATES -160, 0, 48
    SET_ENTITY_DIMENSIONS 32, 32
    SET_ENTITY_ANIMATION 107
    EXECUTE_SUBROUTINE .wait_loop

; ----- cs850 In-balloon sprites (DMA + RGBA fade cycle) -----
; Drawn after the ascent fade completes. The background plate
; (moonMountainBackgroundTextureSegment) draws first, then eight
; holdableItems sprites fade in/out on timers with palettes 99..103.

.asc_bg_plate:
    DMA_SPRITE 96, 0, _moonMountainBackgroundTextureSegmentRomStart, _moonMountainBackgroundTextureSegmentRomEnd, _moonMountainBackgroundAssetsIndexSegmentRomStart, _moonMountainBackgroundAssetsIndexSegmentRomEnd, 0, 0, 0x80261000, 0, 0x80266000, 0x80266100, 0x80266300, 0x80266400
    SET_ANIM_DATA_PTR_WITH_FLAG .anim_126F48
    SET_COORDINATES 0, -120, 254
    SET_SPRITE_SCALE 2, 2, 0
    SET_RGBA 0, 0, 0, 0
    SET_WAIT_FRAMES 1
    UPDATE_RGBA 255, 255, 255, 255, 8
    WAIT_RGBA_FINISHED
    SET_WAIT_FRAMES 180
    UPDATE_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    EXECUTE_SUBROUTINE .wait_loop

.asc_sprite_a:
    DMA_SPRITE 97, 1, _holdableItemsTextureSegmentRomStart, _holdableItemsTextureSegmentRomEnd, _holdableItemsAssetsIndexSegmentRomStart, _holdableItemsAssetsIndexSegmentRomEnd, _holdableItemsSpritesheetIndexSegmentRomStart, _holdableItemsSpritesheetIndexSegmentRomEnd, 0x802BBE50, 0x802BC250, 0x802C8650, 0x802CAE50, 0x802CE350, 0x802CE550
    SET_ANIM_DATA_PTR_WITH_FLAG .anim_126F54
    SET_COORDINATES 160, -160, 255
    SET_SPRITE_PALETTE 99
    SET_RGBA 0, 0, 0, 0
    SET_WAIT_FRAMES 1
    UPDATE_RGBA 255, 255, 255, 255, 8
    SET_FRAME_DELTA -1, 1, 0, 212
    UPDATE_RGBA 0, 0, 0, 0, 8
    SET_FRAME_DELTA -1, 1, 0, 32
    EXECUTE_SUBROUTINE .wait_loop

