    WAIT_FOR_DIALOGUE_INPUT 0
    BRANCH_ON_DIALOGUE 0, 0, .cs851_kai_accept
    BRANCH_ON_DIALOGUE 0, 1, .cs851_kai_decline

.cs851_kai_accept:
    SET_SPECIAL_BIT 9, var0
    INIT_MESSAGE_BOX_TYPE1 0, SOWING_FESTIVAL_TEXT_INDEX, 77
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    UPDATE_U8_VALUE 8, 255, npcAffection[KAI]
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    DEACTIVATE_EXECUTOR 38
    SET_WAIT_FRAMES 1
    SPAWN_EXECUTOR 38, .cs851_kai_in_balloon
    DEACTIVATE_SELF

.cs851_kai_decline:
    TOGGLE_PAUSE_ENTITY 0
    EXECUTE_SUBROUTINE .cs851_kai_wait

.cs851_kai_in_balloon:
    SET_WAIT_FRAMES 1
    SET_SHADOW_FLAGS 11, 255
    EXECUTE_SUBROUTINE .setup_kai
    EXECUTE_SUBROUTINE .cs851_ascent_start

.cs851_karen:
    EXECUTE_SUBROUTINE .setup_karen
    SET_ENTITY_NON_COLLIDABLE
    SET_COORDINATES 128, 0, -288

.cs851_karen_wait:
    SET_ASSET_ROTATION 0
    SET_CALLBACK_ROUTINE 0, 32768, .cs851_karen_on_interact
    EXECUTE_SUBROUTINE .wait_loop

.cs851_karen_on_interact:
    EXECUTE_SUBROUTINE .setup_message_box
    BRANCH_ON_SPECIAL_BIT 18, var1, .cs851_karen_dialogue
    UPDATE_U8_VALUE 2, 255, npcAffection[KAREN]
    SET_SPECIAL_BIT 18, var1

.cs851_karen_dialogue:
    PAUSE_ENTITY 0
    FLIP_ENTITY_DIRECTION 0
    INIT_DIALOGUE_SESSION 0, DIALOGUE_TEXT_55, 11
    WAIT_FOR_DIALOGUE_INPUT 0
    BRANCH_ON_DIALOGUE 0, 0, .cs851_karen_accept
    BRANCH_ON_DIALOGUE 0, 1, .cs851_karen_decline

.cs851_karen_accept:
    SET_SPECIAL_BIT 4, var0
    INIT_MESSAGE_BOX_TYPE1 0, SOWING_FESTIVAL_TEXT_INDEX, 57
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    UPDATE_U8_VALUE 8, 255, npcAffection[KAREN]
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    DEACTIVATE_EXECUTOR 39
    SET_WAIT_FRAMES 1
    SPAWN_EXECUTOR 39, .cs851_karen_in_balloon
    DEACTIVATE_SELF

.cs851_karen_decline:
    TOGGLE_PAUSE_ENTITY 0
    EXECUTE_SUBROUTINE .cs851_karen_wait

.cs851_karen_in_balloon:
