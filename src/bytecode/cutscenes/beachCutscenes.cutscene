; ============================================================
; Cutscene 756 - Starry night at the beach
; ============================================================
; Sets special bit 15 to mark cutscene as seen. If MARRIED
; (lifeEventBits[0] bit MARRIED) AND gWife == KAREN, branches
; into the wife-specific sequence with texts 50/51. Otherwise the
; unmarried Karen-date path plays, with a yes/no dialogue
; (session 2) and a low-affection branch.

.cutscene_756:
    SET_SPECIAL_BIT 15, gCutsceneCompletionFlags
    STOP_SEQUENCE_WITH_FADE 0, 8
    IDLE_WHILE_SEQUENCE_PLAYING 0
    SET_AUDIO_SEQUENCE 0, _beachAmbience1SegmentRomStart, _beachAmbience1SegmentRomEnd
    SET_AUDIO_SEQUENCE_VOLUME 0, 128, 8
    SPAWN_EXECUTOR 1, .cs756_karen_setup
    UPDATE_U8_VALUE 2, 255, npcAffection[KAREN]
    UPDATE_U8_VALUE 5, 255, gHappiness
    EXECUTE_SUBROUTINE .setup_player
    SET_COORDINATES -256, 0, 4
    SET_ASSET_ROTATION NORTHEAST
    UPDATE_GLOBAL_RGBA 254, 254, 254, 254, 0
    WAIT_RGBA_FINISHED
    SET_WAIT_FRAMES 20
    BRANCH_ON_SPECIAL_BIT MARRIED, lifeEventBits[0], .cs756_married_dispatch
    INIT_MESSAGE_BOX_TYPE1 0, BEACH_CUTSCENES_TEXT_INDEX, 42
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 1, .cs756_karen_anim_53_55
    SET_WAIT_FRAMES 5
    SET_ASSET_ROTATION SOUTHEAST
    SET_WAIT_FRAMES 15
    SET_ENTITY_ANIMATION 501
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_ANIMATION 507
    SET_WAIT_FRAMES 30
    BRANCH_ON_SPECIAL_BIT 15, D_801C3F4C, .cs756_already_seen
    SET_SPECIAL_BIT 15, D_801C3F4C
    INIT_MESSAGE_BOX_TYPE1 0, BEACH_CUTSCENES_TEXT_INDEX, 44

.cs756_continuation:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_WAIT_FRAMES 45
    SET_OTHER_EXECUTOR_PTR 1, .cs756_karen_dialog
    SET_WAIT_FRAMES 15
    SET_ENTITY_ANIMATION 501
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SET_WAIT_FRAMES 10
    SET_ASSET_ROTATION NORTHEAST
    EXECUTE_SUBROUTINE .wait_loop

.cs756_married_dispatch:
    BRANCH_U8_VAR_WITHIN_RANGE KAREN, KAREN, gWife, .cs756_wife_karen
    RETURN_FROM_SUBROUTINE

.cs756_already_seen:
    INIT_MESSAGE_BOX_TYPE1 0, BEACH_CUTSCENES_TEXT_INDEX, 43
    EXECUTE_SUBROUTINE .cs756_continuation

.cs756_player_walk_and_fade:
    ENTITY_WALK 32, NORTH, 2
    SET_AUDIO_SEQUENCE_VOLUME 0, 0, 4
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    ENTITY_WALK 64, NORTH, 2
    STOP_SEQUENCE_WITH_FADE 0, 1
    IDLE_WHILE_SEQUENCE_PLAYING 0
    SET_ENTITY_MAP_SPACE_INDEPENDENT FALSE
    EXECUTE_SUBROUTINE .finish_cutscene

.cs756_player_walk_ne:
    ENTITY_WALK 6, NORTHEAST, 2
    EXECUTE_SUBROUTINE .wait_loop

.cs756_player_anim_429:
    SET_ENTITY_DIRECTIONAL_ANIMATION 429
    WAIT_ENTITY_ANIMATION
    SET_OTHER_EXECUTOR_PTR 1, .cs756_karen_cold_hands
    EXECUTE_SUBROUTINE .wait_loop

.cs756_karen_setup:
    EXECUTE_SUBROUTINE .setup_karen_ent37
    SET_COORDINATES -256, 0, -32
    SET_ASSET_ROTATION SOUTHWEST
    EXECUTE_SUBROUTINE .wait_loop

.cs756_karen_anim_53_55:
    SET_ASSET_ROTATION SOUTHEAST
    SET_WAIT_FRAMES 5
    SET_ENTITY_ANIMATION 53
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_ANIMATION 55
    EXECUTE_SUBROUTINE .wait_loop

.cs756_karen_dialog:
    SET_ENTITY_ANIMATION 53
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SET_WAIT_FRAMES 15
    SET_ENTITY_DIRECTIONAL_ANIMATION 94
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 25
    SET_WAIT_FRAMES 15
    INIT_DIALOGUE_SESSION 0, DIALOGUE_BEACH_CUTSCENES, 2
    WAIT_FOR_DIALOGUE_INPUT 0
    BRANCH_ON_DIALOGUE 0, 0, .cs756_dialog_yes
    BRANCH_ON_DIALOGUE 0, 1, .cs756_dialog_no

.cs756_dialog_yes:
    BRANCH_U8_VAR_WITHIN_RANGE 0, 100, npcAffection[KAREN], .cs756_low_affection
    SET_OTHER_EXECUTOR_PTR 0, .cs756_player_walk_ne
    SET_WAIT_FRAMES 10
    SET_ENTITY_DIRECTIONAL_ANIMATION 94
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SET_ENTITY_ANIMATION 49
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_ANIMATION 51
