    RESET_MESSAGE_BOX_AVATAR 0
    SET_WAIT_FRAMES 10
    SET_OTHER_EXECUTOR_PTR 41, .cs754_frame_pan_out
    EXECUTE_SUBROUTINE .wait_loop

; ============================================================
; Cutscene 755 - KAREN_PINK_HEART_EVENT (blue feather request)
; ============================================================
; Karen asks if the player brought a blue feather. Branches on
; playeR dialogue choice (session 1) -- option 0 declines, which
; sends the player to her and she plays the accept sequence;
; option 1 rejects and Karen plays the refusal lines.

.cutscene_755_pink_heart:
    SPAWN_EXECUTOR 1, .cs755_karen_setup
    DEACTIVATE_SELF

.cs755_karen_setup:
    EXECUTE_SUBROUTINE .setup_karen_ent37
    SET_COORDINATES -256, 0, 0
    SET_ASSET_ROTATION SOUTHEAST
    UPDATE_RGBA 254, 254, 254, 254, 0
    WAIT_RGBA_FINISHED
    SET_CALLBACK_ROUTINE 0, 32768, .cs755_karen_on_interact
    EXECUTE_SUBROUTINE .wait_loop

.cs755_karen_on_interact:
    EXECUTE_SUBROUTINE .setup_message_box_type1
    UPDATE_U8_VALUE 10, 255, gHappiness
    PAUSE_ENTITY 0
    FLIP_ENTITY_DIRECTION 0
    INIT_MESSAGE_BOX_TYPE1 0, BEACH_CUTSCENES_TEXT_INDEX, 34
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    ENTITY_WALK 32, NORTH, 2
    SPAWN_EXECUTOR 0, .player_setup_face_north_release
    SET_WAIT_FRAMES 30
    INIT_DIALOGUE_SESSION 0, DIALOGUE_BEACH_CUTSCENES, 1
    WAIT_FOR_DIALOGUE_INPUT 0
    BRANCH_ON_DIALOGUE 0, 0, .cs755_accept
    BRANCH_ON_DIALOGUE 0, 1, .cs755_decline

.cs755_accept:
    SET_ASSET_ROTATION SOUTH
    SET_WAIT_FRAMES 10
    INIT_MESSAGE_BOX_TYPE1 0, BEACH_CUTSCENES_TEXT_INDEX, 37
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SPAWN_EXECUTOR 0, .cs755_player_approach_karen
    EXECUTE_SUBROUTINE .wait_loop

.cs755_player_approach_karen:
    EXECUTE_SUBROUTINE .setup_player
    SET_ASSET_ROTATION NORTH
    SET_WAIT_FRAMES 30
    INIT_MESSAGE_BOX_TYPE1 0, BEACH_CUTSCENES_TEXT_INDEX, 38
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 1, .cs755_karen_anim_48_50
    EXECUTE_SUBROUTINE .wait_loop

.cs755_karen_anim_48_50:
    SET_ASSET_ROTATION SOUTHWEST
    SET_WAIT_FRAMES 20
    SET_ENTITY_ANIMATION 48
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_ANIMATION 50
    INIT_MESSAGE_BOX_TYPE1 0, BEACH_CUTSCENES_TEXT_INDEX, 39
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_ENTITY_ANIMATION 48
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    ENTITY_WALK 96, NORTH, 2
    TOGGLE_PAUSE_ENTITY 0
    SET_OTHER_EXECUTOR_PTR 0, .player_release_map
