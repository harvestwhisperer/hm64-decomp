    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    INIT_MESSAGE_BOX_TYPE1 0, BEACH_CUTSCENES_TEXT_INDEX, 29
    WAIT_MESSAGE_BOX_CLOSED 0
    INIT_MESSAGE_BOX_TYPE1 0, BEACH_CUTSCENES_TEXT_INDEX, 30
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_ENTITY_ANIMATION 49
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_ANIMATION 51
    SET_WAIT_FRAMES 30
    INIT_MESSAGE_BOX_TYPE1 0, BEACH_CUTSCENES_TEXT_INDEX, 31
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 2, .cs754_elli_walk_south
    SET_ENTITY_ANIMATION 49
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    EXECUTE_SUBROUTINE .wait_loop

.cs754_elli_setup:
    SETUP_ENTITY 36, ENTITY_ASSET_ELLI, 1
    SET_ENTITY_ANIMATIONS 36, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    SET_COORDINATES -256, 0, 96
    SET_ASSET_ROTATION SOUTH
    EXECUTE_SUBROUTINE .wait_loop

.cs754_elli_walk_south:
    SET_ASSET_ROTATION NORTH
    SET_WAIT_FRAMES 20
    INIT_MESSAGE_BOX_TYPE1 0, BEACH_CUTSCENES_TEXT_INDEX, 32
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    ENTITY_WALK 96, NORTH, 2
    SET_OTHER_EXECUTOR_PTR 1, .cs754_karen_reflect
    DEACTIVATE_SELF

.cs754_karen_reflect:
    ENTITY_WALK 8, SOUTHWEST, 2
    SET_WAIT_FRAMES 60
