    SET_OTHER_EXECUTOR_PTR 1, .face_northwest
    SPAWN_EXECUTOR 2, .ann_hostess_greet
    EXECUTE_SUBROUTINE .wait_loop

.wife_greet_karen_start:
    SET_OTHER_EXECUTOR_PTR 0, .face_northwest
    SET_OTHER_EXECUTOR_PTR 1, .face_northwest
    SPAWN_EXECUTOR 2, .karen_hostess_greet
    EXECUTE_SUBROUTINE .wait_loop

.wife_hostess_walk_NE_face_SW:
    ENTITY_WALK 16, NORTHEAST, 2
    SET_ASSET_ROTATION SOUTHWEST
    EXECUTE_SUBROUTINE .wait_loop

; ----- Wife entity setup helpers -----
; Subroutines that SETUP_ENTITY each wife at the slot the wife
; hostess scene expects, with the appropriate idle/animation
; pair pre-loaded.
.setup_maria_slot24:
    SETUP_ENTITY 24, ENTITY_ASSET_MARIA, 1
    SET_ENTITY_ANIMATIONS 24, 0, 8, 0, 108, 118, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    RETURN_FROM_SUBROUTINE

.setup_popuri_slot25:
    SETUP_ENTITY 25, ENTITY_ASSET_POPURI, 1
