; ============================================
; Bank 25 - Evaluation
; ============================================
; Cutscene indices 1550 - 1553: evaluation/credits sequence.
;   1550 = EVALUATION (current map, then loads map 0)
;   1551 = transitions to MOUNTAIN_1_SPAWN_POINT_1
;   1552 = transitions to HOUSE_SPAWN_POINT_1 (loads map 78)
;   1553 = credits sequence

#include "entities.h"
#include "maps.h"
#include "texts.h"
#include "dialogues.h"

#define MAIN_MAP_INDEX 0

; lifeEventBits[0] bit indices referenced here.
#define MARRIED 0
#define HAVE_BABY 1

.buffer 2

.local var0, u32, 0

.array npcAffection, u8
.array lifeEventBits, u32

.main:
    SET_SPECIAL_BIT 12, gCutsceneCompletionFlags
    SET_U8_VALUE 12, gHour
    SET_U8_VALUE 0, gMinutes
    EXECUTE_SUBROUTINE .setup_message_box_default
    TOGGLE_PAUSE_ENTITIES
    BRANCH_U16_VAR_WITHIN_RANGE 1550, 1550, gCutsceneIndex, .cutscene_1550
    BRANCH_U16_VAR_WITHIN_RANGE 1551, 1551, gCutsceneIndex, .cutscene_1551
    BRANCH_U16_VAR_WITHIN_RANGE 1552, 1552, gCutsceneIndex, .cutscene_1552
    BRANCH_U16_VAR_WITHIN_RANGE 1553, 1553, gCutsceneIndex, .cutscene_1553

; ============================================================
; Common helpers
; ============================================================
.exit_demo:
    SET_SPECIAL_BIT 0, gCutsceneCompletionFlags
    DEACTIVATE_SELF

.wait_loop:
    SET_WAIT_FRAMES 1
    EXECUTE_SUBROUTINE .wait_loop
 
.setup_message_box_default:
    SET_MESSAGE_INTERPOLATION -4, 0, 0
    SET_MESSAGE_BOX_ASSETS 0, 0, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 24, -64, 352
    RETURN_FROM_SUBROUTINE

.setup_message_box_alt:
    SET_MESSAGE_INTERPOLATION -4, 0, 0
    SET_MESSAGE_BOX_ASSETS 0, 1, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 0, -64, 352
    RETURN_FROM_SUBROUTINE

.setup_player:
    SETUP_ENTITY 0, ENTITY_ASSET_PLAYER, 1
    SET_ENTITY_ANIMATIONS 0, 0, 8, 16, 24, 32, 40
    SET_BEHAVIOR_FLAGS CUTSCENE_ASSET_BEHAVIOR_TRACK_ENTITY
    RETURN_FROM_SUBROUTINE

; ----- Direction-only executor stubs -----
; Each one sets the active asset rotation, then idles via
; .wait_loop. Used as SET_OTHER_EXECUTOR_PTR targets to point
; another executor at a fixed facing.
.face_northeast:
    SET_ASSET_ROTATION NORTHEAST
    EXECUTE_SUBROUTINE .wait_loop

.face_northwest:
    SET_ASSET_ROTATION NORTHWEST
    EXECUTE_SUBROUTINE .wait_loop

.face_southwest:
    SET_ASSET_ROTATION SOUTHWEST
    EXECUTE_SUBROUTINE .wait_loop

.face_southeast:
    SET_ASSET_ROTATION SOUTHEAST
    EXECUTE_SUBROUTINE .wait_loop

.face_west:
    SET_ASSET_ROTATION WEST
    EXECUTE_SUBROUTINE .wait_loop

.face_south:
    SET_ASSET_ROTATION SOUTH
    EXECUTE_SUBROUTINE .wait_loop

.face_north:
    SET_ASSET_ROTATION NORTH
    EXECUTE_SUBROUTINE .wait_loop

.face_east:
    SET_ASSET_ROTATION EAST
    EXECUTE_SUBROUTINE .wait_loop

; Held item that tracks the mayor (slot 23); spawned from the
; low-tier branch of .mayor_evaluation_intro.
.mayor_held_item:
    SETUP_ENTITY 39, ENTITY_ASSET_EXPRESSION_BUBBLES, 1
    SET_ENTITY_ANIMATIONS 39, 0, 0, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_RGBA 255, 255, 255, 255
    SET_ENTITY_TRACKING_TARGET 23, -24, 32, 8, 0
    SET_ENTITY_ANIMATION 5
    WAIT_ENTITY_ANIMATION
    DEACTIVATE_SELF

; ============================================================
; Cutscene 1550 - Evaluation panel on the players current map
; ============================================================
; Four villager NPCs (DAD, MAYOR, MIDWIFE, POTION_SHOP_DEALER)
; surround the player and judge their stats one after another.
; Each NPC intro routine BRANCHes on a stat to pick a high /
; mid / fallthrough-low message. After all four finish, the map
; transitions to map 0 for a second NPC pair (DOUG, SHIPPER).
.cutscene_1550:
    STOP_SEQUENCE_WITH_FADE 0, 1
    IDLE_WHILE_SEQUENCE_PLAYING 0
    BRANCH_U32_VAR_WITHIN_RANGE 0, 1000, gGold, .cutscene_1550_gate_check

.cutscene_1550_start:
    SET_AUDIO_SEQUENCE 0, _sportsFestival1SegmentRomStart, _sportsFestival1SegmentRomEnd
    SET_AUDIO_SEQUENCE_VOLUME 0, 128, 8

.cutscene_1550_spawn_npcs:
    SPAWN_EXECUTOR 1, .cutscene_1550_dad_setup
    SPAWN_EXECUTOR 2, .cutscene_1550_mayor_setup
    SPAWN_EXECUTOR 3, .cutscene_1550_midwife_setup
    SPAWN_EXECUTOR 4, .cutscene_1550_potion_dealer_setup
    SPAWN_EXECUTOR 41, .cutscene_1550_scene_controller
    EXECUTE_SUBROUTINE .setup_player
    DEACTIVATE_SELF

.cutscene_1550_scene_controller:
    SETUP_MAP_ASSET MAIN_MAP_INDEX
    SET_ASSET_ROTATION SOUTH
    SET_COORDINATES -16, 96, 64
    SET_WAIT_FRAMES 40
    SET_OTHER_EXECUTOR_PTR 2, .mayor_evaluation_intro
    EXECUTE_SUBROUTINE .wait_loop

.setup_dad_slot22:
    SETUP_ENTITY 22, ENTITY_ASSET_DAD, 1
    SET_ENTITY_ANIMATIONS 22, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    RETURN_FROM_SUBROUTINE

.cutscene_1550_dad_setup:
    EXECUTE_SUBROUTINE .setup_dad_slot22
    SET_COORDINATES 8, 0, 64
    SET_ASSET_ROTATION NORTHWEST
    EXECUTE_SUBROUTINE .wait_loop

.cutscene_1550_mayor_setup:
    SETUP_ENTITY 23, ENTITY_ASSET_MAYOR, 1
    SET_ENTITY_ANIMATIONS 23, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    SET_COORDINATES -48, 0, 64
    SET_ASSET_ROTATION SOUTHEAST
    EXECUTE_SUBROUTINE .wait_loop

.mayor_evaluation_intro:
    SET_ASSET_ROTATION SOUTH
    SET_WAIT_FRAMES 20
    SET_ASSET_ROTATION EAST
    SET_WAIT_FRAMES 20
    SET_ASSET_ROTATION SOUTHEAST
    SET_WAIT_FRAMES 10
    BRANCH_U16_VAR_WITHIN_RANGE 4001, 65535, D_801C3B62, .mayor_talk_high
    BRANCH_U16_VAR_WITHIN_RANGE 1001, 4000, D_801C3B62, .mayor_talk_mid
    SPAWN_EXECUTOR 16, .mayor_held_item
    SET_ENTITY_ANIMATION 18
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_ANIMATION_WITH_DIRECTION_CHANGE 0
    INIT_MESSAGE_BOX_TYPE1 0, SEA_FESTIVAL_AND_EVALUATION_TEXT_INDEX, 80

.mayor_post_talk:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 3, .midwife_evaluation_intro
    EXECUTE_SUBROUTINE .wait_loop

.mayor_talk_high:
    SET_ENTITY_ANIMATION 17
    WAIT_ENTITY_ANIMATION
    SET_WAIT_FRAMES 20
    SET_ENTITY_ANIMATION_WITH_DIRECTION_CHANGE 0
    INIT_MESSAGE_BOX_TYPE1 0, SEA_FESTIVAL_AND_EVALUATION_TEXT_INDEX, 78
    EXECUTE_SUBROUTINE .mayor_post_talk

.mayor_talk_mid:
    SET_ENTITY_ANIMATION 22
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_ANIMATION_WITH_DIRECTION_CHANGE 0
    INIT_MESSAGE_BOX_TYPE1 0, SEA_FESTIVAL_AND_EVALUATION_TEXT_INDEX, 79
    EXECUTE_SUBROUTINE .mayor_post_talk

.cutscene_1550_midwife_setup:
    SETUP_ENTITY 24, ENTITY_ASSET_MIDWIFE, 1
    SET_ENTITY_ANIMATIONS 24, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    SET_COORDINATES -16, 0, 32
    SET_ASSET_ROTATION SOUTHWEST
    EXECUTE_SUBROUTINE .wait_loop

.midwife_evaluation_intro:
    SET_OTHER_EXECUTOR_PTR 1, .face_north
    SET_WAIT_FRAMES 20
    SET_ENTITY_ANIMATION_WITH_DIRECTION_CHANGE 18
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_ANIMATION_WITH_DIRECTION_CHANGE 26
    SET_WAIT_FRAMES 20
    SET_ENTITY_ANIMATION_WITH_DIRECTION_CHANGE 18
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_ANIMATION_WITH_DIRECTION_CHANGE 0
    BRANCH_U16_VAR_WITHIN_RANGE 1001, 65535, D_80215DF0, .midwife_talk_high
    BRANCH_U16_VAR_WITHIN_RANGE 251, 1000, D_80215DF0, .midwife_talk_mid
    INIT_MESSAGE_BOX_TYPE1 0, SEA_FESTIVAL_AND_EVALUATION_TEXT_INDEX, 83

.midwife_post_talk:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 4, .potion_dealer_evaluation_intro
    EXECUTE_SUBROUTINE .wait_loop

.midwife_talk_high:
    INIT_MESSAGE_BOX_TYPE1 0, SEA_FESTIVAL_AND_EVALUATION_TEXT_INDEX, 81
    EXECUTE_SUBROUTINE .midwife_post_talk

.midwife_talk_mid:
    INIT_MESSAGE_BOX_TYPE1 0, SEA_FESTIVAL_AND_EVALUATION_TEXT_INDEX, 82
    EXECUTE_SUBROUTINE .midwife_post_talk

.cutscene_1550_potion_dealer_setup:
    SETUP_ENTITY 25, ENTITY_ASSET_POTION_SHOP_DEALER, 1
    SET_ENTITY_ANIMATIONS 25, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    SET_COORDINATES -16, 0, 96
    SET_ASSET_ROTATION NORTHEAST
    EXECUTE_SUBROUTINE .wait_loop

.potion_dealer_evaluation_intro:
    SET_OTHER_EXECUTOR_PTR 1, .face_west
    SET_WAIT_FRAMES 20
    SET_ENTITY_ANIMATION 20
    WAIT_ENTITY_ANIMATION
    BRANCH_U16_VAR_WITHIN_RANGE 0, 2, D_801886E0, .potion_dealer_talk_low
    BRANCH_U16_VAR_WITHIN_RANGE 3, 9, D_801886E0, .potion_dealer_talk_mid
    INIT_MESSAGE_BOX_TYPE1 0, SEA_FESTIVAL_AND_EVALUATION_TEXT_INDEX, 86

.potion_dealer_post_talk:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_WAIT_FRAMES 10
    SET_OTHER_EXECUTOR_PTR 41, .cutscene_1550_transition_to_ranch
    EXECUTE_SUBROUTINE .wait_loop

.potion_dealer_talk_low:
    INIT_MESSAGE_BOX_TYPE1 0, SEA_FESTIVAL_AND_EVALUATION_TEXT_INDEX, 84
    EXECUTE_SUBROUTINE .potion_dealer_post_talk

.potion_dealer_talk_mid:
    INIT_MESSAGE_BOX_TYPE1 0, SEA_FESTIVAL_AND_EVALUATION_TEXT_INDEX, 85
    EXECUTE_SUBROUTINE .potion_dealer_post_talk

; ----- Cutscene 1550 part 2: ranch (DOUG, SHIPPER) -----
.cutscene_1550_transition_to_ranch:
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    DEACTIVATE_EXECUTOR 2
    DEACTIVATE_EXECUTOR 3
    DEACTIVATE_EXECUTOR 4
    SET_WAIT_FRAMES 1
    DEACTIVATE_MAP_OBJECTS 0
    SET_SPECIAL_BIT 29, gCutsceneCompletionFlags
    LOAD_MAP MAIN_MAP_INDEX, RANCH
    SETUP_MAP_ASSET MAIN_MAP_INDEX
    SET_ASSET_ROTATION SOUTH
    SET_COORDINATES 160, 96, -320
    SET_OTHER_EXECUTOR_PTR 1, .map0_player_position
    SPAWN_EXECUTOR 2, .cutscene_1550_doug_setup
    SPAWN_EXECUTOR 3, .cutscene_1550_shipper_setup
    SET_WAIT_FRAMES 1
    UPDATE_GLOBAL_RGBA 255, 255, 255, 255, 8
    WAIT_RGBA_FINISHED
    SET_WAIT_FRAMES 30
    SET_OTHER_EXECUTOR_PTR 2, .doug_evaluation_intro
    EXECUTE_SUBROUTINE .wait_loop

.map0_player_position:
    SET_COORDINATES 160, 0, -320
    SET_ASSET_ROTATION SOUTHWEST
    EXECUTE_SUBROUTINE .wait_loop

.cutscene_1550_doug_setup:
    SETUP_ENTITY 23, ENTITY_ASSET_DOUG, 1
    SET_ENTITY_ANIMATIONS 23, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    SET_COORDINATES 192, 0, -288
    SET_ASSET_ROTATION NORTHWEST
    EXECUTE_SUBROUTINE .wait_loop

.doug_evaluation_intro:
    SET_OTHER_EXECUTOR_PTR 1, .face_south
    SET_WAIT_FRAMES 20
    SET_ENTITY_ANIMATION 17
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_ANIMATION_WITH_DIRECTION_CHANGE 0
    BRANCH_U16_VAR_WITHIN_RANGE 0, 0, D_801886A8, .doug_high_tier_check
    BRANCH_U16_VAR_WITHIN_RANGE 2, 999, D_801886A8, .doug_talk_low

.doug_talk_mid:
    INIT_MESSAGE_BOX_TYPE1 0, SEA_FESTIVAL_AND_EVALUATION_TEXT_INDEX, 88

.doug_post_talk:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 3, .shipper_evaluation_intro
    EXECUTE_SUBROUTINE .wait_loop

.doug_high_tier_check:
    BRANCH_U8_VAR_WITHIN_RANGE 0, 3, D_80205209, .doug_talk_mid
    BRANCH_U8_VAR_WITHIN_RANGE 0, 0, D_801D62C6, .doug_talk_mid
    BRANCH_U8_VAR_WITHIN_RANGE 0, 0, D_801886D0, .doug_talk_mid
    BRANCH_ON_SPECIAL_BIT 5, lifeEventBits[0], .doug_talk_high_animal_care
    EXECUTE_SUBROUTINE .doug_talk_mid

.doug_talk_high_animal_care:
    INIT_MESSAGE_BOX_TYPE1 0, SEA_FESTIVAL_AND_EVALUATION_TEXT_INDEX, 87
    EXECUTE_SUBROUTINE .doug_post_talk

.doug_talk_low:
    INIT_MESSAGE_BOX_TYPE1 0, SEA_FESTIVAL_AND_EVALUATION_TEXT_INDEX, 89
    EXECUTE_SUBROUTINE .doug_post_talk

.cutscene_1550_shipper_setup:
    SETUP_ENTITY 24, ENTITY_ASSET_SHIPPER, 1
    SET_ENTITY_ANIMATIONS 24, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    SET_COORDINATES 128, 0, -288
    SET_ASSET_ROTATION SOUTHEAST
    EXECUTE_SUBROUTINE .wait_loop

.shipper_evaluation_intro:
    SET_OTHER_EXECUTOR_PTR 1, .face_west
    SET_WAIT_FRAMES 20
    SET_ENTITY_ANIMATION 24
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_ANIMATION 25
    SET_WAIT_FRAMES 20
    SET_ENTITY_ANIMATION 24
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_ANIMATION_WITH_DIRECTION_CHANGE 0
    BRANCH_U32_VAR_WITHIN_RANGE 9000, 99999999, D_801C3E1C, .shipper_talk_high_followup
    INIT_MESSAGE_BOX_TYPE1 0, SEA_FESTIVAL_AND_EVALUATION_TEXT_INDEX, 94

.shipper_post_talk:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_WAIT_FRAMES 10
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    DEACTIVATE_EXECUTOR 1
    DEACTIVATE_EXECUTOR 2
    DEACTIVATE_EXECUTOR 41
    SET_SPECIAL_BIT 1, gCutsceneCompletionFlags
    EXECUTE_SUBROUTINE .exit_demo

.shipper_talk_high_followup:
    INIT_MESSAGE_BOX_TYPE1 0, SEA_FESTIVAL_AND_EVALUATION_TEXT_INDEX, 90
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_ENTITY_ANIMATION 24
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_ANIMATION 25
    SET_WAIT_FRAMES 20
    SET_ENTITY_ANIMATION 24
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_ANIMATION_WITH_DIRECTION_CHANGE 0
    BRANCH_U16_VAR_WITHIN_RANGE 0, 0, D_80189824, .shipper_followup_low_milk
    BRANCH_U16_VAR_WITHIN_RANGE 1, 1, D_80189824, .shipper_followup_low_eggs
    INIT_MESSAGE_BOX_TYPE1 0, SEA_FESTIVAL_AND_EVALUATION_TEXT_INDEX, 93
    EXECUTE_SUBROUTINE .shipper_post_talk

.shipper_followup_low_milk:
    INIT_MESSAGE_BOX_TYPE1 0, SEA_FESTIVAL_AND_EVALUATION_TEXT_INDEX, 91
    EXECUTE_SUBROUTINE .shipper_post_talk

.shipper_followup_low_eggs:
    INIT_MESSAGE_BOX_TYPE1 0, SEA_FESTIVAL_AND_EVALUATION_TEXT_INDEX, 92
    EXECUTE_SUBROUTINE .shipper_post_talk

; ============================================================
; Cutscene 1551 - Evaluation on Mountain 1, then map 78
; ============================================================
; Same shape as 1550. NPCs on Mountain 1: DAD, MASTER_CARPENTER,
; ASSISTANT_CARPENTER (silent), GREG. Map-78 NPCs: GOURMET_JUDGE,
; BASIL.
.cutscene_1551:
    SPAWN_EXECUTOR 1, .cutscene_1551_dad_setup
    SPAWN_EXECUTOR 2, .cutscene_1551_master_carpenter_setup
    SPAWN_EXECUTOR 3, .cutscene_1551_assistant_carpenter_setup
    SPAWN_EXECUTOR 4, .cutscene_1551_greg_setup
    SPAWN_EXECUTOR 41, .cutscene_1551_scene_controller
    EXECUTE_SUBROUTINE .setup_player
    DEACTIVATE_SELF

.cutscene_1551_scene_controller:
    SETUP_MAP_ASSET MAIN_MAP_INDEX
    SET_ASSET_ROTATION SOUTH
    SET_COORDINATES 96, 96, 32
    SET_WAIT_FRAMES 40
    SET_OTHER_EXECUTOR_PTR 4, .greg_evaluation_intro
    EXECUTE_SUBROUTINE .wait_loop

.cutscene_1551_dad_setup:
    EXECUTE_SUBROUTINE .setup_dad_slot22
    SET_COORDINATES 64, 0, 32
    SET_ASSET_ROTATION NORTHEAST
    EXECUTE_SUBROUTINE .wait_loop

.cutscene_1551_master_carpenter_setup:
    SETUP_ENTITY 23, ENTITY_ASSET_MASTER_CARPENTER, 1
    SET_ENTITY_ANIMATIONS 23, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    SET_COORDINATES 32, 0, 0
    SET_ASSET_ROTATION SOUTHEAST
    EXECUTE_SUBROUTINE .wait_loop

.master_carpenter_evaluation_intro:
    SET_OTHER_EXECUTOR_PTR 1, .face_north
    SET_WAIT_FRAMES 20
    BRANCH_U8_VAR_WITHIN_RANGE 6, 255, D_8017026E, .master_carpenter_talk_high
    BRANCH_U8_VAR_WITHIN_RANGE 3, 5, D_8017026E, .master_carpenter_talk_mid
    INIT_MESSAGE_BOX_TYPE1 0, SEA_FESTIVAL_AND_EVALUATION_TEXT_INDEX, 100

.master_carpenter_post_talk:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 41, .cutscene_1551_transition_to_road
    EXECUTE_SUBROUTINE .wait_loop

.master_carpenter_talk_high:
    INIT_MESSAGE_BOX_TYPE1 0, SEA_FESTIVAL_AND_EVALUATION_TEXT_INDEX, 98
    EXECUTE_SUBROUTINE .master_carpenter_post_talk

.master_carpenter_talk_mid:
    INIT_MESSAGE_BOX_TYPE1 0, SEA_FESTIVAL_AND_EVALUATION_TEXT_INDEX, 99
    EXECUTE_SUBROUTINE .master_carpenter_post_talk

.cutscene_1551_assistant_carpenter_setup:
    SETUP_ENTITY 24, ENTITY_ASSET_ASSISTANT_CARPENTER, 1
    SET_ENTITY_ANIMATIONS 24, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    SET_COORDINATES 64, 0, -32
    SET_ASSET_ROTATION SOUTHWEST
    EXECUTE_SUBROUTINE .wait_loop

.cutscene_1551_greg_setup:
    SETUP_ENTITY 25, ENTITY_ASSET_GREG, 1
    SET_ENTITY_ANIMATIONS 25, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    SET_COORDINATES 96, 0, 0
    SET_ASSET_ROTATION NORTHWEST
    EXECUTE_SUBROUTINE .wait_loop

.greg_evaluation_intro:
    SET_OTHER_EXECUTOR_PTR 1, .face_east
    SET_WAIT_FRAMES 20
    BRANCH_U16_VAR_WITHIN_RANGE 201, 999, D_801D62C4, .greg_talk_high
    BRANCH_U16_VAR_WITHIN_RANGE 31, 200, D_801D62C4, .greg_talk_mid
    INIT_MESSAGE_BOX_TYPE1 0, SEA_FESTIVAL_AND_EVALUATION_TEXT_INDEX, 97

.greg_post_talk:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_WAIT_FRAMES 10
    SET_OTHER_EXECUTOR_PTR 2, .master_carpenter_evaluation_intro
    EXECUTE_SUBROUTINE .wait_loop

.greg_talk_high:
    INIT_MESSAGE_BOX_TYPE1 0, SEA_FESTIVAL_AND_EVALUATION_TEXT_INDEX, 95
    EXECUTE_SUBROUTINE .greg_post_talk

.greg_talk_mid:
    INIT_MESSAGE_BOX_TYPE1 0, SEA_FESTIVAL_AND_EVALUATION_TEXT_INDEX, 96
    EXECUTE_SUBROUTINE .greg_post_talk

; ----- Cutscene 1551 part 2: Road (GOURMET_JUDGE, BASIL) -----
.cutscene_1551_transition_to_road:
    SET_WAIT_FRAMES 10
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    DEACTIVATE_EXECUTOR 2
    DEACTIVATE_EXECUTOR 3
    DEACTIVATE_EXECUTOR 4
    SET_WAIT_FRAMES 1
    SET_SPECIAL_BIT 29, gCutsceneCompletionFlags
    DEACTIVATE_MAP_OBJECTS 0
    LOAD_MAP MAIN_MAP_INDEX, ROAD
    SETUP_MAP_ASSET MAIN_MAP_INDEX
    SET_ASSET_ROTATION SOUTH
    SET_COORDINATES -64, 96, -32
    SET_OTHER_EXECUTOR_PTR 1, .map78_player_position
    SPAWN_EXECUTOR 2, .cutscene_1551_gourmet_judge_setup
    SPAWN_EXECUTOR 3, .cutscene_1551_basil_setup
    SET_WAIT_FRAMES 1
    UPDATE_GLOBAL_RGBA 255, 255, 255, 255, 8
    WAIT_RGBA_FINISHED
    SET_OTHER_EXECUTOR_PTR 3, .basil_evaluation_intro
    EXECUTE_SUBROUTINE .wait_loop

.map78_player_position:
    SET_COORDINATES -32, 0, -32
    SET_ASSET_ROTATION SOUTHWEST
    EXECUTE_SUBROUTINE .wait_loop

.cutscene_1551_gourmet_judge_setup:
    SETUP_ENTITY 23, ENTITY_ASSET_GOURMET_JUDGE, 1
    SET_ENTITY_ANIMATIONS 23, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    SET_COORDINATES -64, 0, 0
    SET_ASSET_ROTATION SOUTHEAST
    EXECUTE_SUBROUTINE .wait_loop

.gourmet_judge_evaluation_intro:
    SET_OTHER_EXECUTOR_PTR 1, .face_west
    SET_WAIT_FRAMES 20
    SET_ENTITY_ANIMATION 16
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_ANIMATION_WITH_DIRECTION_CHANGE 0
    BRANCH_U8_VAR_WITHIN_RANGE 35, 255, D_80188F68, .gourmet_judge_talk_high
    BRANCH_U8_VAR_WITHIN_RANGE 6, 34, D_80188F68, .gourmet_judge_talk_mid
    INIT_MESSAGE_BOX_TYPE1 0, SEA_FESTIVAL_AND_EVALUATION_TEXT_INDEX, 106

.gourmet_judge_post_talk:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_WAIT_FRAMES 10
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    DEACTIVATE_EXECUTOR 1
    DEACTIVATE_EXECUTOR 3
    DEACTIVATE_EXECUTOR 41
    SET_SPECIAL_BIT 1, gCutsceneCompletionFlags
    EXECUTE_SUBROUTINE .exit_demo

.gourmet_judge_talk_high:
    INIT_MESSAGE_BOX_TYPE1 0, SEA_FESTIVAL_AND_EVALUATION_TEXT_INDEX, 104
    EXECUTE_SUBROUTINE .gourmet_judge_post_talk

.gourmet_judge_talk_mid:
    INIT_MESSAGE_BOX_TYPE1 0, SEA_FESTIVAL_AND_EVALUATION_TEXT_INDEX, 105
    EXECUTE_SUBROUTINE .gourmet_judge_post_talk

.cutscene_1551_basil_setup:
    SETUP_ENTITY 24, ENTITY_ASSET_BASIL, 1
    SET_ENTITY_ANIMATIONS 24, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    SET_COORDINATES 0, 0, 0
    SET_ASSET_ROTATION NORTHWEST
    EXECUTE_SUBROUTINE .wait_loop

.basil_evaluation_intro:
    SET_OTHER_EXECUTOR_PTR 1, .face_south
    SET_WAIT_FRAMES 20
    BRANCH_U16_VAR_WITHIN_RANGE 120, 999, D_80205638, .basil_talk_high
    BRANCH_U16_VAR_WITHIN_RANGE 51, 119, D_80205638, .basil_talk_mid
    INIT_MESSAGE_BOX_TYPE1 0, SEA_FESTIVAL_AND_EVALUATION_TEXT_INDEX, 103

.basil_post_talk:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_WAIT_FRAMES 10
    SET_OTHER_EXECUTOR_PTR 2, .gourmet_judge_evaluation_intro
    EXECUTE_SUBROUTINE .wait_loop

.basil_talk_high:
    INIT_MESSAGE_BOX_TYPE1 0, SEA_FESTIVAL_AND_EVALUATION_TEXT_INDEX, 101
    EXECUTE_SUBROUTINE .basil_post_talk

.basil_talk_mid:
    INIT_MESSAGE_BOX_TYPE1 0, SEA_FESTIVAL_AND_EVALUATION_TEXT_INDEX, 102
    EXECUTE_SUBROUTINE .basil_post_talk

.cutscene_1552_dog_setup:
    SETUP_ENTITY 39, ENTITY_ASSET_STATIC_ITEM, 1
    SET_ENTITY_ANIMATIONS 39, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_ANIMATION 231
    SET_ENTITY_TRACKING_TARGET 0, 0, 14, 12, 255
    EXECUTE_SUBROUTINE .wait_loop

; ============================================================
; Cutscene 1552 - Brief house scene (DAD greeting + dog trick)
; ============================================================
.cutscene_1552:
    SET_SPECIAL_BIT 15, gCutsceneCompletionFlags
    SPAWN_EXECUTOR 1, .cutscene_1552_dad_setup
    EXECUTE_SUBROUTINE .setup_player
    SET_COORDINATES -64, 0, -96
    SET_ASSET_ROTATION SOUTHWEST
    SET_WAIT_FRAMES 40
    INIT_MESSAGE_BOX_TYPE1 0, SEA_FESTIVAL_AND_EVALUATION_TEXT_INDEX, 28
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_WAIT_FRAMES 10
    SPAWN_EXECUTOR 16, .cutscene_1552_dog_setup
    SET_ENTITY_ANIMATION 475
    SET_WAIT_FRAMES 60
    SET_AUDIO_SEQUENCE_VOLUME 0, 0, 4
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    STOP_SEQUENCE_WITH_FADE 0, 1
    DEACTIVATE_EXECUTOR 1
    DEACTIVATE_EXECUTOR 16
    IDLE_WHILE_SEQUENCE_PLAYING 0
    SET_SPECIAL_BIT 1, gCutsceneCompletionFlags
    EXECUTE_SUBROUTINE .exit_demo

.cutscene_1552_dad_setup:
    EXECUTE_SUBROUTINE .setup_dad_slot22
    SET_COORDINATES -64, 0, -56
    SET_ASSET_ROTATION NORTHEAST
    EXECUTE_SUBROUTINE .wait_loop

; ============================================================
; Cutscene 1553 - Credits sequence
; ============================================================
; If the player flunks the gate (low gold + low everything),
; .cutscene_1553_gate_check skips most of the festival and
; routes to a short bad-ending body via .cutscene_1553_start +
; var0 bit 0. Otherwise the long path runs:
;
;   1. DAD walks in, optional gold/affection/happiness prompts.
;   2. .cutscene_1553_dispatch_on_wife (if married) selects the
;      wife and runs her greeting/tribute scene; unmarried path
;      goes straight to .tribute_dispatch_start.
;   3. Tribute chain spawns one .tribute_<npc> executor for
;      every villager whose npcAffection >= 160; D_801886D2
;      tracks how many tributes have been placed.
;   4. Once dispatch finishes, DAD reacts to the crowd size,
;      then .cutscene_1553_ending_frame_fade tears everything
;      down and chains to .credits_roll_player.
;
; gWife mapping: 0 = Maria, 1 = Popuri, 2 = Elli, 3 = Ann,
;                4 = Karen.
.cutscene_1553:
    SET_SPECIAL_BIT 31, gCutsceneCompletionFlags
    BRANCH_U32_VAR_WITHIN_RANGE 0, 1000, gGold, .cutscene_1553_gate_check

.cutscene_1553_start:
    SET_WAIT_FRAMES 5
    SET_AUDIO_SEQUENCE 0, _starryNightFestivalSegmentRomStart, _starryNightFestivalSegmentRomEnd
    SET_AUDIO_SEQUENCE_VOLUME 0, 128, 8
    SPAWN_EXECUTOR 37, .cutscene_1553_map_asset
    SPAWN_EXECUTOR 1, .cutscene_1553_dad_entry
    EXECUTE_SUBROUTINE .setup_player
    SET_COORDINATES -352, 0, -16
    SET_ASSET_ROTATION SOUTHEAST
    UPDATE_GLOBAL_RGBA 255, 255, 255, 255, 8
    ENTITY_WALK 68, SOUTHEAST, 2
    EXECUTE_SUBROUTINE .wait_loop

.cutscene_1553_map_asset:
    SETUP_MAP_ASSET MAIN_MAP_INDEX
    SET_ASSET_ROTATION SOUTH
    EXECUTE_SUBROUTINE .wait_loop

.cutscene_1550_gate_check:
    BRANCH_U8_VAR_WITHIN_RANGE 1, 255, D_80205209, .cutscene_1550_start
    BRANCH_U8_VAR_WITHIN_RANGE 1, 255, D_801D62C6, .cutscene_1550_start
    BRANCH_U8_VAR_WITHIN_RANGE 1, 255, D_801886D0, .cutscene_1550_start
    BRANCH_ON_SPECIAL_BIT MARRIED, lifeEventBits[0], .cutscene_1550_start
    BRANCH_U16_VAR_WITHIN_RANGE 301, 65535, D_801C3B62, .cutscene_1550_start
    SET_SPECIAL_BIT 0, var0
    SET_AUDIO_SEQUENCE 0, _goodbyeSegmentRomStart, _goodbyeSegmentRomEnd
    SET_AUDIO_SEQUENCE_VOLUME 0, 128, 8
    EXECUTE_SUBROUTINE .cutscene_1550_spawn_npcs

.cutscene_1553_bad_ending_exit:
    ENTITY_WALK 80, SOUTHWEST, 2
    ENTITY_WALK 16, NORTHWEST, 2
    SET_AUDIO_SEQUENCE_VOLUME 0, 0, 4
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    ENTITY_WALK 56, NORTHWEST, 2
    WAIT_RGBA_FINISHED
    STOP_SEQUENCE_WITH_FADE 0, 1
    IDLE_WHILE_SEQUENCE_PLAYING 0
    DEACTIVATE_EXECUTOR 1
    DEACTIVATE_EXECUTOR 2
    DEACTIVATE_EXECUTOR 37
    SPAWN_EXECUTOR 32, .credits_roll_player
    DEACTIVATE_SELF

.cutscene_1553_dad_entry:
    EXECUTE_SUBROUTINE .setup_dad_slot22
    SET_COORDINATES -352, 0, 16
    SET_ASSET_ROTATION SOUTHEAST
    ENTITY_WALK 68, SOUTHEAST, 2
    SET_WAIT_FRAMES 30
    SET_ASSET_ROTATION SOUTH
    SET_WAIT_FRAMES 30
    SPAWN_EXECUTOR 2, .cutscene_1553_dog_entry_walk
    SET_ASSET_ROTATION SOUTHEAST
    SET_WAIT_FRAMES 30
    SET_ASSET_ROTATION EAST
    SET_WAIT_FRAMES 60
    BRANCH_ON_SPECIAL_BIT 0, var0, .cutscene_1553_bad_ending_line
    SET_ASSET_ROTATION NORTHEAST
    SPAWN_EXECUTOR 41, .cutscene_1553_gold_prompt
    EXECUTE_SUBROUTINE .wait_loop

.cutscene_1553_gold_prompt:
    SET_U16_VALUE 0, D_80180710
    BRANCH_U32_VAR_WITHIN_RANGE 0, 99999, gGold, .cutscene_1553_affection_dispatch
    UPDATE_U16_VALUE 1, 255, D_80180710
    INIT_DIALOGUE_SESSION 0, DIALOGUE_TEXT_50, 3
    WAIT_FOR_DIALOGUE_INPUT 0
    EXECUTE_SUBROUTINE .cutscene_1553_affection_dispatch

.cutscene_1553_extras_check_d3:
    BRANCH_U8_VAR_WITHIN_RANGE 0, 0, D_801D62C6, .cutscene_1553_happiness_conditional
    EXECUTE_SUBROUTINE .cutscene_1553_check_all_good_stats

.cutscene_1553_extras_check_d2:
    BRANCH_U8_VAR_WITHIN_RANGE 0, 1, D_801D62C6, .cutscene_1553_happiness_conditional
    EXECUTE_SUBROUTINE .cutscene_1553_check_all_good_stats

.cutscene_1553_extras_check_d1:
    BRANCH_U8_VAR_WITHIN_RANGE 0, 2, D_801D62C6, .cutscene_1553_happiness_conditional
    EXECUTE_SUBROUTINE .cutscene_1553_check_all_good_stats

.cutscene_1553_extras_check_d0:
    BRANCH_U8_VAR_WITHIN_RANGE 0, 3, D_801D62C6, .cutscene_1553_happiness_conditional
    EXECUTE_SUBROUTINE .cutscene_1553_check_all_good_stats

.cutscene_1553_affection_dispatch:
    SET_OTHER_EXECUTOR_PTR 0, .player_walk_NE_64
    SET_OTHER_EXECUTOR_PTR 1, .wife_walk_NE_64
    SET_WAIT_FRAMES 64
    BRANCH_U8_VAR_WITHIN_RANGE 0, 0, D_80205209, .cutscene_1553_extras_check_d0
    BRANCH_U8_VAR_WITHIN_RANGE 1, 1, D_80205209, .cutscene_1553_extras_check_d1
    BRANCH_U8_VAR_WITHIN_RANGE 2, 2, D_80205209, .cutscene_1553_extras_check_d2
    BRANCH_U8_VAR_WITHIN_RANGE 3, 3, D_80205209, .cutscene_1553_extras_check_d3

.cutscene_1553_check_all_good_stats:
    BRANCH_U8_VAR_WITHIN_RANGE 0, 3, D_801886D0, .cutscene_1553_happiness_conditional
    BRANCH_ON_SPECIAL_BIT 5, lifeEventBits[0], .cutscene_1553_extra_dialogue_session_4
    EXECUTE_SUBROUTINE .cutscene_1553_happiness_conditional

.cutscene_1553_extra_dialogue_session_4:
    SET_OTHER_EXECUTOR_PTR 0, .face_southwest
    SET_WAIT_FRAMES 20
    SET_OTHER_EXECUTOR_PTR 1, .face_southeast
    SET_WAIT_FRAMES 20
    SET_OTHER_EXECUTOR_PTR 1, .face_northeast
    SET_WAIT_FRAMES 20
    SET_SPECIAL_BIT 1, var0
    UPDATE_U16_VALUE 1, 255, D_80180710
    INIT_DIALOGUE_SESSION 0, DIALOGUE_TEXT_50, 4
    WAIT_FOR_DIALOGUE_INPUT 0

.cutscene_1553_happiness_conditional:
    SET_OTHER_EXECUTOR_PTR 0, .player_walk_NE_64
    SET_OTHER_EXECUTOR_PTR 1, .wife_walk_NE_64
    SET_WAIT_FRAMES 64
    BRANCH_U16_VAR_WITHIN_RANGE 0, 3599, D_801C3B62, .cutscene_1553_high_happiness_sequence
    SET_OTHER_EXECUTOR_PTR 0, .face_southwest
    SET_WAIT_FRAMES 20
    SET_OTHER_EXECUTOR_PTR 1, .face_southeast
    SET_WAIT_FRAMES 20
    SET_OTHER_EXECUTOR_PTR 1, .face_northeast
    SET_WAIT_FRAMES 20
    UPDATE_U16_VALUE 1, 255, D_80180710
    INIT_DIALOGUE_SESSION 0, DIALOGUE_TEXT_50, 5
    WAIT_FOR_DIALOGUE_INPUT 0

.cutscene_1553_high_happiness_sequence:
    BRANCH_U8_VAR_WITHIN_RANGE 0, 219, gHappiness, .cutscene_1553_low_happiness_sequence
    SET_OTHER_EXECUTOR_PTR 0, .player_walk_high_happiness_path
    SET_WAIT_FRAMES 16
    SET_OTHER_EXECUTOR_PTR 1, .wife_walk_high_happiness_path
    SET_WAIT_FRAMES 144
    UPDATE_U16_VALUE 1, 255, D_80180710
    INIT_DIALOGUE_SESSION 0, DIALOGUE_TEXT_50, 7
    WAIT_FOR_DIALOGUE_INPUT 0
    SET_OTHER_EXECUTOR_PTR 0, .player_walk_NW_112
    SET_OTHER_EXECUTOR_PTR 1, .wife_walk_NW_112
    SET_WAIT_FRAMES 128

.dad_final_line_dispatch:
    BRANCH_ON_SPECIAL_BIT 1, var0, .dad_final_after_extras
    BRANCH_U16_VAR_WITHIN_RANGE 0, 0, D_80189824, .dad_talk_needs_more_animals
    INIT_MESSAGE_BOX_TYPE1 0, SEA_FESTIVAL_AND_EVALUATION_TEXT_INDEX, 47
    EXECUTE_SUBROUTINE .cutscene_1553_after_dad_final

.dad_final_after_extras:
    BRANCH_U16_VAR_WITHIN_RANGE 0, 0, D_80189824, .dad_talk_needs_more_animals
    BRANCH_U16_VAR_WITHIN_RANGE 4, 4, D_80189824, .dad_talk_proud_high
    INIT_MESSAGE_BOX_TYPE1 0, SEA_FESTIVAL_AND_EVALUATION_TEXT_INDEX, 48
    EXECUTE_SUBROUTINE .cutscene_1553_after_dad_final

.dad_talk_proud_high:
    INIT_MESSAGE_BOX_TYPE1 0, SEA_FESTIVAL_AND_EVALUATION_TEXT_INDEX, 49
    EXECUTE_SUBROUTINE .cutscene_1553_after_dad_final

.dad_talk_needs_more_animals:
    INIT_MESSAGE_BOX_TYPE1 0, SEA_FESTIVAL_AND_EVALUATION_TEXT_INDEX, 46
    EXECUTE_SUBROUTINE .cutscene_1553_after_dad_final

.cutscene_1553_dispatch_on_wife:
    BRANCH_U8_VAR_WITHIN_RANGE 0, 0, gWife, .wife_greet_maria_start
    BRANCH_U8_VAR_WITHIN_RANGE 1, 1, gWife, .wife_greet_popuri_start
    BRANCH_U8_VAR_WITHIN_RANGE 2, 2, gWife, .wife_greet_elli_start
    BRANCH_U8_VAR_WITHIN_RANGE 3, 3, gWife, .wife_greet_ann_start
    BRANCH_U8_VAR_WITHIN_RANGE 4, 4, gWife, .wife_greet_karen_start
    RETURN_FROM_SUBROUTINE

.cutscene_1553_after_dad_final:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    DEACTIVATE_EXECUTOR 2
    SET_WAIT_FRAMES 5
    BRANCH_ON_SPECIAL_BIT MARRIED, lifeEventBits[0], .cutscene_1553_dispatch_on_wife

; ----- Tribute dispatch chain ------------------------------
; Each link checks one NPC affection (>= 160) and either
; spawns the tribute executor (`.spawn_tribute_<npc>`) or
; falls through to the next check. Wife-related skips guard
; the eligible-romance NPCs from being tributed when they are
; the active spouse. The whole chain bails out via the
; D_801886D2 == 10 cap to avoid overflowing the tribute slots.
.tribute_dispatch_start:
    SET_WAIT_FRAMES 15
    SET_OTHER_EXECUTOR_PTR 0, .face_southwest
    SET_OTHER_EXECUTOR_PTR 1, .face_southwest
    SET_WAIT_FRAMES 15
    SET_OTHER_EXECUTOR_PTR 2, .wife_hostess_walk_NE_face_SW
    SET_U16_VALUE 0, D_801886D2
    BRANCH_U8_VAR_WITHIN_RANGE 160, 255, npcAffection[NPC_SHIPPER], .spawn_tribute_shipper

.tribute_dispatch_after_shipper:
    BRANCH_U8_VAR_WITHIN_RANGE 160, 255, npcAffection[NPC_MAY], .spawn_tribute_may

.tribute_dispatch_after_may:
    BRANCH_U8_VAR_WITHIN_RANGE 160, 255, npcAffection[NPC_PASTOR], .spawn_tribute_pastor

.tribute_dispatch_after_pastor:
    BRANCH_U8_VAR_WITHIN_RANGE 160, 255, npcAffection[NPC_RICK], .spawn_tribute_rick

.tribute_dispatch_after_rick:
    BRANCH_U8_VAR_WITHIN_RANGE 160, 255, npcAffection[NPC_GOTZ], .spawn_tribute_gotz

.tribute_dispatch_after_gotz:
    BRANCH_U8_VAR_WITHIN_RANGE 160, 255, npcAffection[NPC_SASHA], .spawn_tribute_sasha

.tribute_dispatch_after_sasha:
    BRANCH_U8_VAR_WITHIN_RANGE 160, 255, npcAffection[NPC_LILLIA], .spawn_tribute_lillia

.tribute_dispatch_after_lillia:
    BRANCH_U8_VAR_WITHIN_RANGE 160, 255, npcAffection[NPC_BASIL], .spawn_tribute_basil

.tribute_dispatch_after_basil:
    BRANCH_U8_VAR_WITHIN_RANGE 160, 255, npcAffection[NPC_MAYOR], .spawn_tribute_mayor

.tribute_dispatch_after_mayor:
    BRANCH_U8_VAR_WITHIN_RANGE 160, 255, npcAffection[NPC_MAYOR_WIFE], .spawn_tribute_mayor_wife

.tribute_dispatch_after_mayor_wife:
    BRANCH_U16_VAR_WITHIN_RANGE 10, 10, D_801886D2, .tribute_dispatch_finalize
    BRANCH_U8_VAR_WITHIN_RANGE 160, 255, npcAffection[NPC_DOUG], .spawn_tribute_doug

.tribute_dispatch_after_doug:
    BRANCH_U16_VAR_WITHIN_RANGE 10, 10, D_801886D2, .tribute_dispatch_finalize
    BRANCH_U8_VAR_WITHIN_RANGE 160, 255, npcAffection[NPC_KENT], .spawn_tribute_kent

.tribute_dispatch_after_kent:
    BRANCH_U16_VAR_WITHIN_RANGE 10, 10, D_801886D2, .tribute_dispatch_finalize
    BRANCH_U8_VAR_WITHIN_RANGE 160, 255, npcAffection[NPC_STU], .spawn_tribute_stu

.tribute_dispatch_after_stu:
    BRANCH_U16_VAR_WITHIN_RANGE 10, 10, D_801886D2, .tribute_dispatch_finalize
    BRANCH_ON_SPECIAL_BIT 15, lifeEventBits[1], .tribute_dispatch_after_karen
    BRANCH_ON_SPECIAL_BIT MARRIED, lifeEventBits[0], .tribute_karen_wife_skip
    EXECUTE_SUBROUTINE .tribute_karen_check

.tribute_karen_wife_skip:
    BRANCH_U8_VAR_WITHIN_RANGE 4, 4, gWife, .tribute_dispatch_after_karen

.tribute_karen_check:
    BRANCH_U8_VAR_WITHIN_RANGE 160, 255, npcAffection[KAREN], .spawn_tribute_karen

.tribute_dispatch_after_karen:
    BRANCH_U16_VAR_WITHIN_RANGE 10, 10, D_801886D2, .tribute_dispatch_finalize
    BRANCH_ON_SPECIAL_BIT 14, lifeEventBits[1], .tribute_dispatch_after_kai
    BRANCH_U8_VAR_WITHIN_RANGE 160, 255, npcAffection[KAI], .spawn_tribute_kai

.tribute_dispatch_after_kai:
    BRANCH_U16_VAR_WITHIN_RANGE 10, 10, D_801886D2, .tribute_dispatch_finalize
    BRANCH_ON_SPECIAL_BIT MARRIED, lifeEventBits[0], .tribute_popuri_wife_skip
    EXECUTE_SUBROUTINE .tribute_popuri_check

.tribute_popuri_wife_skip:
    BRANCH_U8_VAR_WITHIN_RANGE 1, 1, gWife, .tribute_dispatch_after_popuri

.tribute_popuri_check:
    BRANCH_U8_VAR_WITHIN_RANGE 160, 255, npcAffection[POPURI], .spawn_tribute_popuri

.tribute_dispatch_after_popuri:
    BRANCH_U16_VAR_WITHIN_RANGE 10, 10, D_801886D2, .tribute_dispatch_finalize
    BRANCH_U8_VAR_WITHIN_RANGE 160, 255, npcAffection[GRAY], .spawn_tribute_gray

.tribute_dispatch_after_gray:
    BRANCH_U16_VAR_WITHIN_RANGE 10, 10, D_801886D2, .tribute_dispatch_finalize
    BRANCH_ON_SPECIAL_BIT MARRIED, lifeEventBits[0], .tribute_elli_wife_skip
    EXECUTE_SUBROUTINE .tribute_elli_check

.tribute_elli_wife_skip:
    BRANCH_U8_VAR_WITHIN_RANGE 2, 2, gWife, .tribute_dispatch_after_elli

.tribute_elli_check:
    BRANCH_U8_VAR_WITHIN_RANGE 160, 255, npcAffection[ELLI], .spawn_tribute_elli

.tribute_dispatch_after_elli:
    BRANCH_U16_VAR_WITHIN_RANGE 10, 10, D_801886D2, .tribute_dispatch_finalize
    BRANCH_U8_VAR_WITHIN_RANGE 160, 255, npcAffection[JEFF], .spawn_tribute_jeff

.tribute_dispatch_after_jeff:
    BRANCH_U16_VAR_WITHIN_RANGE 10, 10, D_801886D2, .tribute_dispatch_finalize
    BRANCH_ON_SPECIAL_BIT MARRIED, lifeEventBits[0], .tribute_ann_wife_skip
    EXECUTE_SUBROUTINE .tribute_ann_check

.tribute_ann_wife_skip:
    BRANCH_U8_VAR_WITHIN_RANGE 3, 3, gWife, .tribute_dispatch_after_ann

.tribute_ann_check:
    BRANCH_U8_VAR_WITHIN_RANGE 160, 255, npcAffection[ANN], .spawn_tribute_ann

.tribute_dispatch_after_ann:
    BRANCH_U16_VAR_WITHIN_RANGE 10, 10, D_801886D2, .tribute_dispatch_finalize
    BRANCH_ON_SPECIAL_BIT 13, lifeEventBits[1], .tribute_dispatch_after_cliff
    BRANCH_U8_VAR_WITHIN_RANGE 160, 255, npcAffection[CLIFF], .spawn_tribute_cliff

.tribute_dispatch_after_cliff:
    BRANCH_U16_VAR_WITHIN_RANGE 10, 10, D_801886D2, .tribute_dispatch_finalize
    BRANCH_ON_SPECIAL_BIT MARRIED, lifeEventBits[0], .tribute_maria_wife_skip
    EXECUTE_SUBROUTINE .tribute_maria_check

.tribute_maria_wife_skip:
    BRANCH_U8_VAR_WITHIN_RANGE 0, 0, gWife, .tribute_dispatch_after_maria

.tribute_maria_check:
    BRANCH_U8_VAR_WITHIN_RANGE 160, 255, npcAffection[MARIA], .spawn_tribute_maria

.tribute_dispatch_after_maria:
    BRANCH_U16_VAR_WITHIN_RANGE 10, 10, D_801886D2, .tribute_dispatch_finalize
    BRANCH_U8_VAR_WITHIN_RANGE 160, 255, npcAffection[HARRIS], .spawn_tribute_harris

; ----- After all tributes placed -----
; DAD picks one of three lines based on tribute count
; (D_801886D2): low (0..3), mid (4..7), or fallthrough high.
.tribute_dispatch_finalize:
    BRANCH_U16_VAR_WITHIN_RANGE 0, 3, D_801886D2, .dad_crowd_talk_low
    BRANCH_U16_VAR_WITHIN_RANGE 4, 7, D_801886D2, .dad_crowd_talk_mid
    INIT_MESSAGE_BOX_TYPE1 0, SEA_FESTIVAL_AND_EVALUATION_TEXT_INDEX, 66

.dad_crowd_aftermath:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    BRANCH_ON_SPECIAL_BIT MARRIED, lifeEventBits[0], .cutscene_1553_dispatch_wife_credit

.cutscene_1553_play_end_fade:
    SET_OTHER_EXECUTOR_PTR 0, .cutscene_1553_player_idle_halt
    SET_OTHER_EXECUTOR_PTR 37, .cutscene_1553_ending_frame_fade
    DEACTIVATE_SELF

.cutscene_1553_dispatch_wife_credit:
    BRANCH_U8_VAR_WITHIN_RANGE 0, 0, gWife, .maria_greet_dad_intro
    BRANCH_U8_VAR_WITHIN_RANGE 1, 1, gWife, .popuri_greet_dad_intro
    BRANCH_U8_VAR_WITHIN_RANGE 2, 2, gWife, .elli_greet_dad_intro
    BRANCH_U8_VAR_WITHIN_RANGE 3, 3, gWife, .ann_greet_dad_intro
    BRANCH_U8_VAR_WITHIN_RANGE 4, 4, gWife, .karen_greet_dad_intro
    RETURN_FROM_SUBROUTINE

.dad_crowd_talk_low:
    INIT_MESSAGE_BOX_TYPE1 0, SEA_FESTIVAL_AND_EVALUATION_TEXT_INDEX, 64
    EXECUTE_SUBROUTINE .dad_crowd_aftermath

.dad_crowd_talk_mid:
    INIT_MESSAGE_BOX_TYPE1 0, SEA_FESTIVAL_AND_EVALUATION_TEXT_INDEX, 65
    EXECUTE_SUBROUTINE .dad_crowd_aftermath

; ----- Pre-tribute wife greetings -----
; Five variants (one per wife) for the wife calling DAD over
; before the tribute walk-in starts. Each has an alternate
; all-attended line when D_801886D2 hits 10.
.maria_greet_dad_intro:
    SET_OTHER_EXECUTOR_PTR 0, .face_northwest
    SET_OTHER_EXECUTOR_PTR 1, .face_northwest
    SET_OTHER_EXECUTOR_PTR 2, .face_southeast
    SET_WAIT_FRAMES 10
    BRANCH_U16_VAR_WITHIN_RANGE 10, 10, D_801886D2, .maria_greet_dad_all_attended
    INIT_MESSAGE_BOX_TYPE1 0, SEA_FESTIVAL_AND_EVALUATION_TEXT_INDEX, 67

.wife_greet_dad_transition:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
