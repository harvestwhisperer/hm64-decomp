    EXECUTE_SUBROUTINE .credits_slide_fade_cycle
    SET_ANIM_DATA_PTR_WITH_FLAG .anim_1500A8
    EXECUTE_SUBROUTINE .credits_slide_fade_cycle
    SET_ANIM_DATA_PTR_WITH_FLAG .anim_1500B4
    EXECUTE_SUBROUTINE .credits_slide_fade_cycle
    SET_ANIM_DATA_PTR_WITH_FLAG .anim_1500C0
    EXECUTE_SUBROUTINE .credits_slide_fade_cycle
    SET_ANIM_DATA_PTR_WITH_FLAG .anim_1500CC
    EXECUTE_SUBROUTINE .credits_slide_fade_cycle
    SET_ANIM_DATA_PTR_WITH_FLAG .anim_150108
    EXECUTE_SUBROUTINE .credits_slide_fade_cycle
    SET_ANIM_DATA_PTR_WITH_FLAG .anim_1500D8
    EXECUTE_SUBROUTINE .credits_slide_fade_cycle
    SET_ANIM_DATA_PTR_WITH_FLAG .anim_1500E4
    EXECUTE_SUBROUTINE .credits_slide_fade_cycle
    SET_ANIM_DATA_PTR_WITH_FLAG .anim_1500F0
    EXECUTE_SUBROUTINE .credits_slide_fade_cycle
    SET_MESSAGE_INTERPOLATION -4, 0, 0
    SET_MESSAGE_BOX_ASSETS 0, 255, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 0, -9, 352
    INIT_MESSAGE_BOX_TYPE2 0, SEA_FESTIVAL_AND_EVALUATION_TEXT_INDEX, 143
    UPDATE_MESSAGE_BOX_RGBA 0, 0, 0, 0, 0, 255
    SET_WAIT_FRAMES 15
    UPDATE_MESSAGE_BOX_RGBA 0, 255, 255, 255, 255, 8
    SET_ANIM_DATA_PTR_WITH_FLAG .anim_1500FC
    UPDATE_RGBA 255, 255, 255, 255, 8
    WAIT_RGBA_FINISHED
    SET_WAIT_FRAMES 142
    UPDATE_MESSAGE_BOX_RGBA 0, 0, 0, 0, 0, 4
    UPDATE_RGBA 0, 0, 0, 0, 4
    WAIT_RGBA_FINISHED
    RESET_MESSAGE_BOX_AVATAR 0
    SET_WAIT_FRAMES 40
    IDLE_WHILE_SEQUENCE_PLAYING 0
    SET_WAIT_FRAMES 30
    SET_U16_VALUE 0, D_80180710
    BRANCH_ON_SPECIAL_BIT 0, var0, .credits_bad_ending_flag_set
    EXECUTE_SUBROUTINE .exit_demo

.credits_bad_ending_flag_set:
    SET_U16_VALUE 65535, D_80180710
    EXECUTE_SUBROUTINE .exit_demo

.cutscene_1553_gate_check:
    BRANCH_U8_VAR_WITHIN_RANGE 1, 255, D_80205209, .cutscene_1553_start
    BRANCH_U8_VAR_WITHIN_RANGE 1, 255, D_801D62C6, .cutscene_1553_start
    BRANCH_U8_VAR_WITHIN_RANGE 1, 255, D_801886D0, .cutscene_1553_start
    BRANCH_ON_SPECIAL_BIT MARRIED, lifeEventBits[0], .cutscene_1553_start
    BRANCH_U16_VAR_WITHIN_RANGE 301, 65535, D_801C3B62, .cutscene_1553_start
    SET_SPECIAL_BIT 0, var0
    EXECUTE_SUBROUTINE .cutscene_1553_start

