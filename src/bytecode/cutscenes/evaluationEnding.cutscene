; ----- Shared tribute helpers -----
.tribute_walk_in_path:
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    SET_COORDINATES -248, 0, -96
    ENTITY_WALK 80, NORTHEAST, 2
    RETURN_FROM_SUBROUTINE

.tribute_walk_post_greet:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    ENTITY_WALK 8, NORTHEAST, 2
    ENTITY_WALK 52, NORTHWEST, 2
    RETURN_FROM_SUBROUTINE

.cutscene_1553_low_happiness_sequence:
    SET_OTHER_EXECUTOR_PTR 0, .player_walk_NE_24
    SET_OTHER_EXECUTOR_PTR 1, .wife_walk_NE_24
    SET_WAIT_FRAMES 24
    EXECUTE_SUBROUTINE .dad_final_line_dispatch

; ----- Cutscene 1553 walk helpers (paired player + wife paths) -----
.player_walk_NE_64:
    ENTITY_WALK 64, NORTHEAST, 2
    EXECUTE_SUBROUTINE .wait_loop

.wife_walk_NE_64:
    ENTITY_WALK 64, NORTHEAST, 2
    EXECUTE_SUBROUTINE .wait_loop

.player_walk_high_happiness_path:
    ENTITY_WALK 16, NORTHEAST, 2
    ENTITY_WALK 128, SOUTHEAST, 2
    SET_ASSET_ROTATION SOUTHWEST
    EXECUTE_SUBROUTINE .wait_loop

.wife_walk_high_happiness_path:
    ENTITY_WALK 32, NORTHEAST, 2
    ENTITY_WALK 112, SOUTHEAST, 2
    SET_ASSET_ROTATION SOUTHWEST
    EXECUTE_SUBROUTINE .wait_loop

.player_walk_NW_112:
    ENTITY_WALK 112, NORTHWEST, 2
    SET_ASSET_ROTATION SOUTHWEST
    EXECUTE_SUBROUTINE .wait_loop

.wife_walk_NW_112:
    ENTITY_WALK 112, NORTHWEST, 2
    SET_ASSET_ROTATION SOUTHWEST
    EXECUTE_SUBROUTINE .wait_loop

.player_walk_NE_24:
    ENTITY_WALK 24, NORTHEAST, 2
    SET_ASSET_ROTATION SOUTHWEST
    EXECUTE_SUBROUTINE .wait_loop

.wife_walk_NE_24:
    ENTITY_WALK 24, NORTHEAST, 2
    EXECUTE_SUBROUTINE .wait_loop

; ----- Cutscene 1553 bad-ending body + dog trick -----
.cutscene_1553_bad_ending_line:
    SET_ASSET_ROTATION NORTHEAST
    SET_WAIT_FRAMES 20
    INIT_MESSAGE_BOX_TYPE1 0, SEA_FESTIVAL_AND_EVALUATION_TEXT_INDEX, 29
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_WAIT_FRAMES 10
    SET_OTHER_EXECUTOR_PTR 2, .cutscene_1553_dog_trick_sequence
    ENTITY_WALK 32, SOUTHWEST, 2
    SET_OTHER_EXECUTOR_PTR 0, .cutscene_1553_bad_ending_exit
    ENTITY_WALK 32, SOUTHWEST, 2
    ENTITY_WALK 96, NORTHWEST, 2
    EXECUTE_SUBROUTINE .wait_loop

.setup_player_dog_slot1:
    SETUP_ENTITY 1, ENTITY_ASSET_PLAYER_DOG, 1
    SET_ENTITY_ANIMATIONS 1, 0, 8, 16, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    RETURN_FROM_SUBROUTINE

.cutscene_1553_dog_entry_walk:
    EXECUTE_SUBROUTINE .setup_player_dog_slot1
    SET_ASSET_ROTATION SOUTHWEST
    SET_COORDINATES -248, 0, -240
    ENTITY_WALK 80, SOUTHWEST, 2
    EXECUTE_SUBROUTINE .wait_loop

.cutscene_1553_dog_trick_sequence:
    SET_ENTITY_ANIMATION_WITH_DIRECTION_CHANGE 144
    SET_SFX 59, 128
    SET_WAIT_FRAMES 10
    SET_SFX 59, 128
    SET_WAIT_FRAMES 15
    SET_SFX 59, 128
    SET_WAIT_FRAMES 10
    SET_SFX 59, 128
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_ANIMATION_WITH_DIRECTION_CHANGE 0
    SET_WAIT_FRAMES 10
    SET_ENTITY_ANIMATION_WITH_DIRECTION_CHANGE 48
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_ANIMATION_WITH_DIRECTION_CHANGE 40
    EXECUTE_SUBROUTINE .wait_loop

; ============================================================
; Credits roll - shared fade cycle + main player
; ============================================================
.credits_slide_fade_cycle:
    UPDATE_RGBA 255, 255, 255, 255, 8
    WAIT_RGBA_FINISHED
    SET_WAIT_FRAMES 142
    UPDATE_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    RETURN_FROM_SUBROUTINE

.credits_roll_player:
    SET_AUDIO_SEQUENCE 0, _openingSegmentRomStart, _openingSegmentRomEnd
    SET_AUDIO_SEQUENCE_VOLUME 0, 128, 128
    SET_SPECIAL_BIT 8, gCutsceneCompletionFlags
    DMA_SPRITE 80, 0, _creditsTextureSegmentRomStart, _creditsTextureSegmentRomEnd, _creditsAssetsIndexSegmentRomStart, _creditsAssetsIndexSegmentRomEnd, 0, 0, 0x80294250, 0, 0x8028DD50, 0x80290550, 0x80293A50, 0x80293C50
    SET_SPRITE_BILINEAR 0
    SET_ANIM_DATA_PTR_WITH_FLAG .anim_150048
    SET_RGBA 0, 0, 0, 0
    SET_COORDINATES 0, 0, 254
    EXECUTE_SUBROUTINE .credits_slide_fade_cycle
    SET_ANIM_DATA_PTR_WITH_FLAG .anim_150054
    EXECUTE_SUBROUTINE .credits_slide_fade_cycle
    SET_ANIM_DATA_PTR_WITH_FLAG .anim_150060
    EXECUTE_SUBROUTINE .credits_slide_fade_cycle
