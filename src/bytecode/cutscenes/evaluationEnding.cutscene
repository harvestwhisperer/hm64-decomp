; ----- Wife hostess greet bodies (per-wife) -----
.maria_hostess_greet:
    SETUP_ENTITY 24, ENTITY_ASSET_MARIA, 1
    SET_ENTITY_ANIMATIONS 24, 0, 8, 0, 108, 118, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    SET_COORDINATES -408, 0, -288
    BRANCH_ON_SPECIAL_BIT HAVE_BABY, lifeEventBits[0], .wife_hostess_with_baby
    SET_ASSET_ROTATION SOUTHEAST
    ENTITY_WALK 64, SOUTHEAST, 2
    INIT_MESSAGE_BOX_TYPE1 0, SEA_FESTIVAL_AND_EVALUATION_TEXT_INDEX, 50

.wife_hostess_post_greet:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 41, .tribute_dispatch_start
    EXECUTE_SUBROUTINE .wait_loop

.popuri_hostess_greet:
    SETUP_ENTITY 24, ENTITY_ASSET_POPURI, 1
    SET_ENTITY_ANIMATIONS 24, 0, 8, 0, 122, 132, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    SET_COORDINATES -408, 0, -288
    BRANCH_ON_SPECIAL_BIT HAVE_BABY, lifeEventBits[0], .wife_hostess_with_baby
    SET_ASSET_ROTATION SOUTHEAST
    ENTITY_WALK 64, SOUTHEAST, 2
    INIT_MESSAGE_BOX_TYPE1 0, SEA_FESTIVAL_AND_EVALUATION_TEXT_INDEX, 107
    EXECUTE_SUBROUTINE .wife_hostess_post_greet

.elli_hostess_greet:
    SETUP_ENTITY 24, ENTITY_ASSET_ELLI, 1
    SET_ENTITY_ANIMATIONS 24, 0, 8, 0, 105, 115, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    SET_COORDINATES -408, 0, -288
    BRANCH_ON_SPECIAL_BIT HAVE_BABY, lifeEventBits[0], .wife_hostess_with_baby
    SET_ASSET_ROTATION SOUTHEAST
    ENTITY_WALK 64, SOUTHEAST, 2
    INIT_MESSAGE_BOX_TYPE1 0, SEA_FESTIVAL_AND_EVALUATION_TEXT_INDEX, 116
    EXECUTE_SUBROUTINE .wife_hostess_post_greet

.ann_hostess_greet:
    SETUP_ENTITY 24, ENTITY_ASSET_ANN, 1
    SET_ENTITY_ANIMATIONS 24, 0, 8, 0, 111, 121, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    SET_COORDINATES -408, 0, -288
    BRANCH_ON_SPECIAL_BIT HAVE_BABY, lifeEventBits[0], .wife_hostess_with_baby
    SET_ASSET_ROTATION SOUTHEAST
    ENTITY_WALK 64, SOUTHEAST, 2
    INIT_MESSAGE_BOX_TYPE1 0, SEA_FESTIVAL_AND_EVALUATION_TEXT_INDEX, 125
    EXECUTE_SUBROUTINE .wife_hostess_post_greet

.karen_hostess_greet:
    SETUP_ENTITY 24, ENTITY_ASSET_KAREN, 1
    SET_ENTITY_ANIMATIONS 24, 0, 8, 0, 102, 112, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    SET_COORDINATES -408, 0, -288
    BRANCH_ON_SPECIAL_BIT HAVE_BABY, lifeEventBits[0], .wife_hostess_with_baby
    SET_ASSET_ROTATION SOUTHEAST
    ENTITY_WALK 64, SOUTHEAST, 2
    INIT_MESSAGE_BOX_TYPE1 0, SEA_FESTIVAL_AND_EVALUATION_TEXT_INDEX, 134
    EXECUTE_SUBROUTINE .wife_hostess_post_greet

.wife_hostess_with_baby:
    SET_HOLDING_ANIMATION_FLAG TRUE
    SPAWN_EXECUTOR 3, .baby_entity_setup
    RETURN_FROM_SUBROUTINE

.baby_entity_setup:
    SETUP_ENTITY 39, ENTITY_ASSET_STATIC_ITEM, 1
    SET_ENTITY_ANIMATIONS 39, 0, 0, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    BRANCH_U8_VAR_WITHIN_RANGE 30, 255, gBabyAge, .baby_older_anim
    SET_ENTITY_ANIMATION_WITH_DIRECTION_CHANGE 213

.baby_attach_to_wife:
    SET_ENTITY_TRACKING_TARGET 24, 0, 24, 20, 254
    EXECUTE_SUBROUTINE .wait_loop

.baby_older_anim:
    SET_ENTITY_ANIMATION_WITH_DIRECTION_CHANGE 221
    EXECUTE_SUBROUTINE .baby_attach_to_wife

; ----- Tribute walk paths -----
; Each path takes the tribute from the entry point to its slot
; in the crowd. Selected by D_801886D2 (1..9); tribute 10+
; falls through to .tribute_walk_path_overflow.
.tribute_walk_to_position:
    BRANCH_U16_VAR_WITHIN_RANGE 1, 1, D_801886D2, .tribute_walk_path_1
    BRANCH_U16_VAR_WITHIN_RANGE 2, 2, D_801886D2, .tribute_walk_path_2
    BRANCH_U16_VAR_WITHIN_RANGE 3, 3, D_801886D2, .tribute_walk_path_3
    BRANCH_U16_VAR_WITHIN_RANGE 4, 4, D_801886D2, .tribute_walk_path_4
    BRANCH_U16_VAR_WITHIN_RANGE 5, 5, D_801886D2, .tribute_walk_path_5
    BRANCH_U16_VAR_WITHIN_RANGE 6, 6, D_801886D2, .tribute_walk_path_6
    BRANCH_U16_VAR_WITHIN_RANGE 7, 7, D_801886D2, .tribute_walk_path_7
    BRANCH_U16_VAR_WITHIN_RANGE 8, 8, D_801886D2, .tribute_walk_path_8
    BRANCH_U16_VAR_WITHIN_RANGE 9, 9, D_801886D2, .tribute_walk_path_9
    EXECUTE_SUBROUTINE .tribute_walk_path_overflow

.tribute_walk_path_1:
    ENTITY_WALK 72, NORTHEAST, 2
    ENTITY_WALK 48, NORTHWEST, 2
    SET_ASSET_ROTATION SOUTH
    EXECUTE_SUBROUTINE .wait_loop

.tribute_walk_path_2:
    ENTITY_WALK 48, NORTHWEST, 2
    ENTITY_WALK 48, NORTHEAST, 2
    SET_ASSET_ROTATION SOUTHEAST
    EXECUTE_SUBROUTINE .wait_loop

.tribute_walk_path_3:
    ENTITY_WALK 72, NORTHEAST, 2
    ENTITY_WALK 24, NORTHWEST, 2
    SET_ASSET_ROTATION SOUTHWEST
    EXECUTE_SUBROUTINE .wait_loop

.tribute_walk_path_4:
    ENTITY_WALK 24, NORTHWEST, 2
    ENTITY_WALK 24, NORTHEAST, 2
    SET_ASSET_ROTATION NORTHEAST
    EXECUTE_SUBROUTINE .wait_loop

.tribute_walk_path_5:
    ENTITY_WALK 72, NORTHEAST, 2
    SET_ASSET_ROTATION WEST
    EXECUTE_SUBROUTINE .wait_loop

.tribute_walk_path_6:
    ENTITY_WALK 48, NORTHEAST, 2
    SET_ASSET_ROTATION NORTHWEST
    EXECUTE_SUBROUTINE .wait_loop

.tribute_walk_path_7:
    ENTITY_WALK 48, NORTHWEST, 2
    ENTITY_WALK 8, SOUTHWEST, 2
    SET_ASSET_ROTATION EAST
    EXECUTE_SUBROUTINE .wait_loop

.tribute_walk_path_8:
    ENTITY_WALK 48, NORTHWEST, 2
    ENTITY_WALK 24, NORTHEAST, 2
    SET_ASSET_ROTATION EAST
    EXECUTE_SUBROUTINE .wait_loop

.tribute_walk_path_9:
    ENTITY_WALK 24, NORTHWEST, 2
    ENTITY_WALK 8, SOUTHWEST, 2
    SET_ASSET_ROTATION NORTHEAST
    EXECUTE_SUBROUTINE .wait_loop

.tribute_walk_path_overflow:
    EXECUTE_SUBROUTINE .wait_loop

