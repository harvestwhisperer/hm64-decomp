    EXECUTE_SUBROUTINE .wait_loop

.wife_credit_wife_karen:
    SPAWN_EXECUTOR 2, .karen_credit_sequence
    EXECUTE_SUBROUTINE .wait_loop

; ----- Per-wife credit bodies -----
; Each body: setup wife + (optional) baby, two opening lines,
; a SELECTION dialogue session (different ID per wife), then a
; baby-aware closing line. All five chain into
; .wife_credit_fade_to_credits to roll credits.
.maria_credit_sequence:
    EXECUTE_SUBROUTINE .setup_maria_slot24
    SET_COORDINATES -368, 0, -300
    SET_ASSET_ROTATION SOUTHEAST
    SET_ENTITY_ANIMATION 55
    UPDATE_GLOBAL_RGBA 64, 64, 64, 64, 6
    WAIT_RGBA_FINISHED
    SET_WAIT_FRAMES 30
