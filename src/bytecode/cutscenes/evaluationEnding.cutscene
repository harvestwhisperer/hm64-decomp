; ----- Wife hostess greeting (married, pre-tribute) -----
; Each variant sets up the wife at her assigned slot, walks her
; in, and emits a ready greeting; HAVE_BABY branches
; spawn .baby_entity_setup to put the baby in her arms.
.wife_greet_maria_start:
    SET_OTHER_EXECUTOR_PTR 0, .face_northwest
    SET_OTHER_EXECUTOR_PTR 1, .face_northwest
    SPAWN_EXECUTOR 2, .maria_hostess_greet
    EXECUTE_SUBROUTINE .wait_loop

.wife_greet_popuri_start:
    SET_OTHER_EXECUTOR_PTR 0, .face_northwest
    SET_OTHER_EXECUTOR_PTR 1, .face_northwest
    SPAWN_EXECUTOR 2, .popuri_hostess_greet
    EXECUTE_SUBROUTINE .wait_loop

.wife_greet_elli_start:
    SET_OTHER_EXECUTOR_PTR 0, .face_northwest
    SET_OTHER_EXECUTOR_PTR 1, .face_northwest
    SPAWN_EXECUTOR 2, .elli_hostess_greet
    EXECUTE_SUBROUTINE .wait_loop

.wife_greet_ann_start:
