    SPAWN_EXECUTOR 32, .credits_roll_player
    DEACTIVATE_SELF

; ----- Married-path credit dispatch -----
; Picks a per-wife credit body via gWife (see mapping above).
.wife_credit_dispatch:
    BRANCH_U8_VAR_WITHIN_RANGE 0, 0, gWife, .wife_credit_wife_maria
    BRANCH_U8_VAR_WITHIN_RANGE 1, 1, gWife, .wife_credit_wife_popuri
    BRANCH_U8_VAR_WITHIN_RANGE 2, 2, gWife, .wife_credit_wife_elli
    BRANCH_U8_VAR_WITHIN_RANGE 3, 3, gWife, .wife_credit_wife_ann
    BRANCH_U8_VAR_WITHIN_RANGE 4, 4, gWife, .wife_credit_wife_karen
    RETURN_FROM_SUBROUTINE

.wife_credit_player_pose:
    SET_BEHAVIOR_FLAGS CUTSCENE_ASSET_BEHAVIOR_TRACK_ENTITY
    SET_COORDINATES -352, 0, -320
    SET_ASSET_ROTATION SOUTHEAST
    SET_ENTITY_ANIMATION 507
    EXECUTE_SUBROUTINE .wait_loop

.wife_credit_player_anim_501:
    SET_ENTITY_ANIMATION 501
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_ANIMATION_WITH_DIRECTION_CHANGE 0
    EXECUTE_SUBROUTINE .wait_loop

.wife_credit_player_anim_495:
    SET_ENTITY_ANIMATION 495
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_ANIMATION_WITH_DIRECTION_CHANGE 0
    EXECUTE_SUBROUTINE .wait_loop

.wife_credit_player_anim_473_474:
    SET_ENTITY_ANIMATION 473
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_ANIMATION 474
    EXECUTE_SUBROUTINE .wait_loop

.wife_credit_dog_setup:
    EXECUTE_SUBROUTINE .setup_player_dog_slot1
    SET_COORDINATES -352, 0, -272
    SET_ASSET_ROTATION SOUTHEAST
    SET_ENTITY_ANIMATION_WITH_DIRECTION_CHANGE 40
    EXECUTE_SUBROUTINE .wait_loop

.wife_credit_dog_animations:
    SET_ENTITY_ANIMATION_WITH_DIRECTION_CHANGE 104
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_ANIMATION_WITH_DIRECTION_CHANGE 40
    SET_WAIT_FRAMES 60
    SET_ENTITY_ANIMATION_WITH_DIRECTION_CHANGE 120
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_ANIMATION_WITH_DIRECTION_CHANGE 40
    EXECUTE_SUBROUTINE .wait_loop

.wife_credit_wife_maria:
    SPAWN_EXECUTOR 2, .maria_credit_sequence
    EXECUTE_SUBROUTINE .wait_loop

.wife_credit_wife_popuri:
    SPAWN_EXECUTOR 2, .popuri_credit_sequence
    EXECUTE_SUBROUTINE .wait_loop

.wife_credit_wife_elli:
