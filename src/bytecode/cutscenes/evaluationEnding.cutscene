    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 0, .wife_credit_player_anim_501
    SET_WAIT_FRAMES 30
    SET_OTHER_EXECUTOR_PTR 0, .wife_credit_player_anim_495
    SET_WAIT_FRAMES 30
    INIT_MESSAGE_BOX_TYPE1 0, SEA_FESTIVAL_AND_EVALUATION_TEXT_INDEX, 70
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_ENTITY_ANIMATION 53
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_ANIMATION_WITH_DIRECTION_CHANGE 0
    SET_WAIT_FRAMES 20
    SET_ASSET_ROTATION EAST
    INIT_DIALOGUE_SESSION 0, DIALOGUE_TEXT_50, 16
    WAIT_FOR_DIALOGUE_INPUT 0
    BRANCH_ON_DIALOGUE 0, 0, .maria_credit_no_baby_yet
    BRANCH_ON_DIALOGUE 0, 1, .maria_credit_no_final_word

