; ============================================================
; Tribute executors - 23 villagers
; ============================================================
; Each .tribute_<npc> executor:
;   1. dispatches on D_801886D2 (1..N) into a per-slot setup
;      branch that calls SETUP_ENTITY at the matching slot
;      (slot 25 = 1st tribute, 26 = 2nd, ... 34 = 10th);
;   2. runs .tribute_walk_in_path to walk the NPC on-screen;
;   3. emits the NPC tribute line (text 51..63 / 144..153);
;   4. runs .tribute_walk_post_greet to finish positioning;
;   5. chains executor 41 to the next link in the dispatch
;      chain so the next tribute can be considered.
.tribute_maria:
    BRANCH_U16_VAR_WITHIN_RANGE 1, 1, D_801886D2, .tribute_maria_slot_1
    BRANCH_U16_VAR_WITHIN_RANGE 2, 2, D_801886D2, .tribute_maria_slot_2
    BRANCH_U16_VAR_WITHIN_RANGE 3, 3, D_801886D2, .tribute_maria_slot_3
    BRANCH_U16_VAR_WITHIN_RANGE 4, 4, D_801886D2, .tribute_maria_slot_4
    BRANCH_U16_VAR_WITHIN_RANGE 5, 5, D_801886D2, .tribute_maria_slot_5
    BRANCH_U16_VAR_WITHIN_RANGE 6, 6, D_801886D2, .tribute_maria_slot_6
    BRANCH_U16_VAR_WITHIN_RANGE 7, 7, D_801886D2, .tribute_maria_slot_7
    BRANCH_U16_VAR_WITHIN_RANGE 8, 8, D_801886D2, .tribute_maria_slot_8
    BRANCH_U16_VAR_WITHIN_RANGE 9, 9, D_801886D2, .tribute_maria_slot_9
    BRANCH_U16_VAR_WITHIN_RANGE 10, 10, D_801886D2, .tribute_maria_slot_10
    EXECUTE_SUBROUTINE .tribute_walk_in_path
    INIT_MESSAGE_BOX_TYPE1 0, SEA_FESTIVAL_AND_EVALUATION_TEXT_INDEX, 51
    EXECUTE_SUBROUTINE .tribute_walk_post_greet
    SET_OTHER_EXECUTOR_PTR 41, .tribute_dispatch_after_maria
    EXECUTE_SUBROUTINE .tribute_walk_to_position

