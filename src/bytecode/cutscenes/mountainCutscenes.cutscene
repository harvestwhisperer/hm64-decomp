; ============================================
; Cutscene 348 (re-entry into cutscene 347 body)
; Executes .cutscene_347_body directly; player-entity pose keyed on
; gItemBeingHeld (anim 24 if holding, else idle).
; ============================================

.cutscene_348_entry:
    EXECUTE_SUBROUTINE .cutscene_347_body

.executor_player_entity_348:
    EXECUTE_SUBROUTINE .setup_player_entity
    SET_COORDINATES 0, 0, 0
    SET_ASSET_ROTATION 0
    BRANCH_U8_VAR_WITHIN_RANGE 0, 254, gItemBeingHeld, .branch_1151D4
    EXECUTE_SUBROUTINE .idle

.branch_1151D4:
    SET_ENTITY_DIRECTIONAL_ANIMATION 24
    EXECUTE_SUBROUTINE .idle

; ============================================
; Cutscene 349 (Mountain exit goodbye from Assistant Carpenter)
; Player runs day/stamina branch: day 30 = text 258 (end-of-year),
; stamina 0-1 = text 256 (rest message), else text 257 (end-of-day).
; NPC idles and on A-press says 258 on day 30 or 257 otherwise.
; ============================================

.cutscene_349_entry:
    SPAWN_EXECUTOR 1, .executor_asst_carp_349
    SET_U16_VALUE 0, playerIdleCounter
    EXECUTE_SUBROUTINE .setup_player_entity
    SET_COORDINATES -288, 0, -120
    BRANCH_U8_VAR_WITHIN_RANGE 0, 254, gItemBeingHeld, .player_preserve_carry
    SET_ASSET_ROTATION 2
    SET_WAIT_FRAMES 40
    BRANCH_U8_VAR_WITHIN_RANGE 30, 30, gDayOfMonth, .player_349_end_of_year
    BRANCH_U8_VAR_WITHIN_RANGE 0, 1, gPlayer.currentStamina, .player_349_low_stamina
    ; we are done for the day -- come again tomorrow
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 257
.player_349_close_and_end:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_ENTITY_MAP_SPACE_INDEPENDENT FALSE
    EXECUTE_SUBROUTINE .end_cutscene

.player_349_end_of_year:
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 258
    EXECUTE_SUBROUTINE .player_349_close_and_end

.player_349_low_stamina:
    ; Assistant Carpenter: cant do anything if youre too tired
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 256
    EXECUTE_SUBROUTINE .player_349_close_and_end

.executor_asst_carp_349:
    EXECUTE_SUBROUTINE .setup_assistant_carpenter_e37
    SET_COORDINATES -320, 0, -120
    SET_ASSET_ROTATION 6

.asst_carp_349_wait:
    SET_CALLBACK_ROUTINE 0, BUTTON_A, .asst_carp_349_on_interact
    EXECUTE_SUBROUTINE .idle

.asst_carp_349_on_interact:
    PAUSE_ENTITIES
    FLIP_ENTITY_DIRECTION 0
    EXECUTE_SUBROUTINE .setup_message_box
    BRANCH_U8_VAR_WITHIN_RANGE 30, 30, gDayOfMonth, .asst_carp_349_end_of_year
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 257

.asst_carp_349_close_and_resume:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .asst_carp_349_wait

.asst_carp_349_end_of_year:
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 258
    EXECUTE_SUBROUTINE .asst_carp_349_close_and_resume

; ============================================
; Cutscene 350 (New Year)
; ============================================

.cutscene_350_entry:
    EXECUTE_SUBROUTINE .setup_assistant_carpenter_e37
    SET_COORDINATES -320, 0, -120
    SET_ASSET_ROTATION 6

.asst_carp_350_wait:
    SET_CALLBACK_ROUTINE 0, BUTTON_A, .asst_carp_350_on_interact
    EXECUTE_SUBROUTINE .idle

.asst_carp_350_on_interact:
    PAUSE_ENTITIES
    FLIP_ENTITY_DIRECTION 0
    EXECUTE_SUBROUTINE .setup_message_box
    BRANCH_U8_VAR_WITHIN_RANGE 30, 30, gDayOfMonth, .asst_carp_350_end_of_year
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 257
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .asst_carp_350_wait

.asst_carp_350_end_of_year:
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 258
    EXECUTE_SUBROUTINE .asst_carp_349_close_and_resume
