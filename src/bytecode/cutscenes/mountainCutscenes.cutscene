; ============================================
; Dispatcher (cutscenes 300..350)
; ============================================

.dispatch:
    TOGGLE_PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .setup_message_box
    BRANCH_U16_VAR_WITHIN_RANGE 300, 300, gCutsceneIndex, .cutscene_300_entry
    BRANCH_U16_VAR_WITHIN_RANGE 301, 301, gCutsceneIndex, .cutscene_301_entry
    BRANCH_U16_VAR_WITHIN_RANGE 302, 302, gCutsceneIndex, .cutscene_302_entry
    ; no cutscene 303
    BRANCH_U16_VAR_WITHIN_RANGE 304, 304, gCutsceneIndex, .cutscene_304_entry
    BRANCH_U16_VAR_WITHIN_RANGE 305, 305, gCutsceneIndex, .cutscene_305_entry
    BRANCH_U16_VAR_WITHIN_RANGE 306, 306, gCutsceneIndex, .cutscene_306_entry
    BRANCH_U16_VAR_WITHIN_RANGE 307, 307, gCutsceneIndex, .cutscene_307_entry
    BRANCH_U16_VAR_WITHIN_RANGE 308, 308, gCutsceneIndex, .cutscene_308_entry
    BRANCH_U16_VAR_WITHIN_RANGE 309, 309, gCutsceneIndex, .cutscene_309_entry
    BRANCH_U16_VAR_WITHIN_RANGE 310, 310, gCutsceneIndex, .cutscene_310_entry
    BRANCH_U16_VAR_WITHIN_RANGE 311, 311, gCutsceneIndex, .cutscene_311_entry
    BRANCH_U16_VAR_WITHIN_RANGE 312, 312, gCutsceneIndex, .cutscene_312_entry
    ; missing 313
    BRANCH_U16_VAR_WITHIN_RANGE 314, 314, gCutsceneIndex, .cutscene_314_entry
    BRANCH_U16_VAR_WITHIN_RANGE 315, 315, gCutsceneIndex, .cutscene_315_entry
    BRANCH_U16_VAR_WITHIN_RANGE 316, 316, gCutsceneIndex, .cutscene_316_entry
    BRANCH_U16_VAR_WITHIN_RANGE 317, 317, gCutsceneIndex, .cutscene_317_entry
    BRANCH_U16_VAR_WITHIN_RANGE 318, 318, gCutsceneIndex, .cutscene_318_entry
    BRANCH_U16_VAR_WITHIN_RANGE 319, 319, gCutsceneIndex, .cutscene_319_entry
    BRANCH_U16_VAR_WITHIN_RANGE 320, 320, gCutsceneIndex, .cutscene_320_entry
    BRANCH_U16_VAR_WITHIN_RANGE 321, 321, gCutsceneIndex, .cutscene_321_entry
    BRANCH_U16_VAR_WITHIN_RANGE 322, 322, gCutsceneIndex, .cutscene_322_entry
    BRANCH_U16_VAR_WITHIN_RANGE 324, 324, gCutsceneIndex, .cutscene_324_entry
    BRANCH_U16_VAR_WITHIN_RANGE 325, 325, gCutsceneIndex, .cutscene_325_entry
    BRANCH_U16_VAR_WITHIN_RANGE 326, 326, gCutsceneIndex, .cutscene_326_entry
