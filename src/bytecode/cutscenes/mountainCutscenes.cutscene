    BRANCH_U8_VAR_WITHIN_RANGE 16, 16, cutsceneLevelInteractionIndex, .leave_mountain_prompt_347
    BRANCH_U8_VAR_WITHIN_RANGE 32, 32, cutsceneLevelInteractionIndex, .branch_114AD0
    EXECUTE_SUBROUTINE .main_wait_loop_347

