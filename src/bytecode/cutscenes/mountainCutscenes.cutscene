    BRANCH_U16_VAR_WITHIN_RANGE 330, 330, gCutsceneIndex, .cutscene_330_entry
    ; no cutscenes 331..335
    BRANCH_U16_VAR_WITHIN_RANGE 336, 336, gCutsceneIndex, .cutscene_336_entry
    BRANCH_U16_VAR_WITHIN_RANGE 337, 337, gCutsceneIndex, .cutscene_337_entry
    BRANCH_U16_VAR_WITHIN_RANGE 338, 338, gCutsceneIndex, .cutscene_338_entry
    BRANCH_U16_VAR_WITHIN_RANGE 339, 339, gCutsceneIndex, .cutscene_339_entry
    BRANCH_U16_VAR_WITHIN_RANGE 340, 340, gCutsceneIndex, .cutscene_340_entry
    BRANCH_U16_VAR_WITHIN_RANGE 341, 341, gCutsceneIndex, .cutscene_341_entry
    BRANCH_U16_VAR_WITHIN_RANGE 342, 342, gCutsceneIndex, .cutscene_342_entry
    BRANCH_U16_VAR_WITHIN_RANGE 343, 343, gCutsceneIndex, .cutscene_343_entry
    BRANCH_U16_VAR_WITHIN_RANGE 344, 344, gCutsceneIndex, .cutscene_344_entry
    BRANCH_U16_VAR_WITHIN_RANGE 345, 345, gCutsceneIndex, .cutscene_345_entry
    BRANCH_U16_VAR_WITHIN_RANGE 346, 346, gCutsceneIndex, .cutscene_346_entry
    BRANCH_U16_VAR_WITHIN_RANGE 347, 347, gCutsceneIndex, .cutscene_347_entry
    BRANCH_U16_VAR_WITHIN_RANGE 348, 348, gCutsceneIndex, .cutscene_348_entry
    BRANCH_U16_VAR_WITHIN_RANGE 349, 349, gCutsceneIndex, .cutscene_349_entry
    BRANCH_U16_VAR_WITHIN_RANGE 350, 350, gCutsceneIndex, .cutscene_350_entry


