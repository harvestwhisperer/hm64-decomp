; ============================================
; Cutscene 300 (Mountain Beetles)
; Maria, Kent, and Stu talk about missing beetles and
; trying honey or sugar water on the trees. Interacting
; with Maria or Stu cuts the conversation short.
; ============================================

; 0x10FFAC
.cutscene_300_entry:
    SPAWN_EXECUTOR 1, .executor_maria
    SPAWN_EXECUTOR 2, .executor_kent
    SPAWN_EXECUTOR 3, .executor_stu
    DEACTIVATE_SELF

; 0x10FFC8
.setup_maria:
    SETUP_ENTITY 37, ENTITY_ASSET_MARIA, 1
    SET_ENTITY_ANIMATIONS 37, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    RETURN_FROM_SUBROUTINE

; 0x10FFEC
.executor_maria:
    EXECUTE_SUBROUTINE .setup_maria
    SET_COORDINATES -88, 0, -168
    SET_ASSET_ROTATION 2
    SET_CALLBACK_ROUTINE 0, BUTTON_A, .handle_maria_interaction
    EXECUTE_SUBROUTINE .idle

; 0x110008
.executor_kent:
    SETUP_ENTITY 23, ENTITY_ASSET_KENT, 1
    SET_ENTITY_ANIMATIONS 23, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_COORDINATES -152, 0, -168
    SET_ASSET_ROTATION 6
    SET_CALLBACK_ROUTINE 0, BUTTON_A, .handle_kent_interaction
    EXECUTE_SUBROUTINE .idle

; 0x11003C
.setup_stu:
    SETUP_ENTITY 36, ENTITY_ASSET_STU, 1
    SET_ENTITY_ANIMATIONS 36, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    RETURN_FROM_SUBROUTINE

; 0x11005C
.executor_stu:
    EXECUTE_SUBROUTINE .setup_stu
    SET_COORDINATES -120, 0, -136
    SET_ASSET_ROTATION 4
    SET_CALLBACK_ROUTINE 0, BUTTON_A, .handle_stu_interaction
    EXECUTE_SUBROUTINE .idle

.handle_maria_interaction:
    PAUSE_ENTITY 0
    SET_SPECIAL_BIT 0, var0
    ; kent
    SET_OTHER_EXECUTOR_PTR 2, .executor_2_10FC5C
    ; stu
    SET_OTHER_EXECUTOR_PTR 3, .executor_2_10FC5C
    SPAWN_EXECUTOR 6, .executor_dialogue
    EXECUTE_SUBROUTINE .idle

; 0x1100A0
.handle_kent_interaction:
    PAUSE_ENTITY 0
    ; maria
    SET_OTHER_EXECUTOR_PTR 1, .executor_2_10FC5C
    ; stu
    SET_OTHER_EXECUTOR_PTR 3, .executor_2_10FC5C
    SPAWN_EXECUTOR 6, .executor_dialogue
    EXECUTE_SUBROUTINE .idle

; 0x1100C0
.handle_stu_interaction:
    PAUSE_ENTITY 0
    SET_SPECIAL_BIT 1, var0
    ; maria
    SET_OTHER_EXECUTOR_PTR 1, .executor_2_10FC5C
    ; kent
    SET_OTHER_EXECUTOR_PTR 2, .executor_2_10FC5C
    SPAWN_EXECUTOR 6, .executor_dialogue
    EXECUTE_SUBROUTINE .idle

.dialogue_exit_maria_path:
    ; maria was the speaker; restore her idle and clear bit
    SET_OTHER_EXECUTOR_PTR 1, .executor_1_10FF60
    CLEAR_SPECIAL_BIT 0, var0
    RETURN_FROM_SUBROUTINE

.dialogue_exit_stu_path:
    ; stu was the speaker; face maria west and clear bit
    SET_OTHER_EXECUTOR_PTR 1, .face_w
    CLEAR_SPECIAL_BIT 1, var0
    RETURN_FROM_SUBROUTINE

; 0x110110
.executor_dialogue:
    EXECUTE_SUBROUTINE .setup_message_box
    ; Kent: Where are all the beetles?
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 0
    WAIT_MESSAGE_BOX_CLOSED 0
    ; Stu: They were here last year.
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 1
    WAIT_MESSAGE_BOX_CLOSED 0
    BRANCH_ON_SPECIAL_BIT 0, var0, .dialogue_exit_maria_path
    BRANCH_ON_SPECIAL_BIT 1, var0, .dialogue_exit_stu_path
    ; Maria: The children were trying to find some beetles...
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 2
    WAIT_MESSAGE_BOX_CLOSED 0
    ; Kent: They say it helps to put honey on the trees, right Maria?
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 3
    WAIT_MESSAGE_BOX_CLOSED 0
    ; rotate maria
    SET_OTHER_EXECUTOR_PTR 1, .face_nw
    ; Maria: Yes, lets try putting some sugar water or honey on the trees.
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 4
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 1, .handle_maria_exit
    DEACTIVATE_SELF

; 0x110180
.handle_maria_exit:
    ENTITY_WALK 32, DIRECTION_E, 2
    ENTITY_WALK 128, DIRECTION_S, 2
    SET_OTHER_EXECUTOR_PTR 2, .handle_kent_post_cutscene_movement
    SET_OTHER_EXECUTOR_PTR 3, .handle_stu_post_cutscene_movement
    TOGGLE_PAUSE_ENTITY 0
    EXECUTE_SUBROUTINE .end_cutscene

; 0x1101A8
.handle_kent_post_cutscene_movement:
    SET_ENTITY_WANDER 2, 16, 16
; 0x1101B0
.setup_kent_post_cutscene_callback:
    SET_CALLBACK_ROUTINE 0, BUTTON_A, .handle_kent_post_cutscene_interaction
    EXECUTE_SUBROUTINE .idle

; 0x1101BC
.handle_stu_post_cutscene_movement:
    SET_ENTITY_WANDER 2, 16, 16
; 0x1101C4
.setup_stu_post_cutscene_callback:
    SET_CALLBACK_ROUTINE 0, BUTTON_A, .handle_stu_post_cutscene_interaction
    EXECUTE_SUBROUTINE .idle

; 0x1101D0
.handle_kent_post_cutscene_interaction:
    EXECUTE_SUBROUTINE .setup_message_box
    PAUSE_ENTITIES
    FLIP_ENTITY_DIRECTION 0
    INIT_DIALOGUE_SESSION 0, DIALOGUE_KENT, 0
    WAIT_FOR_DIALOGUE_INPUT 0
    TOGGLE_PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .setup_kent_post_cutscene_callback

; 0x1101F0
.handle_stu_post_cutscene_interaction:
    EXECUTE_SUBROUTINE .setup_message_box
    PAUSE_ENTITIES
    FLIP_ENTITY_DIRECTION 0
    INIT_DIALOGUE_SESSION 0, DIALOGUE_STU, 0
    WAIT_FOR_DIALOGUE_INPUT 0
    TOGGLE_PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .setup_stu_post_cutscene_callback


; ============================================
; Cutscene 301 (Popuri getting flower)
; Popuri calls for help from a flower-reaching pose; player
; lifts her up and the affection shift depends on the dialogue choice.
; ============================================

; 0x110210
.cutscene_301_entry:
    SPAWN_EXECUTOR 1, .executor_popuri_301
    SET_WAIT_FRAMES 32
    PAUSE_ENTITY 0
    EXECUTE_SUBROUTINE .setup_message_box_2
    ; Popuri: Help!
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 9
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    EXECUTE_SUBROUTINE .setup_message_box
    TOGGLE_PAUSE_ENTITY 0
    SPAWN_EXECUTOR 37, .idle_until_player_reaches_tile
    DEACTIVATE_SELF

; 0x110248
.executor_popuri_301:
    EXECUTE_SUBROUTINE .setup_popuri
    SET_ENTITY_PHYSICS_FLAGS 0
    ; set Popuri on tree
    SET_COORDINATES -176, 192, -272
    SET_ASSET_ROTATION 4

.popuri_anim_loop:
    SET_ENTITY_ANIMATION 140
    SET_WAIT_FRAMES 15
    SPAWN_EXECUTOR 32, .executor_32_10FD00
    SET_ENTITY_ANIMATION 141
    WAIT_ENTITY_ANIMATION
    EXECUTE_SUBROUTINE .popuri_anim_loop

; 0x110278
.idle_until_player_reaches_tile:
    SET_WAIT_FRAMES 1
    BRANCH_U8_VAR_WITHIN_RANGE 32, 32, interactedWithLevelInteractionIndex, .pick_up_popuri
    EXECUTE_SUBROUTINE .idle_until_player_reaches_tile

; 0x11028C
.pick_up_popuri:
    SET_U8_VALUE 0, interactedWithLevelInteractionIndex
    ; require empty hands and player facing from the south/west arc
    BRANCH_U8_VAR_WITHIN_RANGE 0, 254, gItemBeingHeld, .idle_until_player_reaches_tile
    BRANCH_ON_ENTITY_DIR ENTITY_PLAYER, DIRECTION_N, .idle_until_player_reaches_tile
    BRANCH_ON_ENTITY_DIR ENTITY_PLAYER, DIRECTION_NW, .idle_until_player_reaches_tile
    BRANCH_ON_ENTITY_DIR ENTITY_PLAYER, DIRECTION_NE, .idle_until_player_reaches_tile
    BRANCH_ON_ENTITY_DIR ENTITY_PLAYER, DIRECTION_W, .idle_until_player_reaches_tile
    BRANCH_ON_ENTITY_DIR ENTITY_PLAYER, DIRECTION_E, .idle_until_player_reaches_tile
    SPAWN_EXECUTOR 0, .executor_player_301
    DEACTIVATE_SELF

; 0x1102D4
.executor_player_301:
    EXECUTE_SUBROUTINE .setup_player_entity
    ; popuri
    SET_OTHER_EXECUTOR_PTR 1, .popuri_scene_script
    SET_ENTITY_DIRECTIONAL_ANIMATION 429
    WAIT_ENTITY_ANIMATION
    SET_WAIT_FRAMES 8
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SET_ASSET_ROTATION 4
    EXECUTE_SUBROUTINE .idle

; 0x1102F8
.popuri_scene_script:
    SET_ENTITY_ANIMATION 140
    SET_FRAME_DELTA 0, 4, 0, 7
    SET_WAIT_FRAMES 8
    ; lift Popuri up from cliff edge
    SET_COORDINATES -176, 0, -336
    SET_ENTITY_PHYSICS_FLAGS 1
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SET_ASSET_ROTATION 0
    SET_WAIT_FRAMES 20
    EXECUTE_SUBROUTINE .setup_message_box
    ; Popuri: Phew... I was trying to get a flower... Thanks, you saved me.
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 10
    WAIT_MESSAGE_BOX_CLOSED 0
    ; Popuri: Hasnt something like this happened before? (yes/no)
    INIT_DIALOGUE_SESSION 0, DIALOGUE_TEXT_54, 11
    WAIT_FOR_DIALOGUE_INPUT 0
    BRANCH_ON_DIALOGUE 0, 0, .popuri_301_choice_yes
    BRANCH_ON_DIALOGUE 0, 1, .popuri_301_choice_no

; 0x110354
.popuri_301_choice_yes:
    UPDATE_U8_VALUE 8, 255, npcAffection[POPURI]
    ; Popuri: I thought so. Youve gotten so big...
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 13

; 0x110368
.handle_popuri_301_leave:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    ENTITY_WALK 128, DIRECTION_E, 2
    ; player
    SET_OTHER_EXECUTOR_PTR 0, .deactivate_executor_player
    EXECUTE_SUBROUTINE .end_cutscene

; 0x110384
.popuri_301_choice_no:
    UPDATE_U8_VALUE -2, 255, npcAffection[POPURI]
    ; Popuri: Oh, its just me then...
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 14
    EXECUTE_SUBROUTINE .handle_popuri_301_leave


; ============================================
; Cutscene 302 (Popuri sprained ankle)
; Popuri sits near the player; Button A opens dialogue 54 offering
; to help. Choice 0: player carries her (+10 Popuri, sets bit 30).
; Choice 1: Gray carries her instead (+20 Gray, -30 Popuri, clears bit 30).
; ============================================

; 0x11039C
.cutscene_302_entry:
    SPAWN_EXECUTOR 1, .executor_popuri_302
    DEACTIVATE_SELF

; 0x1103A8
.setup_popuri:
    SETUP_ENTITY 37, ENTITY_ASSET_POPURI, 1
    SET_ENTITY_ANIMATIONS 37, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    RETURN_FROM_SUBROUTINE

; 0x1103CC
.executor_popuri_302:
    EXECUTE_SUBROUTINE .setup_popuri
    SET_COORDINATES -96, 0, -168
    SET_ENTITY_ANIMATION 34
    UPDATE_RGBA 254, 254, 254, 254, 0
    WAIT_RGBA_FINISHED
.popuri_302_wait:
    SET_CALLBACK_ROUTINE 0, BUTTON_A, .popuri_302_on_interact
    EXECUTE_SUBROUTINE .idle
.popuri_302_on_interact:
    EXECUTE_SUBROUTINE .setup_message_box
    ; require empty hands to initiate
    BRANCH_U8_VAR_WITHIN_RANGE 0, 254, gItemBeingHeld, .popuri_302_wait
    PAUSE_ENTITY 0
    ; help her? (yes/no)
    INIT_DIALOGUE_SESSION 0, DIALOGUE_TEXT_54, 0
    WAIT_FOR_DIALOGUE_INPUT 0
    BRANCH_ON_DIALOGUE 0, 0, .player_helps_popuri
    BRANCH_ON_DIALOGUE 0, 1, .gray_helps_popuri

.player_helps_popuri:
    UPDATE_U8_VALUE 10, 255, npcAffection[POPURI]
    ; Popuri: Really? Sorry, .... I look kind of bad
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 22
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SPAWN_EXECUTOR 7, .executor_player_302
    EXECUTE_SUBROUTINE .idle

; 0x110454
.executor_player_302:
    EXECUTE_SUBROUTINE .setup_player_entity
    TOGGLE_PAUSE_ENTITIES
    SET_ENTITY_DIRECTIONAL_ANIMATION 429
    WAIT_ENTITY_ANIMATION
    SET_HOLDING_ANIMATION_FLAG TRUE
    SET_OTHER_EXECUTOR_PTR 1, .player_carry_pose
    SET_WAIT_FRAMES 1
    SET_ASSET_ROTATION 6
    SET_ENTITY_DIRECTIONAL_ANIMATION 24
    SET_WAIT_FRAMES 15
    ENTITY_WALK 31, DIRECTION_E, 2
    SET_OTHER_EXECUTOR_PTR 1, .handle_carry_popuri
    ENTITY_WALK 1, DIRECTION_E, 2
    ENTITY_WALK 48, DIRECTION_S, 2
    SET_AUDIO_SEQUENCE_VOLUME 0, 0, 8
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    ENTITY_WALK 48, DIRECTION_S, 2
    WAIT_RGBA_FINISHED
    STOP_SEQUENCE_WITH_FADE 0, 1
    DEACTIVATE_EXECUTOR 1
    SET_HOLDING_ANIMATION_FLAG FALSE
    IDLE_WHILE_SEQUENCE_PLAYING 0
    SET_SPECIAL_BIT 30, gCutsceneCompletionFlags
    EXECUTE_SUBROUTINE .end_cutscene

.player_carry_pose:
    SET_ENTITY_TRACKING_TARGET 0, 0, 19, 17, 255
    SET_ENTITY_ANIMATION 46
    EXECUTE_SUBROUTINE .idle

; 0x1104F0
.handle_carry_popuri:
    SET_ENTITY_TRACKING_TARGET 0, 0, 19, 17, 255
    SET_ENTITY_ANIMATION 47
    EXECUTE_SUBROUTINE .idle

