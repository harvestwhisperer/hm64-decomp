.executor_entomologist_316:
    EXECUTE_SUBROUTINE .setup_entomologist_316
    SET_COORDINATES -136, 0, -152
    SET_ASSET_ROTATION 0
    SET_CALLBACK_ROUTINE 0, BUTTON_A, .entomologist_316_first_interact
    EXECUTE_SUBROUTINE .idle

.entomologist_316_first_interact:
    EXECUTE_SUBROUTINE .setup_message_box
    PAUSE_ENTITY 0
    ; Entomologist: Ohhhhhhhh!
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 102
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_ENTITY_ANIMATION 16
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SET_WAIT_FRAMES 15
    FLIP_ENTITY_DIRECTION 0
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    ; Entomologist: Its Blue Mist! When that blooms, theres still hope
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 100
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITY 0
    SPAWN_EXECUTOR 0, .end_cutscene

.entomologist_316_idle_loop:
    SET_CALLBACK_ROUTINE 0, BUTTON_A, .entomologist_316_reinteract
    EXECUTE_SUBROUTINE .idle

.entomologist_316_reinteract:
    PAUSE_ENTITIES
    FLIP_ENTITY_DIRECTION 0
    EXECUTE_SUBROUTINE .setup_message_box
    INIT_DIALOGUE_SESSION 0, DIALOGUE_ENTOMOLOGIST, 0
    WAIT_FOR_DIALOGUE_INPUT 0
    TOGGLE_PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .entomologist_316_idle_loop

; ============================================
; Cutscene 317 (Entomologist photographs emerald butterfly)
; Popuri watches; player approaches, Entomologist walks in, reacts to the
; Emerald butterfly, takes a photo (SFX 94 + flash sprite), sets
; dailyEventBits[1] bit 27, then walks off. Tint picked by gHour.
; ============================================

.cutscene_317_entry:
    SPAWN_EXECUTOR 1, .executor_popuri_317
    SPAWN_EXECUTOR 2, .executor_purple_butterfly_317
    DEACTIVATE_SELF

.executor_popuri_317:
    EXECUTE_SUBROUTINE .setup_popuri
    SET_COORDINATES -172, 0, -172
    SET_ASSET_ROTATION 0

.popuri_317_wait:
    SET_CALLBACK_ROUTINE 0, BUTTON_A, .popuri_317_on_interact
    EXECUTE_SUBROUTINE .idle

.popuri_317_on_interact:
    BRANCH_U8_VAR_WITHIN_RANGE 0, 254, gItemBeingHeld, .popuri_317_wait
    EXECUTE_SUBROUTINE .setup_message_box
    PAUSE_ENTITY 0
    FLIP_ENTITY_DIRECTION 0
    ; Popuri: Its so pretty. Blue Mist and Emerald butterflies...
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 101
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_WAIT_FRAMES 30
    ; Entomologist (off-screen): Ohhhhhhhh!
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 102
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_ASSET_ROTATION 6
    SPAWN_EXECUTOR 0, .executor_player_entity_317
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    TOGGLE_PAUSE_ENTITY 0
    SPAWN_EXECUTOR 0, .executor_player_entity_317_2
    SET_WAIT_FRAMES 1
    SPAWN_EXECUTOR 3, .executor_entomologist_317
    SPAWN_EXECUTOR 41, .map_anchor_317_start
    EXECUTE_SUBROUTINE .idle

.executor_player_entity_317:
    EXECUTE_SUBROUTINE .setup_player_entity
    SET_ASSET_ROTATION 6
    SET_ENTITY_MAP_SPACE_INDEPENDENT FALSE
    DEACTIVATE_SELF

.executor_purple_butterfly_317:
    SETUP_ENTITY 14, ENTITY_ASSET_PURPLE_BUTTERFLY, 1
    SET_ENTITY_ANIMATIONS 14, 0, 0, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_PHYSICS_FLAGS 0
    SET_COORDINATES -172, 160, -140
    SET_ENTITY_ANIMATION 0

.butterfly_orbit_loop:
    SET_FRAME_DELTA 1, 1, 0, 4
    SET_FRAME_DELTA 1, 0, 1, 4
    SET_FRAME_DELTA 0, -1, 1, 4
    SET_FRAME_DELTA -1, 0, 1, 4
    SET_FRAME_DELTA -1, 1, 0, 4
    SET_FRAME_DELTA -1, 0, -1, 4
    SET_FRAME_DELTA 0, -1, -1, 4
    SET_FRAME_DELTA 1, 0, -1, 4
    EXECUTE_SUBROUTINE .butterfly_orbit_loop

.executor_player_entity_317_2:
    EXECUTE_SUBROUTINE .setup_player_entity
    SET_BEHAVIOR_FLAGS 0
    BRANCH_U8_VAR_WITHIN_RANGE 0, 254, gItemBeingHeld, .player_preserve_carry
    SET_COORDINATES -176, 0, -104
    SET_ASSET_ROTATION 6
    EXECUTE_SUBROUTINE .idle

.map_anchor_317_start:
    SETUP_MAP_ASSET MAIN_MAP_INDEX
    SET_COORDINATES 64, 96, -144
    EXECUTE_SUBROUTINE .idle

.map_anchor_317_walk_in:
    SET_FRAME_DELTA -2, 0, 0, 80
    EXECUTE_SUBROUTINE .idle

.map_anchor_317_walk_out:
    SET_FRAME_DELTA -2, 0, 1, 40
    SET_OTHER_EXECUTOR_PTR 0, .executor_7_10FF48
    SET_OTHER_EXECUTOR_PTR 1, .popuri_post_scene_listener
    EXECUTE_SUBROUTINE .idle

.popuri_post_scene_listener:
    SET_CALLBACK_ROUTINE 0, BUTTON_A, .popuri_replay_msg101
    EXECUTE_SUBROUTINE .idle

.popuri_replay_msg101:
    EXECUTE_SUBROUTINE .setup_message_box
    PAUSE_ENTITIES
    ; Popuri: replay of her butterfly line
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 101
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .popuri_post_scene_listener

.executor_entomologist_317:
    SETUP_ENTITY 36, ENTITY_ASSET_ENTOMOLOGIST, 1
    SET_ENTITY_ANIMATIONS 36, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_COORDINATES 64, 96, -144
    SET_ASSET_ROTATION 2
    EXECUTE_SUBROUTINE .apply_hour_tint_317

.apply_hour_tint_317:
    BRANCH_U8_VAR_WITHIN_RANGE 12, 15, gHour, .tint_day_317
    BRANCH_U8_VAR_WITHIN_RANGE 16, 16, gHour, .tint_late_afternoon_317
    BRANCH_U8_VAR_WITHIN_RANGE 17, 17, gHour, .tint_dusk_317

.tint_day_317:
    UPDATE_GLOBAL_RGBA 255, 255, 255, 255, 8
    EXECUTE_SUBROUTINE .entomologist_arrive_and_photo

.tint_late_afternoon_317:
    UPDATE_GLOBAL_RGBA 255, 224, 224, 224, 8
    EXECUTE_SUBROUTINE .entomologist_arrive_and_photo

.tint_dusk_317:
    UPDATE_GLOBAL_RGBA 255, 192, 192, 192, 8
    EXECUTE_SUBROUTINE .entomologist_arrive_and_photo

.entomologist_arrive_and_photo:
    WAIT_RGBA_FINISHED
    SET_OTHER_EXECUTOR_PTR 41, .map_anchor_317_walk_in
    ENTITY_WALK 80, DIRECTION_W, 2
    SET_ENTITY_ANIMATION 16
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    ; Entomologist: Its an Emerald butterfly! Queen of the butterflies
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 103
    WAIT_MESSAGE_BOX_CLOSED 0
    ; Entomologist: Oh, the camera, I must take a picture
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 104
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_WAIT_FRAMES 10
    ; mark photo-taken (daily bit)
    SET_SPECIAL_BIT 27, dailyEventBits[1]
    ; SFX 94 = camera shutter
    SET_SFX 94, 128
    SPAWN_EXECUTOR 33, .camera_flash_sprite
    SET_WAIT_FRAMES 30
    SET_OTHER_EXECUTOR_PTR 2, .butterfly_flyaway
    ; Entomologist: Im going to remember this forever
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 105
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    ENTITY_WALK 96, DIRECTION_E, 2
    ENTITY_WALK 32, DIRECTION_S, 2
    SET_OTHER_EXECUTOR_PTR 41, .map_anchor_317_walk_out
    ENTITY_WALK 32, DIRECTION_E, 2
    EXECUTE_SUBROUTINE .end_cutscene

.butterfly_flyaway:
    SET_FRAME_DELTA -1, 1, 1, 128
    DEACTIVATE_SELF

.camera_flash_sprite:
    DMA_SPRITE 128, 0, _funeralIntroTextureSegmentRomStart, _funeralIntroTextureSegmentRomEnd, _funeralIntroAssetsIndexSegmentRomStart, _funeralIntroAssetsIndexSegmentRomEnd, 0, 0, 0x8028B930, 0, 0x8028DD50, 0x80290550, 0x80293A50, 0x80293C50
    SET_ANIM_DATA_PTR_WITH_FLAG .anim_110C8C
    SET_COORDINATES 0, 0, 330
    SET_SPRITE_SCALE 20, 20, 0
    SET_RGBA 255, 255, 255, 255
    SET_WAIT_FRAMES 2
    SET_SPRITE_RENDERING_LAYER 2
    UPDATE_RGBA 255, 255, 255, 0, 64
    WAIT_RGBA_FINISHED
    DEACTIVATE_SELF



; ============================================
; Cutscene 318 (Get fishing pole from Greg)
; Greg offers the player a fishing rod via DIALOGUE_TEXT_54 prompt 2.
; Yes: text 108 (rules), give-rod + text 109 (Try it), end.
; No: text 110, give-rod anyway, then post-gift idle loop with DIALOGUE_GREG.
; ============================================

; 0x1124BC
.cutscene_318_entry:
    SPAWN_EXECUTOR 1, .executor_greg_318
    DEACTIVATE_SELF

; 0x1124C8
.setup_greg:
    SETUP_ENTITY 37, ENTITY_ASSET_GREG, 1
    SET_ENTITY_ANIMATIONS 37, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    RETURN_FROM_SUBROUTINE

; 0x1124EC
.executor_greg_318:
    EXECUTE_SUBROUTINE .setup_greg
    SET_COORDINATES 160, 0, -64
    SET_ASSET_ROTATION 4
    SET_ENTITY_ANIMATION 18
    UPDATE_RGBA 254, 254, 254, 254, 8
    WAIT_RGBA_FINISHED

.greg_318_wait:
    SET_CALLBACK_ROUTINE 0, BUTTON_A, .greg_318_on_interact
    EXECUTE_SUBROUTINE .idle

.greg_318_on_interact:
    EXECUTE_SUBROUTINE .setup_message_box
    BRANCH_U8_VAR_WITHIN_RANGE 0, 254, gItemBeingHeld, .greg_318_wait
    PAUSE_ENTITY 0
    FLIP_ENTITY_DIRECTION 0
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    INIT_DIALOGUE_SESSION 0, DIALOGUE_TEXT_54, 2
    WAIT_FOR_DIALOGUE_INPUT 0
    BRANCH_ON_DIALOGUE 0, 0, .greg_318_choice_yes
    BRANCH_ON_DIALOGUE 0, 1, .greg_318_choice_no

.greg_318_choice_yes:
    ; Greg: Ill give you one of my rods; use B to cast; release on bite
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 108
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SPAWN_EXECUTOR 7, .give_rod_after_yes
    EXECUTE_SUBROUTINE .idle

.greg_try_it_then_end:
    ; Greg: Try it.
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 109
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITY 0
    SET_OTHER_EXECUTOR_PTR 7, .deactivate_executor_player
    SPAWN_EXECUTOR 13, .end_cutscene

.greg_post_gift_idle_loop:
    SET_CALLBACK_ROUTINE 0, BUTTON_A, .greg_post_gift_on_interact
    EXECUTE_SUBROUTINE .idle

.greg_post_gift_on_interact:
    PAUSE_ENTITY 0
    FLIP_ENTITY_DIRECTION 0
    EXECUTE_SUBROUTINE .setup_message_box
    INIT_DIALOGUE_SESSION 0, DIALOGUE_GREG, 0
    WAIT_FOR_DIALOGUE_INPUT 0
    TOGGLE_PAUSE_ENTITY 0
    EXECUTE_SUBROUTINE .greg_post_gift_idle_loop

.give_rod_after_yes:
    EXECUTE_SUBROUTINE .setup_player_entity
    SET_AUDIO_SEQUENCE 2, _fanfareSegmentRomStart, _fanfareSegmentRomEnd
    SET_AUDIO_SEQUENCE_VOLUME 2, 128, 128
    SPAWN_EXECUTOR 10, .executor_10_10FDE0
    SET_ENTITY_ANIMATION 369
    SET_WAIT_FRAMES 30
    IDLE_WHILE_SEQUENCE_PLAYING 2
    DEACTIVATE_EXECUTOR 10
    FLIP_ENTITY_DIRECTION 37
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SET_OTHER_EXECUTOR_PTR 1, .greg_try_it_then_end
    EXECUTE_SUBROUTINE .idle

.greg_318_choice_no:
    ; Greg: (decline reply - still hands over the rod)
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 110
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SPAWN_EXECUTOR 7, .give_rod_after_no
    EXECUTE_SUBROUTINE .idle

.give_rod_after_no:
    EXECUTE_SUBROUTINE .setup_player_entity
    SET_AUDIO_SEQUENCE 2, _fanfareSegmentRomStart, _fanfareSegmentRomEnd
    SET_AUDIO_SEQUENCE_VOLUME 2, 128, 128
    SPAWN_EXECUTOR 10, .executor_10_10FDE0
    SET_ENTITY_ANIMATION 369
    SET_WAIT_FRAMES 30
    IDLE_WHILE_SEQUENCE_PLAYING 2
    DEACTIVATE_EXECUTOR 10
    FLIP_ENTITY_DIRECTION 37
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    TOGGLE_PAUSE_ENTITY 0
    SET_ENTITY_MAP_SPACE_INDEPENDENT FALSE
    SET_OTHER_EXECUTOR_PTR 1, .greg_post_gift_idle_loop
    EXECUTE_SUBROUTINE .end_cutscene




; ============================================
; Cutscene 319 (Spawn Greg - respawn variant)
; Places Greg at (-216, 0, 80) facing NW with anim 17, fades in,
; reuses .greg_318_on_interact for BUTTON_A (same rod-gift flow).
; ============================================

.cutscene_319_entry:
    SPAWN_EXECUTOR 1, .executor_greg_319
    DEACTIVATE_SELF

.executor_greg_319:
    EXECUTE_SUBROUTINE .setup_greg
    SET_COORDINATES -216, 0, 80
    SET_ASSET_ROTATION 2
    SET_ENTITY_ANIMATION 17
    UPDATE_RGBA 254, 254, 254, 254, 8
    WAIT_RGBA_FINISHED
    SET_CALLBACK_ROUTINE 0, BUTTON_A, .greg_318_on_interact
    EXECUTE_SUBROUTINE .idle

; ============================================
; Cutscene 320 (Greg farewell - heads south for winter)
; A-press triggers text 111 (Ill head south, see you in spring);
; Greg walks NW/W/SW offscreen.
; ============================================

.cutscene_320_entry:
    SPAWN_EXECUTOR 1, .executor_greg_320
    EXECUTE_SUBROUTINE .idle

.executor_greg_320:
    EXECUTE_SUBROUTINE .setup_greg
    SET_COORDINATES 160, 0, 32
    SET_ASSET_ROTATION 0
    UPDATE_RGBA 254, 254, 254, 254, 0
    WAIT_RGBA_FINISHED
    SET_CALLBACK_ROUTINE 0, BUTTON_A, .greg_320_on_farewell
    EXECUTE_SUBROUTINE .idle

.greg_320_on_farewell:
    EXECUTE_SUBROUTINE .setup_message_box
    PAUSE_ENTITY 0
    FLIP_ENTITY_DIRECTION 0
    ; Greg: Well, goodbye. Ill head south. See you in the spring.
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 111
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    ENTITY_WALK 40, DIRECTION_W, 2
    ENTITY_WALK 48, DIRECTION_SW, 2
    ENTITY_WALK 72, DIRECTION_S, 2
    TOGGLE_PAUSE_ENTITY 0
    EXECUTE_SUBROUTINE .end_cutscene

; ============================================
; Cutscene 321 (Greg shares fish with player)
; Empty-handed A-press triggers text 112 (shared fish), player
; plays receive-item animation, then cutscene ends.
; ============================================

.cutscene_321_entry:
    SPAWN_EXECUTOR 1, .executor_greg_321
    DEACTIVATE_SELF

.executor_greg_321:
    EXECUTE_SUBROUTINE .setup_greg
    SET_COORDINATES -216, 0, 80
    SET_ASSET_ROTATION 2
    SET_ENTITY_ANIMATION 17

.greg_321_wait:
    SET_CALLBACK_ROUTINE 0, BUTTON_A, .greg_321_on_interact
    EXECUTE_SUBROUTINE .idle

.greg_321_on_interact:
    EXECUTE_SUBROUTINE .setup_message_box
    BRANCH_U8_VAR_WITHIN_RANGE 0, 254, gItemBeingHeld, .greg_321_wait
    PAUSE_ENTITY 0
    FLIP_ENTITY_DIRECTION 0
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    ; Greg: I caught lots of fish today. Ill share some with you.
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 112
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SPAWN_EXECUTOR 7, .executor_player_entity_321
    EXECUTE_SUBROUTINE .greg_post_gift_idle_loop

.executor_player_entity_321:
    EXECUTE_SUBROUTINE .setup_player_entity
    SET_ASSET_ROTATION 0
    SPAWN_EXECUTOR 10, .greg_321_item_tracker
    SET_ENTITY_DIRECTIONAL_ANIMATION 24
    SET_WAIT_FRAMES 16
    SET_ENTITY_ANIMATION 437
    WAIT_ENTITY_ANIMATION
    FLIP_ENTITY_DIRECTION 37
    SET_ENTITY_MAP_SPACE_INDEPENDENT FALSE
    TOGGLE_PAUSE_ENTITY 0
    EXECUTE_SUBROUTINE .end_cutscene

.greg_321_item_tracker:
    EXECUTE_SUBROUTINE .sub_10FD88
    SET_ENTITY_TRACKING_TARGET 0, 0, 14, 20, 255
    SET_ENTITY_ANIMATION 37
    SET_WAIT_FRAMES 16
    SET_ENTITY_TRACKING_TARGET 0, 0, 32, 16, 255
    SET_WAIT_FRAMES 10
    DEACTIVATE_SELF

; ============================================
; Cutscene 322 (Harvest Sprites give Power Nut)
; Three sprites at entities 22/23/24; A on any triggers text 113
; (shiny one gift), then sets acquiredPowerNutBits, +15 stamina (cap 250),
; +2 happiness, and lifeEventBits[4] bit 2. After reward, each sprite
; opens DIALOGUE_HARVEST_SPRITE_1/2/3 on subsequent A presses.
; ============================================

.cutscene_322_entry:
    SPAWN_EXECUTOR 1, .executor_sprite_e22
    SPAWN_EXECUTOR 2, .executor_sprite_e23
    SPAWN_EXECUTOR 3, .executor_sprite_e24
    DEACTIVATE_SELF

.setup_harvest_sprite_322:
    SETUP_ENTITY 22, ENTITY_ASSET_HARVEST_SPRITE, 1
    SET_ENTITY_ANIMATIONS 22, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    RETURN_FROM_SUBROUTINE

.executor_sprite_e22:
    EXECUTE_SUBROUTINE .setup_harvest_sprite_322
    SET_COORDINATES 0, 0, -16
    SET_WAIT_FRAMES 1
    SET_CALLBACK_ROUTINE 0, BUTTON_A, .sprite_e22_on_a_pressed
    EXECUTE_SUBROUTINE .idle

.setup_harvest_sprite_e23:
    SETUP_ENTITY 23, ENTITY_ASSET_HARVEST_SPRITE, 1
    SET_ENTITY_ANIMATIONS 23, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    RETURN_FROM_SUBROUTINE

.executor_sprite_e23:
    EXECUTE_SUBROUTINE .setup_harvest_sprite_e23
    SET_COORDINATES -56, 0, -32
    SET_CALLBACK_ROUTINE 0, BUTTON_A, .sprite_e23_on_a_pressed
    EXECUTE_SUBROUTINE .idle

.setup_harvest_sprite_e24:
    SETUP_ENTITY 24, ENTITY_ASSET_HARVEST_SPRITE, 1
    SET_ENTITY_ANIMATIONS 24, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    RETURN_FROM_SUBROUTINE

.executor_sprite_e24:
    EXECUTE_SUBROUTINE .setup_harvest_sprite_e24
    SET_COORDINATES 0, 0, -112
    SET_CALLBACK_ROUTINE 0, BUTTON_A, .sprite_e24_on_a_pressed
    EXECUTE_SUBROUTINE .idle

.sprite_e22_on_a_pressed:
    EXECUTE_SUBROUTINE .setup_message_box
    PAUSE_ENTITY 0
    FLIP_ENTITY_DIRECTION 0
    SET_OTHER_EXECUTOR_PTR 2, .e23_react_when_e22_speaks
    SET_OTHER_EXECUTOR_PTR 3, .e24_walk_to_e22
    EXECUTE_SUBROUTINE .show_power_nut_gift_message
    SET_ENTITY_DIRECTIONAL_ANIMATION 16
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 24
    SPAWN_EXECUTOR 10, .exec10_camera_track_e22
    SET_WAIT_FRAMES 30
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SPAWN_EXECUTOR 7, .apply_power_nut_rewards
    EXECUTE_SUBROUTINE .idle

.sprite_e23_on_a_pressed:
    EXECUTE_SUBROUTINE .setup_message_box
    PAUSE_ENTITY 0
    FLIP_ENTITY_DIRECTION 0
    SET_OTHER_EXECUTOR_PTR 1, .e22_react_when_e23_speaks
    SET_OTHER_EXECUTOR_PTR 3, .e24_walk_to_e23
    EXECUTE_SUBROUTINE .show_power_nut_gift_message
    SET_ENTITY_DIRECTIONAL_ANIMATION 16
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 24
    SPAWN_EXECUTOR 10, .exec10_camera_track_e23
    SET_WAIT_FRAMES 30
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SPAWN_EXECUTOR 7, .apply_power_nut_rewards
    EXECUTE_SUBROUTINE .idle

.sprite_e24_on_a_pressed:
    EXECUTE_SUBROUTINE .setup_message_box
    PAUSE_ENTITY 0
    FLIP_ENTITY_DIRECTION 0
    SET_OTHER_EXECUTOR_PTR 1, .e22_walk_to_e24
    SET_OTHER_EXECUTOR_PTR 2, .e23_walk_to_e24
    EXECUTE_SUBROUTINE .show_power_nut_gift_message
    SET_ENTITY_DIRECTIONAL_ANIMATION 16
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 24
    SPAWN_EXECUTOR 10, .exec10_camera_track_e24
    SET_WAIT_FRAMES 30
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SPAWN_EXECUTOR 7, .apply_power_nut_rewards
    EXECUTE_SUBROUTINE .idle

.e23_react_when_e22_speaks:
    SET_CALLBACK_ROUTINE 0xFFFF, BUTTON_A, .sprite_e24_on_a_pressed
    SET_ENTITY_ANIMATION 35
    EXECUTE_SUBROUTINE .idle

.e24_walk_to_e22:
    SET_CALLBACK_ROUTINE 0xFFFF, BUTTON_A, .sprite_e24_on_a_pressed
    ENTITY_WALK 16, DIRECTION_E, 2
    ENTITY_WALK 32, DIRECTION_S, 2
    SET_ENTITY_ANIMATION 36
    EXECUTE_SUBROUTINE .idle

.e22_react_when_e23_speaks:
    SET_CALLBACK_ROUTINE 0xFFFF, BUTTON_A, .sprite_e24_on_a_pressed
    SET_ENTITY_ANIMATION 37
    EXECUTE_SUBROUTINE .idle

.e24_walk_to_e23:
    SET_CALLBACK_ROUTINE 0xFFFF, BUTTON_A, .sprite_e24_on_a_pressed
    ENTITY_WALK 32, DIRECTION_W, 2
    ENTITY_WALK 16, DIRECTION_S, 2
    SET_ENTITY_ANIMATION 32
    EXECUTE_SUBROUTINE .idle

.e22_walk_to_e24:
    SET_CALLBACK_ROUTINE 0xFFFF, BUTTON_A, .sprite_e24_on_a_pressed
    ENTITY_WALK 20, DIRECTION_E, 2
    ENTITY_WALK 36, DIRECTION_N, 2
    SET_ENTITY_ANIMATION 33
    EXECUTE_SUBROUTINE .idle

.e23_walk_to_e24:
    SET_CALLBACK_ROUTINE 0xFFFF, BUTTON_A, .sprite_e24_on_a_pressed
    ENTITY_WALK 48, DIRECTION_N, 2
    SET_ENTITY_ANIMATION 39
    EXECUTE_SUBROUTINE .idle

.show_power_nut_gift_message:
    ; Harvest Sprite 1: Wow! Its a shiny one! Here you go! You can have it!
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 113
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    RETURN_FROM_SUBROUTINE

.exec10_camera_track_e22:
    EXECUTE_SUBROUTINE .sub_10FD88
    SET_ENTITY_TRACKING_TARGET 22, 0, 8, 16, 255
    SET_ENTITY_ANIMATION 210
    EXECUTE_SUBROUTINE .idle

.exec10_camera_track_e23:
    EXECUTE_SUBROUTINE .sub_10FD88
    SET_ENTITY_TRACKING_TARGET 23, 0, 8, 16, 255
    SET_ENTITY_ANIMATION 210
    EXECUTE_SUBROUTINE .idle

.exec10_camera_track_e24:
    EXECUTE_SUBROUTINE .sub_10FD88
    SET_ENTITY_TRACKING_TARGET 24, 0, 8, 16, 255
    SET_ENTITY_ANIMATION 210
    EXECUTE_SUBROUTINE .idle

.apply_power_nut_rewards:
    TOGGLE_PAUSE_ENTITY 0
    EXECUTE_SUBROUTINE .setup_player_entity
    EXECUTE_SUBROUTINE .sub_10FF14
    ; mark Power Nut #1 received; bump stamina/happiness; set lifeEventBits[4] bit 2
    SET_SPECIAL_BIT 1, acquiredPowerNutBits
    UPDATE_U8_VALUE 15, 250, gMaximumStamina
    UPDATE_U8_VALUE 2, 255, gHappiness
    SET_SPECIAL_BIT 2, lifeEventBits[4]
    SET_ASSET_ROTATION 0
    TOGGLE_PAUSE_ENTITIES
    SET_OTHER_EXECUTOR_PTR 1, .e22_post_reward_listener
    SET_OTHER_EXECUTOR_PTR 2, .e23_post_reward_listener
    SET_OTHER_EXECUTOR_PTR 3, .e24_post_reward_listener
    SPAWN_EXECUTOR 16, .end_cutscene
    DEACTIVATE_SELF

.e22_post_reward_listener:
    SET_CALLBACK_ROUTINE 0, BUTTON_A, .e22_talk_harvest_sprite_1
    EXECUTE_SUBROUTINE .idle

.e23_post_reward_listener:
    SET_CALLBACK_ROUTINE 0, BUTTON_A, .e23_talk_harvest_sprite_2
    EXECUTE_SUBROUTINE .idle

.e24_post_reward_listener:
    SET_CALLBACK_ROUTINE 0, BUTTON_A, .e24_talk_harvest_sprite_3
    EXECUTE_SUBROUTINE .idle

.e22_talk_harvest_sprite_1:
    PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .setup_message_box
    INIT_DIALOGUE_SESSION 0, DIALOGUE_HARVEST_SPRITE_1, 0
    WAIT_FOR_DIALOGUE_INPUT 0
    TOGGLE_PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .e22_post_reward_listener

.e23_talk_harvest_sprite_2:
    PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .setup_message_box
    INIT_DIALOGUE_SESSION 0, DIALOGUE_HARVEST_SPRITE_2, 0
    WAIT_FOR_DIALOGUE_INPUT 0
    TOGGLE_PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .e23_post_reward_listener

.e24_talk_harvest_sprite_3:
    PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .setup_message_box
    INIT_DIALOGUE_SESSION 0, DIALOGUE_HARVEST_SPRITE_3, 0
    WAIT_FOR_DIALOGUE_INPUT 0
    TOGGLE_PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .e24_post_reward_listener

; ============================================
; Cutscene 324 (Master Carpenter recruitment)
; Dialogue 54/12 prompt. Accept: +5 affection for MASTER_CARPENTER,
; CARPENTER_1, CARPENTER_2; text 220; sets gCutsceneCompletionFlags bit 1.
; Decline: text 221; carpenter walks off NE; Assistant stands guard and
; barks text 249 on A-press. Cutscene 328 re-runs this entire flow.
; ============================================

.cutscene_324_entry:
    SET_SPECIAL_BIT 15, gCutsceneCompletionFlags
    SPAWN_EXECUTOR 1, .executor_master_carpenter_idle
    EXECUTE_SUBROUTINE .setup_player_entity
    SET_COORDINATES -16, 0, 320
    SET_ASSET_ROTATION 4
    SET_WAIT_FRAMES 40
    INIT_DIALOGUE_SESSION 0, DIALOGUE_TEXT_54, 12
    WAIT_FOR_DIALOGUE_INPUT 0
    BRANCH_ON_DIALOGUE 0, 0, .recruit_accept
    BRANCH_ON_DIALOGUE 0, 1, .recruit_decline

.recruit_accept:
    UPDATE_U8_VALUE 5, 255, npcAffection[MASTER_CARPENTER]
    UPDATE_U8_VALUE 5, 255, npcAffection[CARPENTER_1]
    UPDATE_U8_VALUE 5, 255, npcAffection[CARPENTER_2]
    ; Master Carpenter: Thanks, its a really big help!
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 220
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_WAIT_FRAMES 10
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    DEACTIVATE_EXECUTOR 1
    SET_SPECIAL_BIT 1, gCutsceneCompletionFlags
    EXECUTE_SUBROUTINE .end_cutscene

.recruit_decline:
    ; Master Carpenter: Well, I cant force you.
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 221
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 1, .executor_master_carpenter_leave
    SPAWN_EXECUTOR 2, .executor_assistant_guard
    EXECUTE_SUBROUTINE .idle

.setup_master_carpenter:
    SETUP_ENTITY 24, ENTITY_ASSET_MASTER_CARPENTER, 1
    SET_ENTITY_ANIMATIONS 24, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    RETURN_FROM_SUBROUTINE

.executor_master_carpenter_idle:
    EXECUTE_SUBROUTINE .setup_master_carpenter
    SET_COORDINATES -16, 0, 272
    SET_ASSET_ROTATION 0
    EXECUTE_SUBROUTINE .idle

.executor_master_carpenter_leave:
    ENTITY_WALK 96, DIRECTION_N, 2
    SET_OTHER_EXECUTOR_PTR 0, .deactivate_executor_player
    SPAWN_EXECUTOR 19, .end_cutscene
    DEACTIVATE_SELF

.setup_assistant_carpenter_e25:
    SETUP_ENTITY 25, ENTITY_ASSET_ASSISTANT_CARPENTER, 1
    SET_ENTITY_ANIMATIONS 25, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    RETURN_FROM_SUBROUTINE

.setup_assistant_carpenter_e26:
    SETUP_ENTITY 26, ENTITY_ASSET_ASSISTANT_CARPENTER, 1
    SET_ENTITY_ANIMATIONS 26, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    RETURN_FROM_SUBROUTINE

.executor_assistant_guard:
    EXECUTE_SUBROUTINE .setup_assistant_carpenter_e26
    SET_COORDINATES 32, 0, -416
    SET_ASSET_ROTATION 6

.assistant_guard_loop:
    SET_CALLBACK_ROUTINE 0, BUTTON_A, .assistant_guard_on_a_press
    EXECUTE_SUBROUTINE .idle

.assistant_guard_on_a_press:
    EXECUTE_SUBROUTINE .setup_message_box
    PAUSE_ENTITY 0
    ; Assistant Carpenter: No trespassing past this point! Its dangerous.
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 249
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITY 0
    EXECUTE_SUBROUTINE .assistant_guard_loop

; ============================================
; Cutscene 325 (Assistant guard only - shares executor with 324 decline path)
; Just spawns .executor_assistant_guard and ends.
; ============================================

.cutscene_325_entry:
    SPAWN_EXECUTOR 2, .executor_assistant_guard
    EXECUTE_SUBROUTINE .end_cutscene

; ============================================
; Cutscene 326 (Mountain construction work day)
; Branches on mountainConstructionWorkDays:
;   day 1 (default): stump cut + lumber carry path (msgs 226, 235, 223)
;   days 2-3:        hammer loop (msg 227)
;   day 4:           hammer loop, final-day variant (msg 229)
; Ends with fade to black, time set to 15:00, bit 1 of gCutsceneCompletionFlags.
; ============================================

.cutscene_326_entry:
    SET_SPECIAL_BIT 12, gCutsceneCompletionFlags
    SPAWN_EXECUTOR 2, .assistant_spot_ne
    SPAWN_EXECUTOR 3, .assistant_spot_far_w
    BRANCH_U8_VAR_WITHIN_RANGE 2, 3, mountainConstructionWorkDays, .construction_days_2_3
    BRANCH_U8_VAR_WITHIN_RANGE 4, 4, mountainConstructionWorkDays, .construction_day_4
    SPAWN_EXECUTOR 1, .master_carpenter_spot_se
    EXECUTE_SUBROUTINE .setup_player_entity
    SET_COORDINATES -80, 0, -48
    SET_ASSET_ROTATION 7
    UPDATE_GLOBAL_RGBA 255, 255, 255, 255, 8
    SET_WAIT_FRAMES 40
    ; Assistant Carpenter: OK, now cut that tree stump.
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 226
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    EXECUTE_SUBROUTINE .axe_swing_x4
    ; Master Carpenter: Carry the lumber!
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 235
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_WAIT_FRAMES 10
    EXECUTE_SUBROUTINE .carry_lumber_nw
    ; Assistant Carpenter: Thanks! We could use some more help, too!
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 223
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_WAIT_FRAMES 10
    ENTITY_WALK 32, DIRECTION_E, 2
    SET_ASSET_ROTATION 7
    EXECUTE_SUBROUTINE .axe_swing_x4
    EXECUTE_SUBROUTINE .carry_lumber_nw
    SET_WAIT_FRAMES 10
    ENTITY_WALK 32, DIRECTION_E, 2
    SET_ASSET_ROTATION 7
    SPAWN_EXECUTOR 41, .fade_out_and_end
    EXECUTE_SUBROUTINE .axe_swing_x4
    EXECUTE_SUBROUTINE .carry_lumber_nw
    EXECUTE_SUBROUTINE .idle

.construction_days_2_3:
    SPAWN_EXECUTOR 1, .master_carpenter_spot_w
    EXECUTE_SUBROUTINE .setup_player_entity
    SET_COORDINATES -152, 0, 24
    SET_ASSET_ROTATION 2
    UPDATE_GLOBAL_RGBA 255, 255, 255, 255, 8
    SET_WAIT_FRAMES 40
    ; Assistant Carpenter: Hit this with a hammer!
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 227
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SPAWN_EXECUTOR 40, .wait_then_fade_out_and_end

.hammer_loop:
    SET_ENTITY_DIRECTIONAL_ANIMATION 224
    WAIT_ENTITY_ANIMATION
    SET_WAIT_FRAMES 10
    SET_SFX 20, 128
    SET_ENTITY_DIRECTIONAL_ANIMATION 248
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SET_WAIT_FRAMES 20
    EXECUTE_SUBROUTINE .hammer_loop

.construction_day_4:
    SPAWN_EXECUTOR 1, .master_carpenter_spot_w
    EXECUTE_SUBROUTINE .setup_player_entity
    SET_COORDINATES -152, 0, 24
    SET_ASSET_ROTATION 2
    UPDATE_GLOBAL_RGBA 255, 255, 255, 255, 8
    SET_WAIT_FRAMES 40
    ; Assistant Carpenter: OK, were almost done! Lets get this done!
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 229
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SPAWN_EXECUTOR 40, .wait_then_fade_out_and_end
    EXECUTE_SUBROUTINE .hammer_loop

.wait_then_fade_out_and_end:
    SET_WAIT_FRAMES 120

.fade_out_and_end:
    SET_WAIT_FRAMES 60
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    SET_WAIT_FRAMES 40
    DEACTIVATE_EXECUTOR 0
    DEACTIVATE_EXECUTOR 1
    DEACTIVATE_EXECUTOR 2
    DEACTIVATE_EXECUTOR 3
    DEACTIVATE_EXECUTOR 16
    ; force time to 15:00
    SET_U8_VALUE 15, gHour
    SET_U8_VALUE 0, gMinutes
    SET_SPECIAL_BIT 1, gCutsceneCompletionFlags
    EXECUTE_SUBROUTINE .end_cutscene

.axe_swing_x4:
    SET_WAIT_FRAMES 10
    SET_ENTITY_DIRECTIONAL_ANIMATION 176
    WAIT_ENTITY_ANIMATION
    SET_WAIT_FRAMES 10
    SET_SFX 17, 128
    SET_ENTITY_DIRECTIONAL_ANIMATION 200
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SET_WAIT_FRAMES 10
    SET_ENTITY_DIRECTIONAL_ANIMATION 176
    WAIT_ENTITY_ANIMATION
    SET_WAIT_FRAMES 10
    SET_SFX 17, 128
    SET_ENTITY_DIRECTIONAL_ANIMATION 200
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SET_WAIT_FRAMES 10
    SET_ENTITY_DIRECTIONAL_ANIMATION 176
    WAIT_ENTITY_ANIMATION
    SET_WAIT_FRAMES 10
    SET_SFX 17, 128
    SET_ENTITY_DIRECTIONAL_ANIMATION 200
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SET_WAIT_FRAMES 10
    SET_ENTITY_DIRECTIONAL_ANIMATION 176
    WAIT_ENTITY_ANIMATION
    SET_WAIT_FRAMES 10
    SET_SFX 17, 128
    SET_ENTITY_DIRECTIONAL_ANIMATION 200
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SET_WAIT_FRAMES 10
    RETURN_FROM_SUBROUTINE

.carry_lumber_nw:
    SPAWN_EXECUTOR 16, .executor_16_10FE98
    SET_HOLDING_ANIMATION_FLAG TRUE
    ENTITY_WALK 32, DIRECTION_W, 2
    DEACTIVATE_EXECUTOR 16
    SET_HOLDING_ANIMATION_FLAG FALSE
    RETURN_FROM_SUBROUTINE

.master_carpenter_spot_se:
    EXECUTE_SUBROUTINE .setup_master_carpenter
    SET_COORDINATES -144, 0, 16
    SET_ASSET_ROTATION 6
    EXECUTE_SUBROUTINE .idle

.master_carpenter_spot_w:
    EXECUTE_SUBROUTINE .setup_master_carpenter
    SET_COORDINATES -96, 0, -32
    SET_ASSET_ROTATION 1
    EXECUTE_SUBROUTINE .idle

.assistant_spot_ne:
    EXECUTE_SUBROUTINE .setup_assistant_carpenter_e25
    SET_COORDINATES 96, 0, -80
    SET_ASSET_ROTATION 2
    SET_ENTITY_DIRECTIONAL_ANIMATION 20
    EXECUTE_SUBROUTINE .idle

.assistant_spot_far_w:
    EXECUTE_SUBROUTINE .setup_assistant_carpenter_e26
    SET_COORDINATES -176, 0, -48
    SET_ASSET_ROTATION 2
    SET_ENTITY_DIRECTIONAL_ANIMATION 44
    EXECUTE_SUBROUTINE .idle

; ============================================
; Cutscene 327 (Master Carpenter end-of-day pay)
;   Regular days: +1000 G, text 237, master walks off.
;   Day 27 (bridge completion): text 239 + branch by
;   5-day work also gets +3 affection with every NPC.
;   Closes with assistant lines 244-245 and walk-off NE.
; ============================================

.cutscene_327_entry:
    UPDATE_U8_VALUE 1, 255, mountainConstructionWorkDays
    SPAWN_EXECUTOR 1, .executor_master_carpenter_idle
    EXECUTE_SUBROUTINE .setup_player_entity
    SET_COORDINATES -16, 0, 320
    SET_ASSET_ROTATION 4
    ; pay 1000 G for the days work
    UPDATE_U32_VALUE 1000, 999999, gGold
    ; day 27 = bridge completion branch
    BRANCH_U8_VAR_WITHIN_RANGE 27, 27, gDayOfMonth, .bridge_completion_day
    SET_WAIT_FRAMES 40
    ; Master Carpenter: Good work! Heres your pay. Come again tomorrow.
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 237
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 1, .executor_master_carpenter_leave
    EXECUTE_SUBROUTINE .idle

.bridge_completion_day:
    SPAWN_EXECUTOR 2, .assistant_left_spawn_327
    SPAWN_EXECUTOR 3, .assistant_right_spawn_327
    SET_WAIT_FRAMES 40
    ; Master Carpenter: bridge completion intro
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 239
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    BRANCH_U8_VAR_WITHIN_RANGE 1, 2, mountainConstructionWorkDays, .branch_1_or_2_workdays
    BRANCH_U8_VAR_WITHIN_RANGE 3, 3, mountainConstructionWorkDays, .branch_3_workdays
    BRANCH_U8_VAR_WITHIN_RANGE 4, 4, mountainConstructionWorkDays, .branch_4_workdays
    BRANCH_U8_VAR_WITHIN_RANGE 5, 5, mountainConstructionWorkDays, .branch_5_workdays

.finish_bridge_closing_lines:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_WAIT_FRAMES 30
    ; Assistant Carpenter: closing line 1
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 244
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_WAIT_FRAMES 20
    ; Assistant Carpenter: closing line 2
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 245
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 1, .executor_master_carpenter_leave
    SET_OTHER_EXECUTOR_PTR 2, .assistants_walk_off_ne
    SET_OTHER_EXECUTOR_PTR 3, .assistants_walk_off_ne
    EXECUTE_SUBROUTINE .idle

.branch_1_or_2_workdays:
    ; Master Carpenter: 1-2 day worker line
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 243
    EXECUTE_SUBROUTINE .finish_bridge_closing_lines

.branch_3_workdays:
    ; Master Carpenter: 3-day worker line
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 242
    EXECUTE_SUBROUTINE .finish_bridge_closing_lines

.branch_4_workdays:
    ; Master Carpenter: 4-day worker line
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 241
    EXECUTE_SUBROUTINE .finish_bridge_closing_lines

.branch_5_workdays:
    EXECUTE_SUBROUTINE .boost_all_npc_affection_by_3
    ; Master Carpenter: 5-day worker reward line
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 240
    EXECUTE_SUBROUTINE .finish_bridge_closing_lines

.boost_all_npc_affection_by_3:
    ; +3 affection for every NPC (5-workdays reward)
    UPDATE_U8_VALUE 3, 255, npcAffection[MARIA]
    UPDATE_U8_VALUE 3, 255, npcAffection[POPURI]
    UPDATE_U8_VALUE 3, 255, npcAffection[ELLI]
    UPDATE_U8_VALUE 3, 255, npcAffection[ANN]
    UPDATE_U8_VALUE 3, 255, npcAffection[KAREN]
