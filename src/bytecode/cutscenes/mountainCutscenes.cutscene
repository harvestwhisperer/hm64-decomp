    UPDATE_U8_VALUE 2, 255, npcAffection[POPURI]
    UPDATE_U8_VALUE 5, 255, gHappiness
    SET_WAIT_FRAMES 1
    BRANCH_ON_SPECIAL_BIT MARRIED, lifeEventBits[0], .branch_married
    SPAWN_EXECUTOR 1, .executor_popuri_305
    SPAWN_EXECUTOR 41, .executor_41_110D4C
