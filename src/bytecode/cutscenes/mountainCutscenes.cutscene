; ============================================
; Cutscene 306 (Ann with baby chick)
; Ann stands on the mountain; Button A (empty hands) opens a
; two-option dialogue. Choice 0: +8 affection. Choice 1: -2.
; Both paths end with Ann walking SW off screen.
; ============================================

.cutscene_306_entry:
    SPAWN_EXECUTOR 1, .executor_ann_306
    DEACTIVATE_SELF

.setup_ann:
    SETUP_ENTITY 37, ENTITY_ASSET_ANN, 1
    SET_ENTITY_ANIMATIONS 37, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    RETURN_FROM_SUBROUTINE

.executor_ann_306:
    EXECUTE_SUBROUTINE .setup_ann
    SET_COORDINATES -216, 0, -200
    SET_ASSET_ROTATION 6
    SET_ENTITY_ANIMATION 55
    UPDATE_RGBA 254, 254, 254, 254, 8
    WAIT_RGBA_FINISHED
    SPAWN_EXECUTOR 11, .executor_11_camera_in
    EXECUTE_SUBROUTINE .idle

.sub_111254:
    SETUP_MAP_ASSET MAIN_MAP_INDEX
    SET_ASSET_ROTATION 7
    RETURN_FROM_SUBROUTINE

