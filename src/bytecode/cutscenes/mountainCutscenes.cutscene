; ============================================
; Cutscene 305 (Mountain shooting-star date - Popuri)
; Popuri meets the player on the mountain; dialogue gates on
; her affection and on Harvest Sprite affection. Married path
; (Popuri wife) runs a variant via .branch_married_popuri.
; ============================================

.cutscene_305_entry:
    SET_SPECIAL_BIT 13, gCutsceneCompletionFlags
    SET_SPECIAL_BIT 14, gCutsceneCompletionFlags
    SET_SPECIAL_BIT 15, gCutsceneCompletionFlags
    STOP_SEQUENCE_WITH_FADE 0, 8
    IDLE_WHILE_SEQUENCE_PLAYING 0
