    EXECUTE_SUBROUTINE .setup_message_box
    PAUSE_ENTITY 0
    SET_ENTITY_DIRECTIONAL_ANIMATION 103
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SET_WAIT_FRAMES 8
    FLIP_ENTITY_DIRECTION 0
    ; Ann: acorn and rabbit poop observation
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 47
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SPAWN_EXECUTOR 2, .executor_gray_307
