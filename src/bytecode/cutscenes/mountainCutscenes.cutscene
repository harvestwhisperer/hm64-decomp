; ============================================
; Cutscene 309 (Cliff, Ann, hawk Kane, bunny)
; Cliff (with hawk Kane on his shoulder) talks with Ann about
; Kane eating rabbits; a bunny walks up, takes Ann static-item food,
; and Cliff closes with msg 66.
; ============================================

.cutscene_309_entry:
    SPAWN_EXECUTOR 1, .executor_ann_309
    SPAWN_EXECUTOR 2, .executor_cliff_309
    SPAWN_EXECUTOR 3, .executor_static_item_309
    SPAWN_EXECUTOR 4, .executor_hawk_309
    DEACTIVATE_SELF

.executor_ann_309:
    EXECUTE_SUBROUTINE .setup_ann
    SET_COORDINATES -32, 0, -88
    SET_ASSET_ROTATION 4
    SET_ENTITY_DIRECTIONAL_ANIMATION 16
    EXECUTE_SUBROUTINE .idle

.executor_cliff_309:
    SETUP_ENTITY 36, ENTITY_ASSET_CLIFF, 1
    SET_ENTITY_ANIMATIONS 36, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    SET_COORDINATES -32, 0, -140
    SET_ASSET_ROTATION 0
    SET_ENTITY_ANIMATION 25
    SET_WAIT_FRAMES 1
    UPDATE_GLOBAL_RGBA 254, 254, 254, 254, 8
    WAIT_RGBA_FINISHED
    SPAWN_EXECUTOR 11, .executor_11_309
    EXECUTE_SUBROUTINE .idle

.executor_11_309:
    EXECUTE_SUBROUTINE .sub_111254
    SPAWN_EXECUTOR 7, .executor_player_entity_306
    SET_WAIT_FRAMES 1
    SET_FRAME_DELTA 0, 0, -2, 112
    SET_FRAME_DELTA -2, 0, -2, 64
    ; Cliff: Kane has to eat birds and rabbits to survive
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 62
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 1, .executor_ann_309_after_msg62
    EXECUTE_SUBROUTINE .idle

.executor_ann_309_after_msg62:
    SET_OTHER_EXECUTOR_PTR 3, .face_sw
    SET_ASSET_ROTATION 0
    SET_ENTITY_ANIMATION 58
    SET_WAIT_FRAMES 15
    ; Ann: I understand but I still do not like the idea
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 64
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    DEACTIVATE_EXECUTOR 3
    SPAWN_EXECUTOR 5, .executor_bunny_309
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    EXECUTE_SUBROUTINE .idle

.executor_bunny_309:
    SETUP_ENTITY 19, ENTITY_ASSET_BUNNY, 1
    SET_ENTITY_ANIMATIONS 19, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    SET_COORDINATES -32, 0, -72
    SET_ASSET_ROTATION 0
    SET_WAIT_FRAMES 15
    ENTITY_WALK 8, DIRECTION_S, 2
    SET_ENTITY_ANIMATION 20
    WAIT_ENTITY_ANIMATION
    SET_OTHER_EXECUTOR_PTR 1, .face_w
    ENTITY_WALK 16, DIRECTION_SW, 2
    ; Cliff: Thats Kanes food......
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 65
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    ENTITY_WALK 64, DIRECTION_W, 2
    SET_OTHER_EXECUTOR_PTR 1, .executor_ann_309_after_bunny
    DEACTIVATE_SELF

.executor_ann_309_after_bunny:
    ENTITY_WALK 16, DIRECTION_SE, 2
    ENTITY_WALK 120, DIRECTION_S, 2
    ; Cliff: She took your food, so you have to eat the fish instead
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 66
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 11, .camera_end_309
    DEACTIVATE_SELF

.camera_end_309:
    SET_FRAME_DELTA 0, 0, 2, 112
    SET_FRAME_DELTA 2, 0, 2, 64
    DEACTIVATE_EXECUTOR 2
    DEACTIVATE_EXECUTOR 4
    SET_OTHER_EXECUTOR_PTR 7, .executor_7_10FF48
    SPAWN_EXECUTOR 32, .end_cutscene
    EXECUTE_SUBROUTINE .idle

.executor_static_item_309:
    SETUP_ENTITY 43, ENTITY_ASSET_STATIC_ITEM, 1
    SET_ENTITY_ANIMATIONS 43, 179, 0, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    SET_ASSET_ROTATION 4
    SET_ENTITY_TRACKING_TARGET 37, 0, 6, 16, 255
    EXECUTE_SUBROUTINE .idle

.executor_hawk_309:
    SETUP_ENTITY 18, ENTITY_ASSET_HAWK, 1
    SET_ENTITY_ANIMATIONS 18, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ASSET_ROTATION 0
    SET_ENTITY_TRACKING_TARGET 36, -18, 16, -4, 255
    EXECUTE_SUBROUTINE .idle

; ============================================
; Cutscene 310 (Maria watches Elli cook fish)
; Maria and Elli chat over cooking fish (texts 67..71).
; ============================================

.cutscene_310_entry:
    SPAWN_EXECUTOR 1, .executor_maria_310
    SPAWN_EXECUTOR 2, .executor_elli_310
    DEACTIVATE_SELF

.executor_maria_310:
    EXECUTE_SUBROUTINE .setup_maria
    SET_COORDINATES 140, 0, 8
    SET_ASSET_ROTATION 4
    SET_ENTITY_DIRECTIONAL_ANIMATION 25
    UPDATE_GLOBAL_RGBA 254, 254, 254, 254, 8
    WAIT_RGBA_FINISHED
    PAUSE_ENTITY 0
    SPAWN_EXECUTOR 11, .executor_310_dialogue
    EXECUTE_SUBROUTINE .idle

.executor_310_dialogue:
    EXECUTE_SUBROUTINE .sub_1115C4
    SPAWN_EXECUTOR 7, .executor_player_entity_308
    SET_WAIT_FRAMES 1
    SET_FRAME_DELTA 0, 0, -2, 84
    SET_FRAME_DELTA 2, 0, -2, 92
    SET_WAIT_FRAMES 15
    ; Maria: Wow Elli, youre good at cooking fish
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 67
    WAIT_MESSAGE_BOX_CLOSED 0
    ; Elli: reflects on respecting the life taken
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 68
    WAIT_MESSAGE_BOX_CLOSED 0
    ; Maria: decides to practice cooking fish
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 69
    WAIT_MESSAGE_BOX_CLOSED 0
    ; Elli: offers to teach, hands over the dish
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 70
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 2, .elli_310_cook_anim
    EXECUTE_SUBROUTINE .idle

.elli_310_cook_anim:
    SET_ENTITY_DIRECTIONAL_ANIMATION 96
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SET_ENTITY_ANIMATION 17
    WAIT_ENTITY_ANIMATION
    SPAWN_EXECUTOR 10, .executor_10_10FE1C
    SET_WAIT_FRAMES 30
    SET_OTHER_EXECUTOR_PTR 1, .maria_310_receive
    EXECUTE_SUBROUTINE .idle

.maria_310_receive:
    SET_ENTITY_DIRECTIONAL_ANIMATION 100
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SET_WAIT_FRAMES 15
    SET_OTHER_EXECUTOR_PTR 2, .executor_3_10FF58
    DEACTIVATE_EXECUTOR 10
    ; Maria: Thank you.
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 71
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 11, .cutscene_310_end
    EXECUTE_SUBROUTINE .idle

.cutscene_310_end:
    SET_WAIT_FRAMES 15
    SET_FRAME_DELTA 0, 0, 2, 84
    SET_FRAME_DELTA -2, 0, 2, 92
    DEACTIVATE_EXECUTOR 1
    DEACTIVATE_EXECUTOR 2
    SET_OTHER_EXECUTOR_PTR 7, .executor_7_10FF48
    SPAWN_EXECUTOR 32, .end_cutscene
    EXECUTE_SUBROUTINE .idle

.setup_elli_310:
    SETUP_ENTITY 36, ENTITY_ASSET_ELLI, 1
    SET_ENTITY_ANIMATIONS 36, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    RETURN_FROM_SUBROUTINE

.executor_elli_310:
    EXECUTE_SUBROUTINE .setup_elli_310
    SET_COORDINATES 140, 0, -48
    SET_ASSET_ROTATION 0
    SET_ENTITY_DIRECTIONAL_ANIMATION 25
    EXECUTE_SUBROUTINE .idle

; ============================================
; Cutscene 311 (Maria removes a bug from Karen)
; Maria pulls a bug off of Karen; banter about grasshoppers (texts 72..80).
; ============================================

.cutscene_311_entry:
    SPAWN_EXECUTOR 1, .executor_maria_311
    SPAWN_EXECUTOR 2, .executor_karen_311
    DEACTIVATE_SELF

.executor_maria_311:
    EXECUTE_SUBROUTINE .setup_maria
    SET_COORDINATES -112, 0, -136
    SET_ASSET_ROTATION 6
    SET_ENTITY_ANIMATION 23
    UPDATE_GLOBAL_RGBA 254, 254, 254, 254, 8
    WAIT_RGBA_FINISHED
    SPAWN_EXECUTOR 11, .maria_311_bug_dialogue
    EXECUTE_SUBROUTINE .idle

.maria_311_bug_dialogue:
    EXECUTE_SUBROUTINE .sub_111254
    SPAWN_EXECUTOR 7, .executor_player_entity_306
    SET_WAIT_FRAMES 1
    SET_FRAME_DELTA 0, 0, -2, 112
    SET_FRAME_DELTA -2, 0, -2, 96
    ; Karen: Quick! Quick! Get it off!
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 72
    WAIT_MESSAGE_BOX_CLOSED 0
    ; Maria: cannot help if you keep moving
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 73
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 2, .executor_3_10FF58
    SET_WAIT_FRAMES 30
    SET_OTHER_EXECUTOR_PTR 2, .karen_311_hurry_reaction
    EXECUTE_SUBROUTINE .idle

.karen_311_hurry_reaction:
    SET_ENTITY_ANIMATION 38
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_ANIMATION 42
    WAIT_ENTITY_ANIMATION
    ; Karen: Hurry, youre so slow
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 74
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_ENTITY_ANIMATION 38
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SET_WAIT_FRAMES 15
    SET_OTHER_EXECUTOR_PTR 1, .maria_311_compare
    EXECUTE_SUBROUTINE .idle

.maria_311_compare:
    SET_ENTITY_ANIMATION 38
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_ANIMATION 42
    SET_WAIT_FRAMES 30
    SET_ENTITY_ANIMATION 38
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    ; Maria: There, got it off
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 75
    WAIT_MESSAGE_BOX_CLOSED 0
    ; Karen: Ha ha
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 76
    WAIT_MESSAGE_BOX_CLOSED 0
    ; Maria: this little guy looks like you Karen
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 77
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 2, .karen_311_offended_exit
    EXECUTE_SUBROUTINE .idle

.karen_311_offended_exit:
    SET_ASSET_ROTATION 2
    SET_WAIT_FRAMES 15
    SET_ENTITY_ANIMATION 36
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_ANIMATION 40
    ; Karen: who are you calling a grasshopper
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 78
    WAIT_MESSAGE_BOX_CLOSED 0
    SET_OTHER_EXECUTOR_PTR 1, .maria_311_anim59_wait
    ; Maria: oops sorry
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 79
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_ENTITY_ANIMATION 36
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SET_OTHER_EXECUTOR_PTR 1, .executor_3_10FF58
    SET_WAIT_FRAMES 15
    ENTITY_WALK 24, DIRECTION_E, 2
    SET_OTHER_EXECUTOR_PTR 1, .executor_1_10FF94
    ENTITY_WALK 16, DIRECTION_SE, 2
    ENTITY_WALK 96, DIRECTION_S, 2
    ; Maria: meant your hair looks like antennas, was a compliment
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 80
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_WAIT_FRAMES 15
    SET_OTHER_EXECUTOR_PTR 11, .cutscene_311_end
    DEACTIVATE_SELF

.maria_311_anim59_wait:
    SET_ENTITY_ANIMATION 59
    WAIT_ENTITY_ANIMATION
    EXECUTE_SUBROUTINE .idle

.cutscene_311_end:
    SET_FRAME_DELTA 0, 0, 2, 112
    SET_FRAME_DELTA 2, 0, 2, 96
    DEACTIVATE_EXECUTOR 1
    SET_OTHER_EXECUTOR_PTR 7, .executor_7_10FF48
    SPAWN_EXECUTOR 32, .end_cutscene
    EXECUTE_SUBROUTINE .idle

.setup_karen:
    SETUP_ENTITY 36, ENTITY_ASSET_KAREN, 1
    SET_ENTITY_ANIMATIONS 36, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    SET_ENTITY_PHYSICS_FLAGS 1
    RETURN_FROM_SUBROUTINE

.executor_karen_311:
    EXECUTE_SUBROUTINE .setup_karen
    SET_COORDINATES -88, 0, -136
    SET_ASSET_ROTATION 6

.karen_311_idle_loop:
    SET_ENTITY_ANIMATION 59
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SET_WAIT_FRAMES 1
    EXECUTE_SUBROUTINE .karen_311_idle_loop

; ============================================
; Cutscene 312 (Popuri and Elli chat about marriage in hot springs)
; Triggered by level interaction 18; runs in two beats separated by
; a second interaction-18 wait. Clears bit 9 and dailyEventBits[1] bit 8.
; ============================================

.cutscene_312_entry:
    SET_SPECIAL_BIT 9, gCutsceneCompletionFlags

.wait_for_interaction_18_a:
    SET_WAIT_FRAMES 1
    BRANCH_U8_VAR_WITHIN_RANGE 18, 18, interactedWithLevelInteractionIndex, .on_interaction_18_a
    EXECUTE_SUBROUTINE .wait_for_interaction_18_a

.on_interaction_18_a:
    PAUSE_ENTITY 0
    EXECUTE_SUBROUTINE .show_text_81_centered
    ; a man working hard looks better
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 82
    WAIT_MESSAGE_BOX_CLOSED 0
    ; Popuri, what type of guys do you like
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 83
    WAIT_MESSAGE_BOX_CLOSED 0
    ; Hmmmm, lets see...
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 84
    WAIT_MESSAGE_BOX_CLOSED 0
    ; somebody like your father
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 85
    WAIT_MESSAGE_BOX_CLOSED 0
    ; no, not someone who is never home
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 86
    WAIT_MESSAGE_BOX_CLOSED 0
    ; cant wait to get married and have children
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 87
    WAIT_MESSAGE_BOX_CLOSED 0
    ; with who, Elli
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 88
    WAIT_MESSAGE_BOX_CLOSED 0
    ; well, I was thinking maybe... but
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 89
    WAIT_MESSAGE_BOX_CLOSED 0
    ; thats what I thought
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 90
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    EXECUTE_SUBROUTINE .setup_message_box
    TOGGLE_PAUSE_ENTITY 0
    EXECUTE_SUBROUTINE .wait_for_interaction_18_b

.wait_for_interaction_18_b:
    SET_WAIT_FRAMES 1
    BRANCH_U8_VAR_WITHIN_RANGE 18, 18, interactedWithLevelInteractionIndex, .on_interaction_18_b
    EXECUTE_SUBROUTINE .wait_for_interaction_18_b

.on_interaction_18_b:
    SPAWN_EXECUTOR 7, .executor_player_entity_312
    DEACTIVATE_SELF

.executor_player_entity_312:
    EXECUTE_SUBROUTINE .setup_player_entity
    ENTITY_WALK 32, DIRECTION_E, 2
    SET_ASSET_ROTATION 2
    SPAWN_EXECUTOR 1, .executor_popuri_312
    EXECUTE_SUBROUTINE .idle

.executor_popuri_312:
    EXECUTE_SUBROUTINE .setup_popuri
    SET_COORDINATES -40, 0, -32
    ENTITY_WALK 20, DIRECTION_SW, 2
    SPAWN_EXECUTOR 2, .executor_elli_312
    SET_ASSET_ROTATION 6
    EXECUTE_SUBROUTINE .idle

.executor_elli_312:
    EXECUTE_SUBROUTINE .setup_elli_310
    SET_COORDINATES -40, 0, -32
    SET_ASSET_ROTATION 6
    ; Popuri: Im going, see you later
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 91
    WAIT_MESSAGE_BOX_CLOSED 0
    ; Elli: See you
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 92
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 1, .executor_popuri_312_exit
    ENTITY_WALK 20, DIRECTION_SW, 2
    SET_OTHER_EXECUTOR_PTR 7, .face_w
    ENTITY_WALK 60, DIRECTION_S, 2
    SET_OTHER_EXECUTOR_PTR 7, .face_sw
    ENTITY_WALK 112, DIRECTION_E, 2
    SET_OTHER_EXECUTOR_PTR 7, .deactivate_executor_player
    CLEAR_SPECIAL_BIT 9, gCutsceneCompletionFlags
    CLEAR_SPECIAL_BIT 8, dailyEventBits[1]
    EXECUTE_SUBROUTINE .end_cutscene

.executor_popuri_312_exit:
    ENTITY_WALK 60, DIRECTION_S, 2
    ENTITY_WALK 112, DIRECTION_E, 2
    DEACTIVATE_SELF

; ============================================
; Cutscene 313 missing
; ============================================

; ============================================
; Cutscene 314 (Karen and Popuri - moondrop flower wine chat)
; Five-line exchange (texts 93..97) about using the flower to make wine.
; ============================================

.cutscene_314_entry:
    SPAWN_EXECUTOR 1, .executor_popuri_314
    SPAWN_EXECUTOR 2, .executor_karen_314
    DEACTIVATE_SELF

.executor_popuri_314:
    EXECUTE_SUBROUTINE .setup_popuri
