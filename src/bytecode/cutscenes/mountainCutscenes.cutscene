; ============================================
; Cutscene 307 (Ann and Gray - acorn/stale-candy exchange)
; Ann waits for Button A; after the opening line, Gray walks in
; from the south and the two exchange 7 dialogue messages (47..53).
; ============================================

.cutscene_307_entry:
    SPAWN_EXECUTOR 1, .executor_ann_307
    DEACTIVATE_SELF

.executor_ann_307:
    EXECUTE_SUBROUTINE .setup_ann
    SET_COORDINATES -88, 0, -168
    SET_ASSET_ROTATION 2
    SET_ENTITY_DIRECTIONAL_ANIMATION 25
