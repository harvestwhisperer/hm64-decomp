    SET_WAIT_FRAMES 15
    SET_ENTITY_ANIMATION 53
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SET_WAIT_FRAMES 15
    ENTITY_WALK 32, DIRECTION_E, 2
    SET_OTHER_EXECUTOR_PTR 11, .executor_11_camera_out
    SET_CALLBACK_ROUTINE 0, BUTTON_A, .ann_on_interact
