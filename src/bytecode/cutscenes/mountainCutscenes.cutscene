    EXECUTE_SUBROUTINE .setup_gray
    SET_COORDINATES -16, 0, 80
    ENTITY_WALK 120, DIRECTION_N, 2
    SET_ASSET_ROTATION 2
    ; Gray: sounds like somebody I know
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 48
    WAIT_MESSAGE_BOX_CLOSED 0
    SET_OTHER_EXECUTOR_PTR 1, .face_se
    ; Ann: you scared me; who are you talking about
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 49
    WAIT_MESSAGE_BOX_CLOSED 0
    ; Gray: the person who forgets treats in cabinets
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 50
    WAIT_MESSAGE_BOX_CLOSED 0
    SET_OTHER_EXECUTOR_PTR 1, .executor_ann_react_307
    ; Ann: it is not like I forgot about them
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 51
    WAIT_MESSAGE_BOX_CLOSED 0
    ; Gray: you like stale candy
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 52
    WAIT_MESSAGE_BOX_CLOSED 0
    ; Ann: forget it
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 53
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 1, .executor_ann_exit_307
