; ============================================
; Cutscene 302 - Gray-helps-instead branch
; ============================================

.gray_helps_popuri:
    UPDATE_U8_VALUE 20, 255, npcAffection[GRAY]
    UPDATE_U8_VALUE -30, 255, npcAffection[POPURI]
    ; fade to black, respawn with Gray, restore lighting
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    SPAWN_EXECUTOR 2, .executor_gray_302
    SPAWN_EXECUTOR 7, .executor_player_302_2
    SET_WAIT_FRAMES 15
    EXECUTE_SUBROUTINE .set_lighting
.finish_lighting_fade:
    WAIT_RGBA_FINISHED
    SET_WAIT_FRAMES 15
    SET_OTHER_EXECUTOR_PTR 2, .gray_scene_script_302
    EXECUTE_SUBROUTINE .idle

; 0x1106C4
