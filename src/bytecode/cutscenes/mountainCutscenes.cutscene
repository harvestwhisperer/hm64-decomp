; ============================================
; Cutscene 315 (Popuri blue mist)
; A-press on Popuri delivers two lines (texts 98, 99); she walks SE.
; On exit, POPURI, BASIL, and LILLIA affection all get +8.
; ============================================

.cutscene_315_entry:
    SPAWN_EXECUTOR 1, .executor_popuri_315
    DEACTIVATE_SELF

.executor_popuri_315:
    EXECUTE_SUBROUTINE .setup_popuri
    SET_COORDINATES -136, 0, -152
    SET_ASSET_ROTATION 0
    SET_CALLBACK_ROUTINE 0, BUTTON_A, .popuri_315_on_interact
    EXECUTE_SUBROUTINE .idle

.popuri_315_on_interact:
    EXECUTE_SUBROUTINE .setup_message_box
    PAUSE_ENTITY 0
    FLIP_ENTITY_DIRECTION 0
    ; Popuri: Wow, amazing. First time seeing the real thing, so pretty
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 98
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    ENTITY_WALK 32, DIRECTION_E, 2
    SET_ASSET_ROTATION 2
    SPAWN_EXECUTOR 7, .executor_player_entity_315
    ; Popuri: I hope the butterflies come
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 99
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    ENTITY_WALK 56, DIRECTION_E, 2
    ENTITY_WALK 48, DIRECTION_SE, 2
    ENTITY_WALK 32, DIRECTION_E, 2
    UPDATE_U8_VALUE 8, 255, npcAffection[POPURI]
    UPDATE_U8_VALUE 8, 255, npcAffection[BASIL]
    UPDATE_U8_VALUE 8, 255, npcAffection[LILLIA]
    SET_OTHER_EXECUTOR_PTR 7, .deactivate_executor_player
    TOGGLE_PAUSE_ENTITY 0
    EXECUTE_SUBROUTINE .end_cutscene

.executor_player_entity_315:
    EXECUTE_SUBROUTINE .setup_player_entity
    SET_ASSET_ROTATION 6
    EXECUTE_SUBROUTINE .idle

; ============================================
