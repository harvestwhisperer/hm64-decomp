    UPDATE_U8_VALUE 3, 255, npcAffection[HARRIS]
    UPDATE_U8_VALUE 3, 255, npcAffection[GRAY]
    UPDATE_U8_VALUE 3, 255, npcAffection[JEFF]
    UPDATE_U8_VALUE 3, 255, npcAffection[CLIFF]
    UPDATE_U8_VALUE 3, 255, npcAffection[KAI]
    UPDATE_U8_VALUE 3, 255, npcAffection[MAYOR]
    UPDATE_U8_VALUE 3, 255, npcAffection[MAYOR_WIFE]
    UPDATE_U8_VALUE 3, 255, npcAffection[LILLIA]
    UPDATE_U8_VALUE 3, 255, npcAffection[BASIL]
    UPDATE_U8_VALUE 3, 255, npcAffection[ELLEN]
    UPDATE_U8_VALUE 3, 255, npcAffection[DOUG]
    UPDATE_U8_VALUE 3, 255, npcAffection[GOTZ]
    UPDATE_U8_VALUE 3, 255, npcAffection[SASHA]
    UPDATE_U8_VALUE 3, 255, npcAffection[POTION_SHOP_DEALER]
    UPDATE_U8_VALUE 3, 255, npcAffection[KENT]
    UPDATE_U8_VALUE 3, 255, npcAffection[STU]
    UPDATE_U8_VALUE 3, 255, npcAffection[MIDWIFE]
    UPDATE_U8_VALUE 3, 255, npcAffection[MAY]
    UPDATE_U8_VALUE 3, 255, npcAffection[RICK]
    UPDATE_U8_VALUE 3, 255, npcAffection[PASTOR]
    UPDATE_U8_VALUE 3, 255, npcAffection[SHIPPER]
    UPDATE_U8_VALUE 3, 255, npcAffection[SAIBARA]
    UPDATE_U8_VALUE 3, 255, npcAffection[DUKE]
    UPDATE_U8_VALUE 3, 255, npcAffection[GREG]
    UPDATE_U8_VALUE 3, 255, npcAffection[HARVEST_SPRITE_1]
    UPDATE_U8_VALUE 3, 255, npcAffection[HARVEST_SPRITE_2]
    UPDATE_U8_VALUE 3, 255, npcAffection[HARVEST_SPRITE_3]
    UPDATE_U8_VALUE 3, 255, npcAffection[SYDNEY]
    UPDATE_U8_VALUE 3, 255, npcAffection[BARLEY]
    UPDATE_U8_VALUE 3, 255, npcAffection[MRS_MANA]
    UPDATE_U8_VALUE 3, 255, npcAffection[JOHN]
    UPDATE_U8_VALUE 3, 255, npcAffection[GOURMET_JUDGE]
    UPDATE_U8_VALUE 3, 255, npcAffection[MARIA_HARRIS_BABY]
    UPDATE_U8_VALUE 3, 255, npcAffection[POPURI_GRAY_BABY]
    UPDATE_U8_VALUE 3, 255, npcAffection[ELLI_JEFF_BABY]
    UPDATE_U8_VALUE 3, 255, npcAffection[ANN_CLIFF_BABY]
    UPDATE_U8_VALUE 3, 255, npcAffection[KAREN_KAI_BABY]
    RETURN_FROM_SUBROUTINE

.assistant_left_spawn_327:
    EXECUTE_SUBROUTINE .setup_assistant_carpenter_e25
    SET_COORDINATES -48, 0, 272
    SET_ASSET_ROTATION 0
    EXECUTE_SUBROUTINE .idle

.assistant_right_spawn_327:
    EXECUTE_SUBROUTINE .setup_assistant_carpenter_e26
    SET_COORDINATES 16, 0, 272
    SET_ASSET_ROTATION 0
    EXECUTE_SUBROUTINE .idle

.assistants_walk_off_ne:
    ENTITY_WALK 96, DIRECTION_N, 2
    DEACTIVATE_SELF

; ============================================
; Cutscene 328 (alias - delegates to Cutscene 324)
; No distinct logic; re-runs the full Master Carpenter recruitment flow.
; ============================================

.cutscene_328_entry:
    EXECUTE_SUBROUTINE .cutscene_324_entry

; ============================================
; Cutscene 329 (Hot springs work)
; Marks daily bit 12, loads map addition 6, places Master Carpenter
; and assistants; shows text 236 (wedge), player walks NE into the
; hammer loop, screen fades, time forced to 15:00, bit 1 set.
; ============================================

.cutscene_329_entry:
    SET_SPECIAL_BIT 12, gCutsceneCompletionFlags
    INIT_MAP_ADDITION 6, 0
    SPAWN_EXECUTOR 1, .spawn_master_carpenter_329
    SPAWN_EXECUTOR 2, .spawn_assistant_1_329
    SPAWN_EXECUTOR 3, .spawn_assistant_2_329
    EXECUTE_SUBROUTINE .setup_player_entity
    SET_COORDINATES -96, 0, 0
    SET_ASSET_ROTATION 1
    SET_WAIT_FRAMES 40
    ; Assistant Carpenter: Hit a wedge in here!
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 236
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    ENTITY_WALK 16, DIRECTION_N, 2
    SET_WAIT_FRAMES 10
    SPAWN_EXECUTOR 40, .fade_and_end_329
    EXECUTE_SUBROUTINE .hammer_loop

.spawn_master_carpenter_329:
    EXECUTE_SUBROUTINE .setup_master_carpenter
    SET_COORDINATES -144, 0, 16
    SET_ASSET_ROTATION 6
    EXECUTE_SUBROUTINE .idle

.spawn_assistant_1_329:
    EXECUTE_SUBROUTINE .setup_assistant_carpenter_e25
    SET_COORDINATES -128, 0, -96
    SET_ASSET_ROTATION 6
    SET_ENTITY_DIRECTIONAL_ANIMATION 44
    EXECUTE_SUBROUTINE .idle

.spawn_assistant_2_329:
    EXECUTE_SUBROUTINE .setup_assistant_carpenter_e26
    SET_COORDINATES 0, 0, -48
    SET_ASSET_ROTATION 4
    SET_ENTITY_DIRECTIONAL_ANIMATION 44
    EXECUTE_SUBROUTINE .idle

.fade_and_end_329:
    SET_WAIT_FRAMES 180
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    SET_WAIT_FRAMES 40
    DEACTIVATE_EXECUTOR 0
    DEACTIVATE_EXECUTOR 1
    DEACTIVATE_EXECUTOR 2
    DEACTIVATE_EXECUTOR 3
    SET_U8_VALUE 15, gHour
    SET_U8_VALUE 0, gMinutes
    SET_SPECIAL_BIT 1, gCutsceneCompletionFlags
    EXECUTE_SUBROUTINE .end_cutscene

; ============================================
; Cutscene 330 (Hot spring help completion - day 16)
; ============================================

.cutscene_330_entry:
    UPDATE_U8_VALUE 1, 255, mountainConstructionWorkDays
    SPAWN_EXECUTOR 1, .executor_master_carpenter_idle
    EXECUTE_SUBROUTINE .setup_player_entity
    SET_COORDINATES -16, 0, 320
    SET_ASSET_ROTATION 4
    UPDATE_U32_VALUE 1000, 999999, gGold
    ; day 16 = mountain-site final day
    BRANCH_U8_VAR_WITHIN_RANGE 16, 16, gDayOfMonth, .branch_final_day_payout_330
    SET_WAIT_FRAMES 40
    ; Master Carpenter: Good work! Heres your pay. Come again tomorrow.
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 237
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 1, .executor_master_carpenter_leave
    EXECUTE_SUBROUTINE .idle

.branch_final_day_payout_330:
    SPAWN_EXECUTOR 2, .assistant_left_spawn_327
    SPAWN_EXECUTOR 3, .assistant_right_spawn_327
    SET_WAIT_FRAMES 40
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 239
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    BRANCH_U8_VAR_WITHIN_RANGE 1, 2, mountainConstructionWorkDays, .branch_1_or_2_workdays_330
    BRANCH_U8_VAR_WITHIN_RANGE 3, 3, mountainConstructionWorkDays, .branch_3_workdays_330
    BRANCH_U8_VAR_WITHIN_RANGE 4, 4, mountainConstructionWorkDays, .branch_4_workdays_330
    BRANCH_U8_VAR_WITHIN_RANGE 5, 5, mountainConstructionWorkDays, .branch_5_workdays_330

.payout_closing_lines_330:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_WAIT_FRAMES 20
    ; Assistant Carpenter: Hey, lets be the first ones in the hot spring!
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 247
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_WAIT_FRAMES 20
    ; Assistant Carpenter: Hot springs feel best when youre tired.
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 248
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 1, .executor_master_carpenter_leave
    SET_OTHER_EXECUTOR_PTR 2, .assistants_walk_off_ne
    SET_OTHER_EXECUTOR_PTR 3, .assistants_walk_off_ne
    EXECUTE_SUBROUTINE .idle

.branch_1_or_2_workdays_330:
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 243
    EXECUTE_SUBROUTINE .payout_closing_lines_330

.branch_3_workdays_330:
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 242
    EXECUTE_SUBROUTINE .payout_closing_lines_330

.branch_4_workdays_330:
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 241
    EXECUTE_SUBROUTINE .payout_closing_lines_330

.branch_5_workdays_330:
    EXECUTE_SUBROUTINE .boost_all_npc_affection_by_3
    SET_SPECIAL_BIT 24, dailyEventBits[1]
    ; Master Carpenter: Thanks for your help; Ill send leftover lumber to your farm.
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 246
    EXECUTE_SUBROUTINE .payout_closing_lines_330

; ============================================
; Cutscene 336 (Kappa gifts item at pond)
; Player throws a fish; Kappa emerges, speaks (text 164, 165),
; submerges, reappears to deliver parting line (text 166), ends.
; The 8 capture_*/reaim_* branch pairs read the players facing
; direction and play it back as the Kappas rotation.
; ============================================

.cutscene_336_entry:
    PAUSE_ENTITY 0
    SPAWN_EXECUTOR 1, .executor_kappa_greeting
    DEACTIVATE_SELF

.sub_113550:
    SETUP_ENTITY 37, ENTITY_ASSET_KAPPA, 1
    SET_ENTITY_ANIMATIONS 37, 0, 0, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_PHYSICS_FLAGS 0
    SET_COORDINATES 136, -16, -168
    SET_ENTITY_ANIMATION 0
    SET_FRAME_DELTA 0, 1, 0, 40
    RETURN_FROM_SUBROUTINE

.executor_kappa_greeting:
    EXECUTE_SUBROUTINE .sub_113550
    ; Kappa: Im the water imp of this pond. You gave me a fish... Ill give you this.
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 164
    WAIT_MESSAGE_BOX_CLOSED 0
    WAIT_MESSAGE_BOX_CLOSED 0
    TOGGLE_PAUSE_ENTITY 0
    SPAWN_EXECUTOR 0, .executor_player_throws_336
    EXECUTE_SUBROUTINE .idle

.executor_kappa_submerge:
    SET_ENTITY_ANIMATION 1
    SET_FRAME_DELTA 0, -1, 0, 40
    SET_OTHER_EXECUTOR_PTR 0, .executor_capture_player_dir
    DEACTIVATE_SELF

.throw_splash_cycle_a:
    SET_ENTITY_DIRECTIONAL_ANIMATION 24
    SET_WAIT_FRAMES 10
    SPAWN_EXECUTOR 10, .executor_10_10FE64
    SET_WAIT_FRAMES 5
    DEACTIVATE_EXECUTOR 10
    SET_WAIT_FRAMES 10
    SPAWN_EXECUTOR 10, .executor_10_10FE64
    SET_WAIT_FRAMES 5
    DEACTIVATE_EXECUTOR 10
    SET_WAIT_FRAMES 8
    SPAWN_EXECUTOR 10, .executor_10_10FE64
    SET_WAIT_FRAMES 5
    DEACTIVATE_EXECUTOR 10
    SET_WAIT_FRAMES 4
    SPAWN_EXECUTOR 10, .executor_10_10FE64
    SET_WAIT_FRAMES 20
    RETURN_FROM_SUBROUTINE

.sub_113618:
    SET_ENTITY_DIRECTIONAL_ANIMATION 24
    SET_WAIT_FRAMES 10
    SPAWN_EXECUTOR 10, .executor_10_10FE34
    SET_WAIT_FRAMES 5
    DEACTIVATE_EXECUTOR 10
    SET_WAIT_FRAMES 10
    SPAWN_EXECUTOR 10, .executor_10_10FE34
    SET_WAIT_FRAMES 5
    DEACTIVATE_EXECUTOR 10
    SET_WAIT_FRAMES 8
    SPAWN_EXECUTOR 10, .executor_10_10FE34
    SET_WAIT_FRAMES 5
    DEACTIVATE_EXECUTOR 10
    SET_WAIT_FRAMES 4
    SPAWN_EXECUTOR 10, .executor_10_10FE34
    SET_WAIT_FRAMES 20
    RETURN_FROM_SUBROUTINE

.executor_player_throws_336:
    EXECUTE_SUBROUTINE .setup_player_entity
    EXECUTE_SUBROUTINE .throw_splash_cycle_a
    ; Kappa: Eat that and you wont tire even in the rain...
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 165
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 1, .executor_kappa_submerge
    EXECUTE_SUBROUTINE .idle

.executor_capture_player_dir:
    BRANCH_ON_ENTITY_DIR 0, DIRECTION_N, .capture_ne
    BRANCH_ON_ENTITY_DIR 0, DIRECTION_NE, .capture_e
    BRANCH_ON_ENTITY_DIR 0, DIRECTION_E, .capture_se
    BRANCH_ON_ENTITY_DIR 0, DIRECTION_SE, .capture_s
    BRANCH_ON_ENTITY_DIR 0, DIRECTION_S, .capture_sw
    BRANCH_ON_ENTITY_DIR 0, DIRECTION_SW, .capture_w
    BRANCH_ON_ENTITY_DIR 0, DIRECTION_W, .capture_nw
    BRANCH_ON_ENTITY_DIR 0, DIRECTION_NW, .capture_n
    SET_ASSET_ROTATION 0
    SET_OTHER_EXECUTOR_PTR 10, .executor_10_10FED0
    SET_ENTITY_DIRECTIONAL_ANIMATION 24
    SET_WAIT_FRAMES 16
    SET_ENTITY_ANIMATION 437
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    BRANCH_ON_SPECIAL_BIT 0, var0, .reaim_ne
    BRANCH_ON_SPECIAL_BIT 1, var0, .reaim_e
    BRANCH_ON_SPECIAL_BIT 2, var0, .reaim_se
    BRANCH_ON_SPECIAL_BIT 3, var0, .reaim_s
    BRANCH_ON_SPECIAL_BIT 4, var0, .reaim_sw
    BRANCH_ON_SPECIAL_BIT 5, var0, .reaim_w
    BRANCH_ON_SPECIAL_BIT 6, var0, .reaim_nw
    BRANCH_ON_SPECIAL_BIT 7, var0, .reaim_n
    SPAWN_EXECUTOR 1, .executor_kappa_farewell
    EXECUTE_SUBROUTINE .idle

.capture_ne:
    SET_SPECIAL_BIT 0, var0
    RETURN_FROM_SUBROUTINE

.capture_e:
    SET_SPECIAL_BIT 1, var0
    RETURN_FROM_SUBROUTINE

.capture_se:
    SET_SPECIAL_BIT 2, var0
    RETURN_FROM_SUBROUTINE

.capture_s:
    SET_SPECIAL_BIT 3, var0
    RETURN_FROM_SUBROUTINE

.capture_sw:
    SET_SPECIAL_BIT 4, var0
    RETURN_FROM_SUBROUTINE

.capture_w:
    SET_SPECIAL_BIT 5, var0
    RETURN_FROM_SUBROUTINE

.capture_nw:
    SET_SPECIAL_BIT 6, var0
    RETURN_FROM_SUBROUTINE

.capture_n:
    SET_SPECIAL_BIT 7, var0
    RETURN_FROM_SUBROUTINE

.reaim_ne:
    SET_ASSET_ROTATION 4
    RETURN_FROM_SUBROUTINE

.reaim_e:
    SET_ASSET_ROTATION 5
    RETURN_FROM_SUBROUTINE

.reaim_se:
    SET_ASSET_ROTATION 6
    RETURN_FROM_SUBROUTINE

.reaim_s:
    SET_ASSET_ROTATION 7
    RETURN_FROM_SUBROUTINE

.reaim_sw:
    SET_ASSET_ROTATION 0
    RETURN_FROM_SUBROUTINE

.reaim_w:
    SET_ASSET_ROTATION 1
    RETURN_FROM_SUBROUTINE

.reaim_nw:
    SET_ASSET_ROTATION 2
    RETURN_FROM_SUBROUTINE

.reaim_n:
    SET_ASSET_ROTATION 3
    RETURN_FROM_SUBROUTINE

.executor_kappa_farewell:
    EXECUTE_SUBROUTINE .sub_113550
    ; Kappa: Dont work too hard; itll wear you out. Bye.
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 166
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_ENTITY_ANIMATION 1
    SET_FRAME_DELTA 0, -1, 0, 40
    SET_OTHER_EXECUTOR_PTR 0, .deactivate_executor_player
    EXECUTE_SUBROUTINE .end_cutscene

; ============================================
; Cutscene 337 (Kappa gives Power Nut - bit 3)
; Thanks (text 167), grants acquiredPowerNutBits bit 3 + max stamina 250
; + happiness 255, farewell (text 168), Kappa walks off.
; ============================================

.cutscene_337_entry:
    PAUSE_ENTITY 0
    SPAWN_EXECUTOR 1, .kappa_thanks_337
    DEACTIVATE_SELF

.kappa_thanks_337:
    EXECUTE_SUBROUTINE .sub_113550
    ; Kappa: Thank you. I love big fish. This is for you.
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 167
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITY 0
    SPAWN_EXECUTOR 0, .grant_power_nut_337
    EXECUTE_SUBROUTINE .idle

.grant_power_nut_337:
    EXECUTE_SUBROUTINE .setup_player_entity
    EXECUTE_SUBROUTINE .sub_113618
    SET_SPECIAL_BIT 3, acquiredPowerNutBits
    UPDATE_U8_VALUE 15, 250, gMaximumStamina
    UPDATE_U8_VALUE 2, 255, gHappiness
    ; Kappa: (farewell line)
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 168
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 1, .kappa_pre_walk_delay_337
    EXECUTE_SUBROUTINE .idle

.kappa_pre_walk_delay_337:
    SET_ENTITY_ANIMATION 1
    SET_FRAME_DELTA 0, -1, 0, 40
    SET_OTHER_EXECUTOR_PTR 0, .kappa_walk_away_337
    DEACTIVATE_SELF

.kappa_walk_away_337:
    SET_ASSET_ROTATION 0
    SET_OTHER_EXECUTOR_PTR 10, .executor_10_10FED0
    SET_ENTITY_DIRECTIONAL_ANIMATION 24
    SET_WAIT_FRAMES 16
    SET_ENTITY_ANIMATION 437
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SET_ENTITY_MAP_SPACE_INDEPENDENT FALSE
    EXECUTE_SUBROUTINE .end_cutscene

; ============================================
; Cutscene 338 (Stu, May, butterfly in spider web)
; Either NPC spawns the same dialogue; Stu asks about saving the butterfly,
; May suggests the spider needs it. Choice 0: +5 Stu, tint-lit release with
; white butterfly + text 174 farewell. Choice 1: +5 May, texts 175-177 decline.
; ============================================

.cutscene_338_entry:
    SPAWN_EXECUTOR 1, .executor_stu_338
    SPAWN_EXECUTOR 2, .executor_may_338
    DEACTIVATE_SELF

.executor_stu_338:
    EXECUTE_SUBROUTINE .setup_stu
    SET_ENTITY_NON_COLLIDABLE
    SET_COORDINATES -240, 0, -88
    SET_ASSET_ROTATION 2
    SET_CALLBACK_ROUTINE 0, BUTTON_A, .stu_on_interact_338
    EXECUTE_SUBROUTINE .idle

.executor_may_338:
    SETUP_ENTITY 37, ENTITY_ASSET_MAY, 1
    SET_ENTITY_ANIMATIONS 37, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    SET_ENTITY_PHYSICS_FLAGS 1
    SET_ASSET_ROTATION 0
    SET_COORDINATES -256, 0, -108
    SET_CALLBACK_ROUTINE 0, BUTTON_A, .may_on_interact_338
    EXECUTE_SUBROUTINE .idle

.stu_on_interact_338:
    EXECUTE_SUBROUTINE .setup_message_box
    PAUSE_ENTITY 0
    FLIP_ENTITY_DIRECTION 0
    SET_OTHER_EXECUTOR_PTR 2, .executor_2_10FC5C
    SPAWN_EXECUTOR 6, .dialogue_338
    EXECUTE_SUBROUTINE .idle

.may_on_interact_338:
    EXECUTE_SUBROUTINE .setup_message_box
    PAUSE_ENTITY 0
    SET_OTHER_EXECUTOR_PTR 1, .executor_2_10FC5C
    SET_WAIT_FRAMES 1
    SET_OTHER_EXECUTOR_PTR 1, .face_ne
    SPAWN_EXECUTOR 6, .dialogue_338
    EXECUTE_SUBROUTINE .idle

.dialogue_338:
    ; Stu: Theres a butterfly caught in a spider web; should I help it?
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 169
    WAIT_MESSAGE_BOX_CLOSED 0
    SET_OTHER_EXECUTOR_PTR 2, .executor_1_10FF94
    ; May: the spider might need to eat too
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 170
    WAIT_MESSAGE_BOX_CLOSED 0
    ; two-option prompt: save vs leave butterfly
    INIT_DIALOGUE_SESSION 0, DIALOGUE_TEXT_54, 3
    WAIT_FOR_DIALOGUE_INPUT 0
    BRANCH_ON_DIALOGUE 0, 0, .choice_save_butterfly_338
    BRANCH_ON_DIALOGUE 0, 1, .choice_leave_butterfly_338

.choice_save_butterfly_338:
    UPDATE_U8_VALUE 5, 255, npcAffection[STU]
    SET_OTHER_EXECUTOR_PTR 1, .stu_post_choice_338
    DEACTIVATE_SELF

.stu_post_choice_338:
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    SET_OTHER_EXECUTOR_PTR 2, .may_post_choice_338
    SET_COORDINATES -208, 0, -88
    SET_ASSET_ROTATION 2
    SPAWN_EXECUTOR 3, .executor_player_entity_338
    EXECUTE_SUBROUTINE .idle

.may_post_choice_338:
    SET_COORDINATES -224, 0, -108
    SET_ASSET_ROTATION 2
    EXECUTE_SUBROUTINE .idle

.apply_time_weather_tint_338:
    BRANCH_U8_VAR_WITHIN_RANGE 2, 2, gWeather, .branch_113B18
    BRANCH_U8_VAR_WITHIN_RANGE 0, 4, gHour, .branch_113AAC
    BRANCH_U8_VAR_WITHIN_RANGE 5, 5, gHour, .branch_113AB8
    BRANCH_U8_VAR_WITHIN_RANGE 6, 7, gHour, .branch_113AC4
    BRANCH_U8_VAR_WITHIN_RANGE 8, 11, gHour, .branch_113AD0
    BRANCH_U8_VAR_WITHIN_RANGE 12, 15, gHour, .branch_113ADC
    BRANCH_U8_VAR_WITHIN_RANGE 16, 16, gHour, .branch_113AE8
    BRANCH_U8_VAR_WITHIN_RANGE 17, 17, gHour, .branch_113AF4
    BRANCH_U8_VAR_WITHIN_RANGE 18, 19, gHour, .branch_113AB8
    BRANCH_U8_VAR_WITHIN_RANGE 20, 23, gHour, .branch_113AAC
    EXECUTE_SUBROUTINE .play_wave_then_spawn_butterfly

.branch_113AAC:
    UPDATE_GLOBAL_RGBA 80, 80, 80, 80, 8
    EXECUTE_SUBROUTINE .play_wave_then_spawn_butterfly

.branch_113AB8:
    UPDATE_GLOBAL_RGBA 128, 128, 128, 128, 8
    EXECUTE_SUBROUTINE .play_wave_then_spawn_butterfly

.branch_113AC4:
    UPDATE_GLOBAL_RGBA 192, 192, 192, 192, 8
    EXECUTE_SUBROUTINE .play_wave_then_spawn_butterfly

.branch_113AD0:
    UPDATE_GLOBAL_RGBA 224, 224, 224, 224, 8
    EXECUTE_SUBROUTINE .play_wave_then_spawn_butterfly

.branch_113ADC:
    UPDATE_GLOBAL_RGBA 255, 255, 255, 255, 8
    EXECUTE_SUBROUTINE .play_wave_then_spawn_butterfly

.branch_113AE8:
    UPDATE_GLOBAL_RGBA 255, 224, 224, 224, 8
    EXECUTE_SUBROUTINE .play_wave_then_spawn_butterfly

.branch_113AF4:
    BRANCH_U8_VAR_WITHIN_RANGE 3, 3, gWeather, .branch_113B0C
    UPDATE_GLOBAL_RGBA 255, 192, 192, 192, 8
    EXECUTE_SUBROUTINE .play_wave_then_spawn_butterfly

.branch_113B0C:
    UPDATE_GLOBAL_RGBA 255, 192, 192, 192, 8
    EXECUTE_SUBROUTINE .play_wave_then_spawn_butterfly

.branch_113B18:
    BRANCH_U8_VAR_WITHIN_RANGE 0, 4, gHour, .branch_113B70
    BRANCH_U8_VAR_WITHIN_RANGE 5, 7, gHour, .branch_113B7C
    BRANCH_U8_VAR_WITHIN_RANGE 8, 11, gHour, .branch_113B88
    BRANCH_U8_VAR_WITHIN_RANGE 12, 15, gHour, .branch_113B94
    BRANCH_U8_VAR_WITHIN_RANGE 16, 17, gHour, .branch_113B88
    BRANCH_U8_VAR_WITHIN_RANGE 18, 19, gHour, .branch_113B7C
    BRANCH_U8_VAR_WITHIN_RANGE 20, 23, gHour, .branch_113B70
    EXECUTE_SUBROUTINE .play_wave_then_spawn_butterfly

.branch_113B70:
    UPDATE_GLOBAL_RGBA 80, 80, 128, 80, 8
    EXECUTE_SUBROUTINE .play_wave_then_spawn_butterfly

.branch_113B7C:
    UPDATE_GLOBAL_RGBA 112, 112, 192, 112, 8
    EXECUTE_SUBROUTINE .play_wave_then_spawn_butterfly

.branch_113B88:
    UPDATE_GLOBAL_RGBA 128, 128, 208, 128, 8
    EXECUTE_SUBROUTINE .play_wave_then_spawn_butterfly

.branch_113B94:
    UPDATE_GLOBAL_RGBA 144, 144, 255, 144, 8
    EXECUTE_SUBROUTINE .play_wave_then_spawn_butterfly

.executor_player_entity_338:
    EXECUTE_SUBROUTINE .setup_player_entity
    TOGGLE_PAUSE_ENTITY 0
    SET_COORDINATES -240, 0, -90
    SET_ASSET_ROTATION 2
    SET_WAIT_FRAMES 15
    EXECUTE_SUBROUTINE .apply_time_weather_tint_338

.play_wave_then_spawn_butterfly:
    WAIT_RGBA_FINISHED
    SET_WAIT_FRAMES 15
    SET_ENTITY_DIRECTIONAL_ANIMATION 456
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SPAWN_EXECUTOR 5, .executor_white_butterfly_338
    PAUSE_ENTITY 0
    SET_ENTITY_MAP_SPACE_INDEPENDENT FALSE
    DEACTIVATE_SELF

.executor_white_butterfly_338:
    SETUP_ENTITY 19, ENTITY_ASSET_WHITE_BUTTERFLY, 1
    SET_ENTITY_ANIMATIONS 19, 0, 0, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_PHYSICS_FLAGS 0
    SET_COORDINATES -272, 160, -90
    SET_ENTITY_ANIMATION 2
    SET_FRAME_DELTA -1, 1, 2, 64
    SET_OTHER_EXECUTOR_PTR 1, .stu_farewell_butterfly_338
    DEACTIVATE_SELF

.stu_farewell_butterfly_338:
    SET_ENTITY_ANIMATION 33
    WAIT_ENTITY_ANIMATION
    ; Stu: bye-bye Mr butterfly, be careful
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 174
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 2, .may_walk_off_save_338
    ENTITY_WALK 144, DIRECTION_S, 2
    TOGGLE_PAUSE_ENTITY 0
    EXECUTE_SUBROUTINE .end_cutscene

.may_walk_off_save_338:
    ENTITY_WALK 144, DIRECTION_S, 2
    DEACTIVATE_SELF

.choice_leave_butterfly_338:
    UPDATE_U8_VALUE 5, 255, npcAffection[MAY]
    ; May: Really?
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 175
    WAIT_MESSAGE_BOX_CLOSED 0
    ; Stu: thats so cruel
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 176
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 1, .stu_walk_off_leave_338
    SET_WAIT_FRAMES 32
    ; May: Im going home too
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 177
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 2, .may_walk_off_leave_338
    DEACTIVATE_SELF

.stu_walk_off_leave_338:
    ENTITY_WALK 128, DIRECTION_S, 2
    DEACTIVATE_SELF

.may_walk_off_leave_338:
    ENTITY_WALK 130, DIRECTION_S, 2
    TOGGLE_PAUSE_ENTITY 0
    EXECUTE_SUBROUTINE .end_cutscene

.show_text_81_centered:
    SET_MESSAGE_INTERPOLATION -4, 0, 0
    SET_MESSAGE_BOX_ASSETS 0, 1, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 0, -64, 352
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 81
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_WAIT_FRAMES 30
    RETURN_FROM_SUBROUTINE

; ============================================
; Cutscene 339 (Moon Mountain hot spring discovery)
; Polls for level interaction 18; shows texts 179, 180, 181 (hot spring).
; ============================================

.cutscene_339_entry:
    SET_SPECIAL_BIT 9, gCutsceneCompletionFlags

.wait_interaction_18_339:
    SET_WAIT_FRAMES 1
    BRANCH_U8_VAR_WITHIN_RANGE 18, 18, interactedWithLevelInteractionIndex, .on_interaction_18_339
    EXECUTE_SUBROUTINE .wait_interaction_18_339

.on_interaction_18_339:
    PAUSE_ENTITY 0
    EXECUTE_SUBROUTINE .show_text_81_centered
    ; So this is the wonderful, hidden Moon mountain hot spring!
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 179
    WAIT_MESSAGE_BOX_CLOSED 0
    ; This is the best
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 180
    WAIT_MESSAGE_BOX_CLOSED 0
    ; This feels so good
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 181
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_MESSAGE_BOX_ASSETS 0, 0, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 24, -64, 256
    TOGGLE_PAUSE_ENTITY 0
    EXECUTE_SUBROUTINE .wait_interaction_18_339

; ============================================
; Cutscene 340 (Hot spring relaxing/revived reaction)
; Polls for level interaction 18; shows texts 182, 183.
; ============================================

.cutscene_340_entry:
    SET_SPECIAL_BIT 9, gCutsceneCompletionFlags

.wait_interaction_18_340:
    SET_WAIT_FRAMES 1
    BRANCH_U8_VAR_WITHIN_RANGE 18, 18, interactedWithLevelInteractionIndex, .on_interaction_18_340
    EXECUTE_SUBROUTINE .wait_interaction_18_340

.on_interaction_18_340:
    PAUSE_ENTITY 0
    EXECUTE_SUBROUTINE .show_text_81_centered
    ; This is so relaxing...
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 182
    WAIT_MESSAGE_BOX_CLOSED 0
    ; I feel revived...
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 183
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_MESSAGE_BOX_ASSETS 0, 0, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 24, -64, 256
    TOGGLE_PAUSE_ENTITY 0
    EXECUTE_SUBROUTINE .wait_interaction_18_340



; ============================================
; Cutscene 341 (Harvest Goddess offering menu)
; 4-option dialogue (DIALOGUE_TEXT_54, 9):
;   0 = weather wish       (sets lifeEventBits[2] bit 4)
;   1 = stamina wish       (daily refill OR one-time Power Nut bit 6)
;   2 = worship             (random +1 affection among 5 bachelorettes)
;   3 = just wanted to see   (no effect)
; Repeat visits on the same day skip straight to the short greeting.
; ============================================

.setup_harvest_goddess:
    SETUP_ENTITY 37, ENTITY_ASSET_HARVEST_GODDESS, 1
    SET_ENTITY_ANIMATIONS 37, 0, 0, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_PHYSICS_FLAGS 0
    RETURN_FROM_SUBROUTINE

.cutscene_341_entry:
    PAUSE_ENTITY 0
    EXECUTE_SUBROUTINE .setup_harvest_goddess
    SET_COORDINATES -32, 0, -224
    SET_ENTITY_ANIMATION 0
    SET_FRAME_DELTA 0, 1, 0, 112
    BRANCH_ON_SPECIAL_BIT 9, D_80237A00, .hg_already_greeted_today
    SET_SPECIAL_BIT 9, D_80237A00
    ; Harvest Goddess: An offering? Whats your wish?
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 204

.hg_prompt_offering:
    WAIT_MESSAGE_BOX_CLOSED 0
    INIT_DIALOGUE_SESSION 0, DIALOGUE_TEXT_54, 9
    WAIT_FOR_DIALOGUE_INPUT 0
    BRANCH_ON_DIALOGUE 0, 0, .hg_option_weather_wish
    BRANCH_ON_DIALOGUE 0, 1, .hg_option_stamina_wish
    BRANCH_ON_DIALOGUE 0, 2, .hg_option_worship_random
    BRANCH_ON_DIALOGUE 0, 3, .hg_option_just_visiting

.hg_option_weather_wish:
    ; set WEATHER_WISH bit to get alternate forecast weights
    SET_SPECIAL_BIT 4, lifeEventBits[2]
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 207
    EXECUTE_SUBROUTINE .hg_close_and_end

.hg_option_stamina_wish:
    BRANCH_IF_U8_PTR_RANGE gPlayer.currentStamina, gMaximumStamina, gMaximumStamina, .hg_stamina_full_check_power_nut

.hg_grant_stamina_refill:
    ; set HARVEST_GODDESS_STAMINA_WISH_DAILY
    SET_SPECIAL_BIT 11, dailyEventBits[1]
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 207
    EXECUTE_SUBROUTINE .hg_close_and_end

.hg_stamina_full_check_power_nut:
    BRANCH_ON_SPECIAL_BIT 6, acquiredPowerNutBits, .hg_grant_stamina_refill
    ; Harvest Goddess: youre full of energy; Ill give you something else
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 250
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SPAWN_EXECUTOR 1, .hg_grant_power_nut
    EXECUTE_SUBROUTINE .idle

.hg_grant_power_nut:
    TOGGLE_PAUSE_ENTITY 0
    EXECUTE_SUBROUTINE .setup_player_entity
    EXECUTE_SUBROUTINE .sub_113618
    SET_SPECIAL_BIT 6, acquiredPowerNutBits
    UPDATE_U8_VALUE 15, 250, gMaximumStamina
    UPDATE_U8_VALUE 2, 255, gHappiness
    SET_ASSET_ROTATION 0
    SET_OTHER_EXECUTOR_PTR 10, .executor_10_10FED0
    SET_ENTITY_DIRECTIONAL_ANIMATION 24
    SET_WAIT_FRAMES 16
    SET_ENTITY_ANIMATION 437
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SET_OTHER_EXECUTOR_PTR 0, .hg_post_powernut_farewell
    SET_ENTITY_MAP_SPACE_INDEPENDENT FALSE
    PAUSE_ENTITY 0
    DEACTIVATE_SELF

.hg_option_worship_random:
    BRANCH_ON_RANDOM 0, 20, .hg_random_maria
    BRANCH_ON_RANDOM 21, 40, .hg_random_popuri
    BRANCH_ON_RANDOM 41, 60, .hg_random_elli
    BRANCH_ON_RANDOM 61, 80, .hg_random_ann
    BRANCH_ON_RANDOM 81, 100, .hg_random_karen

.hg_random_maria:
    UPDATE_U8_VALUE 1, 255, npcAffection[MARIA]
    EXECUTE_SUBROUTINE .hg_show_wish_heard

.hg_random_popuri:
    UPDATE_U8_VALUE 1, 255, npcAffection[POPURI]
    EXECUTE_SUBROUTINE .hg_show_wish_heard

.hg_random_elli:
    UPDATE_U8_VALUE 1, 255, npcAffection[ELLI]
    EXECUTE_SUBROUTINE .hg_show_wish_heard

.hg_random_ann:
    UPDATE_U8_VALUE 1, 255, npcAffection[ANN]
    EXECUTE_SUBROUTINE .hg_show_wish_heard

.hg_random_karen:
    UPDATE_U8_VALUE 1, 255, npcAffection[KAREN]
    EXECUTE_SUBROUTINE .hg_show_wish_heard

.hg_show_wish_heard:
    ; Harvest Goddess: OK, I hear your wish (worship reply)
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 207
    EXECUTE_SUBROUTINE .hg_close_and_end

.hg_close_and_end:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_FRAME_DELTA 0, -1, 0, 112
    TOGGLE_PAUSE_ENTITY 0
    EXECUTE_SUBROUTINE .end_cutscene

.hg_post_powernut_farewell:
    ; Harvest Goddess: Well, see you later
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 251
    EXECUTE_SUBROUTINE .hg_close_and_end

.hg_option_just_visiting:
    ; Harvest Goddess: Oh really, you just wanted to see me
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 208
    EXECUTE_SUBROUTINE .hg_close_and_end

.hg_already_greeted_today:
    ; Harvest Goddess: Hello, how are you (repeat-visit greeting)
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 205
    EXECUTE_SUBROUTINE .hg_prompt_offering

; ============================================
; Cutscene 342 (Popuri confession - Button A talk)
; Multi-level DIALOGUE_TEXT_54 menu; accept path plays hug anims and
; text 194/195 (+10 happiness), reject path reads entity-37 facing to
; mirror Popuris rotation then text 191/193 farewell. Tease-out paths
; rearm the A-button loop. Note: text 188/189 have MARIA_9 avatar tags
; despite Popuri driving the scene - likely a generic portrait reuse.
; ============================================

.cutscene_342_entry:
    SPAWN_EXECUTOR 1, .executor_popuri_342
    DEACTIVATE_SELF

.executor_popuri_342:
    EXECUTE_SUBROUTINE .setup_popuri
    SET_COORDINATES -88, 0, -168
    SET_ASSET_ROTATION 2
    SET_CALLBACK_ROUTINE 0, BUTTON_A, .popuri_on_interact_342
    EXECUTE_SUBROUTINE .idle

.popuri_on_interact_342:
    EXECUTE_SUBROUTINE .setup_message_box
    ; +10 happiness for talking to Popuri
    UPDATE_U8_VALUE 10, 255, gHappiness
    PAUSE_ENTITY 0
    FLIP_ENTITY_DIRECTION 0
    ; top-level yes/no prompt
    INIT_DIALOGUE_SESSION 0, DIALOGUE_TEXT_54, 4
    WAIT_FOR_DIALOGUE_INPUT 0
    BRANCH_ON_DIALOGUE 0, 0, .popuri_menu_level_2_342
    BRANCH_ON_DIALOGUE 0, 1, .popuri_tease_refuse_342

.popuri_tease_refuse_342:
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 188
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITY 0

.popuri_idle_awaiting_a_342:
    SET_CALLBACK_ROUTINE 0, BUTTON_A, .popuri_tease_silence_342
    EXECUTE_SUBROUTINE .idle

.popuri_tease_silence_342:
    EXECUTE_SUBROUTINE .setup_message_box
    PAUSE_ENTITY 0
    FLIP_ENTITY_DIRECTION 0
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 189
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITY 0
    EXECUTE_SUBROUTINE .popuri_idle_awaiting_a_342

.popuri_menu_level_2_342:
    INIT_DIALOGUE_SESSION 0, DIALOGUE_TEXT_54, 5
    WAIT_FOR_DIALOGUE_INPUT 0
    BRANCH_ON_DIALOGUE 0, 0, .popuri_menu_confession_342
    BRANCH_ON_DIALOGUE 0, 1, .popuri_tease_refuse_342

.popuri_menu_confession_342:
    INIT_DIALOGUE_SESSION 0, DIALOGUE_TEXT_54, 6
    WAIT_FOR_DIALOGUE_INPUT 0
    BRANCH_ON_DIALOGUE 0, 0, .popuri_reject_dispatch_342
    BRANCH_ON_DIALOGUE 0, 1, .popuri_confession_accept_342
    BRANCH_ON_DIALOGUE 0, 2, .popuri_reject_dispatch_342
    BRANCH_ON_DIALOGUE 0, 3, .popuri_reject_dispatch_342
    BRANCH_ON_DIALOGUE 0, 4, .popuri_reject_dispatch_342
    BRANCH_ON_DIALOGUE 0, 5, .popuri_tease_refuse_342

.popuri_confession_accept_342:
    ; Popuri: Really? You promise? Im so happy!
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 194
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    ENTITY_WALK 32, DIRECTION_E, 2
    SET_ENTITY_ANIMATION 58
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_ANIMATION 59
    SPAWN_EXECUTOR 7, .executor_player_entity_315
    EXECUTE_SUBROUTINE .popuri_say_like_you_too_342
    SET_ENTITY_ANIMATION 58
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    ENTITY_WALK 128, DIRECTION_S, 2
    TOGGLE_PAUSE_ENTITY 0
    SET_OTHER_EXECUTOR_PTR 7, .deactivate_executor_player
    EXECUTE_SUBROUTINE .end_cutscene
    EXECUTE_SUBROUTINE .setup_player_entity
    SET_ASSET_ROTATION 0
    EXECUTE_SUBROUTINE .idle

.popuri_say_like_you_too_342:
    ; Popuri: I like you too
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 195
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    RETURN_FROM_SUBROUTINE

.popuri_reject_dispatch_342:
    BRANCH_ON_ENTITY_DIR 37, DIRECTION_N, .popuri_reject_dir_NE
    BRANCH_ON_ENTITY_DIR 37, DIRECTION_NE, .popuri_reject_dir_E
    BRANCH_ON_ENTITY_DIR 37, DIRECTION_E, .popuri_reject_dir_SE
    BRANCH_ON_ENTITY_DIR 37, DIRECTION_SE, .popuri_reject_dir_S
    BRANCH_ON_ENTITY_DIR 37, DIRECTION_S, .popuri_reject_dir_SW
    BRANCH_ON_ENTITY_DIR 37, DIRECTION_SW, .popuri_reject_dir_W
    BRANCH_ON_ENTITY_DIR 37, DIRECTION_W, .popuri_reject_dir_NW
    BRANCH_ON_ENTITY_DIR 37, DIRECTION_NW, .popuri_reject_dir_N
    EXECUTE_SUBROUTINE .idle

.popuri_say_reject_soft_342:
    ; Popuri: I liked you; Ill try to forget
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 191
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    RETURN_FROM_SUBROUTINE

.popuri_reject_dir_NE:
    SET_ASSET_ROTATION 0
    EXECUTE_SUBROUTINE .popuri_say_reject_soft_342
    EXECUTE_SUBROUTINE .popuri_reject_walk_farewell_342

.popuri_reject_dir_E:
    SET_ASSET_ROTATION 1
    EXECUTE_SUBROUTINE .popuri_say_reject_soft_342
    EXECUTE_SUBROUTINE .popuri_reject_walk_farewell_342

.popuri_reject_dir_SE:
    SET_ASSET_ROTATION 2
    EXECUTE_SUBROUTINE .popuri_say_reject_soft_342
    EXECUTE_SUBROUTINE .popuri_reject_walk_farewell_342

.popuri_reject_dir_S:
    SET_ASSET_ROTATION 3
    EXECUTE_SUBROUTINE .popuri_say_reject_soft_342
    EXECUTE_SUBROUTINE .popuri_reject_walk_farewell_342

.popuri_reject_dir_SW:
    SET_ASSET_ROTATION 4
    EXECUTE_SUBROUTINE .popuri_say_reject_soft_342
    EXECUTE_SUBROUTINE .popuri_reject_walk_farewell_342

.popuri_reject_dir_W:
    SET_ASSET_ROTATION 5
    EXECUTE_SUBROUTINE .popuri_say_reject_soft_342

.popuri_reject_walk_farewell_342:
    ENTITY_WALK 32, DIRECTION_E, 2
    SPAWN_EXECUTOR 7, .executor_player_entity_315
    SET_ENTITY_ANIMATION 36
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_ANIMATION 40
    ; Popuri: good luck in love
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 193
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_ENTITY_ANIMATION 36
    WAIT_ENTITY_ANIMATION
    SET_ASSET_ROTATION 2
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SET_WAIT_FRAMES 15
    ENTITY_WALK 128, DIRECTION_S, 2
    TOGGLE_PAUSE_ENTITY 0
    SET_OTHER_EXECUTOR_PTR 7, .deactivate_executor_player
    EXECUTE_SUBROUTINE .end_cutscene

.popuri_reject_dir_NW:
    SET_ASSET_ROTATION 6
    EXECUTE_SUBROUTINE .popuri_say_reject_soft_342
    EXECUTE_SUBROUTINE .popuri_reject_walk_farewell_342

.popuri_reject_dir_N:
    SET_ASSET_ROTATION 7
    EXECUTE_SUBROUTINE .popuri_say_reject_soft_342
    EXECUTE_SUBROUTINE .popuri_reject_walk_farewell_342

; ============================================
; Cutscene 343 (Carrying Elli - parallel of 302 with Elli instead of Popuri)
; A-press (empty hands) opens DIALOGUE_TEXT_54 index 7. Choice 0: +10 Elli,
; player carries her (text 198), sets gCutsceneCompletionFlags bit 30.
; Choice 1: -30 Elli / +20 Jeff; Jeff appears (texts 199-201), Jeff carries
; her, bit 30 cleared. Time/weather tint handled by .apply_time_weather_tint_343.
; ============================================

.cutscene_343_entry:
    SPAWN_EXECUTOR 1, .executor_elli_343
    DEACTIVATE_SELF

.executor_elli_343:
    EXECUTE_SUBROUTINE .setup_elli
    SET_COORDINATES -160, 0, 16
    SET_ASSET_ROTATION 0
    SET_ENTITY_ANIMATION 33
    UPDATE_RGBA 254, 254, 254, 254, 0
    WAIT_RGBA_FINISHED

.elli_343_wait:
    SET_CALLBACK_ROUTINE 0, BUTTON_A, .elli_343_on_interact
    EXECUTE_SUBROUTINE .idle

.elli_343_on_interact:
    EXECUTE_SUBROUTINE .setup_message_box
    BRANCH_U8_VAR_WITHIN_RANGE 0, 254, gItemBeingHeld, .elli_343_wait
    PAUSE_ENTITIES
    INIT_DIALOGUE_SESSION 0, DIALOGUE_TEXT_54, 7
    WAIT_FOR_DIALOGUE_INPUT 0
    BRANCH_ON_DIALOGUE 0, 0, .elli_343_choice_carry
    BRANCH_ON_DIALOGUE 0, 1, .elli_343_choice_jeff_carries

.elli_343_choice_carry:
    UPDATE_U8_VALUE 10, 255, npcAffection[ELLI]
    SPAWN_EXECUTOR 7, .executor_player_entity_343
    EXECUTE_SUBROUTINE .idle

.executor_player_entity_343:
    EXECUTE_SUBROUTINE .setup_player_entity
    TOGGLE_PAUSE_ENTITIES
    SET_ENTITY_DIRECTIONAL_ANIMATION 429
    WAIT_ENTITY_ANIMATION
    SET_HOLDING_ANIMATION_FLAG TRUE
    SET_OTHER_EXECUTOR_PTR 1, .player_carry_pose_343
    SET_WAIT_FRAMES 1
    SET_ASSET_ROTATION 6
    SET_ENTITY_DIRECTIONAL_ANIMATION 24
    SET_WAIT_FRAMES 15
    SPAWN_EXECUTOR 5, .executor_5_10FD34
    ; Elli: No really, Im alright..... Im heavy...
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 198
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    ENTITY_WALK 63, DIRECTION_E, 2
    SET_OTHER_EXECUTOR_PTR 1, .elli_carried_pose_player_343
    ENTITY_WALK 1, DIRECTION_E, 2
    ENTITY_WALK 48, DIRECTION_S, 2
    SET_AUDIO_SEQUENCE_VOLUME 0, 0, 8
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    ENTITY_WALK 48, DIRECTION_S, 2
    WAIT_RGBA_FINISHED
    STOP_SEQUENCE_WITH_FADE 0, 1
    DEACTIVATE_EXECUTOR 1
    SET_HOLDING_ANIMATION_FLAG FALSE
    IDLE_WHILE_SEQUENCE_PLAYING 0
    SET_SPECIAL_BIT 30, gCutsceneCompletionFlags
    EXECUTE_SUBROUTINE .end_cutscene

.player_carry_pose_343:
    SET_ENTITY_TRACKING_TARGET 0, 0, 19, 17, 255
    SET_ENTITY_ANIMATION 46
    EXECUTE_SUBROUTINE .idle

.elli_carried_pose_player_343:
    SET_ENTITY_TRACKING_TARGET 0, 0, 19, 17, 255
    SET_ENTITY_ANIMATION 47
    EXECUTE_SUBROUTINE .idle

.apply_time_weather_tint_343:
    BRANCH_U8_VAR_WITHIN_RANGE 2, 2, gWeather, .branch_1144BC
    BRANCH_U8_VAR_WITHIN_RANGE 0, 4, gHour, .branch_114450
    BRANCH_U8_VAR_WITHIN_RANGE 5, 5, gHour, .branch_11445C
    BRANCH_U8_VAR_WITHIN_RANGE 6, 7, gHour, .branch_114468
    BRANCH_U8_VAR_WITHIN_RANGE 8, 11, gHour, .branch_114474
    BRANCH_U8_VAR_WITHIN_RANGE 12, 15, gHour, .branch_114480
    BRANCH_U8_VAR_WITHIN_RANGE 16, 16, gHour, .branch_11448C
    BRANCH_U8_VAR_WITHIN_RANGE 17, 17, gHour, .branch_114498
    BRANCH_U8_VAR_WITHIN_RANGE 18, 19, gHour, .branch_11445C
    BRANCH_U8_VAR_WITHIN_RANGE 20, 23, gHour, .branch_114450
    EXECUTE_SUBROUTINE .finish_lighting_fade_343

.branch_114450:
    UPDATE_GLOBAL_RGBA 80, 80, 80, 80, 8
    EXECUTE_SUBROUTINE .finish_lighting_fade_343

.branch_11445C:
    UPDATE_GLOBAL_RGBA 128, 128, 128, 128, 8
    EXECUTE_SUBROUTINE .finish_lighting_fade_343

.branch_114468:
    UPDATE_GLOBAL_RGBA 192, 192, 192, 192, 8
    EXECUTE_SUBROUTINE .finish_lighting_fade_343

.branch_114474:
    UPDATE_GLOBAL_RGBA 224, 224, 224, 224, 8
    EXECUTE_SUBROUTINE .finish_lighting_fade_343

.branch_114480:
    UPDATE_GLOBAL_RGBA 255, 255, 255, 255, 8
    EXECUTE_SUBROUTINE .finish_lighting_fade_343

.branch_11448C:
    UPDATE_GLOBAL_RGBA 255, 224, 224, 224, 8
    EXECUTE_SUBROUTINE .finish_lighting_fade_343

.branch_114498:
    BRANCH_U8_VAR_WITHIN_RANGE 3, 3, gWeather, .branch_1144B0
    UPDATE_GLOBAL_RGBA 255, 192, 192, 192, 8
    EXECUTE_SUBROUTINE .finish_lighting_fade_343

.branch_1144B0:
    UPDATE_GLOBAL_RGBA 192, 192, 192, 192, 8
    EXECUTE_SUBROUTINE .finish_lighting_fade_343

.branch_1144BC:
    BRANCH_U8_VAR_WITHIN_RANGE 0, 4, gHour, .branch_114514
    BRANCH_U8_VAR_WITHIN_RANGE 5, 7, gHour, .branch_114520
    BRANCH_U8_VAR_WITHIN_RANGE 8, 11, gHour, .branch_11452C
    BRANCH_U8_VAR_WITHIN_RANGE 12, 15, gHour, .branch_114538
    BRANCH_U8_VAR_WITHIN_RANGE 16, 17, gHour, .branch_11452C
    BRANCH_U8_VAR_WITHIN_RANGE 18, 19, gHour, .branch_114520
    BRANCH_U8_VAR_WITHIN_RANGE 20, 23, gHour, .branch_114514
    EXECUTE_SUBROUTINE .finish_lighting_fade_343

.branch_114514:
    UPDATE_GLOBAL_RGBA 80, 80, 128, 80, 8
    EXECUTE_SUBROUTINE .finish_lighting_fade_343

.branch_114520:
    UPDATE_GLOBAL_RGBA 112, 112, 192, 112, 8
    EXECUTE_SUBROUTINE .finish_lighting_fade_343

.branch_11452C:
    UPDATE_GLOBAL_RGBA 128, 128, 208, 128, 8
    EXECUTE_SUBROUTINE .finish_lighting_fade_343

.branch_114538:
    UPDATE_GLOBAL_RGBA 144, 144, 255, 144, 8
    EXECUTE_SUBROUTINE .finish_lighting_fade_343

.elli_343_choice_jeff_carries:
    UPDATE_U8_VALUE -30, 255, npcAffection[ELLI]
    UPDATE_U8_VALUE 20, 255, npcAffection[JEFF]
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    SPAWN_EXECUTOR 2, .executor_jeff_343
    SPAWN_EXECUTOR 7, .executor_player_entity_343_2
    SET_WAIT_FRAMES 15
    EXECUTE_SUBROUTINE .apply_time_weather_tint_343

.finish_lighting_fade_343:
    WAIT_RGBA_FINISHED
    SET_WAIT_FRAMES 15
    SET_OTHER_EXECUTOR_PTR 2, .jeff_343_script
    EXECUTE_SUBROUTINE .idle

.executor_jeff_343:
    EXECUTE_SUBROUTINE .setup_jeff
    SET_COORDINATES -160, 0, 0
    SET_ASSET_ROTATION 0
    EXECUTE_SUBROUTINE .idle

.jeff_343_script:
    SET_ENTITY_ANIMATION 24
    SET_WAIT_FRAMES 15
    SET_OTHER_EXECUTOR_PTR 1, .elli_carried_pose_jeff_343
    SET_WAIT_FRAMES 1
    SET_ENTITY_ANIMATION 28
    SET_WAIT_FRAMES 15
    SPAWN_EXECUTOR 5, .executor_5_10FD50
    ; Elli: Oh Master... I must be heavy
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 199
    WAIT_MESSAGE_BOX_CLOSED 0
    ; Jeff: Yes, youve gotten much heavier.
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 200
    WAIT_MESSAGE_BOX_CLOSED 0
    SPAWN_EXECUTOR 5, .executor_5_10FD6C
    ; Jeff: I mean since you were a little girl!
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 201
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 1, .jeff_carry_pose_343
    SET_WAIT_FRAMES 1
    SET_ASSET_ROTATION 6
    SET_ENTITY_ANIMATION 35
    SET_FRAME_DELTA 2, 0, 0, 63
    SET_OTHER_EXECUTOR_PTR 1, .elli_carried_pose_jeff_343
    SET_FRAME_DELTA 2, 0, 0, 1
    SET_ASSET_ROTATION 0
    SET_ENTITY_ANIMATION 32
    SET_FRAME_DELTA 0, 0, 2, 160
    CLEAR_SPECIAL_BIT 30, gCutsceneCompletionFlags
    DEACTIVATE_EXECUTOR 1
    SET_OTHER_EXECUTOR_PTR 7, .deactivate_executor_player
    EXECUTE_SUBROUTINE .end_cutscene

.jeff_carry_pose_343:
    SET_ENTITY_TRACKING_TARGET 36, 0, 19, 17, 255
    SET_ENTITY_ANIMATION 46
    EXECUTE_SUBROUTINE .idle

.elli_carried_pose_jeff_343:
    SET_ENTITY_TRACKING_TARGET 36, 0, 19, 17, 255
    SET_ENTITY_ANIMATION 47
    EXECUTE_SUBROUTINE .idle

.executor_player_entity_343_2:
    EXECUTE_SUBROUTINE .setup_player_entity
    TOGGLE_PAUSE_ENTITIES
    SET_COORDINATES -160, 0, 64
    SET_ASSET_ROTATION 4
    EXECUTE_SUBROUTINE .idle

; ============================================
; Cutscene 344 (Harvest Goddess grapevine offering prompt)
; First visit: text 204 offering greeting + yes/no on waking vineyard spirit.
; Accept: text 212, fade, time jumps to 19:00, sets completion bit 1.
; Decline: text 213. Repeat visit: text 210 greeting then re-enters menu.
; ============================================

.cutscene_344_entry:
    PAUSE_ENTITY 0
    EXECUTE_SUBROUTINE .setup_harvest_goddess
    SET_COORDINATES -32, 0, -224
    SET_ENTITY_ANIMATION 0
    SET_FRAME_DELTA 0, 1, 0, 112
    BRANCH_ON_SPECIAL_BIT 9, D_80237A00, .hg_344_greet_returning
    SET_SPECIAL_BIT 9, D_80237A00
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 204

.hg_344_offering_menu:
    WAIT_MESSAGE_BOX_CLOSED 0
    INIT_DIALOGUE_SESSION 0, DIALOGUE_TEXT_54, 10
    WAIT_FOR_DIALOGUE_INPUT 0
    BRANCH_ON_DIALOGUE 0, 0, .hg_344_accept_wish
    BRANCH_ON_DIALOGUE 0, 1, .hg_344_decline_wish

.hg_344_accept_wish:
    ; Harvest Goddess: go wake the spirit of the grapevine at the vineyard
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 212
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    TOGGLE_PAUSE_ENTITY 0
    ; jump time to 19:00
    SET_U8_VALUE 19, gHour
    SET_U8_VALUE 0, gMinutes
    SET_SPECIAL_BIT 1, gCutsceneCompletionFlags
    EXECUTE_SUBROUTINE .end_cutscene

.hg_344_decline_wish:
    ; Harvest Goddess: Really? Maybe later.
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 213
    EXECUTE_SUBROUTINE .hg_close_and_end

.hg_344_greet_returning:
    ; Harvest Goddess: (returning-visitor greeting)
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 210
    EXECUTE_SUBROUTINE .hg_344_offering_menu

; ============================================
; Cutscene 345 (Harvest Goddess awakens sleeper)
; HG prays (text 214); player plays bell/ring animation sequence pulsing
; bits 6/7 of gCutsceneCompletionFlags; sleeper responds (texts 215/216/217).
; Screen fades, KAREN and KAI each get +8 affection.
; ============================================

.cutscene_345_entry:
    SPAWN_EXECUTOR 1, .harvest_goddess_setup_345
    EXECUTE_SUBROUTINE .setup_player_entity
    SET_COORDINATES -384, 0, -272
    SET_ASSET_ROTATION 4
    SET_BEHAVIOR_FLAGS 0
    SPAWN_EXECUTOR 41, .main_director_345
    EXECUTE_SUBROUTINE .idle

.harvest_goddess_setup_345:
    EXECUTE_SUBROUTINE .setup_harvest_goddess
    SET_COORDINATES -336, 128, -336
    SET_ENTITY_ANIMATION 0
    EXECUTE_SUBROUTINE .idle

.harvest_goddess_anim_1_345:
    SET_ENTITY_ANIMATION 1
    EXECUTE_SUBROUTINE .idle

.harvest_goddess_anim_0_8_10_345:
    SET_ENTITY_ANIMATION 0
    SET_WAIT_FRAMES 5
    SET_ENTITY_ANIMATION 8
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_ANIMATION 10
    EXECUTE_SUBROUTINE .idle

.main_director_345:
    SETUP_MAP_ASSET MAIN_MAP_INDEX
    SET_ASSET_ROTATION 7
    SET_COORDINATES -352, 128, -288
    UPDATE_GLOBAL_RGBA 254, 254, 254, 254, 0
    WAIT_RGBA_FINISHED
    SET_WAIT_FRAMES 10
    ; Harvest Goddess: Speak with your heart, pray in your heart
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 214
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 0, .player_ritual_sequence_345
    SET_OTHER_EXECUTOR_PTR 1, .harvest_goddess_anim_1_345
    EXECUTE_SUBROUTINE .idle

.player_ritual_sequence_345:
    SET_ENTITY_ANIMATION 499
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_ANIMATION 505
    SET_WAIT_FRAMES 30
    SET_ENTITY_ANIMATION 499
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SET_ENTITY_DIRECTIONAL_ANIMATION 439
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 447
    SET_WAIT_FRAMES 60
    SET_SPECIAL_BIT 7, gCutsceneCompletionFlags
    SET_WAIT_FRAMES 5
    SET_SPECIAL_BIT 6, gCutsceneCompletionFlags
    SET_WAIT_FRAMES 30
    SET_SPECIAL_BIT 7, gCutsceneCompletionFlags
    SET_WAIT_FRAMES 5
    SET_SPECIAL_BIT 6, gCutsceneCompletionFlags
    SET_WAIT_FRAMES 30
    SET_SPECIAL_BIT 7, gCutsceneCompletionFlags
    SET_WAIT_FRAMES 5
    SET_SPECIAL_BIT 6, gCutsceneCompletionFlags
    SET_WAIT_FRAMES 20
    SET_SPECIAL_BIT 7, gCutsceneCompletionFlags
    SET_WAIT_FRAMES 5
    SET_SPECIAL_BIT 6, gCutsceneCompletionFlags
    SET_WAIT_FRAMES 10
    SET_SPECIAL_BIT 7, gCutsceneCompletionFlags
    SET_WAIT_FRAMES 5
    SET_SPECIAL_BIT 6, gCutsceneCompletionFlags
    SET_WAIT_FRAMES 5
    SET_SPECIAL_BIT 7, gCutsceneCompletionFlags
    SET_ENTITY_DIRECTIONAL_ANIMATION 439
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SET_WAIT_FRAMES 20
    EXECUTE_SUBROUTINE .setup_message_box_2
    ; tree: Who dares disturb my sleep? I was having a good dream.
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 215
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_WAIT_FRAMES 20
    EXECUTE_SUBROUTINE .setup_message_box
    ; Harvest Goddess: Twenty years asleep, listen to him
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 216
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_WAIT_FRAMES 20
    EXECUTE_SUBROUTINE .setup_message_box_2
    ; sleeper: Understood, Ill fetch the fairies
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 217
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_WAIT_FRAMES 20
    SET_OTHER_EXECUTOR_PTR 1, .harvest_goddess_anim_0_8_10_345
    SET_WAIT_FRAMES 20
    SET_ENTITY_ANIMATION 487
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SET_WAIT_FRAMES 10
    SET_AUDIO_SEQUENCE_VOLUME 0, 0, 8
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    STOP_SEQUENCE_WITH_FADE 0, 1
    DEACTIVATE_EXECUTOR 1
    SET_BEHAVIOR_FLAGS CUTSCENE_ASSET_BEHAVIOR_TRACK_ENTITY
    IDLE_WHILE_SEQUENCE_PLAYING 0
    ; +8 KAREN and KAI affection (Kai-related awakening reward)
    UPDATE_U8_VALUE 8, 255, npcAffection[KAREN]
    UPDATE_U8_VALUE 8, 255, npcAffection[KAI]
    EXECUTE_SUBROUTINE .end_cutscene

; ============================================
; Cutscene 346 (Assistant Carpenter job prompt)
; A-press (empty hands) opens DIALOGUE_TEXT_54 idx 14. Yes: text 254,
; fade to black, set completion bit 1. No: text 255. Outside 6:00-16:59:
; text 257 (closing time) or on day 30, text 258 (end of year).
; ============================================

.cutscene_346_entry:
    SPAWN_EXECUTOR 1, .executor_asst_carp_346
    DEACTIVATE_SELF

.executor_asst_carp_346:
    EXECUTE_SUBROUTINE .setup_assistant_carpenter_e37
    SET_COORDINATES -320, 0, -120
    SET_ASSET_ROTATION 6

.asst_carp_346_wait:
    SET_CALLBACK_ROUTINE 0, BUTTON_A, .asst_carp_346_on_interact
    EXECUTE_SUBROUTINE .idle

.asst_carp_346_on_interact:
    BRANCH_U8_VAR_WITHIN_RANGE 0, 254, gItemBeingHeld, .asst_carp_346_wait
    PAUSE_ENTITIES
    FLIP_ENTITY_DIRECTION 0
    EXECUTE_SUBROUTINE .setup_message_box
    BRANCH_U8_VAR_WITHIN_RANGE 17, 24, gHour, .asst_carp_346_off_hours
    BRANCH_U8_VAR_WITHIN_RANGE 0, 5, gHour, .asst_carp_346_off_hours
    INIT_DIALOGUE_SESSION 0, DIALOGUE_TEXT_54, 14
    WAIT_FOR_DIALOGUE_INPUT 0
    BRANCH_ON_DIALOGUE 0, 0, .asst_carp_346_choice_yes
    BRANCH_ON_DIALOGUE 0, 1, .asst_carp_346_choice_no

.asst_carp_346_choice_yes:
    ; Assistant Carpenter: OK, good luck!
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 254
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    SET_SPECIAL_BIT 1, gCutsceneCompletionFlags
    EXECUTE_SUBROUTINE .end_cutscene

.asst_carp_346_choice_no:
    ; Assistant Carpenter: No? Come back again another day then.
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 255

.asst_carp_346_close_and_resume:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .asst_carp_346_wait

.asst_carp_346_off_hours:
    BRANCH_U8_VAR_WITHIN_RANGE 30, 30, gDayOfMonth, .asst_carp_346_end_of_year
    ; Assistant Carpenter: Were done for the day. Come again tomorrow.
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 257
    EXECUTE_SUBROUTINE .asst_carp_346_close_and_resume

.asst_carp_346_end_of_year:
    ; Assistant Carpenter: Were done for the year. Do it again next year!
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 258
    EXECUTE_SUBROUTINE .asst_carp_346_close_and_resume

; ============================================
; Cutscene 347 (Mountaintop random gift event)
; Picks one of four helper NPCs at random (2x Assistant Carpenter, Rick,
; Potion Shop Dealer); idle loop polls gHour, stamina, B-button, level
; interactions. Interaction 16: leave-or-stay prompt (DIALOGUE_TEXT_54 13).
; Gift drop dispatches via gItemBeingHeld to one of several item texts:
;   Coin / Iron Ore / Blue Rock / Moonlight Stone / Rare Metal /
;   Pontata Root / Kazamidori / Power Nut.
; ============================================

.cutscene_347_entry:
    SET_U16_VALUE 1, D_80189824

.cutscene_347_body:
    SPAWN_EXECUTOR 2, .executor_player_entity_348
    SET_SPECIAL_BIT 31, gCutsceneCompletionFlags
    BRANCH_ON_RANDOM 0, 25, .branch_114B0C
    BRANCH_ON_RANDOM 26, 50, .branch_114B18
    BRANCH_ON_RANDOM 51, 75, .branch_114B24
    BRANCH_ON_RANDOM 76, 100, .branch_114B30

