.executor_dialogue_314:
    EXECUTE_SUBROUTINE .sub_1115C4
    SPAWN_EXECUTOR 7, .executor_player_entity_308
    SET_WAIT_FRAMES 1
    SET_FRAME_DELTA 0, 0, -2, 224
    SET_WAIT_FRAMES 15
    ; Karen: Youre giving this to me? Can I make wine with the pedals?
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 93
    WAIT_MESSAGE_BOX_CLOSED 0
    SET_OTHER_EXECUTOR_PTR 1, .executor_3_10FF58
    DEACTIVATE_EXECUTOR 10
    ; Popuri: everything turns into wine with you
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 94
    WAIT_MESSAGE_BOX_CLOSED 0
    ; Karen: delicious, smells good too
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 95
    WAIT_MESSAGE_BOX_CLOSED 0
    ; Popuri: let me taste the Moondrop wine when its done
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 96
    WAIT_MESSAGE_BOX_CLOSED 0
    ; Karen: OK, bye
    INIT_MESSAGE_BOX_TYPE1 0, MOUNTAIN_CUTSCENES_TEXT_INDEX, 97
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 1, .face_sw
    SET_OTHER_EXECUTOR_PTR 2, .karen_314_walk_off
    EXECUTE_SUBROUTINE .idle

