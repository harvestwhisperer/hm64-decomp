.balloon_anim:
    .anim_frame 0, 0xFF, (0, 0, 0), 255, 0
    .anim_end

; ============================================================
; DANCE PHASE - after chosen girl prompt, villagers gather,
; chosen girl performs dance loop, other NPCs do background
; animations, player follows along
; ============================================================

.dance_map_origin:
    SET_COORDINATES -32, 96, -32
    EXECUTE_SUBROUTINE .wait_loop

.player_dance_spawn:
    EXECUTE_SUBROUTINE .setup_player
    SET_BEHAVIOR_FLAGS 0
    SET_COORDINATES -16, 0, 64
    SET_ASSET_ROTATION NORTHEAST
    EXECUTE_SUBROUTINE .wait_loop
    EXECUTE_SUBROUTINE .setup_player
    SET_BEHAVIOR_FLAGS 0
    SET_COORDINATES -128, 0, 0
    SET_ASSET_ROTATION NORTHEAST
    EXECUTE_SUBROUTINE .wait_loop

.deactivate_npc_slots:
    DEACTIVATE_EXECUTOR 6
    DEACTIVATE_EXECUTOR 7
    DEACTIVATE_EXECUTOR 8
    DEACTIVATE_EXECUTOR 9
    DEACTIVATE_EXECUTOR 10
    DEACTIVATE_EXECUTOR 11
    DEACTIVATE_EXECUTOR 12
    DEACTIVATE_EXECUTOR 13
    DEACTIVATE_EXECUTOR 14
    DEACTIVATE_EXECUTOR 15
    DEACTIVATE_EXECUTOR 16
    DEACTIVATE_EXECUTOR 17
    DEACTIVATE_EXECUTOR 18
    DEACTIVATE_EXECUTOR 19
    DEACTIVATE_EXECUTOR 20
    STOP_SEQUENCE_WITH_FADE 0, 1
    SET_WAIT_FRAMES 1
    IDLE_WHILE_SEQUENCE_PLAYING 0
    RETURN_FROM_SUBROUTINE

.dance_bachelor_dispatch:
    BRANCH_U8_VAR_WITHIN_RANGE 1, 1, gHarvestKing, .setup_harris
    BRANCH_U8_VAR_WITHIN_RANGE 2, 2, gHarvestKing, .setup_gray
    BRANCH_U8_VAR_WITHIN_RANGE 3, 3, gHarvestKing, .setup_jeff
    BRANCH_U8_VAR_WITHIN_RANGE 4, 4, gHarvestKing, .setup_cliff
    BRANCH_U8_VAR_WITHIN_RANGE 5, 5, gHarvestKing, .setup_kai
    BRANCH_U8_VAR_WITHIN_RANGE 6, 6, gHarvestKing, .setup_potion_shop_dealer
    SET_COORDINATES -128, 0, 0
    SET_ASSET_ROTATION NORTHEAST
    EXECUTE_SUBROUTINE .wait_loop

.dance_goddess_dispatch:
    BRANCH_U8_VAR_WITHIN_RANGE 0, 0, gFlowerFestivalGoddess, .setup_maria_after_dance
    BRANCH_U8_VAR_WITHIN_RANGE 1, 1, gFlowerFestivalGoddess, .setup_popuri_after_dance
    BRANCH_U8_VAR_WITHIN_RANGE 2, 2, gFlowerFestivalGoddess, .setup_elli_after_dance
    BRANCH_U8_VAR_WITHIN_RANGE 3, 3, gFlowerFestivalGoddess, .setup_ann_after_dance
    BRANCH_U8_VAR_WITHIN_RANGE 4, 4, gFlowerFestivalGoddess, .setup_karen_after_dance
    SET_COORDINATES -128, 0, -32
    SET_ASSET_ROTATION SOUTHWEST
    EXECUTE_SUBROUTINE .wait_loop

.dance_mayor_pos:
    EXECUTE_SUBROUTINE .setup_mayor
    SET_COORDINATES 64, 0, -16
    SET_ASSET_ROTATION NORTHEAST
    EXECUTE_SUBROUTINE .wait_loop

.dance_lillia_pos:
    EXECUTE_SUBROUTINE .setup_mayor_wife
    SET_COORDINATES 64, 0, -48
    SET_ASSET_ROTATION SOUTHWEST
    EXECUTE_SUBROUTINE .wait_loop

.dance_basil_pos:
    EXECUTE_SUBROUTINE .setup_basil
    SET_COORDINATES -128, 0, 0
    SET_ASSET_ROTATION NORTHEAST
    EXECUTE_SUBROUTINE .wait_loop

.dance_lillia_pos_alt:
    EXECUTE_SUBROUTINE .setup_lillia
    SET_COORDINATES -128, 0, -32
    SET_ASSET_ROTATION SOUTHWEST
    EXECUTE_SUBROUTINE .wait_loop

.dance_music_start:
    SET_WAIT_FRAMES 20
    SET_AUDIO_SEQUENCE 0, _festivalDanceSegmentRomStart, _festivalDanceSegmentRomEnd
    SET_AUDIO_SEQUENCE_VOLUME 0, 128, 128
    SET_OTHER_EXECUTOR_PTR 0, .dance_player_loop
    SET_WAIT_FRAMES 1
    SPAWN_EXECUTOR 33, .dance_end_fadeout
    RETURN_FROM_SUBROUTINE

.dance_dispatch_chosen:
    BRANCH_U8_VAR_WITHIN_RANGE 0, 0, gFlowerFestivalGoddess, .dance_maria
    BRANCH_U8_VAR_WITHIN_RANGE 1, 1, gFlowerFestivalGoddess, .dance_popuri
    BRANCH_U8_VAR_WITHIN_RANGE 2, 2, gFlowerFestivalGoddess, .dance_elli
    BRANCH_U8_VAR_WITHIN_RANGE 3, 3, gFlowerFestivalGoddess, .dance_ann
    BRANCH_U8_VAR_WITHIN_RANGE 4, 4, gFlowerFestivalGoddess, .dance_karen
    EXECUTE_SUBROUTINE .wait_loop

.dance_maria:
    SET_OTHER_EXECUTOR_PTR 1, .dance_sequence_maria
    EXECUTE_SUBROUTINE .wait_loop

.dance_popuri:
    SET_OTHER_EXECUTOR_PTR 2, .dance_sequence_popuri
    EXECUTE_SUBROUTINE .wait_loop

.dance_elli:
    SET_OTHER_EXECUTOR_PTR 3, .dance_sequence_elli
    EXECUTE_SUBROUTINE .wait_loop

.dance_ann:
    SET_OTHER_EXECUTOR_PTR 4, .dance_sequence_ann
    EXECUTE_SUBROUTINE .wait_loop

.dance_karen:
    SET_OTHER_EXECUTOR_PTR 5, .dance_sequence_karen
    EXECUTE_SUBROUTINE .wait_loop

.dance_bachelor_wait:
    BRANCH_U8_VAR_WITHIN_RANGE 1, 1, gHarvestKing, .dance_harris_loop
    BRANCH_U8_VAR_WITHIN_RANGE 2, 2, gHarvestKing, .dance_gray_loop
    BRANCH_U8_VAR_WITHIN_RANGE 3, 3, gHarvestKing, .dance_jeff_loop
    BRANCH_U8_VAR_WITHIN_RANGE 4, 4, gHarvestKing, .dance_cliff_loop
    BRANCH_U8_VAR_WITHIN_RANGE 5, 5, gHarvestKing, .dance_kai_loop
    BRANCH_U8_VAR_WITHIN_RANGE 6, 6, gHarvestKing, .dance_potion_loop
    EXECUTE_SUBROUTINE .wait_loop

.dance_goddess_partner_wait:
    BRANCH_U8_VAR_WITHIN_RANGE 0, 0, gFlowerFestivalGoddess, .dance_goddess_body
    BRANCH_U8_VAR_WITHIN_RANGE 1, 1, gFlowerFestivalGoddess, .dance_goddess_popuri_body
    BRANCH_U8_VAR_WITHIN_RANGE 2, 2, gFlowerFestivalGoddess, .dance_goddess_elli_body
    BRANCH_U8_VAR_WITHIN_RANGE 3, 3, gFlowerFestivalGoddess, .dance_goddess_ann_body
    BRANCH_U8_VAR_WITHIN_RANGE 4, 4, gFlowerFestivalGoddess, .dance_goddess_karen_body
    EXECUTE_SUBROUTINE .wait_loop

.dance_spawn_npcs_main:
    SPAWN_EXECUTOR 6, .dance_bachelor_dispatch
    SPAWN_EXECUTOR 7, .dance_goddess_dispatch
    SPAWN_EXECUTOR 8, .dance_mayor_pos
    SPAWN_EXECUTOR 9, .dance_lillia_pos
    TOGGLE_PAUSE_ENTITY 0
    SPAWN_EXECUTOR 0, .player_dance_spawn
    SET_WAIT_FRAMES 1
    SET_OTHER_EXECUTOR_PTR 38, .dance_map_origin
    SET_COORDINATES -16, 0, 32
    SET_ASSET_ROTATION SOUTHWEST
    SET_WAIT_FRAMES 1
    UPDATE_GLOBAL_RGBA 255, 255, 255, 255, 8
    WAIT_RGBA_FINISHED
    RETURN_FROM_SUBROUTINE

; ----- Dance sequence: chosen Maria -----

.dance_sequence_maria:
    UPDATE_U8_VALUE 10, 255, npcAffection[MARIA]
    SET_AUDIO_SEQUENCE_VOLUME 0, 0, 4
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    DEACTIVATE_EXECUTOR 2
    DEACTIVATE_EXECUTOR 3
    DEACTIVATE_EXECUTOR 4
    DEACTIVATE_EXECUTOR 5
    EXECUTE_SUBROUTINE .deactivate_npc_slots
    BRANCH_U8_VAR_WITHIN_RANGE 0, 0, gFlowerFestivalGoddess, .dance_maria_goddess
    BRANCH_U8_VAR_WITHIN_RANGE 0, 0, gHarvestKing, .dance_maria_goddess
    EXECUTE_SUBROUTINE .dance_spawn_npcs_main
    EXECUTE_SUBROUTINE .dance_music_start
    SET_OTHER_EXECUTOR_PTR 6, .dance_bachelor_wait
    SET_OTHER_EXECUTOR_PTR 7, .dance_goddess_partner_wait
    SET_OTHER_EXECUTOR_PTR 8, .dance_mayor_loop
    SET_OTHER_EXECUTOR_PTR 9, .dance_lillia_loop

.dance_loop_maria:
    SET_ENTITY_ANIMATION 91
    SET_WAIT_FRAMES 78
    EXECUTE_SUBROUTINE .dance_maria_bow
    SET_WAIT_FRAMES 2
    SET_ENTITY_ANIMATION 91
    SET_WAIT_FRAMES 78
    EXECUTE_SUBROUTINE .dance_maria_bow
    SET_WAIT_FRAMES 2
    SET_ENTITY_ANIMATION 92
    SET_FRAME_DELTA 0, 0, -1, 48
    SET_WAIT_FRAMES 24
    EXECUTE_SUBROUTINE .dance_maria_bow
    SET_WAIT_FRAMES 2
    SET_ENTITY_ANIMATION 92
    SET_FRAME_DELTA 0, 0, 1, 48
    SET_WAIT_FRAMES 20
    EXECUTE_SUBROUTINE .dance_maria_bow
    EXECUTE_SUBROUTINE .dance_maria_turn
    SET_ENTITY_ANIMATION 92
    SET_FRAME_DELTA 1, 0, 0, 48
    SET_WAIT_FRAMES 24
    EXECUTE_SUBROUTINE .dance_maria_bow
    SET_WAIT_FRAMES 2
    SET_ENTITY_ANIMATION 92
    SET_FRAME_DELTA -1, 0, 0, 48
    SET_WAIT_FRAMES 24
    EXECUTE_SUBROUTINE .dance_maria_bow
    SET_WAIT_FRAMES 2
    SET_ENTITY_ANIMATION 92
