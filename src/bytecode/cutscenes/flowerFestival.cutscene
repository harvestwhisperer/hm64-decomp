    INIT_MESSAGE_BOX_TYPE1 0, FLOWER_FESTIVAL_TEXT_INDEX,50
    EXECUTE_SUBROUTINE .ann_talk_done

.ann_chosen_check:
    BRANCH_ON_SPECIAL_BIT 29, lifeEventBits[0], .ann_life29_talk
    INIT_DIALOGUE_SESSION 0, DIALOGUE_TEXT_49,3
    WAIT_FOR_DIALOGUE_INPUT 0
    BRANCH_ON_DIALOGUE 0, 0, .ann_prompt_yes
    BRANCH_ON_DIALOGUE 0, 1, .ann_prompt_no

.ann_prompt_yes:
    INIT_MESSAGE_BOX_TYPE1 0, FLOWER_FESTIVAL_TEXT_INDEX,53
    EXECUTE_SUBROUTINE .ann_talk_done

.ann_prompt_no:
    INIT_MESSAGE_BOX_TYPE1 0, FLOWER_FESTIVAL_TEXT_INDEX,54
    EXECUTE_SUBROUTINE .ann_talk_done

.ann_wife_reunion:
    INIT_MESSAGE_BOX_TYPE1 0, FLOWER_FESTIVAL_TEXT_INDEX,55
    EXECUTE_SUBROUTINE .ann_talk_done

.ann_life29_talk:
    INIT_MESSAGE_BOX_TYPE1 0, FLOWER_FESTIVAL_TEXT_INDEX,56
    EXECUTE_SUBROUTINE .ann_talk_done

.ann_chosen_confirm:
    BRANCH_U8_VAR_WITHIN_RANGE 3, 3, gFlowerFestivalGoddess, .ann_king_variant
    SET_MESSAGE_INTERPOLATION -4, 0, 0
    SET_MESSAGE_BOX_ASSETS 0, 1, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 0, -64, 256
    INIT_MESSAGE_BOX_TYPE1 0, FLOWER_FESTIVAL_TEXT_INDEX,110
    WAIT_MESSAGE_BOX_CLOSED 0
    INIT_DIALOGUE_SESSION 0, DIALOGUE_TEXT_49,1
    WAIT_FOR_DIALOGUE_INPUT 0
    SET_MESSAGE_BOX_ASSETS 0, 0, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 24, -64, 256
    BRANCH_ON_DIALOGUE 0, 0, .ann_chosen_confirm_yes
    BRANCH_ON_DIALOGUE 0, 1, .ann_chosen_confirm_no

.ann_chosen_confirm_yes:
    DEACTIVATE_EXECUTOR 37
    CLEAR_SPECIAL_BIT 0, flags
    EXECUTE_SUBROUTINE .dance_sequence_ann

.ann_chosen_confirm_no:
    TOGGLE_PAUSE_ENTITY 0
    EXECUTE_SUBROUTINE .ann_wait_loop

.ann_king_variant:
    BRANCH_U8_VAR_WITHIN_RANGE 0, 0, gHarvestKing, .ann_king_player_variant
    INIT_MESSAGE_BOX_TYPE1 0, FLOWER_FESTIVAL_TEXT_INDEX,116
    EXECUTE_SUBROUTINE .ann_talk_done

.ann_king_player_variant:
    INIT_MESSAGE_BOX_TYPE1 0, FLOWER_FESTIVAL_TEXT_INDEX,117
    EXECUTE_SUBROUTINE .ann_talk_done

; ----- Karen (slot 5) - variants share one entry executor with different buddy anims -----

.setup_karen:
    SETUP_ENTITY 5, ENTITY_ASSET_KAREN, 1
    SET_ENTITY_ANIMATIONS 5, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    RETURN_FROM_SUBROUTINE

.karen_enter_with_maria:
    EXECUTE_SUBROUTINE .setup_karen
    EXECUTE_SUBROUTINE .ann_entry_walk
    SET_ENTITY_ANIMATION 76
    SET_WAIT_FRAMES 13
    SPAWN_EXECUTOR 21, .balloon_spr_21
    SET_WAIT_FRAMES 19
    SPAWN_EXECUTOR 22, .balloon_spr_22
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    EXECUTE_SUBROUTINE .karen_wait_loop

.karen_enter_with_elli:
    EXECUTE_SUBROUTINE .setup_karen
    EXECUTE_SUBROUTINE .elli_entry_walk
    SET_ENTITY_ANIMATION 77
    SET_WAIT_FRAMES 13
    SPAWN_EXECUTOR 23, .balloon_spr_23
    SET_WAIT_FRAMES 19
    SPAWN_EXECUTOR 24, .balloon_spr_24
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    EXECUTE_SUBROUTINE .karen_wait_loop

.karen_enter_with_popuri:
    EXECUTE_SUBROUTINE .setup_karen
    EXECUTE_SUBROUTINE .popuri_entry_walk
    SET_ENTITY_ANIMATION 76
    SET_WAIT_FRAMES 13
    SPAWN_EXECUTOR 25, .balloon_spr_25
    SET_WAIT_FRAMES 19
    SPAWN_EXECUTOR 26, .balloon_spr_26
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    EXECUTE_SUBROUTINE .karen_wait_loop

.karen_enter_with_ann:
    EXECUTE_SUBROUTINE .setup_karen
    EXECUTE_SUBROUTINE .maria_entry_walk
    SET_ENTITY_ANIMATION 77
    SET_WAIT_FRAMES 13
    SPAWN_EXECUTOR 27, .balloon_spr_27
    SET_WAIT_FRAMES 19
    SPAWN_EXECUTOR 28, .balloon_spr_28
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    EXECUTE_SUBROUTINE .karen_wait_loop

.setup_karen_after_dance:
    SETUP_ENTITY 5, ENTITY_ASSET_KAREN, 1
    SET_ENTITY_ANIMATIONS 5, 78, 0, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    RETURN_FROM_SUBROUTINE

.karen_after_dance:
    EXECUTE_SUBROUTINE .setup_karen_after_dance
    SET_ASSET_ROTATION SOUTHEAST
    SET_COORDINATES -288, 0, 80
    SET_ENTITY_ANIMATION 86
    SET_FRAME_DELTA 2, 0, 0, 128
    SET_ENTITY_ANIMATION 92
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_ANIMATION 93
    SET_WAIT_FRAMES 30
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    SET_COORDINATES -176, 0, -24
    SET_ENTITY_DIRECTIONAL_ANIMATION 78
    SET_ASSET_ROTATION SOUTHEAST
    SET_OTHER_EXECUTOR_PTR 0, .player_post_intro_walk

.karen_wait_loop:
    SET_CALLBACK_ROUTINE 0, 32768, .karen_on_interact
    EXECUTE_SUBROUTINE .wait_loop

.karen_on_interact:
    BRANCH_ON_SPECIAL_BIT 19, affectionBumpedBits, .karen_talk
    UPDATE_U8_VALUE 2, 255, npcAffection[KAREN]
    SET_SPECIAL_BIT 19, affectionBumpedBits

.karen_talk:
    EXECUTE_SUBROUTINE .setup_message_box
    SET_SPECIAL_BIT 0, flags
    PAUSE_ENTITY 0
    FLIP_ENTITY_DIRECTION 0
    BRANCH_ON_SPECIAL_BIT 2, flags, .karen_chosen_confirm
    BRANCH_U8_VAR_WITHIN_RANGE 4, 4, gFlowerFestivalGoddess, .karen_chosen_check
    SET_ENTITY_DIRECTIONAL_ANIMATION 16
    WAIT_ENTITY_ANIMATION
    SPAWN_EXECUTOR 36, .track_girl5
    SET_WAIT_FRAMES 20
    SPAWN_EXECUTOR 0, .player_bow_to_girl
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SET_WAIT_FRAMES 20
    BRANCH_ON_SPECIAL_BIT MARRIED, lifeEventBits[0], .karen_married_check
    BRANCH_ON_SPECIAL_BIT 30, lifeEventBits[0], .karen_life30_talk
    INIT_MESSAGE_BOX_TYPE1 0, FLOWER_FESTIVAL_TEXT_INDEX,57

.karen_talk_done:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITY 0
    CLEAR_SPECIAL_BIT 0, flags
    EXECUTE_SUBROUTINE .karen_wait_loop

.karen_married_check:
    BRANCH_U8_VAR_WITHIN_RANGE 4, 4, gWife, .karen_wife_reunion
    RETURN_FROM_SUBROUTINE

.karen_chosen_check:
    BRANCH_ON_SPECIAL_BIT 30, lifeEventBits[0], .karen_life30_talk
    INIT_DIALOGUE_SESSION 0, DIALOGUE_TEXT_49,2
    WAIT_FOR_DIALOGUE_INPUT 0
    BRANCH_ON_DIALOGUE 0, 0, .karen_prompt_yes
    BRANCH_ON_DIALOGUE 0, 1, .karen_prompt_no

.karen_prompt_yes:
    INIT_MESSAGE_BOX_TYPE1 0, FLOWER_FESTIVAL_TEXT_INDEX,60
    EXECUTE_SUBROUTINE .karen_talk_done

.karen_prompt_no:
    INIT_MESSAGE_BOX_TYPE1 0, FLOWER_FESTIVAL_TEXT_INDEX,61
    EXECUTE_SUBROUTINE .karen_talk_done

.karen_wife_reunion:
    INIT_MESSAGE_BOX_TYPE1 0, FLOWER_FESTIVAL_TEXT_INDEX,62
    EXECUTE_SUBROUTINE .karen_talk_done

.karen_life30_talk:
    INIT_MESSAGE_BOX_TYPE1 0, FLOWER_FESTIVAL_TEXT_INDEX,63
    EXECUTE_SUBROUTINE .karen_talk_done

.karen_chosen_confirm:
    BRANCH_U8_VAR_WITHIN_RANGE 4, 4, gFlowerFestivalGoddess, .karen_king_variant
    SET_MESSAGE_INTERPOLATION -4, 0, 0
    SET_MESSAGE_BOX_ASSETS 0, 1, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 0, -64, 256
    INIT_MESSAGE_BOX_TYPE1 0, FLOWER_FESTIVAL_TEXT_INDEX,110
    WAIT_MESSAGE_BOX_CLOSED 0
    INIT_DIALOGUE_SESSION 0, DIALOGUE_TEXT_49,1
    WAIT_FOR_DIALOGUE_INPUT 0
    SET_MESSAGE_BOX_ASSETS 0, 0, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 24, -64, 256
    BRANCH_ON_DIALOGUE 0, 0, .karen_chosen_confirm_yes
    BRANCH_ON_DIALOGUE 0, 1, .karen_chosen_confirm_no

.karen_chosen_confirm_yes:
    DEACTIVATE_EXECUTOR 37
    CLEAR_SPECIAL_BIT 0, flags
    EXECUTE_SUBROUTINE .dance_sequence_karen

.karen_chosen_confirm_no:
    TOGGLE_PAUSE_ENTITY 0
    EXECUTE_SUBROUTINE .karen_wait_loop

.karen_king_variant:
    BRANCH_U8_VAR_WITHIN_RANGE 0, 0, gHarvestKing, .karen_king_player_variant
    INIT_MESSAGE_BOX_TYPE1 0, FLOWER_FESTIVAL_TEXT_INDEX,118
    EXECUTE_SUBROUTINE .karen_talk_done

.karen_king_player_variant:
    INIT_MESSAGE_BOX_TYPE1 0, FLOWER_FESTIVAL_TEXT_INDEX,119
    EXECUTE_SUBROUTINE .karen_talk_done

; ============================================================
; BALLOON SPRITES (slots 21..28) - static festival balloon sprites
; spawned after each girl entry walk
; ============================================================

.balloon_spr_21:
