    EXECUTE_SUBROUTINE .dance_sequence_maria

.maria_chosen_confirm_no:
    TOGGLE_PAUSE_ENTITY 0
    EXECUTE_SUBROUTINE .maria_wait_loop

.maria_king_variant:
