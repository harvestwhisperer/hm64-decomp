    EXECUTE_SUBROUTINE .setup_maria_after_dance
    SET_ASSET_ROTATION SOUTHEAST
    SET_COORDINATES -288, 0, 80
    SET_ENTITY_ANIMATION 81
    SET_FRAME_DELTA 2, 0, 0, 128
    SET_ENTITY_ANIMATION 89
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_ANIMATION 90
    SET_WAIT_FRAMES 30
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    SET_COORDINATES -176, 0, -24
    SET_ENTITY_DIRECTIONAL_ANIMATION 73
    SET_ASSET_ROTATION SOUTHEAST
    SET_OTHER_EXECUTOR_PTR 0, .player_post_intro_walk

.maria_wait_loop:
    SET_CALLBACK_ROUTINE 0, 32768, .maria_on_interact
    EXECUTE_SUBROUTINE .wait_loop

.maria_on_interact:
    BRANCH_ON_SPECIAL_BIT 15, affectionBumpedBits, .maria_talk
    UPDATE_U8_VALUE 2, 255, npcAffection
    SET_SPECIAL_BIT 15, affectionBumpedBits

.maria_talk:
    EXECUTE_SUBROUTINE .setup_message_box
    SET_SPECIAL_BIT 0, flags
    PAUSE_ENTITY 0
    FLIP_ENTITY_DIRECTION 0
    BRANCH_ON_SPECIAL_BIT 2, flags, .maria_chosen_confirm
    BRANCH_U8_VAR_WITHIN_RANGE 0, 0, gFlowerFestivalGoddess, .maria_chosen_check
    SET_ENTITY_DIRECTIONAL_ANIMATION 16
    WAIT_ENTITY_ANIMATION
    SPAWN_EXECUTOR 36, .track_girl1
    SET_WAIT_FRAMES 20
    SPAWN_EXECUTOR 0, .player_bow_to_girl
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SET_WAIT_FRAMES 20
    BRANCH_ON_SPECIAL_BIT MARRIED, lifeEventBits[0], .maria_married_check
    BRANCH_ON_SPECIAL_BIT 26, lifeEventBits[0], .maria_life26_talk
    BRANCH_U8_VAR_WITHIN_RANGE 0, 99, npcAffection, .maria_talk_low
    BRANCH_U8_VAR_WITHIN_RANGE 100, 255, npcAffection, .maria_talk_high

.maria_talk_done:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITY 0
    CLEAR_SPECIAL_BIT 0, flags
    EXECUTE_SUBROUTINE .maria_wait_loop

.maria_married_check:
    BRANCH_U8_VAR_WITHIN_RANGE 0, 0, gWife, .maria_wife_reunion
    RETURN_FROM_SUBROUTINE

.maria_talk_low:
    INIT_MESSAGE_BOX_TYPE1 0, FLOWER_FESTIVAL_TEXT_INDEX,27
    EXECUTE_SUBROUTINE .maria_talk_done

.maria_talk_high:
    INIT_MESSAGE_BOX_TYPE1 0, FLOWER_FESTIVAL_TEXT_INDEX,28
    EXECUTE_SUBROUTINE .maria_talk_done

.maria_chosen_check:
    BRANCH_ON_SPECIAL_BIT 26, lifeEventBits[0], .maria_life26_talk
    INIT_DIALOGUE_SESSION 0, DIALOGUE_TEXT_49,6
    WAIT_FOR_DIALOGUE_INPUT 0
    BRANCH_ON_DIALOGUE 0, 0, .maria_prompt_yes
    BRANCH_ON_DIALOGUE 0, 1, .maria_prompt_no

.maria_prompt_yes:
    INIT_MESSAGE_BOX_TYPE1 0, FLOWER_FESTIVAL_TEXT_INDEX,31
    EXECUTE_SUBROUTINE .maria_talk_done

.maria_prompt_no:
