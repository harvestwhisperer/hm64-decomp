; ============================================
; Bank 13 - Flower Festival
; ============================================
;
; The Mayor asks the player to pick a dance partner from the
; five bachelorettes. Villagers populate the square and react
; to the choice. The gHarvestKing value (set by a prior Sowing
; Festival / Starry Night Festival outcome) swaps in different
; NPCs and dialogue branches. gFlowerFestivalGoddess tracks
; which girl was picked in a prior year and gates
; goddess-flavored dialogue.
;
; Cutscene indices:
;   950 (FLOWER_FESTIVAL) -> .main: full festival dispatch
;
; gHarvestKing values (source: src/game/cutscenes.c):
;   0 = PLAYER, 1 = HARRIS, 2 = GRAY, 3 = JEFF, 4 = CLIFF, 5 = KAI,
;   6 = POTION_SHOP_DEALER
;
; gFlowerFestivalGoddess values (girl chosen in prior year):
;   0 = MARIA, 1 = POPURI, 2 = ELLI, 3 = ANN, 4 = KAREN
;
; Executor slot usage:
;   0      - player
;   1..5   - Maria, Popuri, Elli, Ann, Karen (bachelorettes)
;   6..13  - mayor / lillia / basil / kent / stu /
;            potion shop dealer / rick / shady salesman
;   14..18 - Harris, Gray, Jeff, Cliff, Kai (bachelors)
;   19     - Mayor wife
;   20     - Pastor
;   21..28 - balloon sprites
;   32     - power-nut shine
;   33     - end-of-dance fade controller
;   36     - NPC tracking target helper
;   37     - A-button / timer poll helper
;   38     - map-load helper
;
; Local variables (declared below):
;   flags                 - bitfield of festival state flags
;   affectionBumpedBits   - one bit per NPC marking already-bumped
;                           this session (see each NPC interaction
;                           branch for exact bit numbers)

#include "entities.h"
#include "texts.h"
#include "dialogues.h"
#include "entityBuffers.h"

#define MAIN_MAP_INDEX 0
#define MARRIED 0

; gHarvestKing values (see src/game/cutscenes.c)
#define KING_PLAYER 0
#define KING_HARRIS 1
#define KING_GRAY 2
#define KING_JEFF 3
#define KING_CLIFF 4
#define KING_KAI 5
#define KING_POTION_SHOP_DEALER 6

; gFlowerFestivalGoddess values (chosen girl, persisted across years)
#define FFG_MARIA 0
#define FFG_POPURI 1
#define FFG_ELLI 2
#define FFG_ANN 3
#define FFG_KAREN 4

; npcAffection indices beyond the transpiler-built-in set (MARIA..KAI)
#define NPC_MAYOR              0xB
#define NPC_MAYOR_WIFE         0xC
#define NPC_LILLIA             0xD
#define NPC_BASIL              0xE
#define NPC_POTION_SHOP_DEALER 0x13
#define NPC_KENT               0x14
#define NPC_STU                0x15
#define NPC_RICK               0x18
#define NPC_PASTOR             0x19

.buffer 2

; flags bit meanings (bitfield local):
;   bit 0 - player is paused in dialogue
;   bit 1 - first-time setup complete (set by .player_post_intro_walk)
;   bit 2 - a girl has been chosen (dance phase active)
;   bit 3 - shady-salesman flow accepted (power nut purchased)
.local flags, u32
; affectionBumpedBits bit meanings: one bit per NPC; a bit is set
; after that NPC has had their affection bumped this session so
; repeat interactions do not keep stacking. Bit layout is
; executor-dependent; see each NPC interaction branch for the
; exact bit number.
.local affectionBumpedBits, u32

.array npcAffection, u8
.array lifeEventBits, u32

; ============================================================
; DISPATCH - cutscene 950 entry point
; ============================================================

.main:
    SET_SPECIAL_BIT 31, gCutsceneCompletionFlags
    SET_SPECIAL_BIT 12, gCutsceneCompletionFlags
    SET_SPECIAL_BIT 13, gCutsceneCompletionFlags
    SET_SPECIAL_BIT 14, gCutsceneCompletionFlags
    SET_SPECIAL_BIT 15, gCutsceneCompletionFlags
    INIT_MAP_ADDITION 1, 0
    INIT_MAP_ADDITION 2, 0
    INIT_MAP_ADDITION 4, 0
    INIT_MAP_ADDITION 6, 0
    PAUSE_ENTITIES
    STOP_SEQUENCE_WITH_FADE 0, 8
    IDLE_WHILE_SEQUENCE_PLAYING 0
    SET_AUDIO_SEQUENCE 0, _festivalThemeSegmentRomStart, _festivalThemeSegmentRomEnd
    SET_AUDIO_SEQUENCE_VOLUME 0, 128, 8
    UPDATE_U8_VALUE 5, 255, gHappiness
    TOGGLE_PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .setup_message_box
    BRANCH_U16_VAR_WITHIN_RANGE 950, 950, gCutsceneIndex, .spawn_npcs

; ============================================================
; SHARED HELPERS
; ============================================================

.exit_cutscene:
    CLEAR_SPECIAL_BIT 0, flags
    CLEAR_SPECIAL_BIT 1, flags
    CLEAR_SPECIAL_BIT 2, flags
    SET_SPECIAL_BIT 0, gCutsceneCompletionFlags
    DEACTIVATE_SELF

.wait_loop:
    SET_WAIT_FRAMES 1
    EXECUTE_SUBROUTINE .wait_loop

.setup_message_box:
    SET_MESSAGE_INTERPOLATION -4, 0, 0
    SET_MESSAGE_BOX_ASSETS 0, 0, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 24, -64, 352
    RETURN_FROM_SUBROUTINE

.setup_tracking_helper:
    SETUP_ENTITY 22, ENTITY_ASSET_STATIC_ITEM, 1
    SET_ENTITY_ANIMATIONS 22, 0, 0, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    RETURN_FROM_SUBROUTINE

.track_girl1:
    EXECUTE_SUBROUTINE .setup_tracking_helper
    SET_ENTITY_TRACKING_TARGET 1, 0, 14, 20, 255
    SET_ENTITY_ANIMATION 3
    EXECUTE_SUBROUTINE .wait_loop

.track_girl2:
    EXECUTE_SUBROUTINE .setup_tracking_helper
    SET_ENTITY_TRACKING_TARGET 2, 0, 14, 20, 255
    SET_ENTITY_ANIMATION 3
    EXECUTE_SUBROUTINE .wait_loop

.track_girl3:
    EXECUTE_SUBROUTINE .setup_tracking_helper
    SET_ENTITY_TRACKING_TARGET 3, 0, 14, 20, 255
    SET_ENTITY_ANIMATION 3
    EXECUTE_SUBROUTINE .wait_loop

.track_girl4:
    EXECUTE_SUBROUTINE .setup_tracking_helper
    SET_ENTITY_TRACKING_TARGET 4, 0, 14, 20, 255
    SET_ENTITY_ANIMATION 3
    EXECUTE_SUBROUTINE .wait_loop

.track_girl5:
    EXECUTE_SUBROUTINE .setup_tracking_helper
    SET_ENTITY_TRACKING_TARGET 5, 0, 14, 20, 255
    SET_ENTITY_ANIMATION 3
    EXECUTE_SUBROUTINE .wait_loop

.track_player_then_exit:
    SET_ENTITY_TRACKING_TARGET 0, 0, 14, 20, 255
    SET_WAIT_FRAMES 20
    DEACTIVATE_SELF

.setup_player:
    SETUP_ENTITY 0, ENTITY_ASSET_PLAYER, 1
    SET_ENTITY_ANIMATIONS 0, 0, 8, 16, 24, 32, 40
    SET_BEHAVIOR_FLAGS CUTSCENE_ASSET_BEHAVIOR_TRACK_ENTITY
    RETURN_FROM_SUBROUTINE

.face_sw_loop:
    SET_ASSET_ROTATION SOUTHWEST
    EXECUTE_SUBROUTINE .wait_loop

.face_se_loop:
    SET_ASSET_ROTATION SOUTHEAST
    EXECUTE_SUBROUTINE .wait_loop

; ============================================================
; MAIN DISPATCH - spawn NPCs and gate Harvest-King variant
; ============================================================

.spawn_npcs:
    SPAWN_EXECUTOR 6, .mayor_wait
    SPAWN_EXECUTOR 7, .lillia_wait
    SPAWN_EXECUTOR 8, .basil_wait
    SPAWN_EXECUTOR 9, .kent_wait
    SPAWN_EXECUTOR 10, .stu_wait
    SPAWN_EXECUTOR 11, .potion_wait
    SPAWN_EXECUTOR 12, .rick_wait
    BRANCH_ON_SPECIAL_BIT 7, acquiredPowerNutBits, .gate_harvest_king
    SPAWN_EXECUTOR 13, .shady_wait

.gate_harvest_king:
    BRANCH_U8_VAR_WITHIN_RANGE 1, 1, gHarvestKing, .spawn_bachelor_harris
    BRANCH_U8_VAR_WITHIN_RANGE 30, 255, npcAffection[HARRIS], .spawn_bachelor_harris
    BRANCH_U8_VAR_WITHIN_RANGE 2, 2, gHarvestKing, .spawn_bachelor_gray
    BRANCH_U8_VAR_WITHIN_RANGE 50, 255, npcAffection[GRAY], .spawn_bachelor_gray
    BRANCH_U8_VAR_WITHIN_RANGE 3, 3, gHarvestKing, .spawn_bachelor_jeff
    BRANCH_U8_VAR_WITHIN_RANGE 30, 255, npcAffection[JEFF], .spawn_bachelor_jeff
    BRANCH_ON_SPECIAL_BIT 13, lifeEventBits[1], .gate_king_cliff
    BRANCH_U8_VAR_WITHIN_RANGE 4, 4, gHarvestKing, .spawn_bachelor_cliff
    BRANCH_U8_VAR_WITHIN_RANGE 50, 255, npcAffection[CLIFF], .spawn_bachelor_cliff

.gate_king_cliff:
    BRANCH_ON_SPECIAL_BIT 14, lifeEventBits[1], .gate_king_kai
    BRANCH_U8_VAR_WITHIN_RANGE 5, 5, gHarvestKing, .spawn_bachelor_kai
    BRANCH_U8_VAR_WITHIN_RANGE 50, 255, npcAffection[KAI], .spawn_bachelor_kai

.gate_king_kai:
    SPAWN_EXECUTOR 19, .mayor_wife_wait
    SPAWN_EXECUTOR 20, .pastor_wait
    EXECUTE_SUBROUTINE .goddess_intro

; ----- Post-choice girl entrance dispatch (gFlowerFestivalGoddess 0..4) -----

.after_choose_maria:
    SPAWN_EXECUTOR 3, .elli_enter
    SPAWN_EXECUTOR 4, .ann_enter
    SET_WAIT_FRAMES 40
    SPAWN_EXECUTOR 2, .popuri_enter
    BRANCH_ON_SPECIAL_BIT 15, lifeEventBits[1], .after_choose_maria_tail
    SPAWN_EXECUTOR 5, .karen_enter_with_ann

.after_choose_maria_tail:
    SET_WAIT_FRAMES 100
    SPAWN_EXECUTOR 1, .maria_after_dance
    DEACTIVATE_SELF

.after_choose_popuri:
    SPAWN_EXECUTOR 3, .elli_enter
    SPAWN_EXECUTOR 4, .ann_enter
    SET_WAIT_FRAMES 40
    SPAWN_EXECUTOR 1, .maria_enter
    BRANCH_ON_SPECIAL_BIT 15, lifeEventBits[1], .after_choose_popuri_tail
    SPAWN_EXECUTOR 5, .karen_enter_with_popuri

.after_choose_popuri_tail:
    SET_WAIT_FRAMES 100
    SPAWN_EXECUTOR 2, .popuri_after_dance
    DEACTIVATE_SELF

.after_choose_elli:
    SPAWN_EXECUTOR 4, .ann_enter
    BRANCH_ON_SPECIAL_BIT 15, lifeEventBits[1], .after_choose_elli_tail
    SPAWN_EXECUTOR 5, .karen_enter_with_elli

.after_choose_elli_tail:
    SET_WAIT_FRAMES 40
    SPAWN_EXECUTOR 1, .maria_enter
    SPAWN_EXECUTOR 2, .popuri_enter
    SET_WAIT_FRAMES 100
    SPAWN_EXECUTOR 3, .elli_after_dance
    DEACTIVATE_SELF

.after_choose_ann:
    SPAWN_EXECUTOR 3, .elli_enter
    BRANCH_ON_SPECIAL_BIT 15, lifeEventBits[1], .after_choose_ann_tail
    SPAWN_EXECUTOR 5, .karen_enter_with_maria

.after_choose_ann_tail:
    SET_WAIT_FRAMES 40
    SPAWN_EXECUTOR 1, .maria_enter
    SPAWN_EXECUTOR 2, .popuri_enter
    SET_WAIT_FRAMES 100
    SPAWN_EXECUTOR 4, .ann_after_dance
    DEACTIVATE_SELF

.after_choose_karen:
    SPAWN_EXECUTOR 3, .elli_enter
    SPAWN_EXECUTOR 4, .ann_enter
    SET_WAIT_FRAMES 40
    SPAWN_EXECUTOR 1, .maria_enter
    SPAWN_EXECUTOR 2, .popuri_enter
    SET_WAIT_FRAMES 100
    SPAWN_EXECUTOR 5, .karen_after_dance
    DEACTIVATE_SELF

; ----- Harvest-King bachelor spawn (branches from .gate_harvest_king) -----

.spawn_bachelor_harris:
    SPAWN_EXECUTOR 14, .harris_wait
    RETURN_FROM_SUBROUTINE

.spawn_bachelor_gray:
    SPAWN_EXECUTOR 15, .gray_wait
    RETURN_FROM_SUBROUTINE

.spawn_bachelor_jeff:
    SPAWN_EXECUTOR 16, .jeff_wait
    RETURN_FROM_SUBROUTINE

.spawn_bachelor_cliff:
    SPAWN_EXECUTOR 17, .cliff_wait
    RETURN_FROM_SUBROUTINE

.spawn_bachelor_kai:
    SPAWN_EXECUTOR 18, .kai_wait
    RETURN_FROM_SUBROUTINE

; ============================================================
; INTRO - Mayor speech, poll for chosen girl, then dance setup
; ============================================================

.map_helper_southeast:
    SETUP_MAP_ASSET MAIN_MAP_INDEX
    SET_ASSET_ROTATION SOUTH
    SET_COORDINATES -96, 96, 64
    EXECUTE_SUBROUTINE .wait_loop

.poll_until_chosen:
    SET_WAIT_FRAMES 1
    BRANCH_ON_SPECIAL_BIT 0, flags, .poll_until_chosen
    UPDATE_U16_VALUE 1, 9999, D_80189824
    BRANCH_U16_VAR_WITHIN_RANGE 1000, 1000, D_80189824, .after_chosen_dance_setup
    EXECUTE_SUBROUTINE .poll_until_chosen

.poll_during_interact:
    SET_WAIT_FRAMES 1
    BRANCH_ON_SPECIAL_BIT 0, flags, .poll_during_interact
    UPDATE_U16_VALUE 1, 9999, D_80189824
    BRANCH_U16_VAR_WITHIN_RANGE 1000, 1000, D_80189824, .poll_during_interact_msg
    EXECUTE_SUBROUTINE .poll_during_interact

.poll_during_interact_msg:
    PAUSE_ENTITY 0
    INIT_MESSAGE_BOX_TYPE1 0, FLOWER_FESTIVAL_TEXT_INDEX,6
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_U16_VALUE 0, D_80189824
    TOGGLE_PAUSE_ENTITY 0
    EXECUTE_SUBROUTINE .poll_during_interact

.after_chosen_dance_setup:
    PAUSE_ENTITIES
    SET_WAIT_FRAMES 1
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    SET_WAIT_FRAMES 40
    TOGGLE_PAUSE_ENTITIES
    SPAWN_EXECUTOR 0, .player_spawn_sw
    SET_OTHER_EXECUTOR_PTR 6, .face_sw_loop
    SET_WAIT_FRAMES 1
    SPAWN_EXECUTOR 38, .map_helper_southeast
    SET_WAIT_FRAMES 1
    UPDATE_GLOBAL_RGBA 255, 255, 255, 255, 8
    SET_WAIT_FRAMES 40
    BRANCH_U8_VAR_WITHIN_RANGE 0, 0, gFlowerFestivalGoddess, .after_choose_maria
    BRANCH_U8_VAR_WITHIN_RANGE 1, 1, gFlowerFestivalGoddess, .after_choose_popuri
    BRANCH_U8_VAR_WITHIN_RANGE 2, 2, gFlowerFestivalGoddess, .after_choose_elli
    BRANCH_U8_VAR_WITHIN_RANGE 3, 3, gFlowerFestivalGoddess, .after_choose_ann
    BRANCH_U8_VAR_WITHIN_RANGE 4, 4, gFlowerFestivalGoddess, .after_choose_karen
    CLEAR_SPECIAL_BIT 0, flags
    DEACTIVATE_SELF

.goddess_intro:
    EXECUTE_SUBROUTINE .setup_player
    SET_COORDINATES -144, 0, -56
    SET_ASSET_ROTATION NORTHWEST
    SET_WAIT_FRAMES 1
    UPDATE_GLOBAL_RGBA 255, 255, 255, 255, 8
    WAIT_RGBA_FINISHED
    SET_WAIT_FRAMES 15
    INIT_MESSAGE_BOX_TYPE1 0, FLOWER_FESTIVAL_TEXT_INDEX,0
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_U16_VALUE 0, D_80189824
    SPAWN_EXECUTOR 37, .poll_until_chosen
    SET_ENTITY_MAP_SPACE_INDEPENDENT FALSE
    DEACTIVATE_SELF

; ----- Player (slot 0) state variants -----

.player_spawn_sw:
    EXECUTE_SUBROUTINE .setup_player
    SET_BEHAVIOR_FLAGS 0
    SET_COORDINATES 32, 0, 32
    SET_ASSET_ROTATION WEST
    EXECUTE_SUBROUTINE .wait_loop

.player_post_intro_walk:
    SET_BEHAVIOR_FLAGS CUTSCENE_ASSET_BEHAVIOR_TRACK_ENTITY
    SET_WAIT_FRAMES 1
    SET_SPECIAL_BIT 1, flags
    SET_OTHER_EXECUTOR_PTR 6, .face_se_loop
    BRANCH_U8_VAR_WITHIN_RANGE 1, 1, gHarvestKing, .king_slot_harris
    BRANCH_U8_VAR_WITHIN_RANGE 2, 2, gHarvestKing, .king_slot_gray
    BRANCH_U8_VAR_WITHIN_RANGE 3, 3, gHarvestKing, .king_slot_jeff
    BRANCH_U8_VAR_WITHIN_RANGE 4, 4, gHarvestKing, .king_slot_cliff
    BRANCH_U8_VAR_WITHIN_RANGE 5, 5, gHarvestKing, .king_slot_kai
    BRANCH_U8_VAR_WITHIN_RANGE 6, 6, gHarvestKing, .king_slot_potion
    UPDATE_GLOBAL_RGBA 255, 255, 255, 255, 8
    WAIT_RGBA_FINISHED
    SET_ENTITY_MAP_SPACE_INDEPENDENT FALSE
    DEACTIVATE_SELF

.player_bow_to_girl:
    EXECUTE_SUBROUTINE .setup_player
    SET_OTHER_EXECUTOR_PTR 36, .track_player_then_exit
    SET_ENTITY_DIRECTIONAL_ANIMATION 24
    SET_WAIT_FRAMES 20
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SET_ENTITY_MAP_SPACE_INDEPENDENT FALSE
    PAUSE_ENTITY 0
    DEACTIVATE_SELF

.king_slot_harris:
    SET_OTHER_EXECUTOR_PTR 14, .king_avatar_pos
    RETURN_FROM_SUBROUTINE

.king_slot_gray:
    SET_OTHER_EXECUTOR_PTR 15, .king_avatar_pos
    RETURN_FROM_SUBROUTINE

.king_slot_jeff:
    SET_OTHER_EXECUTOR_PTR 16, .king_avatar_pos
    RETURN_FROM_SUBROUTINE

.king_slot_cliff:
    SET_OTHER_EXECUTOR_PTR 17, .king_avatar_pos
    RETURN_FROM_SUBROUTINE

.king_slot_kai:
    SET_OTHER_EXECUTOR_PTR 18, .king_avatar_pos
    RETURN_FROM_SUBROUTINE

.king_slot_potion:
    SET_OTHER_EXECUTOR_PTR 11, .king_avatar_pos
    RETURN_FROM_SUBROUTINE

.king_avatar_pos:
    SET_COORDINATES -176, 0, -88
    SET_ASSET_ROTATION SOUTHEAST
    EXECUTE_SUBROUTINE .wait_loop

; ============================================================
; NPC EXECUTORS - each NPC has:
;   _wait       - idle state, runs callback on interact
;   _on_interact- bumps affection (once per session)
;   _talk*      - message branches varied by affection/state
;   _talk_done  - shared close handler (resumes _wait)
; ============================================================

; ----- Mayor (slot 6) -----

.setup_mayor:
    SETUP_ENTITY 6, ENTITY_ASSET_MAYOR, 1
    SET_ENTITY_ANIMATIONS 6, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    RETURN_FROM_SUBROUTINE

.mayor_wait:
    EXECUTE_SUBROUTINE .setup_mayor
    SET_COORDINATES -176, 0, -56
    SET_ASSET_ROTATION SOUTHEAST

.mayor_wait_loop:
    SET_CALLBACK_ROUTINE 0, 32768, .mayor_on_interact
    EXECUTE_SUBROUTINE .wait_loop

.mayor_on_interact:
    BRANCH_ON_SPECIAL_BIT 0, affectionBumpedBits, .mayor_talk
    UPDATE_U8_VALUE 2, 255, npcAffection[NPC_MAYOR]
    SET_SPECIAL_BIT 0, affectionBumpedBits

.mayor_talk:
    EXECUTE_SUBROUTINE .setup_message_box
    SET_SPECIAL_BIT 0, flags
    PAUSE_ENTITY 0
    FLIP_ENTITY_DIRECTION 0
    BRANCH_ON_SPECIAL_BIT 1, flags, .mayor_choose_partner
    INIT_MESSAGE_BOX_TYPE1 0, FLOWER_FESTIVAL_TEXT_INDEX,0

.mayor_talk_done:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITY 0
    CLEAR_SPECIAL_BIT 0, flags
    EXECUTE_SUBROUTINE .mayor_wait_loop

.mayor_choose_partner:
    SET_SPECIAL_BIT 2, flags
    SET_U16_VALUE 0, D_80189824
    SPAWN_EXECUTOR 37, .poll_during_interact
    BRANCH_U8_VAR_WITHIN_RANGE 0, 0, gHarvestKing, .mayor_player_king_prompt
    INIT_MESSAGE_BOX_TYPE1 0, FLOWER_FESTIVAL_TEXT_INDEX,1
    BRANCH_U8_VAR_WITHIN_RANGE 1, 1, gHarvestKing, .mayor_choose_king_harris
    BRANCH_U8_VAR_WITHIN_RANGE 2, 2, gHarvestKing, .mayor_choose_king_gray
    BRANCH_U8_VAR_WITHIN_RANGE 3, 3, gHarvestKing, .mayor_choose_king_jeff
    BRANCH_U8_VAR_WITHIN_RANGE 4, 4, gHarvestKing, .mayor_choose_king_cliff
    BRANCH_U8_VAR_WITHIN_RANGE 5, 5, gHarvestKing, .mayor_choose_king_kai
    EXECUTE_SUBROUTINE .mayor_talk_done

.mayor_choose_king_harris:
    BRANCH_U8_VAR_WITHIN_RANGE 0, 0, gSumGirlsWithHighAffection, .mayor_talk_done
    BRANCH_U8_VAR_WITHIN_RANGE 0, 0, gFlowerFestivalGoddess, .mayor_harris_g0
    BRANCH_U8_VAR_WITHIN_RANGE 1, 1, gFlowerFestivalGoddess, .mayor_harris_g1
    BRANCH_U8_VAR_WITHIN_RANGE 2, 2, gFlowerFestivalGoddess, .mayor_harris_g2
    BRANCH_U8_VAR_WITHIN_RANGE 3, 3, gFlowerFestivalGoddess, .mayor_harris_g3
    BRANCH_U8_VAR_WITHIN_RANGE 4, 4, gFlowerFestivalGoddess, .mayor_harris_g4

.mayor_king_harris_cue:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_WAIT_FRAMES 20
    SET_OTHER_EXECUTOR_PTR 14, .face_sw_loop
    INIT_MESSAGE_BOX_TYPE1 0, FLOWER_FESTIVAL_TEXT_INDEX,94
    EXECUTE_SUBROUTINE .mayor_player_king_start_dance

.mayor_harris_g0:
    BRANCH_ON_SPECIAL_BIT MARRIED, lifeEventBits[0], .mayor_harris_g0_wife
    BRANCH_U8_VAR_WITHIN_RANGE 1, 1, gSumGirlsWithHighAffection, .mayor_king_harris_cue
    EXECUTE_SUBROUTINE .mayor_talk_done

.mayor_harris_g0_wife:
    BRANCH_U8_VAR_WITHIN_RANGE 0, 0, gWife, .mayor_king_harris_cue
    RETURN_FROM_SUBROUTINE

.mayor_harris_g1:
    BRANCH_ON_SPECIAL_BIT MARRIED, lifeEventBits[0], .mayor_harris_g1_wife
    BRANCH_U8_VAR_WITHIN_RANGE 2, 2, gSumGirlsWithHighAffection, .mayor_king_harris_cue
    EXECUTE_SUBROUTINE .mayor_talk_done

.mayor_harris_g1_wife:
    BRANCH_U8_VAR_WITHIN_RANGE 1, 1, gWife, .mayor_king_harris_cue
    RETURN_FROM_SUBROUTINE

.mayor_harris_g2:
    BRANCH_ON_SPECIAL_BIT MARRIED, lifeEventBits[0], .mayor_harris_g2_wife
    BRANCH_U8_VAR_WITHIN_RANGE 3, 3, gSumGirlsWithHighAffection, .mayor_king_harris_cue
    EXECUTE_SUBROUTINE .mayor_talk_done

.mayor_harris_g2_wife:
    BRANCH_U8_VAR_WITHIN_RANGE 2, 2, gWife, .mayor_king_harris_cue
    RETURN_FROM_SUBROUTINE

.mayor_harris_g3:
    BRANCH_ON_SPECIAL_BIT MARRIED, lifeEventBits[0], .mayor_harris_g3_wife
    BRANCH_U8_VAR_WITHIN_RANGE 4, 4, gSumGirlsWithHighAffection, .mayor_king_harris_cue
    EXECUTE_SUBROUTINE .mayor_talk_done

.mayor_harris_g3_wife:
    BRANCH_U8_VAR_WITHIN_RANGE 3, 3, gWife, .mayor_king_harris_cue
    RETURN_FROM_SUBROUTINE

.mayor_harris_g4:
    BRANCH_ON_SPECIAL_BIT MARRIED, lifeEventBits[0], .mayor_harris_g4_wife
    BRANCH_U8_VAR_WITHIN_RANGE 5, 5, gSumGirlsWithHighAffection, .mayor_king_harris_cue
    EXECUTE_SUBROUTINE .mayor_talk_done

.mayor_harris_g4_wife:
    BRANCH_U8_VAR_WITHIN_RANGE 4, 4, gWife, .mayor_king_harris_cue
    RETURN_FROM_SUBROUTINE

.mayor_choose_king_gray:
    BRANCH_U8_VAR_WITHIN_RANGE 0, 0, gSumGirlsWithHighAffection, .mayor_talk_done
    BRANCH_U8_VAR_WITHIN_RANGE 0, 0, gFlowerFestivalGoddess, .mayor_gray_g0
    BRANCH_U8_VAR_WITHIN_RANGE 1, 1, gFlowerFestivalGoddess, .mayor_gray_g1
    BRANCH_U8_VAR_WITHIN_RANGE 2, 2, gFlowerFestivalGoddess, .mayor_gray_g2
