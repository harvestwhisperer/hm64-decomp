.mayor_player_king_prompt:
    INIT_DIALOGUE_SESSION 0, DIALOGUE_TEXT_49,0
    WAIT_FOR_DIALOGUE_INPUT 0
    BRANCH_ON_DIALOGUE 0, 0, .mayor_player_king_yes
    BRANCH_ON_DIALOGUE 0, 1, .mayor_player_king_no

.mayor_player_king_yes:
    INIT_MESSAGE_BOX_TYPE1 0, FLOWER_FESTIVAL_TEXT_INDEX,4

.mayor_player_king_start_dance:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITY 0
    DEACTIVATE_EXECUTOR 37
    CLEAR_SPECIAL_BIT 0, flags
    EXECUTE_SUBROUTINE .dance_dispatch_chosen

.mayor_player_king_no:
    INIT_MESSAGE_BOX_TYPE1 0, FLOWER_FESTIVAL_TEXT_INDEX,5
    EXECUTE_SUBROUTINE .mayor_talk_done

; ----- Lillia (slot 7) -----

.setup_lillia:
    SETUP_ENTITY 7, ENTITY_ASSET_LILLIA, 1
    SET_ENTITY_ANIMATIONS 7, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    RETURN_FROM_SUBROUTINE

.lillia_wait:
    EXECUTE_SUBROUTINE .setup_lillia
    SET_COORDINATES -160, 0, -224

.lillia_wait_loop:
