    WAIT_ENTITY_ANIMATION
    RETURN_FROM_SUBROUTINE

.dance_goddess_karen_turn:
    SET_ENTITY_ANIMATION 90
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_ANIMATION 91
    WAIT_ENTITY_ANIMATION
    SET_WAIT_FRAMES 14
    SET_ENTITY_ANIMATION 90
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    RETURN_FROM_SUBROUTINE

.dance_goddess_karen_body:
    SET_ENTITY_ANIMATION 87
    SET_WAIT_FRAMES 78
    EXECUTE_SUBROUTINE .dance_goddess_karen_bow
    SET_WAIT_FRAMES 2
    SET_ENTITY_ANIMATION 87
    SET_WAIT_FRAMES 78
    EXECUTE_SUBROUTINE .dance_goddess_karen_bow
    SET_WAIT_FRAMES 2
    SET_ENTITY_ANIMATION 88
    SET_FRAME_DELTA 0, 0, -1, 48
    SET_WAIT_FRAMES 24
    EXECUTE_SUBROUTINE .dance_goddess_karen_bow
    SET_WAIT_FRAMES 2
    SET_ENTITY_ANIMATION 88
    SET_FRAME_DELTA 0, 0, 1, 48
    SET_WAIT_FRAMES 20
    EXECUTE_SUBROUTINE .dance_goddess_karen_bow
    EXECUTE_SUBROUTINE .dance_goddess_karen_turn
    SET_ENTITY_ANIMATION 88
    SET_FRAME_DELTA 1, 0, 0, 48
    SET_WAIT_FRAMES 24
    EXECUTE_SUBROUTINE .dance_goddess_karen_bow
    SET_WAIT_FRAMES 2
    SET_ENTITY_ANIMATION 88
    SET_FRAME_DELTA -1, 0, 0, 48
    SET_WAIT_FRAMES 24
    EXECUTE_SUBROUTINE .dance_goddess_karen_bow
    SET_WAIT_FRAMES 2
    SET_ENTITY_ANIMATION 88
    SET_FRAME_DELTA -1, 0, 0, 48
    SET_WAIT_FRAMES 24
    EXECUTE_SUBROUTINE .dance_goddess_karen_bow
    SET_WAIT_FRAMES 2
    SET_ENTITY_ANIMATION 88
    SET_FRAME_DELTA 1, 0, 0, 48
    SET_WAIT_FRAMES 13
    EXECUTE_SUBROUTINE .dance_goddess_karen_bow
    EXECUTE_SUBROUTINE .dance_goddess_karen_turn
    EXECUTE_SUBROUTINE .dance_goddess_karen_body

; ============================================================
; END-OF-DANCE CONTROLLER (slot 33) - fades music and screen,
; deactivates all executors, returns to exit_cutscene
; ============================================================

.dance_end_fadeout:
    SET_WAIT_FRAMES 1100
    SET_AUDIO_SEQUENCE_VOLUME 0, 0, 2
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 4
    SET_WAIT_FRAMES 80
    DEACTIVATE_EXECUTOR 0
    DEACTIVATE_EXECUTOR 1
    DEACTIVATE_EXECUTOR 2
    DEACTIVATE_EXECUTOR 3
    DEACTIVATE_EXECUTOR 4
    DEACTIVATE_EXECUTOR 5
    DEACTIVATE_EXECUTOR 6
    DEACTIVATE_EXECUTOR 7
    DEACTIVATE_EXECUTOR 8
    DEACTIVATE_EXECUTOR 9
    STOP_SEQUENCE_WITH_FADE 0, 1
    IDLE_WHILE_SEQUENCE_PLAYING 0
    EXECUTE_SUBROUTINE .exit_cutscene
