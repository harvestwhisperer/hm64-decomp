    SET_ANIM_DATA_PTR_WITH_FLAG .balloon_anim
    SET_COORDINATES -32, -16, 16
    SET_RGBA 255, 255, 255, 255
    EXECUTE_SUBROUTINE .wait_loop

.balloon_spr_25:
    DMA_SPRITE 165, 0, _balloonsTextureSegmentRomStart, _balloonsTextureSegmentRomEnd, _balloonsAssetsIndexSegmentRomStart, _balloonsAssetsIndexSegmentRomEnd, 0, 0, ENTITY_REGION_SMALL_SPRITE_BASE, 0, ENTITY_SLOT_FESTIVAL_44_TEXTURE_1, 0x802CEC50, 0x802CF150, 0x802CF250
    SET_ANIM_DATA_PTR_WITH_FLAG .balloon_anim
    SET_COORDINATES -56, 48, 32
    SET_RGBA 255, 255, 255, 255
    EXECUTE_SUBROUTINE .wait_loop

.balloon_spr_26:
    DMA_SPRITE 166, 0, _balloonsTextureSegmentRomStart, _balloonsTextureSegmentRomEnd, _balloonsAssetsIndexSegmentRomStart, _balloonsAssetsIndexSegmentRomEnd, 0, 0, ENTITY_REGION_SMALL_SPRITE_BASE, 0, ENTITY_SLOT_FESTIVAL_44_TEXTURE_1, 0x802CEC50, 0x802CF150, 0x802CF250
    SET_ANIM_DATA_PTR_WITH_FLAG .balloon_anim
    SET_COORDINATES -56, 48, 32
    SET_RGBA 255, 255, 255, 255
    EXECUTE_SUBROUTINE .wait_loop

.balloon_spr_27:
    DMA_SPRITE 167, 0, _balloonsTextureSegmentRomStart, _balloonsTextureSegmentRomEnd, _balloonsAssetsIndexSegmentRomStart, _balloonsAssetsIndexSegmentRomEnd, 0, 0, ENTITY_REGION_SMALL_SPRITE_BASE, 0, ENTITY_SLOT_FESTIVAL_44_TEXTURE_1, 0x802CEC50, 0x802CF150, 0x802CF250
    SET_ANIM_DATA_PTR_WITH_FLAG .balloon_anim
    SET_COORDINATES -80, 32, 16
    SET_RGBA 255, 255, 255, 255
