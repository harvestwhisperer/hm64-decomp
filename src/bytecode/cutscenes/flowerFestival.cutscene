; ============================================================
; CHOSEN-GIRL EXECUTORS - each bachelorette has:
;   _entry_walk    - helper: walk from spawn to square center
;   _enter         - executor: entered but not chosen
;   _after_dance   - executor: post-dance idle + chat
;   plus the full _wait / _talk / _chosen_confirm dialogue tree
; ============================================================

; ----- Maria (slot 1) -----

.maria_entry_walk:
    SET_COORDINATES -288, 0, 96
    SET_ASSET_ROTATION SOUTHEAST
    ENTITY_WALK 32, SOUTHEAST, 2
    ENTITY_WALK 24, SOUTH, 2
    SET_ASSET_ROTATION NORTHEAST
    RETURN_FROM_SUBROUTINE

.maria_enter:
    SETUP_ENTITY 1, ENTITY_ASSET_MARIA, 1
    SET_ENTITY_ANIMATIONS 1, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    EXECUTE_SUBROUTINE .maria_entry_walk
    SET_ENTITY_ANIMATION 72
    SET_WAIT_FRAMES 13
    SPAWN_EXECUTOR 27, .balloon_spr_27
    SET_WAIT_FRAMES 19
    SPAWN_EXECUTOR 28, .balloon_spr_28
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    EXECUTE_SUBROUTINE .maria_wait_loop

.setup_maria_after_dance:
    SETUP_ENTITY 1, ENTITY_ASSET_MARIA, 1
    SET_ENTITY_ANIMATIONS 1, 73, 0, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    RETURN_FROM_SUBROUTINE

