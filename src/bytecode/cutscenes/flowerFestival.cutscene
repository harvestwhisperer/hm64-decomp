    BRANCH_U8_VAR_WITHIN_RANGE 0, 99, npcAffection[NPC_RICK], .rick_talk_low
    BRANCH_U8_VAR_WITHIN_RANGE 100, 255, npcAffection[NPC_RICK], .rick_talk_high

.rick_talk_done:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITY 0
    CLEAR_SPECIAL_BIT 0, flags
    EXECUTE_SUBROUTINE .rick_wait_loop

.rick_talk_2:
    INIT_MESSAGE_BOX_TYPE1 0, FLOWER_FESTIVAL_TEXT_INDEX,14
    EXECUTE_SUBROUTINE .rick_talk_done

; ----- Shady Salesman (slot 13) - sells Power Nut -----

.shady_wait:
    SETUP_ENTITY 13, ENTITY_ASSET_SHADY_SALESMAN, 1
    SET_ENTITY_ANIMATIONS 13, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    SET_COORDINATES -288, 0, -160
    SET_ASSET_ROTATION SOUTHEAST

.shady_wait_loop:
    SET_CALLBACK_ROUTINE 0, 32768, .shady_on_interact
    EXECUTE_SUBROUTINE .wait_loop

.shady_on_interact:
    EXECUTE_SUBROUTINE .setup_message_box
    SET_SPECIAL_BIT 0, flags
    PAUSE_ENTITY 0
    FLIP_ENTITY_DIRECTION 0
    BRANCH_ON_SPECIAL_BIT 3, flags, .shady_already_bought
    INIT_DIALOGUE_SESSION 0, DIALOGUE_TEXT_49,9
    WAIT_FOR_DIALOGUE_INPUT 0
    BRANCH_ON_DIALOGUE 0, 0, .shady_buy_yes
    BRANCH_ON_DIALOGUE 0, 1, .shady_buy_no

.shady_buy_yes:
    BRANCH_U32_VAR_WITHIN_RANGE 0, 999, gGold, .shady_not_enough_gold
    UPDATE_U32_VALUE 4294966296, 999999, gGold
    INIT_MESSAGE_BOX_TYPE1 0, FLOWER_FESTIVAL_TEXT_INDEX,102
    SET_SPECIAL_BIT 3, flags
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITY 0
    SPAWN_EXECUTOR 0, .player_receive_power_nut
    EXECUTE_SUBROUTINE .shady_wait_loop

.shady_already_bought:
    INIT_MESSAGE_BOX_TYPE1 0, FLOWER_FESTIVAL_TEXT_INDEX,102
    EXECUTE_SUBROUTINE .shady_talk_done

.shady_buy_no:
    INIT_MESSAGE_BOX_TYPE1 0, FLOWER_FESTIVAL_TEXT_INDEX,103

.shady_talk_done:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITY 0
    CLEAR_SPECIAL_BIT 0, flags
    EXECUTE_SUBROUTINE .shady_wait_loop

.shady_not_enough_gold:
    INIT_MESSAGE_BOX_TYPE1 0, FLOWER_FESTIVAL_TEXT_INDEX,104
    EXECUTE_SUBROUTINE .shady_talk_done

.player_receive_power_nut:
    EXECUTE_SUBROUTINE .setup_player
    SET_ASSET_ROTATION SOUTHWEST
    SPAWN_EXECUTOR 32, .power_nut_shine
    SET_ENTITY_DIRECTIONAL_ANIMATION 24
    SET_WAIT_FRAMES 30
    SET_ENTITY_ANIMATION 437
    WAIT_ENTITY_ANIMATION
    SET_SPECIAL_BIT 7, acquiredPowerNutBits
    UPDATE_U8_VALUE 15, 250, gMaximumStamina
    UPDATE_U8_VALUE 2, 255, gHappiness
    SET_ENTITY_MAP_SPACE_INDEPENDENT FALSE
    TOGGLE_PAUSE_ENTITIES
    CLEAR_SPECIAL_BIT 0, flags
    DEACTIVATE_SELF

.power_nut_shine:
    SETUP_ENTITY 28, ENTITY_ASSET_STATIC_ITEM, 1
    SET_ENTITY_ANIMATIONS 28, 0, 0, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_ANIMATION 210
    SET_ENTITY_TRACKING_TARGET 0, 0, 14, 20, 255
    SET_WAIT_FRAMES 30
    SET_ENTITY_TRACKING_TARGET 0, 0, 32, 16, 255
    SET_WAIT_FRAMES 10
    DEACTIVATE_SELF

