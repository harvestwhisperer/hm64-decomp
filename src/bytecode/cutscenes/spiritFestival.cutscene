; ============================================================
; Orchestrator helpers (music sequence + stage dispatch)
; ============================================================
; var0 bits 0..3 record which song each assistant chose; the
; orchestrator branches on those bits to start the matching
; sequence, and uses bit 4 to gate the final ensemble song.
; ============================================================

.branch_146F9C:
    BRANCH_ON_SPECIAL_BIT 1, var0, .branch_146FAC
    EXECUTE_SUBROUTINE .orchestrator_play_song_by_var0

.branch_146FAC:
    BRANCH_ON_SPECIAL_BIT 2, var0, .branch_146FBC
    EXECUTE_SUBROUTINE .orchestrator_play_song_by_var0

.branch_146FBC:
    BRANCH_ON_SPECIAL_BIT 3, var0, .branch_146FCC
    EXECUTE_SUBROUTINE .orchestrator_play_song_by_var0

.branch_146FCC:
    SET_AUDIO_SEQUENCE 0, _ensemblePerformanceSegmentRomStart, _ensemblePerformanceSegmentRomEnd
    SET_AUDIO_SEQUENCE_VOLUME 0, 128, 128
    SET_SPECIAL_BIT 4, var0
    EXECUTE_SUBROUTINE .orchestrator_stage2

.branch_146FEC:
    SET_AUDIO_SEQUENCE 1, _vocalPerformanceSegmentRomStart, _vocalPerformanceSegmentRomEnd
    SET_AUDIO_SEQUENCE_VOLUME 1, 128, 128
    RETURN_FROM_SUBROUTINE

.branch_147004:
    SET_AUDIO_SEQUENCE 2, _flutePerformanceSegmentRomStart, _flutePerformanceSegmentRomEnd
    SET_AUDIO_SEQUENCE_VOLUME 2, 128, 128
    RETURN_FROM_SUBROUTINE

.branch_14701C:
    SET_AUDIO_SEQUENCE 3, _sleighBellsSegmentRomStart, _sleighBellsSegmentRomEnd
    SET_AUDIO_SEQUENCE_VOLUME 3, 128, 128
    RETURN_FROM_SUBROUTINE

.branch_147034:
    SET_AUDIO_SEQUENCE 0, _ocarinaPerformanceSegmentRomStart, _ocarinaPerformanceSegmentRomEnd
    SET_AUDIO_SEQUENCE_VOLUME 0, 128, 128
    RETURN_FROM_SUBROUTINE

