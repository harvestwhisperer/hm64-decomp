; ============================================================
; Finale (mayor closing speech + fade to black + teardown)
; ============================================================
; Executor 5 walks east, faces the stage, shows the mayors
; closing speech (text 10), plays SFX 84, fades to black and
; deactivates every executor that was spawned.
; ============================================================

.executor_5_finale:
    ENTITY_WALK 16, DIRECTION_NE, 2
    SET_ASSET_ROTATION 6
    INIT_MESSAGE_BOX_TYPE1 0, SPIRIT_FESTIVAL_TEXT_INDEX, 10
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_ASSET_ROTATION 4
    SET_SFX 84, 128
    SET_WAIT_FRAMES 60
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    DEACTIVATE_EXECUTOR 0
    DEACTIVATE_EXECUTOR 1
    DEACTIVATE_EXECUTOR 2
    DEACTIVATE_EXECUTOR 3
    DEACTIVATE_EXECUTOR 4
    DEACTIVATE_EXECUTOR 6
    DEACTIVATE_EXECUTOR 8
