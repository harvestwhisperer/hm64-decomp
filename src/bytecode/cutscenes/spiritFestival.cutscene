; ============================================================
; Cutscene 1352 - repeat spirit festival
; ============================================================
; Used after the festival has already been watched once. Gives
; last years Harvest King a +3 affection bump, re-rolls a new
; pair of assistants at random, and forces the player into the
; third assistant slot so the scene closes on the player.
; ============================================================

.dispatch_repeat:
    SPAWN_EXECUTOR 1, .executor_1_ocarina_backdrop
    BRANCH_U8_VAR_WITHIN_RANGE 1, 1, gHarvestKing, .last_king_harris
    BRANCH_U8_VAR_WITHIN_RANGE 2, 2, gHarvestKing, .last_king_gray
    BRANCH_U8_VAR_WITHIN_RANGE 3, 3, gHarvestKing, .last_king_jeff
    BRANCH_U8_VAR_WITHIN_RANGE 4, 4, gHarvestKing, .last_king_cliff
    BRANCH_U8_VAR_WITHIN_RANGE 5, 5, gHarvestKing, .last_king_kai
    BRANCH_U8_VAR_WITHIN_RANGE 6, 6, gHarvestKing, .last_king_potion_shop_dealer

.repeat_roll_assistant1:
    EXECUTE_SUBROUTINE .repeat_roll_assistant1_table

.repeat_roll_assistant2:
    EXECUTE_SUBROUTINE .repeat_roll_assistant2_table

.repeat_spawn_audience_as_player:
    SET_U8_VALUE 11, spiritFestivalAssistant3
    SPAWN_EXECUTOR 4, .executor_4_repeat_player
    SPAWN_EXECUTOR 5, .executor_5_14778C
    UPDATE_U8_VALUE 2, 255, npcAffection[NPC_MAYOR]
    SPAWN_EXECUTOR 6, .executor_6_1477B8
    UPDATE_U8_VALUE 2, 255, npcAffection[NPC_MAYOR_WIFE]
    BRANCH_U8_VAR_WITHIN_RANGE 1, 1, gYear, .branch_147C7C
    SPAWN_EXECUTOR 8, .executor_8_1477E4
    UPDATE_U8_VALUE 2, 255, npcAffection[NPC_POTION_SHOP_DEALER]

.branch_147C7C:
    SPAWN_EXECUTOR 9, .executor_9_147810
    UPDATE_U8_VALUE 2, 255, npcAffection[NPC_KENT]
    SPAWN_EXECUTOR 10, .executor_10_14783C
    UPDATE_U8_VALUE 2, 255, npcAffection[NPC_STU]
    SPAWN_EXECUTOR 11, .executor_11_147868
    UPDATE_U8_VALUE 2, 255, npcAffection[NPC_MIDWIFE]
    SPAWN_EXECUTOR 12, .executor_12_147894
    UPDATE_U8_VALUE 2, 255, npcAffection[NPC_DOUG]
    SPAWN_EXECUTOR 13, .executor_13_1478C0
    UPDATE_U8_VALUE 2, 255, npcAffection[NPC_SHIPPER]
