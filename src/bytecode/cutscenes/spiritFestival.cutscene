    SPAWN_EXECUTOR 17, .executor_17_147974
    UPDATE_U8_VALUE 2, 255, npcAffection[NPC_LILLIA]
    SPAWN_EXECUTOR 41, .executor_41_repeat_orchestrator
    DEACTIVATE_SELF

