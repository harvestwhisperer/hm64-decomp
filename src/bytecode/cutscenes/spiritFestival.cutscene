; ============================================================
; Bank 22 - Spirit Festival
; ============================================================
;
;   1350 - player is the Harvest King (spiritFestivalAssistant3
;          is forced to 11, the player, via sub_147C24).
;   1351 - regular spirit festival (three random assistants).
;   1352 - repeat viewing after it has already been watched.
;
; Assistant slot values used by spiritFestivalAssistant1/2/3:
;   1 Maria, 2 Popuri, 3 Elli, 4 Ann, 5 Karen,
;   6 Harris, 7 Gray, 8 Jeff, 9 Cliff, 10 Kai, 11 Player
;
; Executor slot layout (1351 path):
;   0       - player
;   1       - stage backdrop entity
;   2, 3, 4 - the three selected assistants (per spawn pass)
;   5..17   - the fixed audience NPCs
;   40      - map camera / frame delta controller
;   41      - orchestrator: triggers song segments and timing
;
; var0 bit usage (music / dispatch state in executor 41):
;   bit 0   - first assistant has started a song
;   bit 1   - second assistant has started a song
;   bit 2   - third assistant has started a song
;   bit 3   - all three assistants have started
;   bit 4   - final ensemble performance triggered
; ============================================================

#include "entities.h"
#include "texts.h"

#define MAIN_MAP_INDEX 0

.buffer 2

; Local variables
.local var0, u32, 0

.array npcAffection, u8
.array lifeEventBits, u32

.start:
    SET_SPECIAL_BIT 12, gCutsceneCompletionFlags
    SET_SPECIAL_BIT 15, gCutsceneCompletionFlags
    PAUSE_ENTITIES
    STOP_SEQUENCE_WITH_FADE 0, 8
    IDLE_WHILE_SEQUENCE_PLAYING 0
    TOGGLE_PAUSE_ENTITIES
    SET_MESSAGE_INTERPOLATION -4, 0, 0
    SET_MESSAGE_BOX_ASSETS 0, 0, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 24, -64, 352
    BRANCH_U16_VAR_WITHIN_RANGE 1350, 1350, gCutsceneIndex, .dispatch_harvest_king
    BRANCH_U16_VAR_WITHIN_RANGE 1351, 1351, gCutsceneIndex, .dispatch_festival
    BRANCH_U16_VAR_WITHIN_RANGE 1352, 1352, gCutsceneIndex, .dispatch_repeat

; ============================================================
; Shared helpers
; ============================================================

.exit:
    SET_SPECIAL_BIT 0, gCutsceneCompletionFlags
    SET_U8_VALUE 0, spiritFestivalAssistant1
    SET_U8_VALUE 0, spiritFestivalAssistant2
    SET_U8_VALUE 0, spiritFestivalAssistant3
    DEACTIVATE_SELF

.wait_loop:
    SET_WAIT_FRAMES 1
    EXECUTE_SUBROUTINE .wait_loop

.setup_player:
    SETUP_ENTITY 0, ENTITY_ASSET_PLAYER, 1
    SET_ENTITY_ANIMATIONS 0, 0, 8, 16, 24, 32, 40
    SET_BEHAVIOR_FLAGS CUTSCENE_ASSET_BEHAVIOR_TRACK_ENTITY
    RETURN_FROM_SUBROUTINE

; ----- Direction-only executor stubs (handed out via SET_OTHER_EXECUTOR_PTR) -----
.executor_4_145020:
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    EXECUTE_SUBROUTINE .wait_loop

.executor_2_145028:
    SET_ASSET_ROTATION 4
    EXECUTE_SUBROUTINE .wait_loop

.executor_3_145030:
    SET_ASSET_ROTATION 0
    EXECUTE_SUBROUTINE .wait_loop

.executor_2_145038:
    SET_ASSET_ROTATION 6
    EXECUTE_SUBROUTINE .wait_loop

.executor_3_145040:
    SET_ASSET_ROTATION 1
    EXECUTE_SUBROUTINE .wait_loop

; ============================================================
; Cutscene 1350 - player is the Harvest King
; ============================================================
; Same spawn/roll tables as cutscene 1351 below, but entered via
; a separate branch because the caller uses a different camera /
; transition setup for the player-is-king variant.
; ============================================================

.dispatch_harvest_king:
    SPAWN_EXECUTOR 1, .executor_1_ocarina_backdrop
    BRANCH_U8_VAR_WITHIN_RANGE 0, 0, spiritFestivalAssistant1, .roll_assistant1

