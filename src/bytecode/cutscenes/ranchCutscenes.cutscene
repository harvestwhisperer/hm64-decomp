    ENTITY_WALK 96, DIRECTION_N, 2
    SET_WAIT_FRAMES 30
    BRANCH_U16_VAR_WITHIN_RANGE 652, 652, gCutsceneIndex, .cutscene_652_exit
    BRANCH_U16_VAR_WITHIN_RANGE 653, 653, gCutsceneIndex, .cutscene_653_exit
    DEACTIVATE_SELF

