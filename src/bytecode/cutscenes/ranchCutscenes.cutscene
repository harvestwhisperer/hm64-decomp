; --- Gray enters from offscreen, carries items ---

.gray_enter:
    EXECUTE_SUBROUTINE .setup_gray_entity_36
    SET_COORDINATES -352, 0, -88
    SET_ASSET_ROTATION 0
    SET_WAIT_FRAMES 15
    ENTITY_WALK 48, DIRECTION_E, 2
    ENTITY_WALK 40, DIRECTION_N, 2
