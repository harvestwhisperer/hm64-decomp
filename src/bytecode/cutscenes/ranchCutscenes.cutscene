    SET_ASSET_ROTATION 6
    SET_WAIT_FRAMES 30
    SET_OTHER_EXECUTOR_PTR 1, .popuri_gray_manure_talk
    EXECUTE_SUBROUTINE .wait_loop

; --- Popuri and Gray conversation about manure ---

.popuri_gray_manure_talk:
    ENTITY_WALK 80, DIRECTION_W, 2
    SET_ASSET_ROTATION 0
    SET_OTHER_EXECUTOR_PTR 2, .face_northeast_and_wait
    SET_ENTITY_ANIMATION 48
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_ANIMATION 50
    INIT_MESSAGE_BOX_TYPE1 0, RANCH_CUTSCENES_TEXT_INDEX, 27
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_ENTITY_ANIMATION 48
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SET_WAIT_FRAMES 15
    SET_ENTITY_ANIMATION 35
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_ANIMATION 39
    SET_OTHER_EXECUTOR_PTR 2, .face_southwest_and_wait
    SPAWN_EXECUTOR 13, .executor_13_115544
    INIT_MESSAGE_BOX_TYPE1 0, RANCH_CUTSCENES_TEXT_INDEX, 28
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_ENTITY_ANIMATION 35
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SPAWN_EXECUTOR 13, .executor_13_115528
    INIT_MESSAGE_BOX_TYPE1 0, RANCH_CUTSCENES_TEXT_INDEX, 29
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 2, .gray_talk_manure
    EXECUTE_SUBROUTINE .wait_loop

; --- Gray says he was carrying manure ---

.gray_talk_manure:
    ENTITY_WALK 16, DIRECTION_S, 2
    INIT_MESSAGE_BOX_TYPE1 0, RANCH_CUTSCENES_TEXT_INDEX, 30
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 1, .popuri_respond_fertilizer
    EXECUTE_SUBROUTINE .wait_loop

