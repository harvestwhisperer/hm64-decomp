; ===========================================================================
; Bank 6 - Ranch Cutscenes
;
; Index  Description
; -----  -----------
; 650    Get horse
; 651    Horse naming follow-up (post-650, loads level and initializes horse)
; 652    Popuri visits ranch, talks flowers with Ann (spawn point 1)
; 653    Same as 652 (spawn point 2)
; 654    Gray and Popuri talk at ranch evening (spawn point 1)
; 655    Same as 654 (spawn point 2)
; 656    Message about not bothering someone
; 657    Ann and Popuri talk about Gray (spawn point 1)
; 658    Same as 657 (spawn point 2)
; 659    Ann fireworks at ranch (Summer 1 evening)
; 660    Cliff meets Ann at ranch
; 661    Ann high-affection ranch scene
; 662    Ann visits ranch in winter (Winter 10)
; 663    Ann sick visit (in Ann room, after 666 transition)
; 664    Ann marriage repair (in Ann room, after 667 transition)
; 665    Doug free-roam at ranch (alt horse receiving, lifeEventBit 0xE set)
; 666    Ann sick visit transition (loads into Ann room -> 663)
; 667    Ann marriage repair transition (loads into Ann room -> 664)
; ===========================================================================

#include "entities.h"
#include "entityBuffers.h"
#include "texts.h"
#include "maps.h"
#include "dialogues.h"

.buffer 2

#define MAIN_MAP_INDEX 0

#define RANCH_GET_HORSE_CUTSCENE 14

#define HAVE_BABY 1

; Local variables
.local var0, u32, 0

.array npcAffection, u8
.array lifeEventBits, u32

; ===========================================================================
; Dispatch Table
; ===========================================================================

.dispatch:
    TOGGLE_PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .setup_message_box
    BRANCH_U16_VAR_WITHIN_RANGE 650, 650, gCutsceneIndex, .cutscene_650
    BRANCH_U16_VAR_WITHIN_RANGE 651, 651, gCutsceneIndex, .cutscene_651
    BRANCH_U16_VAR_WITHIN_RANGE 652, 652, gCutsceneIndex, .cutscene_652
    BRANCH_U16_VAR_WITHIN_RANGE 653, 653, gCutsceneIndex, .cutscene_653
    BRANCH_U16_VAR_WITHIN_RANGE 654, 654, gCutsceneIndex, .cutscene_654
    BRANCH_U16_VAR_WITHIN_RANGE 655, 655, gCutsceneIndex, .cutscene_655
    BRANCH_U16_VAR_WITHIN_RANGE 656, 656, gCutsceneIndex, .cutscene_656
    BRANCH_U16_VAR_WITHIN_RANGE 657, 657, gCutsceneIndex, .cutscene_657
    BRANCH_U16_VAR_WITHIN_RANGE 658, 658, gCutsceneIndex, .cutscene_658
    BRANCH_U16_VAR_WITHIN_RANGE 659, 659, gCutsceneIndex, .cutscene_659
    BRANCH_U16_VAR_WITHIN_RANGE 660, 660, gCutsceneIndex, .cutscene_660
    BRANCH_U16_VAR_WITHIN_RANGE 661, 661, gCutsceneIndex, .cutscene_661
    BRANCH_U16_VAR_WITHIN_RANGE 662, 662, gCutsceneIndex, .cutscene_662
    BRANCH_U16_VAR_WITHIN_RANGE 663, 663, gCutsceneIndex, .cutscene_663
    BRANCH_U16_VAR_WITHIN_RANGE 664, 664, gCutsceneIndex, .cutscene_664
    BRANCH_U16_VAR_WITHIN_RANGE 665, 665, gCutsceneIndex, .cutscene_665
    BRANCH_U16_VAR_WITHIN_RANGE 666, 666, gCutsceneIndex, .cutscene_666
    BRANCH_U16_VAR_WITHIN_RANGE 667, 667, gCutsceneIndex, .cutscene_667

; ===========================================================================
; Shared Helpers
; ===========================================================================

; --- Complete cutscene: set completion flag and deactivate ---

.complete_cutscene:
    SET_SPECIAL_BIT 0, gCutsceneCompletionFlags
    DEACTIVATE_SELF

; --- Infinite wait loop ---

.wait_loop:
    SET_WAIT_FRAMES 1
    EXECUTE_SUBROUTINE .wait_loop

; --- Standard message box configuration ---

.setup_message_box:
    SET_MESSAGE_INTERPOLATION -4, 0, 0
    SET_MESSAGE_BOX_ASSETS 0, 0, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 24, -64, 352
    RETURN_FROM_SUBROUTINE

; --- Alternate message box configuration ---

.setup_message_box_alt:
    SET_MESSAGE_INTERPOLATION -4, 0, 0
    SET_MESSAGE_BOX_ASSETS 0, 1, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 0, -64, 352
    RETURN_FROM_SUBROUTINE

; --- Setup holdable items (type 2) ---

.setup_holdable_items_2:
    SETUP_ENTITY 47, ENTITY_ASSET_STATIC_ITEM, 1
    SET_ENTITY_ANIMATIONS 47, 0, 0, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    RETURN_FROM_SUBROUTINE

; --- Holdable item tracking: cake on Ann ---

.executor_32_1154B0:
    EXECUTE_SUBROUTINE .setup_holdable_items_2
    SET_ENTITY_TRACKING_TARGET 37, 0, 14, 16, 255
    SET_ENTITY_ANIMATION 6
    EXECUTE_SUBROUTINE .wait_loop

; --- Holdable item: player eating animation ---

.executor_32_1154C8:
    SET_ENTITY_TRACKING_TARGET 0, 0, 14, 20, 255
    SET_WAIT_FRAMES 16
    SET_ENTITY_TRACKING_TARGET 0, 0, 32, 16, 255
    SET_WAIT_FRAMES 10
    DEACTIVATE_SELF

; --- Setup holdable items (type 1) ---

.setup_holdable_items_1:
    SETUP_ENTITY 47, ENTITY_ASSET_EXPRESSION_BUBBLES, 1
    SET_ENTITY_ANIMATIONS 47, 0, 0, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    RETURN_FROM_SUBROUTINE

; --- Holdable item: sparkler on Ann (anim 1) ---

.executor_13_11550C:
    EXECUTE_SUBROUTINE .setup_holdable_items_1
    SET_ENTITY_TRACKING_TARGET 36, -8, 64, 8, 0
    SET_ENTITY_ANIMATION 1
    WAIT_ENTITY_ANIMATION
    DEACTIVATE_SELF

; --- Holdable item: sparkler on Popuri (anim 2) ---

.executor_13_115528:
    EXECUTE_SUBROUTINE .setup_holdable_items_1
    SET_ENTITY_TRACKING_TARGET 37, 0, 64, 8, 0
    SET_ENTITY_ANIMATION 2
    WAIT_ENTITY_ANIMATION
    DEACTIVATE_SELF

; --- Holdable item: sparkler on Ann (anim 6) ---

.executor_13_115544:
    EXECUTE_SUBROUTINE .setup_holdable_items_1
    SET_ENTITY_TRACKING_TARGET 36, 16, 48, 8, 0
    SET_ENTITY_ANIMATION 6
    WAIT_ENTITY_ANIMATION
    DEACTIVATE_SELF

; --- Holdable item: blue feather on player (anim 5) ---

.executor_32_115560:
    EXECUTE_SUBROUTINE .setup_holdable_items_1
    SET_ENTITY_TRACKING_TARGET 37, -24, 32, 8, 0
    SET_ENTITY_ANIMATION 5
    WAIT_ENTITY_ANIMATION
    DEACTIVATE_SELF

; --- Holdable item: blue feather on player (anim 1) ---

.executor_32_11557C:
    EXECUTE_SUBROUTINE .setup_holdable_items_1
    SET_ENTITY_TRACKING_TARGET 37, -8, 64, 8, 0
    SET_ENTITY_ANIMATION 1
    WAIT_ENTITY_ANIMATION
    DEACTIVATE_SELF

; --- Setup player entity ---

.setup_player:
    SETUP_ENTITY 0, ENTITY_ASSET_PLAYER, 1
    SET_ENTITY_ANIMATIONS 0, 0, 8, 16, 24, 32, 40
    SET_BEHAVIOR_FLAGS CUTSCENE_ASSET_BEHAVIOR_TRACK_ENTITY
    RETURN_FROM_SUBROUTINE

; --- Player eat animation ---

.player_eat_anim:
    SET_ASSET_ROTATION 0
    SET_OTHER_EXECUTOR_PTR 32, .executor_32_1154C8
    SET_ENTITY_DIRECTIONAL_ANIMATION 24
    SET_WAIT_FRAMES 16
    SET_ENTITY_ANIMATION 437
    WAIT_ENTITY_ANIMATION
    RETURN_FROM_SUBROUTINE

; --- Shared rotation states (used as SET_OTHER_EXECUTOR_PTR targets) ---

.player_release_map_dep:
    SET_ENTITY_MAP_SPACE_INDEPENDENT FALSE
    DEACTIVATE_SELF

.player_release_with_track:
    SET_BEHAVIOR_FLAGS CUTSCENE_ASSET_BEHAVIOR_TRACK_ENTITY
    SET_WAIT_FRAMES 1
    SET_ENTITY_MAP_SPACE_INDEPENDENT FALSE
    DEACTIVATE_SELF

.face_east_and_wait:
    SET_ASSET_ROTATION 5
    EXECUTE_SUBROUTINE .wait_loop
    SET_ASSET_ROTATION 7
    EXECUTE_SUBROUTINE .wait_loop

.face_north_and_wait:
    SET_ASSET_ROTATION 3
    EXECUTE_SUBROUTINE .wait_loop

.face_west_and_wait:
    SET_ASSET_ROTATION 1
    EXECUTE_SUBROUTINE .wait_loop

.face_northeast_and_wait:
    SET_ASSET_ROTATION 4
    EXECUTE_SUBROUTINE .wait_loop

.face_southwest_and_wait:
    SET_ASSET_ROTATION 0
    EXECUTE_SUBROUTINE .wait_loop

.face_southeast_and_wait:
    SET_ASSET_ROTATION 6
    EXECUTE_SUBROUTINE .wait_loop

.face_northwest_and_wait:
    SET_ASSET_ROTATION 2
    EXECUTE_SUBROUTINE .wait_loop

; ===========================================================================
; Cutscene 650 - Acquire horse
; ===========================================================================

.cutscene_650:
    SPAWN_EXECUTOR 41, .wait_for_interaction
    DEACTIVATE_SELF

; --- Wait for player to reach interaction point ---

.wait_for_interaction:
    SET_WAIT_FRAMES 1
    BRANCH_U8_VAR_WITHIN_RANGE 32, 32, cutsceneLevelInteractionIndex, .after_interaction
    EXECUTE_SUBROUTINE .wait_for_interaction

.after_interaction:
    SET_SPECIAL_BIT 15, gCutsceneCompletionFlags
    SPAWN_EXECUTOR 1, .horse_initial_setup
    SPAWN_EXECUTOR 7, .player_walk_to_doug
    DEACTIVATE_SELF

; --- Player walks northwest then west ---

.player_walk_to_doug:
    EXECUTE_SUBROUTINE .setup_player
    ENTITY_WALK 16, DIRECTION_W, 2
    ENTITY_WALK 72, DIRECTION_SW, 2
    SET_ASSET_ROTATION 2
    SET_OTHER_EXECUTOR_PTR 1, .horse_stop_walking
    SET_ENTITY_DIRECTIONAL_ANIMATION 456
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SPAWN_EXECUTOR 2, .ann_approach_and_talk
    EXECUTE_SUBROUTINE .wait_loop

; --- Ann walks in, asks Doug about horse ---

.ann_approach_and_talk:
    EXECUTE_SUBROUTINE .setup_ann_entity_23
    SET_COORDINATES -160, 0, -272
    ENTITY_WALK 80, DIRECTION_S, 2
    SET_ASSET_ROTATION 1
    SET_OTHER_EXECUTOR_PTR 7, .face_east_and_wait
    INIT_DIALOGUE_SESSION 0, DIALOGUE_CUTSCENES_1, 0
    WAIT_FOR_DIALOGUE_INPUT 0
    SET_OTHER_EXECUTOR_PTR 2, .ann_look_around
    EXECUTE_SUBROUTINE .wait_loop

; --- Ann looks around between Doug and player ---

.ann_look_around:
    ENTITY_WALK 20, DIRECTION_SW, 2
    SET_WAIT_FRAMES 15
    SET_ASSET_ROTATION 0
    SET_ENTITY_DIRECTIONAL_ANIMATION 103
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 25
    SET_WAIT_FRAMES 30
    SET_ENTITY_DIRECTIONAL_ANIMATION 103
    WAIT_ENTITY_ANIMATION
    SET_ASSET_ROTATION 0
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SET_WAIT_FRAMES 30
    SET_ENTITY_DIRECTIONAL_ANIMATION 103
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 25
    SET_WAIT_FRAMES 30
    SET_ENTITY_DIRECTIONAL_ANIMATION 103
    WAIT_ENTITY_ANIMATION
    SET_ASSET_ROTATION 0
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SET_WAIT_FRAMES 30
    SET_ENTITY_ANIMATION 48
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_ANIMATION 50
    SET_WAIT_FRAMES 30
    INIT_MESSAGE_BOX_TYPE1 0, RANCH_CUTSCENES_TEXT_INDEX, 4
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    ENTITY_WALK 96, DIRECTION_N, 2
    SPAWN_EXECUTOR 3, .gray_walk_in
    SET_COORDINATES -160, 0, -304
    ENTITY_WALK 96, DIRECTION_S, 2
    SET_ASSET_ROTATION 1
    INIT_MESSAGE_BOX_TYPE1 0, RANCH_CUTSCENES_TEXT_INDEX, 6
    WAIT_MESSAGE_BOX_CLOSED 0
    INIT_MESSAGE_BOX_TYPE1 0, RANCH_CUTSCENES_TEXT_INDEX, 7
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 3, .gray_walk_away
    SET_OTHER_EXECUTOR_PTR 7, .face_northeast_and_wait
    SET_WAIT_FRAMES 16
    SET_ASSET_ROTATION 2
    SET_WAIT_FRAMES 16
    ENTITY_WALK 16, DIRECTION_W, 2
    SET_ASSET_ROTATION 4
    SET_ENTITY_ANIMATION 37
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_ANIMATION 41
    WAIT_ENTITY_ANIMATION
    INIT_MESSAGE_BOX_TYPE1 0, RANCH_CUTSCENES_TEXT_INDEX, 8
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_ENTITY_ANIMATION 37
    WAIT_ENTITY_ANIMATION
    SET_ASSET_ROTATION 4
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SET_WAIT_FRAMES 30
    SET_ASSET_ROTATION 0
    INIT_MESSAGE_BOX_TYPE1 0, RANCH_CUTSCENES_TEXT_INDEX, 9
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SPAWN_EXECUTOR 4, .doug_offer_horse
    SPAWN_EXECUTOR 5, .horse_pony_walk_in
    EXECUTE_SUBROUTINE .wait_loop

; --- Doug offers horse, dialogue choice ---

.doug_offer_horse:
    SET_SPECIAL_BIT RANCH_GET_HORSE_CUTSCENE, lifeEventBits
    SETUP_ENTITY 25, ENTITY_ASSET_DOUG, 1
    SET_ENTITY_ANIMATIONS 25, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    SET_COORDINATES -160, 0, -304
    ENTITY_WALK 112, DIRECTION_S, 2
    SET_ASSET_ROTATION 1
    SET_OTHER_EXECUTOR_PTR 7, .face_east_and_wait
    INIT_DIALOGUE_SESSION 0, DIALOGUE_CUTSCENES_1, 3
    WAIT_FOR_DIALOGUE_INPUT 0
    BRANCH_ON_DIALOGUE 0, 0, .player_accept_horse
    BRANCH_ON_DIALOGUE 0, 1, .player_decline_horse

; --- Player declines horse ---

.player_decline_horse:
    INIT_MESSAGE_BOX_TYPE1 0, RANCH_CUTSCENES_TEXT_INDEX, 17
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 2, .ann_free_roam_interact
    SET_OTHER_EXECUTOR_PTR 7, .player_release_map_dep

.doug_free_roam_callback:
    TOGGLE_PAUSE_ENTITIES
    SET_CALLBACK_ROUTINE 0, 32768, .doug_on_interact_horse
    EXECUTE_SUBROUTINE .wait_loop

.ann_free_roam_interact:
    TOGGLE_PAUSE_ENTITIES
    SET_CALLBACK_ROUTINE 0, 32768, .ann_on_interact_horse
    EXECUTE_SUBROUTINE .wait_loop

.ann_on_interact_horse:
    EXECUTE_SUBROUTINE .setup_message_box
    PAUSE_ENTITY 0
    FLIP_ENTITY_DIRECTION 0
    INIT_MESSAGE_BOX_TYPE1 0, RANCH_CUTSCENES_TEXT_INDEX, 21
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    EXECUTE_SUBROUTINE .ann_free_roam_interact

; --- Doug re-offers horse on interact ---

.doug_on_interact_horse:
    EXECUTE_SUBROUTINE .setup_message_box
    PAUSE_ENTITY 0
    FLIP_ENTITY_DIRECTION 0
    INIT_DIALOGUE_SESSION 0, DIALOGUE_CUTSCENES_1, 4
    WAIT_FOR_DIALOGUE_INPUT 0
    BRANCH_ON_DIALOGUE 0, 0, .player_accept_horse
    BRANCH_ON_DIALOGUE 0, 1, .doug_tell_player_go_home

.doug_tell_player_go_home:
    INIT_MESSAGE_BOX_TYPE1 0, RANCH_CUTSCENES_TEXT_INDEX, 20
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    EXECUTE_SUBROUTINE .doug_free_roam_callback

.doug_facing_set:
    SET_SPECIAL_BIT 0, var0
    RETURN_FROM_SUBROUTINE

; --- Player accepts horse ---

.player_accept_horse:
    INIT_MESSAGE_BOX_TYPE1 0, RANCH_CUTSCENES_TEXT_INDEX, 13
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    BRANCH_ON_ENTITY_DIR 25, DIRECTION_N, .doug_facing_set
    BRANCH_ON_ENTITY_DIR 25, DIRECTION_NE, .doug_facing_set
    BRANCH_ON_ENTITY_DIR 25, DIRECTION_E, .doug_facing_set
    BRANCH_ON_ENTITY_DIR 25, DIRECTION_SE, .doug_facing_set
    BRANCH_ON_ENTITY_DIR 25, DIRECTION_E, .doug_facing_set
    SET_OTHER_EXECUTOR_PTR 2, .ann_watch_doug_leave
    SET_OTHER_EXECUTOR_PTR 5, .horse_pony_leave
    ENTITY_WALK 32, DIRECTION_N, 2
    ENTITY_WALK 64, DIRECTION_E, 2
    BRANCH_ON_SPECIAL_BIT 0, var0, .doug_exit_from_facing
    SET_OTHER_EXECUTOR_PTR 2, .ann_farewell_southwest

.doug_exit_walk:
    ENTITY_WALK 64, DIRECTION_E, 2
    DEACTIVATE_SELF

.doug_exit_from_facing:
    SET_OTHER_EXECUTOR_PTR 2, .ann_farewell_south
    EXECUTE_SUBROUTINE .doug_exit_walk

.horse_pony_leave:
    ENTITY_WALK 32, DIRECTION_N, 2
    ENTITY_WALK 128, DIRECTION_E, 2
    DEACTIVATE_SELF

; --- Ann watches Doug leave, turns ---

.ann_watch_doug_leave:
    SET_ASSET_ROTATION 7
    SET_WAIT_FRAMES 16
    SET_ASSET_ROTATION 6
    SET_WAIT_FRAMES 16
    SET_ASSET_ROTATION 5
    EXECUTE_SUBROUTINE .wait_loop

; --- Ann says farewell (facing southwest) ---

.ann_farewell_southwest:
    SET_ASSET_ROTATION 0
    EXECUTE_SUBROUTINE .horse_accepted_farewell

; --- Ann says farewell (facing south) ---

.ann_farewell_south:
    SET_ASSET_ROTATION 7
    EXECUTE_SUBROUTINE .horse_accepted_farewell

.horse_accepted_farewell:
    INIT_MESSAGE_BOX_TYPE1 0, RANCH_CUTSCENES_TEXT_INDEX, 14
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_AUDIO_SEQUENCE_VOLUME 0, 0, 4
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    STOP_SEQUENCE_WITH_FADE 0, 1
    DEACTIVATE_EXECUTOR 1
    DEACTIVATE_EXECUTOR 4
    DEACTIVATE_EXECUTOR 5
    DEACTIVATE_EXECUTOR 7
    IDLE_WHILE_SEQUENCE_PLAYING 0
    EXECUTE_SUBROUTINE .complete_cutscene

; --- Horse pony walks in behind Doug ---

.horse_pony_walk_in:
    SETUP_ENTITY 15, ENTITY_ASSET_HORSE_PONY, 1
    SET_ENTITY_ANIMATIONS 15, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    SET_COORDINATES -128, 0, -304
    ENTITY_WALK 112, DIRECTION_S, 2
    EXECUTE_SUBROUTINE .wait_loop

; --- Gray walks in from northeast ---

.gray_walk_away:
    ENTITY_WALK 96, DIRECTION_N, 2
    DEACTIVATE_SELF

; --- Setup Gray entity ---

.setup_gray_entity:
    SETUP_ENTITY 24, ENTITY_ASSET_GRAY, 1
    SET_ENTITY_ANIMATIONS 24, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    RETURN_FROM_SUBROUTINE

; --- Gray walks in, waits ---

.gray_walk_in:
    EXECUTE_SUBROUTINE .setup_gray_entity
    SET_COORDINATES -192, 0, -272
    ENTITY_WALK 96, DIRECTION_S, 2
    EXECUTE_SUBROUTINE .wait_loop
    ENTITY_WALK 32, DIRECTION_W, 2
    SET_ASSET_ROTATION 6
    EXECUTE_SUBROUTINE .wait_loop

; --- Setup horse (unbridled, adult) ---

.setup_horse_unbridled:
    SETUP_ENTITY 14, ENTITY_ASSET_HORSE_UNBRIDLED, 1
    SET_ENTITY_ANIMATIONS 14, 0, 8, 16, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    SET_ENTITY_PALETTE 0
    RETURN_FROM_SUBROUTINE

; --- Horse initial setup for cutscene 650 ---

.horse_initial_setup:
    EXECUTE_SUBROUTINE .setup_horse_unbridled
    SET_COORDINATES -238, 0, 0
    ENTITY_WALK 32, DIRECTION_N, 1
    EXECUTE_SUBROUTINE .wait_loop

.horse_stop_walking:
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    EXECUTE_SUBROUTINE .wait_loop

; ===========================================================================
; Cutscene 651 - Horse Naming Follow-up
; ===========================================================================

; --- Nighttime audio variant ---

.cutscene_651_night:
    SET_AUDIO_SEQUENCE 0, _nightAmbienceSpringSegmentRomStart, _nightAmbienceSpringSegmentRomEnd
    SET_AUDIO_SEQUENCE_VOLUME 0, 128, 8
    EXECUTE_SUBROUTINE .cutscene_651_setup

; --- Daytime: check hour, branch to night if late ---

.cutscene_651:
    BRANCH_U8_VAR_WITHIN_RANGE 18, 24, gHour, .cutscene_651_night
    BRANCH_U8_VAR_WITHIN_RANGE 0, 5, gHour, .cutscene_651_night
    SET_AUDIO_SEQUENCE 0, _springSegmentRomStart, _springSegmentRomEnd
    SET_AUDIO_SEQUENCE_VOLUME 0, 128, 8

.cutscene_651_setup:
    SPAWN_EXECUTOR 1, .horse_named_setup
    SPAWN_EXECUTOR 2, .ann_named_setup
    SPAWN_EXECUTOR 7, .player_named_setup
    DEACTIVATE_SELF

.player_named_setup:
    EXECUTE_SUBROUTINE .setup_player
    SET_COORDINATES -160, 0, -112
    SET_ASSET_ROTATION 2
    SET_WAIT_FRAMES 1
    UPDATE_GLOBAL_RGBA 254, 254, 254, 254, 0
    WAIT_RGBA_FINISHED
    INIT_MESSAGE_BOX_TYPE1 0, RANCH_CUTSCENES_TEXT_INDEX, 15
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_AUDIO_SEQUENCE_VOLUME 0, 0, 4
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    STOP_SEQUENCE_WITH_FADE 0, 1
    IDLE_WHILE_SEQUENCE_PLAYING 0
    DEACTIVATE_EXECUTOR 1
    DEACTIVATE_EXECUTOR 2
    EXECUTE_SUBROUTINE .complete_cutscene

.horse_named_setup:
    EXECUTE_SUBROUTINE .setup_horse_unbridled
    SET_COORDINATES -256, 0, -48
    SET_ASSET_ROTATION 5
    EXECUTE_SUBROUTINE .wait_loop

.ann_named_setup:
    EXECUTE_SUBROUTINE .setup_ann_entity_23
    SET_COORDINATES -192, 0, -112
    SET_ASSET_ROTATION 6
    EXECUTE_SUBROUTINE .wait_loop

; ===========================================================================
; Cutscene 652 - Popuri and Ann Talk About Flowers (spawn point 1)
; ===========================================================================

.cutscene_652:
    SET_WAIT_FRAMES 1
    SPAWN_EXECUTOR 1, .popuri_flower_setup
    SPAWN_EXECUTOR 2, .ann_flower_setup
    SPAWN_EXECUTOR 7, .player_idle_cutscene
    SPAWN_EXECUTOR 11, .cutscene_652_camera
    DEACTIVATE_SELF

.cutscene_652_camera:
    SETUP_MAP_ASSET MAIN_MAP_INDEX
    SET_ASSET_ROTATION 7
    SET_WAIT_FRAMES 1
    UPDATE_GLOBAL_RGBA 254, 254, 254, 254, 0
    WAIT_RGBA_FINISHED
    SET_FRAME_DELTA -1, 0, 3, 88

; --- Shared flower conversation ---

.popuri_ann_flower_talk:
    INIT_MESSAGE_BOX_TYPE1 0, RANCH_CUTSCENES_TEXT_INDEX, 22
    WAIT_MESSAGE_BOX_CLOSED 0
    SET_OTHER_EXECUTOR_PTR 2, .face_northeast_and_wait
    INIT_MESSAGE_BOX_TYPE1 0, RANCH_CUTSCENES_TEXT_INDEX, 23
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 1, .popuri_talk_about_flowers
    EXECUTE_SUBROUTINE .wait_loop

; --- Popuri talks, reacts, then leaves ---

.popuri_talk_about_flowers:
    SET_ASSET_ROTATION 0
    SET_WAIT_FRAMES 15
    SET_ENTITY_ANIMATION 48
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_ANIMATION 50
    SET_WAIT_FRAMES 15
    INIT_MESSAGE_BOX_TYPE1 0, RANCH_CUTSCENES_TEXT_INDEX, 24
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
