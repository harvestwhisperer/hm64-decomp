    UPDATE_U8_VALUE 2, 255, npcAffection[MARIA]
    SET_SPECIAL_BIT 6, var1

.maria_talk:
    PAUSE_ENTITIES
    SET_SPECIAL_BIT 0, var0
    FLIP_ENTITY_DIRECTION 0
    BRANCH_ON_SPECIAL_BIT MARRIED, lifeEventBits[0], .maria_talk_wife_check
    INIT_DIALOGUE_SESSION 0, DIALOGUE_TEXT_52, 1
    WAIT_FOR_DIALOGUE_INPUT 0

.maria_talk_done:
    TOGGLE_PAUSE_ENTITIES
    CLEAR_SPECIAL_BIT 0, var0
    EXECUTE_SUBROUTINE .maria_wait

.maria_talk_wife_check:
    BRANCH_U8_VAR_WITHIN_RANGE 0, 0, gWife, .maria_talk_as_wife
    RETURN_FROM_SUBROUTINE

.maria_talk_as_wife:
    INIT_MESSAGE_BOX_TYPE1 0, FIREFLY_FESTIVAL_TEXT_INDEX, 17
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    EXECUTE_SUBROUTINE .maria_talk_done

.maria_close:
    SET_COORDINATES -288, 0, -32
    SET_ASSET_ROTATION SOUTHWEST
    SET_WAIT_FRAMES 1
    UPDATE_GLOBAL_RGBA 80, 80, 80, 80, 8
    WAIT_RGBA_FINISHED
    BRANCH_ON_SPECIAL_BIT MARRIED, lifeEventBits[0], .maria_close_wife_check
    INIT_DIALOGUE_SESSION 0, DIALOGUE_TEXT_52, 6
    WAIT_FOR_DIALOGUE_INPUT 0
    BRANCH_ON_DIALOGUE 0, 0, .maria_close_accept
    BRANCH_ON_DIALOGUE 0, 1, .maria_close_decline

.maria_close_accept:
    UPDATE_U8_VALUE 5, 255, gHappiness
    SET_OTHER_EXECUTOR_PTR 0, .player_walk_north_and_wait
    ENTITY_WALK 32, NORTH, 2
    SET_ASSET_ROTATION SOUTHWEST
    INIT_MESSAGE_BOX_TYPE1 0, FIREFLY_FESTIVAL_TEXT_INDEX, 15
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_AUDIO_SEQUENCE_VOLUME 0, 0, 2
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    DEACTIVATE_EXECUTOR 0
    STOP_SEQUENCE_WITH_FADE 0, 1
    IDLE_WHILE_SEQUENCE_PLAYING 0
    EXECUTE_SUBROUTINE .exit_demo

.maria_close_decline:
    INIT_MESSAGE_BOX_TYPE1 0, FIREFLY_FESTIVAL_TEXT_INDEX, 16
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    ENTITY_WALK 32, NORTH, 2
    SET_OTHER_EXECUTOR_PTR 0, .npc_face_se_idle
    ENTITY_WALK 64, NORTH, 2
    SET_AUDIO_SEQUENCE_VOLUME 0, 0, 2
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    ENTITY_WALK 32, NORTH, 2
    DEACTIVATE_EXECUTOR 0
    STOP_SEQUENCE_WITH_FADE 0, 1
