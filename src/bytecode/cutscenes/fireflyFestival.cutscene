; ============================================================
; Bank 22 - Firefly Festival
; ============================================================
;
; Summer day 17, nighttime. Villagers gather to float Firefly
; Light flowers for the spirits of their ancestors. Player can
; mingle, then the mayor calls everyone home; an eligible girl or
; wife walks off with the player and the cutscene ends.
;
; Cutscene indices (from src/game/cutscenes.c):
;   1050 = FIREFLY_FESTIVAL
;
; Executor slots:
;   0        - player
;   1        - Mayor
;   2        - Mayor Wife
;   3        - Rick
;   4        - Potion Shop Dealer
;   5        - Kent
;   6        - Stu
;   7..11    - Maria, Popuri, Elli, Ann, Karen (bachelorettes; wife / affection gated)
;   12..16   - Harris, Gray, Jeff, Cliff, Kai (spawned only at affection >= 100)
;   17       - Shipper
;   18..33   - decorative Firefly Light flower entities (asset STATIC_ITEM)
;   41       - festival timer (runs while player is not in a dialogue)
;
; var0 bits:
;   bit 0  - player is currently in a dialogue (blocks timer + other NPC interactions)
;   bit 31 - intro / outro message playing (suppresses NPC A-press handlers)
;
; var1 bits 0..16:
;   once-per-NPC flag marking that the per-slot affection bump has been applied
;   (one bit per executor slot 1..17)

#include "entities.h"
#include "texts.h"
#include "dialogues.h"

#define MAIN_MAP_INDEX 0

.buffer 2

; Local variables
; var0: scratch flags (see file header for bit meanings)
.local var0, u32
; var1: once-per-NPC affection-bump flags (one bit per slot 1..17)
.local var1, u32

.array npcAffection, u8
.array lifeEventBits, u32

#define MARRIED 0

; ============================================================
; SHARED HELPERS
; ============================================================

.main:
    SET_SPECIAL_BIT 31, gCutsceneCompletionFlags
    SET_SPECIAL_BIT 12, gCutsceneCompletionFlags
    SET_SPECIAL_BIT 13, gCutsceneCompletionFlags
    SET_SPECIAL_BIT 14, gCutsceneCompletionFlags
    SET_SPECIAL_BIT 15, gCutsceneCompletionFlags
    PAUSE_ENTITIES
    STOP_SEQUENCE_WITH_FADE 0, 8
    IDLE_WHILE_SEQUENCE_PLAYING 0
    SET_AUDIO_SEQUENCE 0, _starryNightFestivalSegmentRomStart, _starryNightFestivalSegmentRomEnd
    SET_AUDIO_SEQUENCE_VOLUME 0, 128, 8
    TOGGLE_PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .configure_message_box
    BRANCH_U16_VAR_WITHIN_RANGE 1050, 1050, gCutsceneIndex, .spawn_npcs

.exit_demo:
    SET_SPECIAL_BIT 0, gCutsceneCompletionFlags
    DEACTIVATE_SELF

.wait_loop:
    SET_WAIT_FRAMES 1
    EXECUTE_SUBROUTINE .wait_loop

.configure_message_box:
    SET_MESSAGE_INTERPOLATION -4, 0, 0
    SET_MESSAGE_BOX_ASSETS 0, 0, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 24, -64, 352
    RETURN_FROM_SUBROUTINE

; ============================================================
; Firefly Light decorative entities (slots 18..33)
; ============================================================
; Slots 18..22 have two states: an initial "pre-reveal" pose
; (anim 161, earlier coordinates) and a "post-reveal" pose
; (anim 162, new coordinates) installed after branch_1372B0.
; Slots 23..33 only spawn in the post-reveal pose.
; At the close, every slot 18..33 is pointed at .firefly_close,
; which fades them to white.

; ----- Slots 18..22: pre-reveal and post-reveal poses -----

.firefly_18_pre:
    SET_SHADOW_FLAGS 93, 255
    SETUP_ENTITY 23, ENTITY_ASSET_STATIC_ITEM, 1
    SET_ENTITY_ANIMATIONS 23, 0, 0, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_ANIMATION 161
    SET_COORDINATES -352, 0, 0
    UPDATE_RGBA 255, 255, 255, 255, 4
    EXECUTE_SUBROUTINE .wait_loop

.firefly_18_post:
    SET_ENTITY_PHYSICS_FLAGS 0
    SET_ENTITY_ANIMATION 162
    SET_COORDINATES -192, 128, 0
    EXECUTE_SUBROUTINE .wait_loop

.firefly_19_pre:
    SET_SHADOW_FLAGS 93, 255
    SETUP_ENTITY 24, ENTITY_ASSET_STATIC_ITEM, 1
    SET_ENTITY_ANIMATIONS 24, 0, 0, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_ANIMATION 161
    SET_COORDINATES -320, 0, 96
    UPDATE_RGBA 255, 255, 255, 255, 4
    EXECUTE_SUBROUTINE .wait_loop

.firefly_19_post:
    SET_ENTITY_PHYSICS_FLAGS 0
    SET_ENTITY_ANIMATION 162
    SET_COORDINATES -70, 128, -64
    EXECUTE_SUBROUTINE .wait_loop

.firefly_20_pre:
    SET_SHADOW_FLAGS 93, 255
    SETUP_ENTITY 25, ENTITY_ASSET_STATIC_ITEM, 1
    SET_ENTITY_ANIMATIONS 25, 0, 0, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_ANIMATION 161
    SET_COORDINATES -256, 0, -44
    UPDATE_RGBA 255, 255, 255, 255, 4
    EXECUTE_SUBROUTINE .wait_loop

.firefly_20_post:
    SET_ENTITY_PHYSICS_FLAGS 0
    SET_ENTITY_ANIMATION 162
    SET_COORDINATES 0, 128, -96
    EXECUTE_SUBROUTINE .wait_loop

.firefly_21_pre:
    SET_SHADOW_FLAGS 93, 255
    SETUP_ENTITY 26, ENTITY_ASSET_STATIC_ITEM, 1
    SET_ENTITY_ANIMATIONS 26, 0, 0, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_ANIMATION 161
    SET_COORDINATES -358, 0, 192
    UPDATE_RGBA 255, 255, 255, 255, 4
    EXECUTE_SUBROUTINE .wait_loop

.firefly_21_post:
    SET_ENTITY_PHYSICS_FLAGS 0
    SET_ENTITY_ANIMATION 162
    SET_COORDINATES -96, 128, 32
    EXECUTE_SUBROUTINE .wait_loop

.firefly_22_pre:
    SET_SHADOW_FLAGS 93, 255
    SETUP_ENTITY 27, ENTITY_ASSET_STATIC_ITEM, 1
    SET_ENTITY_ANIMATIONS 27, 0, 0, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_ANIMATION 161
    SET_COORDINATES -400, 0, -152
    UPDATE_RGBA 255, 255, 255, 255, 8
    EXECUTE_SUBROUTINE .wait_loop

.firefly_22_post:
    SET_ENTITY_PHYSICS_FLAGS 0
    SET_ENTITY_ANIMATION 162
    SET_COORDINATES -64, 128, -128
    EXECUTE_SUBROUTINE .wait_loop

; ----- Slots 23..33: post-reveal only -----

.firefly_23:
    SET_SHADOW_FLAGS 93, 255
    SETUP_ENTITY 28, ENTITY_ASSET_STATIC_ITEM, 1
    SET_ENTITY_ANIMATIONS 28, 0, 0, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_PHYSICS_FLAGS 0
    SET_ENTITY_ANIMATION 162
    SET_COORDINATES 64, 128, -128
    EXECUTE_SUBROUTINE .wait_loop

.firefly_24:
    SET_SHADOW_FLAGS 93, 255
    SETUP_ENTITY 29, ENTITY_ASSET_STATIC_ITEM, 1
    SET_ENTITY_ANIMATIONS 29, 0, 0, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_PHYSICS_FLAGS 0
    SET_ENTITY_ANIMATION 162
    SET_COORDINATES 128, 128, 96
    EXECUTE_SUBROUTINE .wait_loop

.firefly_25:
    SET_SHADOW_FLAGS 93, 255
    SETUP_ENTITY 30, ENTITY_ASSET_STATIC_ITEM, 1
    SET_ENTITY_ANIMATIONS 30, 0, 0, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_PHYSICS_FLAGS 0
    SET_ENTITY_ANIMATION 162
    SET_COORDINATES 160, 128, 144
    EXECUTE_SUBROUTINE .wait_loop

.firefly_26:
    SET_SHADOW_FLAGS 93, 255
    SETUP_ENTITY 31, ENTITY_ASSET_STATIC_ITEM, 1
    SET_ENTITY_ANIMATIONS 31, 0, 0, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_PHYSICS_FLAGS 0
    SET_ENTITY_ANIMATION 162
    SET_COORDINATES 192, 128, 0
    EXECUTE_SUBROUTINE .wait_loop

.firefly_27:
    SET_SHADOW_FLAGS 93, 255
    SETUP_ENTITY 32, ENTITY_ASSET_STATIC_ITEM, 1
    SET_ENTITY_ANIMATIONS 32, 0, 0, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_PHYSICS_FLAGS 0
    SET_ENTITY_ANIMATION 162
    SET_COORDINATES 56, 128, 32
    EXECUTE_SUBROUTINE .wait_loop

.firefly_28:
    SET_SHADOW_FLAGS 93, 255
    SETUP_ENTITY 33, ENTITY_ASSET_STATIC_ITEM, 1
    SET_ENTITY_ANIMATIONS 33, 0, 0, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_PHYSICS_FLAGS 0
    SET_ENTITY_ANIMATION 162
    SET_COORDINATES -16, 128, 56
    EXECUTE_SUBROUTINE .wait_loop

.firefly_29:
    SET_SHADOW_FLAGS 93, 255
    SETUP_ENTITY 34, ENTITY_ASSET_STATIC_ITEM, 1
    SET_ENTITY_ANIMATIONS 34, 0, 0, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_PHYSICS_FLAGS 0
    SET_ENTITY_ANIMATION 162
    SET_COORDINATES 224, 128, 48
    EXECUTE_SUBROUTINE .wait_loop

.firefly_30:
    SET_SHADOW_FLAGS 93, 255
    SETUP_ENTITY 35, ENTITY_ASSET_STATIC_ITEM, 1
    SET_ENTITY_ANIMATIONS 35, 0, 0, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_PHYSICS_FLAGS 0
    SET_ENTITY_ANIMATION 162
    SET_COORDINATES 200, 128, 128
    EXECUTE_SUBROUTINE .wait_loop

.firefly_31:
    SET_SHADOW_FLAGS 93, 255
    SETUP_ENTITY 36, ENTITY_ASSET_STATIC_ITEM, 1
    SET_ENTITY_ANIMATIONS 36, 0, 0, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_PHYSICS_FLAGS 0
    SET_ENTITY_ANIMATION 162
    SET_COORDINATES 256, 128, -96
    EXECUTE_SUBROUTINE .wait_loop

.firefly_32:
    SET_SHADOW_FLAGS 93, 255
    SETUP_ENTITY 37, ENTITY_ASSET_STATIC_ITEM, 1
    SET_ENTITY_ANIMATIONS 37, 0, 0, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_PHYSICS_FLAGS 0
    SET_ENTITY_ANIMATION 162
    SET_COORDINATES 156, 128, -64
    EXECUTE_SUBROUTINE .wait_loop

.firefly_33:
    SET_SHADOW_FLAGS 93, 255
    SETUP_ENTITY 39, ENTITY_ASSET_STATIC_ITEM, 1
    SET_ENTITY_ANIMATIONS 39, 0, 0, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_PHYSICS_FLAGS 0
    SET_ENTITY_ANIMATION 162
    SET_COORDINATES 288, 128, 32
    EXECUTE_SUBROUTINE .wait_loop

; ----- Shared player / NPC stubs -----

.setup_player:
    SETUP_ENTITY 0, ENTITY_ASSET_PLAYER, 1
    SET_ENTITY_ANIMATIONS 0, 0, 8, 16, 24, 32, 40
    SET_BEHAVIOR_FLAGS CUTSCENE_ASSET_BEHAVIOR_TRACK_ENTITY
    RETURN_FROM_SUBROUTINE
    SET_ENTITY_MAP_SPACE_INDEPENDENT FALSE
    DEACTIVATE_SELF
    SET_BEHAVIOR_FLAGS CUTSCENE_ASSET_BEHAVIOR_TRACK_ENTITY
    SET_WAIT_FRAMES 1
    SET_ENTITY_MAP_SPACE_INDEPENDENT FALSE
    DEACTIVATE_SELF

; Re-pointer used for every NPC slot 1..17 at the outro: rotate SE and idle.
.npc_face_se_idle:
    SET_ASSET_ROTATION SOUTHEAST
    EXECUTE_SUBROUTINE .wait_loop

; ============================================================
; Intro - spawn NPCs, show mayor greeting, start festival timer
; ============================================================

.spawn_npcs:
    SPAWN_EXECUTOR 1, .mayor_setup
    SPAWN_EXECUTOR 2, .mayor_wife_setup
    SPAWN_EXECUTOR 3, .rick_setup
    SPAWN_EXECUTOR 4, .potion_dealer_setup
    SPAWN_EXECUTOR 5, .kent_setup
    SPAWN_EXECUTOR 6, .stu_setup
    SPAWN_EXECUTOR 7, .maria_setup
    SPAWN_EXECUTOR 8, .popuri_setup
    SPAWN_EXECUTOR 9, .elli_setup
    SPAWN_EXECUTOR 10, .ann_setup
    BRANCH_ON_SPECIAL_BIT 15, lifeEventBits[1], .after_karen_check
    BRANCH_ON_SPECIAL_BIT MARRIED, lifeEventBits[0], .spawn_karen_if_wife
    BRANCH_U8_VAR_WITHIN_RANGE 0, 25, npcAffection[KAREN], .after_karen_check

.spawn_karen:
    SPAWN_EXECUTOR 11, .karen_setup

.after_karen_check:
    BRANCH_U8_VAR_WITHIN_RANGE 0, 99, npcAffection[HARRIS], .after_harris_check
    SPAWN_EXECUTOR 12, .harris_setup

.after_harris_check:
    BRANCH_U8_VAR_WITHIN_RANGE 0, 99, npcAffection[GRAY], .after_gray_check
    SPAWN_EXECUTOR 13, .gray_setup

.after_gray_check:
    BRANCH_U8_VAR_WITHIN_RANGE 0, 99, npcAffection[JEFF], .after_jeff_check
    SPAWN_EXECUTOR 14, .jeff_setup

.after_jeff_check:
    BRANCH_ON_SPECIAL_BIT 13, lifeEventBits[1], .after_cliff_check
    BRANCH_U8_VAR_WITHIN_RANGE 0, 99, npcAffection[CLIFF], .after_cliff_check
    SPAWN_EXECUTOR 15, .cliff_setup

.after_cliff_check:
    BRANCH_ON_SPECIAL_BIT 14, lifeEventBits[1], .after_kai_check
    BRANCH_U8_VAR_WITHIN_RANGE 0, 99, npcAffection[KAI], .after_kai_check
    SPAWN_EXECUTOR 16, .kai_setup

.after_kai_check:
    SPAWN_EXECUTOR 17, .shipper_setup
    EXECUTE_SUBROUTINE .setup_player
    SET_COORDINATES -320, 0, 32
    SET_ASSET_ROTATION NORTHWEST
    SET_WAIT_FRAMES 1
    SPAWN_EXECUTOR 18, .firefly_18_pre
    SPAWN_EXECUTOR 19, .firefly_19_pre
    SPAWN_EXECUTOR 20, .firefly_20_pre
    SPAWN_EXECUTOR 21, .firefly_21_pre
    SPAWN_EXECUTOR 22, .firefly_22_pre
    UPDATE_GLOBAL_RGBA 80, 80, 80, 80, 8
    WAIT_RGBA_FINISHED
    SET_WAIT_FRAMES 20
    INIT_MESSAGE_BOX_TYPE1 0, FIREFLY_FESTIVAL_TEXT_INDEX, 0
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_ENTITY_MAP_SPACE_INDEPENDENT FALSE
    SET_U16_VALUE 0, D_80189824
    SPAWN_EXECUTOR 41, .timer_tick
    DEACTIVATE_SELF

.spawn_karen_if_wife:
    BRANCH_U8_VAR_WITHIN_RANGE 4, 4, gWife, .spawn_karen
    RETURN_FROM_SUBROUTINE

; ============================================================
; Festival timer and outro orchestration
; ============================================================
; Slot 41 counts up D_80189824 once per frame (skipped while
; var0 bit 0 is set, i.e. while the player is in a dialogue).
; When the counter reaches 1000, the mayor calls everyone home
; and the close scene is dispatched based on marriage and
; gSumGirlsWithHighAffection.

.timer_tick:
    SET_WAIT_FRAMES 1
    BRANCH_ON_SPECIAL_BIT 0, var0, .timer_tick
    UPDATE_U16_VALUE 1, 9999, D_80189824
    BRANCH_U16_VAR_WITHIN_RANGE 1000, 1000, D_80189824, .timer_expired
    EXECUTE_SUBROUTINE .timer_tick

.timer_expired:
    SET_SPECIAL_BIT 31, var0
    PAUSE_ENTITIES
    INIT_MESSAGE_BOX_TYPE1 0, FIREFLY_FESTIVAL_TEXT_INDEX, 1
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    CLEAR_SPECIAL_BIT 31, var0
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    SET_WAIT_FRAMES 32
    TOGGLE_PAUSE_ENTITIES
    SPAWN_EXECUTOR 0, .player_outro_enter
    SET_WAIT_FRAMES 1
    SETUP_MAP_ASSET MAIN_MAP_INDEX
    SET_ASSET_ROTATION WEST
    SET_COORDINATES -192, 96, -32
    SET_OTHER_EXECUTOR_PTR 1, .npc_face_se_idle
    SET_OTHER_EXECUTOR_PTR 2, .npc_face_se_idle
    SET_OTHER_EXECUTOR_PTR 3, .npc_face_se_idle
    SET_OTHER_EXECUTOR_PTR 4, .npc_face_se_idle
    SET_OTHER_EXECUTOR_PTR 5, .npc_face_se_idle
    SET_OTHER_EXECUTOR_PTR 6, .npc_face_se_idle
    SET_OTHER_EXECUTOR_PTR 7, .npc_face_se_idle
    SET_OTHER_EXECUTOR_PTR 8, .npc_face_se_idle
    SET_OTHER_EXECUTOR_PTR 9, .npc_face_se_idle
    SET_OTHER_EXECUTOR_PTR 10, .npc_face_se_idle
    SET_OTHER_EXECUTOR_PTR 11, .npc_face_se_idle
    SET_OTHER_EXECUTOR_PTR 12, .npc_face_se_idle
    SET_OTHER_EXECUTOR_PTR 13, .npc_face_se_idle
    SET_OTHER_EXECUTOR_PTR 14, .npc_face_se_idle
    SET_OTHER_EXECUTOR_PTR 15, .npc_face_se_idle
    SET_OTHER_EXECUTOR_PTR 16, .npc_face_se_idle
    SET_OTHER_EXECUTOR_PTR 17, .npc_face_se_idle
    SET_OTHER_EXECUTOR_PTR 18, .firefly_18_post
    SET_WAIT_FRAMES 1
    SET_OTHER_EXECUTOR_PTR 19, .firefly_19_post
    SET_WAIT_FRAMES 1
    SET_OTHER_EXECUTOR_PTR 20, .firefly_20_post
    SET_OTHER_EXECUTOR_PTR 21, .firefly_21_post
    SET_WAIT_FRAMES 1
    SET_OTHER_EXECUTOR_PTR 22, .firefly_22_post
    SPAWN_EXECUTOR 23, .firefly_23
    SPAWN_EXECUTOR 24, .firefly_24
    SET_WAIT_FRAMES 1
    SPAWN_EXECUTOR 25, .firefly_25
    SPAWN_EXECUTOR 26, .firefly_26
    SET_WAIT_FRAMES 1
    SPAWN_EXECUTOR 27, .firefly_27
    SPAWN_EXECUTOR 28, .firefly_28
    SET_WAIT_FRAMES 1
    SPAWN_EXECUTOR 29, .firefly_29
    SET_WAIT_FRAMES 1
    SPAWN_EXECUTOR 30, .firefly_30
    SPAWN_EXECUTOR 31, .firefly_31
    SET_WAIT_FRAMES 1
    SPAWN_EXECUTOR 32, .firefly_32
    SPAWN_EXECUTOR 33, .firefly_33
    SET_WAIT_FRAMES 1
    UPDATE_GLOBAL_RGBA 80, 80, 80, 80, 8
    SET_OTHER_EXECUTOR_PTR 18, .firefly_close
    SET_OTHER_EXECUTOR_PTR 19, .firefly_close
    SET_OTHER_EXECUTOR_PTR 20, .firefly_close
    SET_OTHER_EXECUTOR_PTR 21, .firefly_close
    SET_OTHER_EXECUTOR_PTR 22, .firefly_close
    SET_OTHER_EXECUTOR_PTR 23, .firefly_close
    SET_OTHER_EXECUTOR_PTR 24, .firefly_close
    SET_OTHER_EXECUTOR_PTR 25, .firefly_close
    SET_OTHER_EXECUTOR_PTR 26, .firefly_close
    SET_OTHER_EXECUTOR_PTR 27, .firefly_close
    SET_OTHER_EXECUTOR_PTR 28, .firefly_close
    SET_OTHER_EXECUTOR_PTR 29, .firefly_close
    SET_OTHER_EXECUTOR_PTR 30, .firefly_close
    SET_OTHER_EXECUTOR_PTR 31, .firefly_close
    SET_OTHER_EXECUTOR_PTR 32, .firefly_close
    SET_OTHER_EXECUTOR_PTR 33, .firefly_close
    WAIT_RGBA_FINISHED
    SET_FRAME_DELTA 2, 0, 0, 192
    SET_WAIT_FRAMES 30
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    SET_ASSET_ROTATION SOUTH
    DEACTIVATE_EXECUTOR 1
    DEACTIVATE_EXECUTOR 2
    DEACTIVATE_EXECUTOR 3
    DEACTIVATE_EXECUTOR 4
    DEACTIVATE_EXECUTOR 5
    DEACTIVATE_EXECUTOR 6
    DEACTIVATE_EXECUTOR 12
    DEACTIVATE_EXECUTOR 13
    DEACTIVATE_EXECUTOR 14
    DEACTIVATE_EXECUTOR 15
    DEACTIVATE_EXECUTOR 16
    DEACTIVATE_EXECUTOR 17
    DEACTIVATE_EXECUTOR 18
    DEACTIVATE_EXECUTOR 19
    DEACTIVATE_EXECUTOR 20
    DEACTIVATE_EXECUTOR 21
    DEACTIVATE_EXECUTOR 22
    DEACTIVATE_EXECUTOR 23
    DEACTIVATE_EXECUTOR 24
    DEACTIVATE_EXECUTOR 25
    DEACTIVATE_EXECUTOR 26
    DEACTIVATE_EXECUTOR 27
    DEACTIVATE_EXECUTOR 28
    DEACTIVATE_EXECUTOR 29
    DEACTIVATE_EXECUTOR 30
    DEACTIVATE_EXECUTOR 31
    DEACTIVATE_EXECUTOR 32
    DEACTIVATE_EXECUTOR 33
    BRANCH_ON_SPECIAL_BIT MARRIED, lifeEventBits[0], .close_married_dispatch
    BRANCH_U8_VAR_WITHIN_RANGE 1, 1, gSumGirlsWithHighAffection, .close_maria
    BRANCH_U8_VAR_WITHIN_RANGE 2, 2, gSumGirlsWithHighAffection, .close_popuri
    BRANCH_U8_VAR_WITHIN_RANGE 3, 3, gSumGirlsWithHighAffection, .close_elli
    BRANCH_U8_VAR_WITHIN_RANGE 4, 4, gSumGirlsWithHighAffection, .close_ann
    BRANCH_ON_SPECIAL_BIT 15, lifeEventBits[1], .close_no_girl
    BRANCH_U8_VAR_WITHIN_RANGE 0, 25, npcAffection[KAREN], .close_no_girl
    BRANCH_U8_VAR_WITHIN_RANGE 5, 5, gSumGirlsWithHighAffection, .close_karen

.close_no_girl:
    SET_AUDIO_SEQUENCE_VOLUME 0, 0, 2
    SET_WAIT_FRAMES 40
    STOP_SEQUENCE_WITH_FADE 0, 1
    IDLE_WHILE_SEQUENCE_PLAYING 0
    DEACTIVATE_EXECUTOR 0
    EXECUTE_SUBROUTINE .exit_demo

.firefly_close:
    UPDATE_RGBA 255, 255, 255, 255, 8
    WAIT_RGBA_FINISHED
    EXECUTE_SUBROUTINE .wait_loop

.close_married_dispatch:
    BRANCH_U8_VAR_WITHIN_RANGE 0, 0, gWife, .close_maria
    BRANCH_U8_VAR_WITHIN_RANGE 1, 1, gWife, .close_popuri
    BRANCH_U8_VAR_WITHIN_RANGE 2, 2, gWife, .close_elli
    BRANCH_U8_VAR_WITHIN_RANGE 3, 3, gWife, .close_ann
    BRANCH_U8_VAR_WITHIN_RANGE 4, 4, gWife, .close_karen
    RETURN_FROM_SUBROUTINE

.close_maria:
    SET_OTHER_EXECUTOR_PTR 0, .player_outro_track
    SET_OTHER_EXECUTOR_PTR 7, .maria_close
    DEACTIVATE_EXECUTOR 8
    DEACTIVATE_EXECUTOR 9
    DEACTIVATE_EXECUTOR 10
    DEACTIVATE_EXECUTOR 11
    EXECUTE_SUBROUTINE .wait_loop

.close_popuri:
    SET_OTHER_EXECUTOR_PTR 0, .player_outro_track
    SET_OTHER_EXECUTOR_PTR 8, .popuri_close
    DEACTIVATE_EXECUTOR 7
    DEACTIVATE_EXECUTOR 9
    DEACTIVATE_EXECUTOR 10
    DEACTIVATE_EXECUTOR 11
    EXECUTE_SUBROUTINE .wait_loop

.close_elli:
    SET_OTHER_EXECUTOR_PTR 0, .player_outro_track
    SET_OTHER_EXECUTOR_PTR 9, .elli_close
    DEACTIVATE_EXECUTOR 7
    DEACTIVATE_EXECUTOR 8
    DEACTIVATE_EXECUTOR 10
    DEACTIVATE_EXECUTOR 11
    EXECUTE_SUBROUTINE .wait_loop

.close_ann:
    SET_OTHER_EXECUTOR_PTR 0, .player_outro_track
    SET_OTHER_EXECUTOR_PTR 10, .ann_close
    DEACTIVATE_EXECUTOR 7
    DEACTIVATE_EXECUTOR 8
    DEACTIVATE_EXECUTOR 9
    DEACTIVATE_EXECUTOR 11
    EXECUTE_SUBROUTINE .wait_loop

.close_karen:
    SET_OTHER_EXECUTOR_PTR 0, .player_outro_track
    SET_OTHER_EXECUTOR_PTR 11, .karen_close
    DEACTIVATE_EXECUTOR 7
    DEACTIVATE_EXECUTOR 8
    DEACTIVATE_EXECUTOR 9
    DEACTIVATE_EXECUTOR 10
    EXECUTE_SUBROUTINE .wait_loop

; ----- Player outro executor states -----

.player_outro_enter:
    EXECUTE_SUBROUTINE .setup_player
    SET_BEHAVIOR_FLAGS 0
    SET_COORDINATES -256, 0, 0
    SET_ASSET_ROTATION NORTHEAST
    EXECUTE_SUBROUTINE .wait_loop

.player_outro_track:
    SET_BEHAVIOR_FLAGS CUTSCENE_ASSET_BEHAVIOR_TRACK_ENTITY
    SET_COORDINATES -288, 0, 0
    SET_ASSET_ROTATION NORTHEAST
    EXECUTE_SUBROUTINE .wait_loop

.player_walk_home_and_end:
    ENTITY_WALK 32, NORTH, 2
    SET_AUDIO_SEQUENCE_VOLUME 0, 0, 2
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    ENTITY_WALK 32, NORTH, 2
    STOP_SEQUENCE_WITH_FADE 0, 1
    IDLE_WHILE_SEQUENCE_PLAYING 0
    EXECUTE_SUBROUTINE .exit_demo

.player_walk_north_and_wait:
    ENTITY_WALK 32, NORTH, 2
    SET_ASSET_ROTATION NORTHEAST
    EXECUTE_SUBROUTINE .wait_loop

; ============================================================
; Slot 1 - Mayor
; ============================================================

.mayor_setup:
    SETUP_ENTITY 1, ENTITY_ASSET_MAYOR, 1
    SET_ENTITY_ANIMATIONS 1, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    SET_COORDINATES -352, 0, 32
    SET_ASSET_ROTATION SOUTHEAST

.mayor_wait:
    SET_CALLBACK_ROUTINE 0, 32768, .mayor_on_interact
    EXECUTE_SUBROUTINE .wait_loop

.mayor_on_interact:
    BRANCH_ON_SPECIAL_BIT 31, var0, .mayor_wait
    BRANCH_ON_SPECIAL_BIT 0, var1, .mayor_talk
    UPDATE_U8_VALUE 2, 255, npcAffection[NPC_MAYOR]
    SET_SPECIAL_BIT 0, var1

.mayor_talk:
    PAUSE_ENTITIES
    SET_SPECIAL_BIT 0, var0
    FLIP_ENTITY_DIRECTION 0
    INIT_MESSAGE_BOX_TYPE1 0, FIREFLY_FESTIVAL_TEXT_INDEX, 0
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITIES
    CLEAR_SPECIAL_BIT 0, var0
    EXECUTE_SUBROUTINE .mayor_wait

