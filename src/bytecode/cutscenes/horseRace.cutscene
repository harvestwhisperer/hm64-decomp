; ------------------------------------------------------------
; Per-horse race-tick state machines (horse1..horse6)
; ------------------------------------------------------------
; Each horse has an identical ~200-line state machine structure:
;   1. 50% chance to enter a random slowdown branch.
;   2. Pick a speed tier based on gRacingContext.displayOddsTop[N]
;      (lower odds = faster).
;   3. Within each tier, roll again to pick a step size; update
;      horseNProgress and SET_FRAME_DELTA to animate.
; The state machines keep looping until cs_race swaps them out
; via SET_OTHER_EXECUTOR_PTR to .horse_slowdown_after_finish.

.horse1_race_tick:
    BRANCH_ON_RANDOM 0, 50, .branch_12BCF4

.sub_12B908:
    SET_ANIM_DATA_PTR .anim_12B8F4
    BRANCH_U16_VAR_WITHIN_RANGE 1, 2, gRacingContext.displayOddsTop[0], .branch_12B970
    BRANCH_U16_VAR_WITHIN_RANGE 3, 6, gRacingContext.displayOddsTop[0], .branch_12B974
    BRANCH_U16_VAR_WITHIN_RANGE 9, 15, gRacingContext.displayOddsTop[0], .branch_12B988
    BRANCH_U16_VAR_WITHIN_RANGE 16, 30, gRacingContext.displayOddsTop[0], .branch_12B99C
    BRANCH_U16_VAR_WITHIN_RANGE 31, 50, gRacingContext.displayOddsTop[0], .branch_12B9B0
    BRANCH_U16_VAR_WITHIN_RANGE 51, 70, gRacingContext.displayOddsTop[0], .branch_12B9C4
    EXECUTE_SUBROUTINE .sub_12B9D8

.branch_12B970:
    EXECUTE_SUBROUTINE .sub_12B9EC

.branch_12B974:
    BRANCH_ON_RANDOM 0, 20, .branch_12BAEC
    BRANCH_ON_RANDOM 0, 60, .branch_12BBF0
    EXECUTE_SUBROUTINE .sub_12B9EC

