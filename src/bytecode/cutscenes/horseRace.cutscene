; ------------------------------------------------------------
; Announcer message bodies and race cleanup (slot 41)
; ------------------------------------------------------------
; Branched to from .announcer_tick. Each race-start handler
; (10h/13h/16h) shows its race text then calls
; .announcer_race_cleanup, which deactivates all NPC slots and
; fades to black. .announcer_between_races shows a fill text
; once, gated by bit 4 of D_801C3F78. .announcer_end_day fires
; at 18h to close out the festival.

.announcer_between_races:
    BRANCH_ON_SPECIAL_BIT 4, D_801C3F78, .announcer_tick
    PAUSE_ENTITIES
    SET_MESSAGE_INTERPOLATION -4, 0, 0
    SET_MESSAGE_BOX_ASSETS 0, 1, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 0, -64, 352
    INIT_MESSAGE_BOX_TYPE1 0, HORSE_RACE_TEXT_INDEX, 121
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_MESSAGE_BOX_ASSETS 0, 0, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 24, -64, 352
    TOGGLE_PAUSE_ENTITIES
    SET_SPECIAL_BIT 4, D_801C3F78
    EXECUTE_SUBROUTINE .announcer_tick

.announcer_race1_start:
    BRANCH_U8_VAR_WITHIN_RANGE 1, 255, gMinutes, .announcer_tick
    PAUSE_ENTITIES
    SET_MESSAGE_INTERPOLATION -4, 0, 0
    SET_MESSAGE_BOX_ASSETS 0, 1, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 0, -64, 352
    INIT_MESSAGE_BOX_TYPE1 0, HORSE_RACE_TEXT_INDEX, 115
    EXECUTE_SUBROUTINE .announcer_race_cleanup

.announcer_race2_start:
    BRANCH_U8_VAR_WITHIN_RANGE 1, 255, gMinutes, .announcer_tick
    PAUSE_ENTITIES
    SET_MESSAGE_INTERPOLATION -4, 0, 0
    SET_MESSAGE_BOX_ASSETS 0, 1, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 0, -64, 352
    INIT_MESSAGE_BOX_TYPE1 0, HORSE_RACE_TEXT_INDEX, 116
    EXECUTE_SUBROUTINE .announcer_race_cleanup

.announcer_race3_start:
    BRANCH_U8_VAR_WITHIN_RANGE 1, 255, gMinutes, .announcer_between_races
    PAUSE_ENTITIES
    SET_MESSAGE_INTERPOLATION -4, 0, 0
    SET_MESSAGE_BOX_ASSETS 0, 1, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 0, -64, 352
    INIT_MESSAGE_BOX_TYPE1 0, HORSE_RACE_TEXT_INDEX, 117
    EXECUTE_SUBROUTINE .announcer_race_cleanup

.announcer_end_day:
    PAUSE_ENTITIES
    SET_AUDIO_SEQUENCE_VOLUME 0, 0, 8
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    SET_WAIT_FRAMES 32
    STOP_SEQUENCE_WITH_FADE 0, 1
    DEACTIVATE_EXECUTOR 1
    DEACTIVATE_EXECUTOR 2
    DEACTIVATE_EXECUTOR 3
    DEACTIVATE_EXECUTOR 4
    DEACTIVATE_EXECUTOR 5
    DEACTIVATE_EXECUTOR 6
    DEACTIVATE_EXECUTOR 7
    DEACTIVATE_EXECUTOR 8
    DEACTIVATE_EXECUTOR 9
    DEACTIVATE_EXECUTOR 10
    DEACTIVATE_EXECUTOR 11
    DEACTIVATE_EXECUTOR 12
    DEACTIVATE_EXECUTOR 13
    DEACTIVATE_EXECUTOR 14
    DEACTIVATE_EXECUTOR 15
    IDLE_WHILE_SEQUENCE_PLAYING 0
    SET_SPECIAL_BIT 1, gCutsceneCompletionFlags
    EXECUTE_SUBROUTINE .exit_cutscene

.announcer_race_cleanup:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    SET_WAIT_FRAMES 32
    DEACTIVATE_EXECUTOR 1
    DEACTIVATE_EXECUTOR 2
    DEACTIVATE_EXECUTOR 3
    DEACTIVATE_EXECUTOR 4
    DEACTIVATE_EXECUTOR 5
    DEACTIVATE_EXECUTOR 6
    DEACTIVATE_EXECUTOR 7
    DEACTIVATE_EXECUTOR 8
    DEACTIVATE_EXECUTOR 9
    DEACTIVATE_EXECUTOR 10
    DEACTIVATE_EXECUTOR 11
    DEACTIVATE_EXECUTOR 12
    DEACTIVATE_EXECUTOR 13
    DEACTIVATE_EXECUTOR 14
    DEACTIVATE_EXECUTOR 15
    TOGGLE_PAUSE_ENTITIES
    SET_SPECIAL_BIT 1, gCutsceneCompletionFlags
    EXECUTE_SUBROUTINE .exit_cutscene

; ============================================================
; CUTSCENE 902 - The Race (player not riding)
; ============================================================
; Orchestrates one race:
;   1. Clear gRaceFinishOrder, spawn map, player stub, 6 horses,
;      and 9 trackside sprites (slots 30, 31, 35-41 -- trees,
;      horse status icons, green dot).
;   2. Show text 118, start SFX 85 and the gallop audio, hand
;      horse/trackside executors over to their race-tick
;      handlers for 240 frames.
;   3. Spawn .race_sfx_loop (slot 26) and
;      .race_track_finishers (slot 33); after 40 more frames,
;      swap horses to .horse_slowdown_after_finish and show
;      text 119.
;   4. Spawn .race_resolve_finish_order (slot 24); wait for it
;      to finish, then show results (text 120) and tear down via
;      .race_final_cleanup.

.cs_race:
    CLEAR_SPECIAL_BIT 0, D_801C3F78
    SET_U8_VALUE 0, gRaceFinishOrder
    SET_U8_VALUE 0, gRaceFinishOrder[1]
    SET_U8_VALUE 0, gRaceFinishOrder[2]
    SET_U8_VALUE 0, gRaceFinishOrder[3]
    SET_U8_VALUE 0, gRaceFinishOrder[4]
    SET_U8_VALUE 0, gRaceFinishOrder[5]
    SPAWN_EXECUTOR 32, .race_setup_map_stub
    SPAWN_EXECUTOR 16, .race_setup_player_stub
    SET_WAIT_FRAMES 2
    SPAWN_EXECUTOR 1, .horse1_setup
    SPAWN_EXECUTOR 2, .horse2_setup
    SPAWN_EXECUTOR 3, .horse3_setup
    SPAWN_EXECUTOR 4, .horse4_setup
    SPAWN_EXECUTOR 5, .horse5_setup
    SPAWN_EXECUTOR 6, .horse6_setup
    SPAWN_EXECUTOR 30, .trees_left_setup
    SPAWN_EXECUTOR 31, .trees_right_setup
    SPAWN_EXECUTOR 35, .green_dot_center_setup
    SPAWN_EXECUTOR 36, .icon_focused_left_setup
    SPAWN_EXECUTOR 37, .icon_neutral_left_setup
    SPAWN_EXECUTOR 38, .icon_tired_left_setup
    SPAWN_EXECUTOR 39, .icon_focused_right_setup
    SPAWN_EXECUTOR 40, .icon_neutral_right_setup
    SPAWN_EXECUTOR 41, .icon_tired_right_setup
    SET_WAIT_FRAMES 32
    SET_MESSAGE_INTERPOLATION -4, 0, 0
    SET_MESSAGE_BOX_ASSETS 0, 1, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 0, -64, 352
    INIT_MESSAGE_BOX_TYPE2 0, HORSE_RACE_TEXT_INDEX, 118
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_WAIT_FRAMES 20
    SET_SFX 85, 128
    SET_WAIT_FRAMES 10
    SET_AUDIO_SEQUENCE 1, _horseGallopFastSegmentRomStart, _horseGallopFastSegmentRomEnd
    SET_AUDIO_SEQUENCE_VOLUME 1, 128, 128
    SET_OTHER_EXECUTOR_PTR 1, .horse1_race_tick
    SET_OTHER_EXECUTOR_PTR 2, .horse2_race_tick
    SET_OTHER_EXECUTOR_PTR 3, .horse3_race_tick
    SET_OTHER_EXECUTOR_PTR 4, .horse4_race_tick
    SET_OTHER_EXECUTOR_PTR 5, .horse5_race_tick
    SET_OTHER_EXECUTOR_PTR 6, .horse6_race_tick
    SET_OTHER_EXECUTOR_PTR 30, .trees_left_race
    SET_OTHER_EXECUTOR_PTR 31, .trees_right_race
    SET_OTHER_EXECUTOR_PTR 35, .green_dot_center_race
    SET_OTHER_EXECUTOR_PTR 36, .icon_focused_left_race
    SET_OTHER_EXECUTOR_PTR 37, .icon_neutral_left_race
    SET_OTHER_EXECUTOR_PTR 38, .icon_tired_left_race
    SET_OTHER_EXECUTOR_PTR 39, .icon_focused_right_race
    SET_OTHER_EXECUTOR_PTR 40, .icon_neutral_right_race
    SET_OTHER_EXECUTOR_PTR 41, .icon_tired_right_race
    SET_WAIT_FRAMES 240
    SPAWN_EXECUTOR 26, .race_sfx_loop
    SET_WAIT_FRAMES 60
    SPAWN_EXECUTOR 32, .green_dot_finish_scroll_in
    SPAWN_EXECUTOR 33, .race_track_finishers
    SET_WAIT_FRAMES 40
    SET_OTHER_EXECUTOR_PTR 1, .horse_slowdown_after_finish
    SET_OTHER_EXECUTOR_PTR 2, .horse_slowdown_after_finish
    SET_OTHER_EXECUTOR_PTR 3, .horse_slowdown_after_finish
    SET_OTHER_EXECUTOR_PTR 4, .horse_slowdown_after_finish
    SET_OTHER_EXECUTOR_PTR 5, .horse_slowdown_after_finish
    SET_OTHER_EXECUTOR_PTR 6, .horse_slowdown_after_finish
    SET_OTHER_EXECUTOR_PTR 30, .wait_loop
    SET_OTHER_EXECUTOR_PTR 31, .wait_loop
    SET_OTHER_EXECUTOR_PTR 36, .wait_loop
    SET_OTHER_EXECUTOR_PTR 37, .wait_loop
    SET_OTHER_EXECUTOR_PTR 38, .wait_loop
    SET_OTHER_EXECUTOR_PTR 39, .wait_loop
    SET_OTHER_EXECUTOR_PTR 40, .wait_loop
    SET_OTHER_EXECUTOR_PTR 41, .wait_loop
    INIT_MESSAGE_BOX_TYPE2 0, HORSE_RACE_TEXT_INDEX, 119
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_AUDIO_SEQUENCE_VOLUME 1, 0, 4
    SPAWN_EXECUTOR 24, .race_resolve_finish_order
    SET_WAIT_FRAMES 60
    STOP_SEQUENCE_WITH_FADE 1, 1
    SET_SPECIAL_BIT 2, gCutsceneCompletionFlags

.race_wait_resolver:
    SET_WAIT_FRAMES 1
    BRANCH_ON_SPECIAL_BIT 2, gCutsceneCompletionFlags, .race_wait_resolver
    SET_WAIT_FRAMES 1
    INIT_MESSAGE_BOX_TYPE1 0, HORSE_RACE_TEXT_INDEX, 120
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    DEACTIVATE_EXECUTOR 26
    SET_WAIT_FRAMES 20
    SET_OTHER_EXECUTOR_PTR 30, .race_end_fade_black_exit
    SET_OTHER_EXECUTOR_PTR 31, .race_end_fade_black_exit
    SET_OTHER_EXECUTOR_PTR 32, .race_end_fade_black_exit
    SET_OTHER_EXECUTOR_PTR 36, .race_end_fade_black_exit
    SET_OTHER_EXECUTOR_PTR 37, .race_end_fade_black_exit
    SET_OTHER_EXECUTOR_PTR 38, .race_end_fade_black_exit
    SET_OTHER_EXECUTOR_PTR 39, .race_end_fade_black_exit
    SET_OTHER_EXECUTOR_PTR 40, .race_end_fade_black_exit
    SET_OTHER_EXECUTOR_PTR 41, .race_final_cleanup
    DEACTIVATE_SELF

.race_sfx_loop:
    SET_SFX 84, 128
    SET_WAIT_FRAMES 35
    EXECUTE_SUBROUTINE .race_sfx_loop

; ------------------------------------------------------------
; Race-end shared handlers (used by cutscenes 902 and 903)
; ------------------------------------------------------------
; .race_end_fade_black_exit is installed on trackside/horse slots
; at race end to fade to black and deactivate.
; .race_final_cleanup runs on the last surviving executor to
; stop audio, reset gMinutes, and exit the cutscene.

.race_end_fade_black_exit:
    UPDATE_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    DEACTIVATE_SELF

.race_final_cleanup:
    SET_AUDIO_SEQUENCE_VOLUME 0, 0, 4
    UPDATE_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    STOP_SEQUENCE_WITH_FADE 0, 1
    IDLE_WHILE_SEQUENCE_PLAYING 0
    SET_U8_VALUE 1, gMinutes
    SET_SPECIAL_BIT 2, D_801C3F78
    SET_SPECIAL_BIT 1, gCutsceneCompletionFlags
    EXECUTE_SUBROUTINE .exit_cutscene

; ------------------------------------------------------------
; Trackside sprite race-tick scroll handlers
; ------------------------------------------------------------
; SET_OTHER_EXECUTOR_PTR targets for the 9 trackside sprite
; slots (30, 31, 35-41) while a race is in progress. Each
; handler scrolls its sprite leftward via SET_FRAME_DELTA and
; loops back through .*_scroll_loop (slot resets to X=-320
; and re-scrolls).

.green_dot_center_race:
    SET_FRAME_DELTA 8, 0, 0, 60
    DEACTIVATE_SELF

.icon_focused_left_race:
    SET_FRAME_DELTA 8, 0, 0, 60
    EXECUTE_SUBROUTINE .icon_focused_scroll_loop

.icon_neutral_left_race:
    SET_FRAME_DELTA 8, 0, 0, 60
    EXECUTE_SUBROUTINE .icon_neutral_scroll_loop

.trees_left_race:
    SET_FRAME_DELTA 8, 0, 0, 60
    EXECUTE_SUBROUTINE .trees_scroll_loop

.icon_tired_left_race:
    SET_FRAME_DELTA 16, 0, 0, 30
    EXECUTE_SUBROUTINE .icon_tired_scroll_loop

.icon_focused_right_race:
    SET_FRAME_DELTA 8, 0, 0, 20

.icon_focused_scroll_loop:
    SET_COORDINATES -320, 0, -100
    SET_FRAME_DELTA 8, 0, 0, 80
    EXECUTE_SUBROUTINE .icon_focused_scroll_loop

.icon_neutral_right_race:
    SET_FRAME_DELTA 8, 0, 0, 20

.icon_neutral_scroll_loop:
    SET_COORDINATES -320, 0, -50
    SET_FRAME_DELTA 8, 0, 0, 80
    EXECUTE_SUBROUTINE .icon_neutral_scroll_loop

.trees_right_race:
    SET_FRAME_DELTA 8, 0, 0, 20

.trees_scroll_loop:
    SET_COORDINATES -320, 0, -40
    SET_FRAME_DELTA 8, 0, 0, 80
    EXECUTE_SUBROUTINE .trees_scroll_loop

.icon_tired_right_race:
    SET_FRAME_DELTA 16, 0, 0, 10

.icon_tired_scroll_loop:
    SET_COORDINATES -320, 0, 50
    SET_FRAME_DELTA 16, 0, 0, 40
    EXECUTE_SUBROUTINE .icon_tired_scroll_loop

; ------------------------------------------------------------
; Trackside sprite setups (horse-race effect spritesheet)
; ------------------------------------------------------------
; All slots DMA from _horseRaceTextureSegment. Each setup picks
; one anim which maps to a texture index in
; assets/sprites/effects/horseRace/textures/:
;   0 = horse icon (focused)     3 = green dot
;   1 = horse icon (neutral)     4 = yellow dot   (unused here)
;   2 = horse icon (tired)       5 = red dot      (unused here)
;   6 = ground                   8, 10 = fence/railing
;   7 = background trees         9 = finish line  (unused here)
; Horse icons overlay the colored dots to show per-horse
; stamina. Slot layout (X, Z):
;   30 trees left  (-160,-40)    31 trees right  (160,-40)
;   36 icon0 left  (-160,-100)   39 icon0 right  (160,-100)
;   37 icon1 left  (-160, -50)   40 icon1 right  (160, -50)
;   38 icon2 left  (-160,  50)   41 icon2 right  (160,  50)
;   35 green dot centered (64, -10)
;   32 green dot scrolls in from X=-320 at race end
; Spring season picks alternate palettes via
; .icon_spring_palette_3 / _8.

.icon_focused_right_setup:
    DMA_SPRITE 160, 0, _horseRaceTextureSegmentRomStart, _horseRaceTextureSegmentRomEnd, _horseRaceAssetsIndexSegmentRomStart, _horseRaceAssetsIndexSegmentRomEnd, 0, 0, 0x80299500, 0, 0x8029DF00, 0x8029E200, 0x8029E400, 0x00000000
    SET_ANIM_DATA_PTR_WITH_FLAG .anim_12B610
    SET_COORDINATES 160, 0, -100
    SET_SPRITE_SCALE 2, 2, 0
    SET_RGBA 0, 0, 0, 0
    SET_WAIT_FRAMES 1
    UPDATE_RGBA 255, 255, 255, 255, 8
    WAIT_RGBA_FINISHED
    EXECUTE_SUBROUTINE .wait_loop

.icon_spring_palette_3:
    SET_SPRITE_PALETTE 3
    RETURN_FROM_SUBROUTINE

.icon_neutral_right_setup:
    DMA_SPRITE 161, 0, _horseRaceTextureSegmentRomStart, _horseRaceTextureSegmentRomEnd, _horseRaceAssetsIndexSegmentRomStart, _horseRaceAssetsIndexSegmentRomEnd, 0, 0, 0x80299500, 0, 0x8029DF00, 0x8029E200, 0x8029E400, 0x00000000
    SET_ANIM_DATA_PTR_WITH_FLAG .anim_12B61C
    SET_SPRITE_PALETTE 5
    BRANCH_U8_VAR_WITHIN_RANGE 1, 1, gSeason, .icon_spring_palette_3
    SET_COORDINATES 160, 0, -50
    SET_SPRITE_SCALE 2, 2, 0
    SET_RGBA 0, 0, 0, 0
    SET_WAIT_FRAMES 1
    UPDATE_RGBA 255, 255, 255, 255, 8
    WAIT_RGBA_FINISHED
    EXECUTE_SUBROUTINE .wait_loop

.trees_right_setup:
    DMA_SPRITE 168, 0, _horseRaceTextureSegmentRomStart, _horseRaceTextureSegmentRomEnd, _horseRaceAssetsIndexSegmentRomStart, _horseRaceAssetsIndexSegmentRomEnd, 0, 0, 0x80299500, 0, 0x8029DF00, 0x8029E200, 0x8029E400, 0x00000000
    SET_ANIM_DATA_PTR_WITH_FLAG .anim_12B640
    SET_COORDINATES 160, 0, -40
    SET_SPRITE_SCALE 2, 2, 0
    SET_RGBA 0, 0, 0, 0
    SET_WAIT_FRAMES 1
    UPDATE_RGBA 255, 255, 255, 255, 8
    WAIT_RGBA_FINISHED
    EXECUTE_SUBROUTINE .wait_loop

.icon_spring_palette_8:
    SET_SPRITE_PALETTE 8
    RETURN_FROM_SUBROUTINE

.icon_tired_right_setup:
    DMA_SPRITE 162, 0, _horseRaceTextureSegmentRomStart, _horseRaceTextureSegmentRomEnd, _horseRaceAssetsIndexSegmentRomStart, _horseRaceAssetsIndexSegmentRomEnd, 0, 0, 0x80299500, 0, 0x8029DF00, 0x8029E200, 0x8029E400, 0x00000000
    SET_ANIM_DATA_PTR_WITH_FLAG .anim_12B628
    SET_SPRITE_PALETTE 10
    BRANCH_U8_VAR_WITHIN_RANGE 1, 1, gSeason, .icon_spring_palette_8
    SET_COORDINATES 160, 0, 50
    SET_SPRITE_SCALE 2, 2, 0
    SET_RGBA 0, 0, 0, 0
    SET_WAIT_FRAMES 1
    UPDATE_RGBA 255, 255, 255, 255, 8
    WAIT_RGBA_FINISHED
    EXECUTE_SUBROUTINE .wait_loop

.icon_focused_left_setup:
    DMA_SPRITE 163, 0, _horseRaceTextureSegmentRomStart, _horseRaceTextureSegmentRomEnd, _horseRaceAssetsIndexSegmentRomStart, _horseRaceAssetsIndexSegmentRomEnd, 0, 0, 0x80299500, 0, 0x8029DF00, 0x8029E200, 0x8029E400, 0x00000000
    SET_ANIM_DATA_PTR_WITH_FLAG .anim_12B610
    SET_COORDINATES -160, 0, -100
    SET_SPRITE_SCALE 2, 2, 0
    SET_RGBA 0, 0, 0, 0
    SET_WAIT_FRAMES 1
    UPDATE_RGBA 255, 255, 255, 255, 8
    WAIT_RGBA_FINISHED
    EXECUTE_SUBROUTINE .wait_loop

.icon_neutral_left_setup:
    DMA_SPRITE 164, 0, _horseRaceTextureSegmentRomStart, _horseRaceTextureSegmentRomEnd, _horseRaceAssetsIndexSegmentRomStart, _horseRaceAssetsIndexSegmentRomEnd, 0, 0, 0x80299500, 0, 0x8029DF00, 0x8029E200, 0x8029E400, 0x00000000
    SET_ANIM_DATA_PTR_WITH_FLAG .anim_12B61C
    SET_SPRITE_PALETTE 5
    BRANCH_U8_VAR_WITHIN_RANGE 1, 1, gSeason, .icon_spring_palette_3
    SET_COORDINATES -160, 0, -50
    SET_SPRITE_SCALE 2, 2, 0
    SET_RGBA 0, 0, 0, 0
    SET_WAIT_FRAMES 1
    UPDATE_RGBA 255, 255, 255, 255, 8
    WAIT_RGBA_FINISHED
    EXECUTE_SUBROUTINE .wait_loop

.trees_left_setup:
    DMA_SPRITE 167, 0, _horseRaceTextureSegmentRomStart, _horseRaceTextureSegmentRomEnd, _horseRaceAssetsIndexSegmentRomStart, _horseRaceAssetsIndexSegmentRomEnd, 0, 0, 0x80299500, 0, 0x8029DF00, 0x8029E200, 0x8029E400, 0x00000000
    SET_ANIM_DATA_PTR_WITH_FLAG .anim_12B640
    SET_COORDINATES -160, 0, -40
