.winner_player_bubble_setup:
    DMA_SPRITE 126, 1, _expressionBubblesTextureSegmentRomStart, _expressionBubblesTextureSegmentRomEnd, _expressionBubblesAssetsIndexSegmentRomStart, _expressionBubblesAssetsIndexSegmentRomEnd, _expressionBubblesSpritesheetIndexSegmentRomStart, _expressionBubblesSpritesheetIndexSegmentRomEnd, 0x80284C00, 0x80286400, 0x80287C00, 0x80288A00, 0x80288C00, 0x80288D00
    SET_ANIM_DATA_PTR_WITH_FLAG .anim_12FC20
    SET_RGBA 255, 255, 255, 255
    SET_COORDINATES 8, 20, 54
    SET_WAIT_FRAMES 40
    DEACTIVATE_SELF

