.sub_129A1C:
    BRANCH_U8_VAR_WITHIN_RANGE 0, 79, npcAffection[MARIA], .branch_129A4C
    INIT_DIALOGUE_SESSION 0, DIALOGUE_HORSE_RACE, 1
    WAIT_FOR_DIALOGUE_INPUT 0
    TOGGLE_PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .square_maria_wait

.branch_129A3C:
    BRANCH_U8_VAR_WITHIN_RANGE 0, 0, gWife, .branch_129A64
