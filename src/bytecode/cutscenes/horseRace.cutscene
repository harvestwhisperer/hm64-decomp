    SET_ANIM_DATA_PTR_WITH_FLAG .anim_12FD14
    SET_RGBA 255, 255, 255, 255
    SET_COORDINATES -160, -160, 30
    SET_FRAME_DELTA 1, 1, 0, 32
    SET_OTHER_EXECUTOR_PTR 1, .winner_player_anim_b
    SET_FRAME_DELTA 1, 1, 0, 96
    SET_ANIM_DATA_PTR .anim_12FD08
    INIT_MESSAGE_BOX_TYPE1 0, HORSE_RACE_TEXT_INDEX, 82
    WAIT_MESSAGE_BOX_CLOSED 0
