; ============================================================
; CUTSCENE 901 - Festival Crowd
; ============================================================
; Main festival view. Always spawns Kent, Stu, Potion Dealer,
; Rick, Popuri, Gray; then conditionally spawns Ann, Jeff, Elli,
; Harris, Cliff, Kai, Karen based on life-event bits, affection,
; and marital state. Old Man and Old Woman always spawn last.
; Time announcer (executor 41) polls gHour to gate the three
; races.

.cs_crowd:
    SET_SPECIAL_BIT 12, gCutsceneCompletionFlags
    STOP_SEQUENCE_WITH_FADE 0, 8
    IDLE_WHILE_SEQUENCE_PLAYING 0
    SET_AUDIO_SEQUENCE 0, _racingFestivalSegmentRomStart, _racingFestivalSegmentRomEnd
    SET_AUDIO_SEQUENCE_VOLUME 0, 128, 8
    SPAWN_EXECUTOR 1, .kent_setup
    SPAWN_EXECUTOR 2, .stu_setup
    SPAWN_EXECUTOR 3, .potion_dealer_setup
    SPAWN_EXECUTOR 4, .rick_setup
    SPAWN_EXECUTOR 5, .popuri_setup
    SPAWN_EXECUTOR 6, .gray_setup
    BRANCH_ON_SPECIAL_BIT 0, D_801C3F78, .branch_129E58

.branch_129D5C:
    SPAWN_EXECUTOR 7, .ann_setup

.branch_129D64:
    SPAWN_EXECUTOR 8, .jeff_setup
    SPAWN_EXECUTOR 9, .elli_setup
    BRANCH_U8_VAR_WITHIN_RANGE 0, 80, npcAffection[HARRIS], .branch_129D88
    SPAWN_EXECUTOR 10, .harris_setup

.branch_129D88:
    BRANCH_U8_VAR_WITHIN_RANGE 0, 80, npcAffection[CLIFF], .branch_129DA8
    BRANCH_ON_SPECIAL_BIT 13, lifeEventBits[1], .branch_129DA8
    SPAWN_EXECUTOR 11, .cliff_setup

.branch_129DA8:
    BRANCH_U8_VAR_WITHIN_RANGE 0, 80, npcAffection[KAI], .branch_129DC8
    BRANCH_ON_SPECIAL_BIT 14, lifeEventBits[1], .branch_129DC8
    SPAWN_EXECUTOR 12, .kai_setup

.branch_129DC8:
    BRANCH_ON_SPECIAL_BIT 15, lifeEventBits[1], .branch_129DF4
    BRANCH_ON_SPECIAL_BIT MARRIED, lifeEventBits[0], .branch_129E34
    BRANCH_U8_VAR_WITHIN_RANGE 0, 80, npcAffection[KAREN], .branch_129DF4

.branch_129DEC:
    SPAWN_EXECUTOR 13, .karen_setup

.branch_129DF4:
    SPAWN_EXECUTOR 14, .old_man_setup
    SPAWN_EXECUTOR 15, .old_woman_setup
    SET_WAIT_FRAMES 1
    UPDATE_GLOBAL_RGBA 254, 254, 254, 254, 0
    SET_WAIT_FRAMES 32
    BRANCH_ON_SPECIAL_BIT 1, D_801C3F78, .branch_129E44
    CLEAR_SPECIAL_BIT 12, gCutsceneCompletionFlags
    SPAWN_EXECUTOR 41, .announcer_tick
    DEACTIVATE_SELF

.branch_129E34:
    BRANCH_U8_VAR_WITHIN_RANGE 4, 4, gWife, .branch_129DEC
    RETURN_FROM_SUBROUTINE

.branch_129E44:
    CLEAR_SPECIAL_BIT 12, gCutsceneCompletionFlags
    SPAWN_EXECUTOR 41, .announcer_tick
    DEACTIVATE_SELF

.branch_129E58:
    BRANCH_ON_SPECIAL_BIT 19, lifeEventBits[2], .branch_129D5C
    BRANCH_ON_SPECIAL_BIT 1, D_801C3F78, .branch_129D64
    EXECUTE_SUBROUTINE .branch_129D5C

; ------------------------------------------------------------
; Time announcer dispatch (executor 41 during cutscenes 900/901)
; ------------------------------------------------------------
; Polls gHour every frame. Message bodies for race starts,
; between-races chatter, and end-of-day fade-out live below the
; NPC block (see .announcer_between_races onwards).

.announcer_tick:
    SET_WAIT_FRAMES 1
    BRANCH_U8_VAR_WITHIN_RANGE 10, 10, gHour, .announcer_race1_start
    BRANCH_U8_VAR_WITHIN_RANGE 13, 13, gHour, .announcer_race2_start
    BRANCH_U8_VAR_WITHIN_RANGE 16, 16, gHour, .announcer_race3_start
    BRANCH_U8_VAR_WITHIN_RANGE 18, 18, gHour, .announcer_end_day
    EXECUTE_SUBROUTINE .announcer_tick

; ------------------------------------------------------------
; NPC executors (cutscene 901). Each follows the same pattern:
;   _setup       -- place NPC and fall through to _wait
;   _wait        -- install interaction callback, then idle
;   _on_interact -- dispatcher: race-done? affection? married?
;   ... leaf handlers vary per NPC, ending in _talk_done style
;       close (WAIT_MESSAGE_BOX_CLOSED + return to _wait)
; Some NPCs have a _wait_2 / _on_interact_2 variant for alternate
; interaction states (Rick, Popuri, Ann).
; ------------------------------------------------------------

.kent_setup:
    SETUP_ENTITY 1, ENTITY_ASSET_KENT, 1
    SET_ENTITY_ANIMATIONS 1, 0, 8, 0, 0, 0, 0
