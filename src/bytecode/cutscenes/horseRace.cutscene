; ------------------------------------------------------------
; Horse slowdown after finish (shared)
; ------------------------------------------------------------
; SET_OTHER_EXECUTOR_PTR installs this on all horse slots once
; the race distance is covered -- horses coast to a stop.

.horse_slowdown_after_finish:
    SET_FRAME_DELTA -8, 0, 0, 60
    DEACTIVATE_SELF

; ------------------------------------------------------------
; Finish-order tracker (executor 33, during the race)
; ------------------------------------------------------------
; finishLine holds the finish-line threshold (decrementing from
; 544); each frame, checks whether horseNProgress has crossed
; finishLine and writes the placement for horse N into
; gRaceFinishOrder. When two horses are tied, the tie is broken
; by jumping into the other dispatcher to re-check. Deactivates
; once all 6 positions are filled.

.race_track_finishers:
    SET_U16_VALUE 544, finishLine

