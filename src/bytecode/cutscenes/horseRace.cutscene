; ============================================================
; CUTSCENE 904 - End-of-Day Closing
; ============================================================
; The closing scene after the race day is over. Loads a
; night-ambience sequence (spring uses
; _nightAmbienceSpringSegmentRom*, other seasons use the autumn
; variant) and spawns the Mayor. Player is placed at
; (-256, 0, 96) facing DIRECTION_NE. Mayor greets the player via text 122
; (non-spring) or text 123 (spring); subsequent interactions use
; text 124.

.cs_end_of_day_spring:
    SET_AUDIO_SEQUENCE 0, _nightAmbienceSpringSegmentRomStart, _nightAmbienceSpringSegmentRomEnd
    EXECUTE_SUBROUTINE .end_of_day_start

.cs_end_of_day:
    BRANCH_U8_VAR_WITHIN_RANGE 1, 1, gSeason, .cs_end_of_day_spring
    SET_AUDIO_SEQUENCE 0, _nightAmbienceAutumnSegmentRomStart, _nightAmbienceAutumnSegmentRomEnd

.end_of_day_start:
    SET_AUDIO_SEQUENCE_VOLUME 0, 128, 8
    SPAWN_EXECUTOR 1, .end_of_day_mayor_setup
    EXECUTE_SUBROUTINE .setup_player
    SET_COORDINATES -256, 0, 96
    SET_ASSET_ROTATION 5
    SET_WAIT_FRAMES 1
    UPDATE_GLOBAL_RGBA 254, 254, 254, 254, 0
    WAIT_RGBA_FINISHED
    BRANCH_U8_VAR_WITHIN_RANGE 1, 1, gSeason, .end_of_day_talk_spring
    INIT_MESSAGE_BOX_TYPE1 0, HORSE_RACE_TEXT_INDEX, 122

.end_of_day_close:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_ENTITY_MAP_SPACE_INDEPENDENT FALSE
    DEACTIVATE_SELF

.end_of_day_talk_spring:
    INIT_MESSAGE_BOX_TYPE1 0, HORSE_RACE_TEXT_INDEX, 123
    EXECUTE_SUBROUTINE .end_of_day_close

.end_of_day_mayor_setup:
    SETUP_ENTITY 1, ENTITY_ASSET_MAYOR, 1
    SET_ENTITY_ANIMATIONS 1, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_COORDINATES -224, 0, 64
    SET_ASSET_ROTATION 1

.end_of_day_mayor_wait:
    SET_CALLBACK_ROUTINE 0, 32768, .end_of_day_mayor_on_interact
    EXECUTE_SUBROUTINE .wait_loop

.end_of_day_mayor_on_interact:
    PAUSE_ENTITIES
    FLIP_ENTITY_DIRECTION 0
    EXECUTE_SUBROUTINE .setup_message_box
    INIT_MESSAGE_BOX_TYPE1 0, HORSE_RACE_TEXT_INDEX, 124
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .end_of_day_mayor_wait
