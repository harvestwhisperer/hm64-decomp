; ------------------------------------------------------------
; Trackside sprite animation tables (one frame each)
; ------------------------------------------------------------
; Each label picks a single texture index into the horse-race
; effect spritesheet (assets/sprites/effects/horseRace/textures):
;   .anim_12B610 -> 0 (horse icon focused)
;   .anim_12B61C -> 1 (horse icon neutral)
;   .anim_12B628 -> 2 (horse icon tired)
;   .anim_12B634 -> 3 (green dot)
;   .anim_12B640 -> 7 (background trees)

.anim_12B610:
    .anim_frame 0, 0xFE, (0, 0, 0), 255, 0
    .anim_end

.anim_12B61C:
    .anim_frame 1, 0xFE, (0, 0, 0), 255, 0
    .anim_end

.anim_12B628:
    .anim_frame 2, 0xFE, (0, 0, 0), 255, 0
    .anim_end

.anim_12B634:
    .anim_frame 3, 0xFE, (0, 0, 0), 255, 0
    .anim_end

.anim_12B640:
    .anim_frame 7, 0xFE, (0, 0, 0), 255, 0
    .anim_end

; ------------------------------------------------------------
; Race setup stubs (spawned once at race start)
; ------------------------------------------------------------
; .race_setup_player_stub calls .setup_player then deactivates.
; .race_setup_map_stub loads the main map asset then deactivates.

.race_setup_player_stub:
    EXECUTE_SUBROUTINE .setup_player
    DEACTIVATE_SELF

.race_setup_map_stub:
    SETUP_MAP_ASSET MAIN_MAP_INDEX
    SET_WAIT_FRAMES 1
    DEACTIVATE_SELF

; ------------------------------------------------------------
; Horse setups (slots 1-6)
; ------------------------------------------------------------
; Each horse DMAs its sprite, picks a palette (coloring),
; positions itself at the starting line, fades in, and seeds
; horseNProgress to 128. Slot 3 is reserved for the player
; horse in cutscene 903 (see .player_horse_setup).

.horse1_setup:
    DMA_SPRITE 136, 1, _horseRacerTextureSegmentRomStart, _horseRacerTextureSegmentRomEnd, _horseRacerAssetsIndexSegmentRomStart, _horseRacerAssetsIndexSegmentRomEnd, _horseRacerSpritesheetIndexSegmentRomStart, _horseRacerSpritesheetIndexSegmentRomEnd, 0x8027C400, 0x8027DC00, 0x8027F400, 0x80280200, 0x80280400, 0x80280500
    SET_ANIM_DATA_PTR_WITH_FLAG .anim_12B8E8
    SET_SPRITE_PALETTE 0
    SET_COORDINATES 96, 24, 0
    SET_RGBA 0, 0, 0, 0
    SET_WAIT_FRAMES 1
    UPDATE_RGBA 255, 255, 255, 255, 8
    WAIT_RGBA_FINISHED
    SET_U16_VALUE 128, horse1Progress
    EXECUTE_SUBROUTINE .wait_loop

