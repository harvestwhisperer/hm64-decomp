    UPDATE_U16_VALUE -8, 9999, finishLine
    SET_WAIT_FRAMES 1
    BRANCH_U8_VAR_WITHIN_RANGE 1, 1, gRaceFinishOrder, .branch_12D24C
    BRANCH_IF_U16_PTR_IN_RANGE horse1Progress, finishLine, progressCeiling, .branch_12D2F0

