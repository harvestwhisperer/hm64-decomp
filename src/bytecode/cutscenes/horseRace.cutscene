; ============================================
; Bank 12 - Horse Race
; ============================================
;
; Five cutscenes, dispatched by gCutsceneIndex at .dispatch:
;   900: ticket-stand area       -> .cs_square  (HORSE_RACE_SQUARE)
;   901: festival crowd          -> .cs_crowd   (HORSE_RACE_STARTING_ANNOUNCEMENT)
;   902: race (player not riding)-> .cs_race
;   903: race (player is riding) -> .cs_race_player  (runs winner ceremony)
;   904: end-of-day closing      -> .cs_end_of_day
;
; D_801C3F78 race-state bits (usage from bytecode only):
;   bit 0: race has completed  (gates the post-race NPC variants)
;   bit 1: player horse placed 1st
;   bit 2: set in .race_final_cleanup
;   bit 3: toggled at .cs_race start; also set at .cs_race_player_after_finish
;   bit 4: between-races announcer message already played
;   bit 5: unused here
;   bit 10: set after player-race ceremony finishes
; Bit numbers above are observations of sets/toggles -- semantics beyond
; that are not verified.
;
; gRaceFinishOrder[0..5]: finishing order (placement codes 1..6).
; horse1Progress..horse6Progress: per-horse position counters.
; finishLine, progressCeiling: scratch for the finish-order resolver.

#include "entities.h"
#include "texts.h"
#include "dialogues.h"

#define MAIN_MAP_INDEX 0

.buffer 2

; 0x802F5000
.local var0, u32, 0
; 0x802F5004
.local horse1Progress, u16, 0
; 0x802F5006
.local horse2Progress, u16, 0
; 0x802F5008
.local horse3Progress, u16, 0
; 0x802F500A
.local horse4Progress, u16, 0
; 0x802F500C
.local horse5Progress, u16, 0
; 0x802F500E
.local horse6Progress, u16, 0
; 0x802F5010
.local finishLine, u16, 0
; 0x802F5012
.local progressCeiling, u16, 999
; 0x802F5014
.local var9, u16, 0

.array npcAffection, u8
.array lifeEventBits, u32
.array dailyEventBits, u32
.array gRaceFinishOrder, u8

.struct gRacingContext, RacingContext

#define MARRIED 0

.dispatch:
    SET_SPECIAL_BIT 13, gCutsceneCompletionFlags
    SET_SPECIAL_BIT 14, gCutsceneCompletionFlags
    SET_SPECIAL_BIT 15, gCutsceneCompletionFlags
    TOGGLE_PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .setup_message_box
    BRANCH_U16_VAR_WITHIN_RANGE 900, 900, gCutsceneIndex, .cs_square
    BRANCH_U16_VAR_WITHIN_RANGE 901, 901, gCutsceneIndex, .cs_crowd
    BRANCH_U16_VAR_WITHIN_RANGE 902, 902, gCutsceneIndex, .cs_race
    BRANCH_U16_VAR_WITHIN_RANGE 903, 903, gCutsceneIndex, .cs_race_player
    BRANCH_U16_VAR_WITHIN_RANGE 904, 904, gCutsceneIndex, .cs_end_of_day

; ============================================================
; SHARED HELPERS
; ============================================================

.exit_cutscene:
    CLEAR_SPECIAL_BIT 0, var0
    CLEAR_SPECIAL_BIT 1, var0
    CLEAR_SPECIAL_BIT 2, var0
    SET_SPECIAL_BIT 0, gCutsceneCompletionFlags
    DEACTIVATE_SELF

.wait_loop:
    SET_WAIT_FRAMES 1
    EXECUTE_SUBROUTINE .wait_loop

.setup_message_box:
    SET_MESSAGE_INTERPOLATION -4, 0, 0
    SET_MESSAGE_BOX_ASSETS 0, 0, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 24, -64, 352
    RETURN_FROM_SUBROUTINE

.setup_player:
    SETUP_ENTITY 0, ENTITY_ASSET_PLAYER, 1
    SET_ENTITY_ANIMATIONS 0, 0, 8, 16, 24, 32, 40
    SET_BEHAVIOR_FLAGS CUTSCENE_ASSET_BEHAVIOR_TRACK_ENTITY
    RETURN_FROM_SUBROUTINE

; ============================================================
; CUTSCENE 900 - Ticket-Stand Square
; ============================================================
; Entered at the ticket-stand area. Starts the racing festival
; music, adds map overlays (season-dependent: spring spawns
; overlays 3 and 5 via .square_spawn_season1_variant, other
; seasons use overlays 1 and 6), and spawns Mayor, Mayor Wife,
; Maria, Shipper, and three festival girls. Announcer
; (executor 41) ticks on gHour.

.cs_square:
    SET_SPECIAL_BIT 12, gCutsceneCompletionFlags
    STOP_SEQUENCE_WITH_FADE 0, 8
    IDLE_WHILE_SEQUENCE_PLAYING 0
    SET_AUDIO_SEQUENCE 0, _racingFestivalSegmentRomStart, _racingFestivalSegmentRomEnd
    SET_AUDIO_SEQUENCE_VOLUME 0, 128, 8
    BRANCH_U8_VAR_WITHIN_RANGE 1, 1, gSeason, .square_spawn_season1_variant
    INIT_MAP_ADDITION 1, 0
    INIT_MAP_ADDITION 6, 0

.square_spawn_npcs:
    SPAWN_EXECUTOR 1, .mayor_setup
    SPAWN_EXECUTOR 2, .mayor_wife_setup
    SPAWN_EXECUTOR 3, .square_maria_setup
    SPAWN_EXECUTOR 4, .shipper_setup
    SPAWN_EXECUTOR 5, .square_girl1_setup
    SPAWN_EXECUTOR 6, .square_girl2_setup
    SPAWN_EXECUTOR 7, .square_girl3_setup
    SET_WAIT_FRAMES 1
    UPDATE_GLOBAL_RGBA 254, 254, 254, 254, 0
    SET_WAIT_FRAMES 32
    CLEAR_SPECIAL_BIT 12, gCutsceneCompletionFlags
    SPAWN_EXECUTOR 41, .announcer_tick
    DEACTIVATE_SELF

.square_spawn_season1_variant:
    INIT_MAP_ADDITION 3, 0
    INIT_MAP_ADDITION 5, 0
    EXECUTE_SUBROUTINE .square_spawn_npcs

.mayor_setup:
    SETUP_ENTITY 1, ENTITY_ASSET_MAYOR, 1
    SET_ENTITY_ANIMATIONS 1, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_COORDINATES -192, 0, -32
    SET_ASSET_ROTATION 6

.mayor_wait:
    SET_CALLBACK_ROUTINE 0, 32768, .mayor_on_interact
    EXECUTE_SUBROUTINE .wait_loop

.mayor_on_interact:
    PAUSE_ENTITIES
    FLIP_ENTITY_DIRECTION 0
    EXECUTE_SUBROUTINE .setup_message_box
    INIT_MESSAGE_BOX_TYPE1 0, HORSE_RACE_TEXT_INDEX, 125
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .mayor_wait

.mayor_wife_setup:
    SETUP_ENTITY 2, ENTITY_ASSET_MAYOR_WIFE, 1
    SET_ENTITY_ANIMATIONS 2, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_COORDINATES -192, 0, 16
    SET_ASSET_ROTATION 6

