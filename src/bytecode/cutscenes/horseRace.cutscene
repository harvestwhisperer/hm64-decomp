; ============================================================
; Winner Celebration (spawned from .race_player_after_finish)
; ============================================================
; Foreground sprite sequence when the player horse places 3rd
; or better:
;   slot 1 (.winner_player_setup)    player walks in, anim swaps
;   slot 2 (.winner_horse_setup)     horse enters, walks off
;   slot 3 (.winner_doug_setup)      Doug enters, text 80
;   slot 4 (.winner_mayor_setup)     Mayor walks up
;   slot 5 (.winner_photographer_setup) photographer
;   slot 6 (.winner_ann_setup)       Ann
;   slot 7 (.winner_player_bubble_setup) expression bubble over
;                                    player at ceremony end
; Finally sets dailyEventBits[1] bit 21 and lifeEventBits[2]
; bit 19 (placement flags consumed elsewhere), then tears down
; via .race_final_cleanup.

.winner_player_setup:
    DMA_SPRITE 135, 1, _playerTextureSegmentRomStart, _playerTextureSegmentRomEnd, _playerAssetsIndexSegmentRomStart, _playerAssetsIndexSegmentRomEnd, _playerSpritesheetIndexSegmentRomStart, _playerSpritesheetIndexSegmentRomEnd, 0x80240B00, 0x80243B00, 0x80246B00, 0x8024AB00, 0x80252300, 0x80252B00
    SET_ANIM_DATA_PTR_WITH_FLAG .anim_12FC38
    SET_COORDINATES -8, -8, 30
    SET_RGBA 0, 0, 0, 0
    SET_WAIT_FRAMES 1
    UPDATE_RGBA 255, 255, 255, 255, 8
    WAIT_RGBA_FINISHED
    EXECUTE_SUBROUTINE .wait_loop

.winner_player_anim_a:
    SET_ANIM_DATA_PTR .anim_12FC44
    EXECUTE_SUBROUTINE .wait_loop

.winner_player_anim_b:
    SET_ANIM_DATA_PTR .anim_12FC38
    EXECUTE_SUBROUTINE .wait_loop

.winner_player_anim_c:
    SET_ANIM_DATA_PTR .anim_12FC50
    EXECUTE_SUBROUTINE .wait_loop

.winner_player_anim_d:
    SET_ANIM_DATA_PTR .anim_12FC5C
    EXECUTE_SUBROUTINE .wait_loop

.winner_player_ceremony:
    SET_ANIM_DATA_PTR .anim_12FC68
    SET_FRAME_DELTA 2, 0, 0, 10
    SET_ANIM_DATA_PTR .anim_12FC5C
    SET_WAIT_FRAMES 2
    SET_ANIM_DATA_PTR .anim_12FC74
    SET_WAIT_FRAMES 10
    SET_OTHER_EXECUTOR_PTR 6, .winner_ann_anim
    SET_WAIT_FRAMES 10
    INIT_MESSAGE_BOX_TYPE1 0, HORSE_RACE_TEXT_INDEX, 78
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 6, .winner_ann_walk_off
    SET_ANIM_DATA_PTR .anim_12FC90
    SET_WAIT_FRAMES 60
    SPAWN_EXECUTOR 7, .winner_player_bubble_setup
    SET_WAIT_FRAMES 40
    SET_SPECIAL_BIT 21, dailyEventBits[1]
    SET_SPECIAL_BIT 19, lifeEventBits[2]
    SET_OTHER_EXECUTOR_PTR 30, .race_end_fade_black_exit
    SET_OTHER_EXECUTOR_PTR 31, .race_end_fade_black_exit
    SET_OTHER_EXECUTOR_PTR 36, .race_end_fade_black_exit
    SET_OTHER_EXECUTOR_PTR 37, .race_end_fade_black_exit
    SET_OTHER_EXECUTOR_PTR 39, .race_end_fade_black_exit
    SET_OTHER_EXECUTOR_PTR 40, .race_end_fade_black_exit
    EXECUTE_SUBROUTINE .race_final_cleanup

.winner_horse_setup:
    DMA_SPRITE 143, 1, _horseGrownTextureSegmentRomStart, _horseGrownTextureSegmentRomEnd, _horseGrownAssetsIndexSegmentRomStart, _horseGrownAssetsIndexSegmentRomEnd, _horseGrownSpritesheetIndexSegmentRomStart, _horseGrownSpritesheetIndexSegmentRomEnd, 0x80295C00, 0x80296C08, 0x80297C10, 0x80298500, 0x80299100, 0x80299200
    SET_ANIM_DATA_PTR_WITH_FLAG .anim_12FC9C
    SET_COORDINATES -16, 16, 10
    SET_RGBA 0, 0, 0, 0
    SET_WAIT_FRAMES 1
    UPDATE_RGBA 255, 255, 255, 255, 8
    WAIT_RGBA_FINISHED
    EXECUTE_SUBROUTINE .wait_loop

.winner_horse_walk_off:
    SET_ANIM_DATA_PTR .anim_12FCB4
    SET_FRAME_DELTA 1, 0, 0, 32
    SET_ANIM_DATA_PTR .anim_12FCA8
    SET_FRAME_DELTA 1, -1, 0, 160
    DEACTIVATE_SELF

.winner_doug_setup:
    DMA_SPRITE 144, 1, _dougTextureSegmentRomStart, _dougTextureSegmentRomEnd, _dougAssetsIndexSegmentRomStart, _dougAssetsIndexSegmentRomEnd, _dougSpritesheetIndexSegmentRomStart, _dougSpritesheetIndexSegmentRomEnd, 0x8026F000, 0x8026FC80, 0x80270900, 0x80271380, 0x80272180, 0x80272280
    SET_ANIM_DATA_PTR_WITH_FLAG .anim_12FCF0
