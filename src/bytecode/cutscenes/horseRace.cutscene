; ============================================================
; CUTSCENE 903 - The Race (player riding)
; ============================================================
; Variant of cutscene 902 where the player controls horse 3
; (slot 21, .player_horse_setup). Flow is the same as cs_race
; except:
;   - No horse3_setup / horse3_race_tick spawned; slot 21 runs
;     .player_horse_tick, which polls controller input via
;     .player_horse_input_poll to pick a speed tier.
;   - Slot 34 shows the .player_horse_indicator sprite above
;     the player horse throughout the race.
;   - On finish, if the player placed 3rd or better, falls into
;     .race_player_after_finish which spawns the winner
;     celebration (slot 1 player, 2 horse, 3 Doug, 4 mayor,
;     5 photographer, 6 Ann) and shows texts 78/80.
;   - Sets bit 10 of D_801C3F78 once ceremony completes.

.cs_race_player:
    EXECUTE_SUBROUTINE .setup_player
    SPAWN_EXECUTOR 5, .race_setup_map_stub
    SPAWN_EXECUTOR 16, .cs_race_player_main
    DEACTIVATE_SELF

.cs_race_player_main:
    CLEAR_SPECIAL_BIT 0, D_801C3F78
    SET_U8_VALUE 0, gRaceFinishOrder
    SET_U8_VALUE 0, gRaceFinishOrder[1]
    SET_U8_VALUE 0, gRaceFinishOrder[2]
    SET_U8_VALUE 0, gRaceFinishOrder[3]
    SET_U8_VALUE 0, gRaceFinishOrder[4]
    SET_U8_VALUE 0, gRaceFinishOrder[5]
    SET_WAIT_FRAMES 2
    SPAWN_EXECUTOR 21, .player_horse_setup
    SPAWN_EXECUTOR 1, .horse1_setup
    SPAWN_EXECUTOR 2, .horse2_setup
    SPAWN_EXECUTOR 4, .horse4_setup
    SPAWN_EXECUTOR 5, .horse5_setup
    SPAWN_EXECUTOR 6, .horse6_setup
    SPAWN_EXECUTOR 34, .player_horse_indicator_setup
    SPAWN_EXECUTOR 30, .trees_left_setup
    SPAWN_EXECUTOR 31, .trees_right_setup
    SPAWN_EXECUTOR 35, .green_dot_center_setup
    SPAWN_EXECUTOR 36, .icon_focused_left_setup
    SPAWN_EXECUTOR 37, .icon_neutral_left_setup
    SPAWN_EXECUTOR 38, .icon_tired_left_setup
    SPAWN_EXECUTOR 39, .icon_focused_right_setup
    SPAWN_EXECUTOR 40, .icon_neutral_right_setup
    SPAWN_EXECUTOR 41, .icon_tired_right_setup
    SET_WAIT_FRAMES 32
    SET_MESSAGE_INTERPOLATION -4, 0, 0
    SET_MESSAGE_BOX_ASSETS 0, 1, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 0, -64, 352
    INIT_MESSAGE_BOX_TYPE1 0, HORSE_RACE_TEXT_INDEX, 128
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_WAIT_FRAMES 30
    INIT_MESSAGE_BOX_TYPE2 0, HORSE_RACE_TEXT_INDEX, 118
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_WAIT_FRAMES 20
    SET_SFX 85, 128
    SET_WAIT_FRAMES 10
    SET_AUDIO_SEQUENCE 1, _horseGallopFastSegmentRomStart, _horseGallopFastSegmentRomEnd
    SET_AUDIO_SEQUENCE_VOLUME 1, 128, 128
    SET_OTHER_EXECUTOR_PTR 1, .horse1_race_tick
    SET_OTHER_EXECUTOR_PTR 2, .horse2_race_tick
    SET_OTHER_EXECUTOR_PTR 4, .horse4_race_tick
    SET_OTHER_EXECUTOR_PTR 5, .horse5_race_tick
    SET_OTHER_EXECUTOR_PTR 6, .horse6_race_tick
    SET_OTHER_EXECUTOR_PTR 21, .player_horse_tick
    SET_OTHER_EXECUTOR_PTR 30, .trees_left_race
    SET_OTHER_EXECUTOR_PTR 31, .trees_right_race
    SET_OTHER_EXECUTOR_PTR 35, .green_dot_center_race
    SET_OTHER_EXECUTOR_PTR 36, .icon_focused_left_race
    SET_OTHER_EXECUTOR_PTR 37, .icon_neutral_left_race
    SET_OTHER_EXECUTOR_PTR 38, .icon_tired_left_race
    SET_OTHER_EXECUTOR_PTR 39, .icon_focused_right_race
    SET_OTHER_EXECUTOR_PTR 40, .icon_neutral_right_race
    SET_OTHER_EXECUTOR_PTR 41, .icon_tired_right_race
    SET_WAIT_FRAMES 240
    SPAWN_EXECUTOR 26, .race_sfx_loop
    SET_WAIT_FRAMES 60
    SPAWN_EXECUTOR 32, .green_dot_finish_scroll_in
    SPAWN_EXECUTOR 33, .race_track_finishers
    SET_WAIT_FRAMES 40
    SET_OTHER_EXECUTOR_PTR 1, .horse_slowdown_after_finish
    SET_OTHER_EXECUTOR_PTR 2, .horse_slowdown_after_finish
    SET_OTHER_EXECUTOR_PTR 4, .horse_slowdown_after_finish
    SET_OTHER_EXECUTOR_PTR 5, .horse_slowdown_after_finish
    SET_OTHER_EXECUTOR_PTR 6, .horse_slowdown_after_finish
    SET_OTHER_EXECUTOR_PTR 21, .horse_slowdown_after_finish
    DEACTIVATE_EXECUTOR 22
    DEACTIVATE_EXECUTOR 23
    SET_OTHER_EXECUTOR_PTR 30, .wait_loop
    SET_OTHER_EXECUTOR_PTR 31, .wait_loop
    SET_OTHER_EXECUTOR_PTR 36, .wait_loop
    SET_OTHER_EXECUTOR_PTR 37, .wait_loop
    SET_OTHER_EXECUTOR_PTR 38, .wait_loop
    SET_OTHER_EXECUTOR_PTR 39, .wait_loop
    SET_OTHER_EXECUTOR_PTR 40, .wait_loop
    SET_OTHER_EXECUTOR_PTR 41, .wait_loop
    INIT_MESSAGE_BOX_TYPE2 0, HORSE_RACE_TEXT_INDEX, 119
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_AUDIO_SEQUENCE_VOLUME 1, 0, 4
    SPAWN_EXECUTOR 24, .race_resolve_finish_order
    SET_WAIT_FRAMES 60
    STOP_SEQUENCE_WITH_FADE 1, 1
    SET_SPECIAL_BIT 2, gCutsceneCompletionFlags

.race_player_wait_resolver:
    SET_WAIT_FRAMES 1
    BRANCH_ON_SPECIAL_BIT 2, gCutsceneCompletionFlags, .race_player_wait_resolver
    SET_WAIT_FRAMES 1
    INIT_MESSAGE_BOX_TYPE1 0, HORSE_RACE_TEXT_INDEX, 120
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    DEACTIVATE_EXECUTOR 26
    SET_WAIT_FRAMES 20
    SET_SPECIAL_BIT 0, D_801C3F78
    SET_SPECIAL_BIT 10, D_801C3F78
    BRANCH_U8_VAR_WITHIN_RANGE 3, 3, gRaceFinishOrder, .race_player_after_finish
    SET_OTHER_EXECUTOR_PTR 30, .race_end_fade_black_exit
    SET_OTHER_EXECUTOR_PTR 31, .race_end_fade_black_exit
    SET_OTHER_EXECUTOR_PTR 32, .race_end_fade_black_exit
    SET_OTHER_EXECUTOR_PTR 34, .race_end_fade_black_exit
    SET_OTHER_EXECUTOR_PTR 36, .race_end_fade_black_exit
    SET_OTHER_EXECUTOR_PTR 37, .race_end_fade_black_exit
    SET_OTHER_EXECUTOR_PTR 38, .race_end_fade_black_exit
    SET_OTHER_EXECUTOR_PTR 39, .race_end_fade_black_exit
    SET_OTHER_EXECUTOR_PTR 40, .race_end_fade_black_exit
    SET_OTHER_EXECUTOR_PTR 41, .race_final_cleanup
    DEACTIVATE_SELF

.race_player_after_finish:
    SET_SPECIAL_BIT 1, D_801C3F78
    SET_OTHER_EXECUTOR_PTR 32, .race_end_fade_black_exit
    SET_OTHER_EXECUTOR_PTR 34, .race_end_fade_black_exit
    SET_OTHER_EXECUTOR_PTR 30, .race_end_fade_black
    SET_OTHER_EXECUTOR_PTR 31, .race_end_fade_black
    SET_OTHER_EXECUTOR_PTR 36, .race_end_fade_black
    SET_OTHER_EXECUTOR_PTR 37, .race_end_fade_black
    SET_OTHER_EXECUTOR_PTR 38, .race_end_fade_black_exit
    SET_OTHER_EXECUTOR_PTR 39, .race_end_fade_black
    SET_OTHER_EXECUTOR_PTR 40, .race_end_fade_black
    SET_OTHER_EXECUTOR_PTR 41, .race_end_fade_black_exit
    SET_WAIT_FRAMES 40
    SPAWN_EXECUTOR 1, .winner_player_setup
    SPAWN_EXECUTOR 2, .winner_horse_setup
    SET_WAIT_FRAMES 1
    SET_OTHER_EXECUTOR_PTR 30, .race_end_fade_white
    SET_OTHER_EXECUTOR_PTR 31, .race_end_fade_white
    SET_OTHER_EXECUTOR_PTR 36, .race_end_fade_white
    SET_OTHER_EXECUTOR_PTR 37, .race_end_fade_white
    SET_OTHER_EXECUTOR_PTR 39, .race_end_fade_white
    SET_OTHER_EXECUTOR_PTR 40, .race_end_fade_white
    SET_WAIT_FRAMES 32
    SPAWN_EXECUTOR 3, .winner_doug_setup
    DEACTIVATE_SELF

.race_end_fade_white:
    UPDATE_RGBA 255, 255, 255, 255, 8
    WAIT_RGBA_FINISHED
    EXECUTE_SUBROUTINE .wait_loop

.race_end_fade_black:
    UPDATE_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    EXECUTE_SUBROUTINE .wait_loop

; ------------------------------------------------------------
; Player horse sprite, tick handler, and indicator (cutscene 903)
; ------------------------------------------------------------
; .player_horse_setup: DMAs the player horse sprite into slot 21
;   and seeds horse3Progress (slot 21 occupies horse 3 slot).
; .player_horse_tick: per-frame state machine that reads
;   controller input via .player_horse_input_poll and maps it to
;   one of four speed tiers (.player_horse_speed_1..4). When the
;   horse crosses the finish line it falls through to the slowdown.
; .player_horse_indicator_setup: small indicator sprite above the
;   player horse, alternating .anim_12F630 / .anim_12F63C.

.player_horse_setup:
    DMA_SPRITE 135, 1, _playerTextureSegmentRomStart, _playerTextureSegmentRomEnd, _playerAssetsIndexSegmentRomStart, _playerAssetsIndexSegmentRomEnd, _playerSpritesheetIndexSegmentRomStart, _playerSpritesheetIndexSegmentRomEnd, 0x80240B00, 0x80243B00, 0x80246B00, 0x8024AB00, 0x80252300, 0x80252B00
    SET_ANIM_DATA_PTR_WITH_FLAG .anim_12F60C
    SET_COORDINATES 96, -24, 10
    SET_RGBA 0, 0, 0, 0
    SET_WAIT_FRAMES 1
    UPDATE_RGBA 255, 255, 255, 255, 8
    WAIT_RGBA_FINISHED
    SET_U16_VALUE 128, horse3Progress
    EXECUTE_SUBROUTINE .wait_loop

.player_horse_tick:
    BRANCH_IF_U16_PTR_IN_RANGE var9, D_80180710, progressCeiling, .branch_12F390
    BRANCH_IF_U16_PTR_IN_RANGE var9, D_801886D2, progressCeiling, .branch_12F370
    BRANCH_ON_RANDOM 0, 50, .branch_12F564

.player_horse_run_anim:
    SET_ANIM_DATA_PTR .anim_12F618
    SPAWN_EXECUTOR 22, .player_horse_input_poll
    SPAWN_EXECUTOR 23, .player_horse_timer_tick
    EXECUTE_SUBROUTINE .wait_loop

.player_horse_timer_tick:
    SET_WAIT_FRAMES 30
    UPDATE_U16_VALUE 1, 9999, var9
    EXECUTE_SUBROUTINE .player_horse_timer_tick

.player_horse_input_poll:
    BRANCH_IF_U16_PTR_IN_RANGE var9, D_80189824, progressCeiling, .branch_12F49C
    BRANCH_ON_SPECIAL_BIT 0, var0, .branch_12F348
    BRANCH_IF_U16_PTR_IN_RANGE var9, D_801886D2, progressCeiling, .branch_12F35C
    BRANCH_ON_SPECIAL_BIT 1, var0, .branch_12F348
    BRANCH_IF_U16_PTR_IN_RANGE var9, D_80180710, progressCeiling, .branch_12F37C

.branch_12F348:
    BRANCH_ON_BUTTON_PRESSED 0, 32768, .branch_12F4BC
    SET_WAIT_FRAMES 1
    EXECUTE_SUBROUTINE .player_horse_input_poll

.branch_12F35C:
    SET_OTHER_EXECUTOR_PTR 34, .player_horse_indicator_anim_b
    SET_SPECIAL_BIT 0, var0
    EXECUTE_SUBROUTINE .branch_12F348

.branch_12F370:
    SET_OTHER_EXECUTOR_PTR 34, .player_horse_indicator_anim_b
    RETURN_FROM_SUBROUTINE

.branch_12F37C:
    SET_OTHER_EXECUTOR_PTR 34, .player_horse_indicator_anim_a
    SET_SPECIAL_BIT 1, var0
    EXECUTE_SUBROUTINE .branch_12F348

.branch_12F390:
    SET_OTHER_EXECUTOR_PTR 34, .player_horse_indicator_anim_a
    RETURN_FROM_SUBROUTINE

.player_horse_speed_1:
    UPDATE_U16_VALUE 2, 9999, horse3Progress
    SET_FRAME_DELTA -2, 0, 0, 1
    EXECUTE_SUBROUTINE .wait_loop

.player_horse_speed_2:
    UPDATE_U16_VALUE 2, 9999, horse3Progress
    SET_FRAME_DELTA -2, 0, 0, 1
    UPDATE_U16_VALUE 2, 9999, horse3Progress
    SET_FRAME_DELTA -2, 0, 0, 1
    EXECUTE_SUBROUTINE .wait_loop

.player_horse_speed_3:
    UPDATE_U16_VALUE 2, 9999, horse3Progress
    SET_FRAME_DELTA -2, 0, 0, 1
    UPDATE_U16_VALUE 2, 9999, horse3Progress
    SET_FRAME_DELTA -2, 0, 0, 1
    UPDATE_U16_VALUE 2, 9999, horse3Progress
    SET_FRAME_DELTA -2, 0, 0, 1
    EXECUTE_SUBROUTINE .wait_loop

.player_horse_speed_4:
    UPDATE_U16_VALUE 2, 9999, horse3Progress
    SET_FRAME_DELTA -2, 0, 0, 1
    UPDATE_U16_VALUE 2, 9999, horse3Progress
    SET_FRAME_DELTA -2, 0, 0, 1
    UPDATE_U16_VALUE 2, 9999, horse3Progress
    SET_FRAME_DELTA -2, 0, 0, 1
    UPDATE_U16_VALUE 2, 9999, horse3Progress
    SET_FRAME_DELTA -2, 0, 0, 1
    EXECUTE_SUBROUTINE .wait_loop

.player_horse_exhausted_slowdown:
    BRANCH_U16_VAR_WITHIN_RANGE 0, 100, horse3Progress, .wait_loop
    UPDATE_U16_VALUE -2, 9999, horse3Progress
    SET_FRAME_DELTA 2, 0, 0, 1
    EXECUTE_SUBROUTINE .wait_loop

.branch_12F49C:
    BRANCH_ON_RANDOM 0, 50, .branch_12F4AC
    SET_WAIT_FRAMES 5
    EXECUTE_SUBROUTINE .branch_12F49C

.branch_12F4AC:
    SET_OTHER_EXECUTOR_PTR 21, .player_horse_exhausted_slowdown
    SET_WAIT_FRAMES 5
    EXECUTE_SUBROUTINE .branch_12F49C

.branch_12F4BC:
    UPDATE_U16_VALUE 5, 9999, var9
    SET_WAIT_FRAMES 1
    BRANCH_ON_RANDOM 0, 10, .branch_12F4F4
    BRANCH_ON_RANDOM 11, 45, .branch_12F500
    BRANCH_ON_RANDOM 46, 80, .branch_12F50C
    BRANCH_ON_RANDOM 81, 100, .branch_12F518
    EXECUTE_SUBROUTINE .branch_12F500
    EXECUTE_SUBROUTINE .player_horse_input_poll

.branch_12F4F4:
    SET_OTHER_EXECUTOR_PTR 21, .player_horse_speed_1
    EXECUTE_SUBROUTINE .player_horse_input_poll

.branch_12F500:
    SET_OTHER_EXECUTOR_PTR 21, .player_horse_speed_2
    EXECUTE_SUBROUTINE .player_horse_input_poll

.branch_12F50C:
    SET_OTHER_EXECUTOR_PTR 21, .player_horse_speed_3
    EXECUTE_SUBROUTINE .player_horse_input_poll

.branch_12F518:
    SET_OTHER_EXECUTOR_PTR 21, .player_horse_speed_4
    EXECUTE_SUBROUTINE .player_horse_input_poll
    BRANCH_ON_RANDOM 0, 30, .branch_12F4F4
    BRANCH_ON_RANDOM 31, 70, .branch_12F500
    BRANCH_ON_RANDOM 71, 100, .branch_12F50C
    EXECUTE_SUBROUTINE .branch_12F4F4
    BRANCH_ON_RANDOM 0, 20, .branch_12F4F4
    BRANCH_ON_RANDOM 21, 50, .branch_12F500
    BRANCH_ON_RANDOM 51, 90, .branch_12F50C
    BRANCH_ON_RANDOM 91, 100, .branch_12F518
    EXECUTE_SUBROUTINE .branch_12F4F4

.branch_12F564:
    UPDATE_U16_VALUE -8, 9999, horse3Progress
    SET_FRAME_DELTA 8, 0, 0, 1
    BRANCH_ON_RANDOM 0, 25, .branch_12F584
    EXECUTE_SUBROUTINE .player_horse_run_anim

.branch_12F584:
    UPDATE_U16_VALUE -8, 9999, horse3Progress
    SET_FRAME_DELTA 8, 0, 0, 1
    EXECUTE_SUBROUTINE .player_horse_run_anim

.player_horse_indicator_setup:
    DMA_SPRITE 142, 0, _horseRaceTextureSegmentRomStart, _horseRaceTextureSegmentRomEnd, _horseRaceAssetsIndexSegmentRomStart, _horseRaceAssetsIndexSegmentRomEnd, 0, 0, 0x80299500, 0, 0x8029DF00, 0x8029E200, 0x8029E400, 0x00000000
    SET_ANIM_DATA_PTR_WITH_FLAG .anim_12F624
    SET_COORDINATES -112, 80, 200
    SET_RGBA 0, 0, 0, 0
    SET_WAIT_FRAMES 1
    UPDATE_RGBA 255, 255, 255, 255, 8
