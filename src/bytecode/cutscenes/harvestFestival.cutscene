; ============================================================
; Player executors - cake ceremony and post-dance reset
; ============================================================
.executor_0_cake_ceremony:
    TOGGLE_PAUSE_ENTITY 0
    EXECUTE_SUBROUTINE .setup_player
    SET_ASSET_ROTATION SOUTHWEST
    SET_OTHER_EXECUTOR_PTR 40, .executor_40_coin_fade_out
    SET_ENTITY_DIRECTIONAL_ANIMATION 24
    SET_WAIT_FRAMES 16
    SET_ENTITY_ANIMATION 437
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SET_WAIT_FRAMES 10
    FLIP_ENTITY_DIRECTION 3
    BRANCH_U8_VAR_WITHIN_RANGE 0, 0, gHarvestCoinFinder, .executor_0_coin_found
    SET_MESSAGE_INTERPOLATION -4, 0, 0
    SET_MESSAGE_BOX_ASSETS 0, 1, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 0, -64, 256
    INIT_MESSAGE_BOX_TYPE1 0, HARVEST_FESTIVAL_TEXT_INDEX, 62
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_MESSAGE_BOX_ASSETS 0, 0, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 24, -64, 256
    SET_OTHER_EXECUTOR_PTR 6, .executor_6_wait_stub
    SET_WAIT_FRAMES 15
    INIT_MESSAGE_BOX_TYPE1 0, HARVEST_FESTIVAL_TEXT_INDEX, 65
    WAIT_MESSAGE_BOX_CLOSED 0
    EXECUTE_SUBROUTINE .announce_king_and_start_dance

.executor_0_coin_found:
    UPDATE_U8_VALUE 5, 255, gHappiness
    SET_ENTITY_ANIMATION 369
    SPAWN_EXECUTOR 40, .executor_40_coin_on_player
    SET_MESSAGE_INTERPOLATION -4, 0, 0
    SET_MESSAGE_BOX_ASSETS 0, 1, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 0, -64, 256
    INIT_MESSAGE_BOX_TYPE1 0, HARVEST_FESTIVAL_TEXT_INDEX, 63
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_MESSAGE_BOX_ASSETS 0, 0, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 24, -64, 256
    DEACTIVATE_EXECUTOR 40
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SET_OTHER_EXECUTOR_PTR 6, .executor_6_wait_stub
    SET_WAIT_FRAMES 15
    INIT_MESSAGE_BOX_TYPE1 0, HARVEST_FESTIVAL_TEXT_INDEX, 64
    WAIT_MESSAGE_BOX_CLOSED 0

.announce_king_and_start_dance:
    INIT_MESSAGE_BOX_TYPE1 0, HARVEST_FESTIVAL_TEXT_INDEX, 66
    WAIT_MESSAGE_BOX_CLOSED 0
    INIT_MESSAGE_BOX_TYPE1 0, HARVEST_FESTIVAL_TEXT_INDEX, 67
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_ENTITY_MAP_SPACE_INDEPENDENT FALSE
    SET_SPECIAL_BIT 0, var0
    TOGGLE_PAUSE_ENTITY 0
    DEACTIVATE_SELF

.executor_0_post_dance:
    EXECUTE_SUBROUTINE .setup_player
    SET_BEHAVIOR_FLAGS 0
    SET_COORDINATES 48, 0, 0
    SET_ASSET_ROTATION NORTHEAST
    EXECUTE_SUBROUTINE .wait_loop

; ============================================================
; Executor 1 - Maria (bachelorette candidate)
; ============================================================
.maria_setup:
    SETUP_ENTITY 1, ENTITY_ASSET_MARIA, 1
    SET_ENTITY_ANIMATIONS 1, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_COORDINATES -96, 0, 192
    SET_ASSET_ROTATION NORTHWEST

.maria_wait:
    SET_CALLBACK_ROUTINE 0, 32768, .maria_on_interact
    EXECUTE_SUBROUTINE .wait_loop

.maria_on_interact:
    BRANCH_ON_SPECIAL_BIT 0, var1, .maria_dialogue_dispatch
    UPDATE_U8_VALUE 2, 255, npcAffection[MARIA]
    SET_SPECIAL_BIT 0, var1

.maria_dialogue_dispatch:
    PAUSE_ENTITY 0
    FLIP_ENTITY_DIRECTION 0
    EXECUTE_SUBROUTINE .setup_message_box
    SET_SPECIAL_BIT 6, var0
    BRANCH_ON_SPECIAL_BIT 0, var0, .maria_dance_prompt
    BRANCH_ON_SPECIAL_BIT 26, lifeEventBits[0], .maria_talk_elli_taught
    BRANCH_ON_SPECIAL_BIT 1, var0, .maria_repeat_interact
    SET_SPECIAL_BIT 1, var0
    BRANCH_ON_SPECIAL_BIT MARRIED, lifeEventBits[0], .maria_married_first_interact
    INIT_DIALOGUE_SESSION 0, DIALOGUE_TEXT_56, 7
    WAIT_FOR_DIALOGUE_INPUT 0
    TOGGLE_PAUSE_ENTITY 0
    CLEAR_SPECIAL_BIT 6, var0
    EXECUTE_SUBROUTINE .maria_wait

.maria_married_first_interact:
    BRANCH_U8_VAR_WITHIN_RANGE MARIA, MARIA, gWife, .maria_talk_cooking_not_organized
    RETURN_FROM_SUBROUTINE

.maria_repeat_interact:
    BRANCH_ON_SPECIAL_BIT MARRIED, lifeEventBits[0], .maria_married_repeat
    INIT_MESSAGE_BOX_TYPE1 0, HARVEST_FESTIVAL_TEXT_INDEX, 28
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITY 0
    CLEAR_SPECIAL_BIT 6, var0
    EXECUTE_SUBROUTINE .maria_wait

.maria_married_repeat:
    BRANCH_U8_VAR_WITHIN_RANGE MARIA, MARIA, gWife, .maria_talk_stew
    RETURN_FROM_SUBROUTINE

.maria_talk_cooking_not_organized:
    INIT_MESSAGE_BOX_TYPE1 0, HARVEST_FESTIVAL_TEXT_INDEX, 27
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITY 0
    CLEAR_SPECIAL_BIT 6, var0
    EXECUTE_SUBROUTINE .maria_wait

.maria_talk_stew:
    INIT_MESSAGE_BOX_TYPE1 0, HARVEST_FESTIVAL_TEXT_INDEX, 29
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITY 0
    CLEAR_SPECIAL_BIT 6, var0
    EXECUTE_SUBROUTINE .maria_wait

.maria_talk_elli_taught:
    INIT_MESSAGE_BOX_TYPE1 0, HARVEST_FESTIVAL_TEXT_INDEX, 30
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITY 0
    CLEAR_SPECIAL_BIT 6, var0
    EXECUTE_SUBROUTINE .maria_wait

.maria_dance_prompt:
    INIT_DIALOGUE_SESSION 0, DIALOGUE_TEXT_56, 3
    WAIT_FOR_DIALOGUE_INPUT 0
    BRANCH_ON_DIALOGUE 0, 0, .choose_dance_maria
    BRANCH_ON_DIALOGUE 0, 1, .maria_dance_declined

.maria_dance_declined:
    TOGGLE_PAUSE_ENTITY 0
    EXECUTE_SUBROUTINE .maria_wait

; ============================================================
; Executor 2 - Popuri (bachelorette candidate)
; ============================================================
.popuri_setup:
    SETUP_ENTITY 2, ENTITY_ASSET_POPURI, 1
    SET_ENTITY_ANIMATIONS 2, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_COORDINATES -128, 0, -256
    SET_ASSET_ROTATION SOUTHWEST

.popuri_wait:
    SET_CALLBACK_ROUTINE 0, 32768, .popuri_on_interact
    EXECUTE_SUBROUTINE .wait_loop

.popuri_on_interact:
    BRANCH_ON_SPECIAL_BIT 1, var1, .popuri_dialogue_dispatch
    UPDATE_U8_VALUE 2, 255, npcAffection[POPURI]
    SET_SPECIAL_BIT 1, var1

.popuri_dialogue_dispatch:
    PAUSE_ENTITY 0
    FLIP_ENTITY_DIRECTION 0
    EXECUTE_SUBROUTINE .setup_message_box
    SET_SPECIAL_BIT 6, var0
    BRANCH_ON_SPECIAL_BIT 0, var0, .popuri_dance_prompt
    BRANCH_ON_SPECIAL_BIT 27, lifeEventBits[0], .popuri_talk_husband_quiet
    BRANCH_ON_SPECIAL_BIT 2, var0, .popuri_repeat_interact
    SET_SPECIAL_BIT 2, var0
    BRANCH_ON_SPECIAL_BIT MARRIED, lifeEventBits[0], .popuri_married_first_interact
    INIT_DIALOGUE_SESSION 0, DIALOGUE_TEXT_56, 11
    WAIT_FOR_DIALOGUE_INPUT 0
    TOGGLE_PAUSE_ENTITY 0
    CLEAR_SPECIAL_BIT 6, var0
    EXECUTE_SUBROUTINE .popuri_wait

.popuri_married_first_interact:
    BRANCH_U8_VAR_WITHIN_RANGE POPURI, POPURI, gWife, .popuri_talk_herbs_missing
    RETURN_FROM_SUBROUTINE

.popuri_repeat_interact:
    BRANCH_ON_SPECIAL_BIT MARRIED, lifeEventBits[0], .popuri_married_repeat
    INIT_MESSAGE_BOX_TYPE1 0, HARVEST_FESTIVAL_TEXT_INDEX, 36
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITY 0
    CLEAR_SPECIAL_BIT 6, var0
    EXECUTE_SUBROUTINE .popuri_wait

.popuri_married_repeat:
    BRANCH_U8_VAR_WITHIN_RANGE POPURI, POPURI, gWife, .popuri_talk_herb_stew
    RETURN_FROM_SUBROUTINE

.popuri_talk_herbs_missing:
    INIT_MESSAGE_BOX_TYPE1 0, HARVEST_FESTIVAL_TEXT_INDEX, 37
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITY 0
    CLEAR_SPECIAL_BIT 6, var0
    EXECUTE_SUBROUTINE .popuri_wait

.popuri_talk_herb_stew:
    INIT_MESSAGE_BOX_TYPE1 0, HARVEST_FESTIVAL_TEXT_INDEX, 38
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITY 0
    CLEAR_SPECIAL_BIT 6, var0
    EXECUTE_SUBROUTINE .popuri_wait

.popuri_talk_husband_quiet:
    INIT_MESSAGE_BOX_TYPE1 0, HARVEST_FESTIVAL_TEXT_INDEX, 39
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITY 0
    CLEAR_SPECIAL_BIT 6, var0
    EXECUTE_SUBROUTINE .popuri_wait

.popuri_dance_prompt:
    INIT_DIALOGUE_SESSION 0, DIALOGUE_TEXT_56, 3
    WAIT_FOR_DIALOGUE_INPUT 0
    BRANCH_ON_DIALOGUE 0, 0, .choose_dance_popuri
    BRANCH_ON_DIALOGUE 0, 1, .popuri_dance_declined

.popuri_dance_declined:
    TOGGLE_PAUSE_ENTITY 0
    EXECUTE_SUBROUTINE .popuri_wait

; ============================================================
; Executor 3 - Elli (bachelorette candidate, also brings the coin cake)
; ============================================================
.elli_setup:
    SETUP_ENTITY 3, ENTITY_ASSET_ELLI, 1
    SET_ENTITY_ANIMATIONS 3, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
