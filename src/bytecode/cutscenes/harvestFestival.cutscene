    SET_BEHAVIOR_FLAGS 0
    SET_COORDINATES -144, 0, 160
    SET_ENTITY_ANIMATION 58
    EXECUTE_SUBROUTINE .wait_loop

.executor_21_setup:
    SETUP_ENTITY 25, ENTITY_ASSET_STATIC_ITEM, 1
    SET_ENTITY_ANIMATIONS 25, 0, 0, 0, 0, 0, 0
