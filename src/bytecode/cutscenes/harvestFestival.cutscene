; ============================================================
; Bank 19 - Harvest Festival
; ============================================================
; Cutscene index 1200: the Harvest Festival, triggered each
; autumn day 12 between 6:00 and 17:59 (see cutscenes.c).
; Mayor opens the ceremony, Elli offers the coin cake to the
; player, the next Harvest King is announced, and a dance
; sequence plays with each of the five bachelorette candidates.
;
; Executor slots:
;   0       - player
;   1..5    - bachelorette candidates: Maria, Popuri, Elli, Ann, Karen
;   6..12   - townspeople always present (Mayor, Mayor wife,
;             Potion Shop Dealer, May, Kent, Stu, Harris)
;   13..16  - conditional spouses of Maria / Elli / Ann / Karen
;             (Gray, Jeff, Cliff, Kai) shown after marriage or
;             when NPC affection is high enough
;   17, 18  - Assistant Carpenter and Shipper
;   19..34  - festival decoration items (entity asset
;             ENTITY_ASSET_STATIC_ITEM)
;   40      - Elli cake / coin overlay
;   41      - random-number ticker that picks the Harvest King
;   33      - dance-phase timer and finale
;
; var0 bit layout:
;   bit 0       - cake ceremony has finished, dance prompt is armed
;   bits 1..5   - per-bachelorette first-interaction flags (Maria..Karen)
;   bit 6       - an interaction is currently active (lock)
;
; var1 bit layout (once-per-cutscene affection bumps):
;   bits 0..17  - one flag per interactive NPC

#include "entities.h"
#include "texts.h"
#include "dialogues.h"

.buffer 2

; Local variables
.local var0, u32, 0
.local var1, u32, 0

.array npcAffection, u8
.array lifeEventBits, u32

#define MAIN_MAP_INDEX 0

; lifeEventBits[0] bit index
#define MARRIED 0

.start:
    SET_SPECIAL_BIT 31, gCutsceneCompletionFlags
    SET_SPECIAL_BIT 12, gCutsceneCompletionFlags
    SET_SPECIAL_BIT 13, gCutsceneCompletionFlags
    SET_SPECIAL_BIT 14, gCutsceneCompletionFlags
    SET_SPECIAL_BIT 15, gCutsceneCompletionFlags
    PAUSE_ENTITIES
    STOP_SEQUENCE_WITH_FADE 0, 8
    IDLE_WHILE_SEQUENCE_PLAYING 0
    SET_AUDIO_SEQUENCE 0, _namingScreenSegmentRomStart, _namingScreenSegmentRomEnd
    SET_AUDIO_SEQUENCE_VOLUME 0, 128, 8
    TOGGLE_PAUSE_ENTITIES
    BRANCH_U16_VAR_WITHIN_RANGE 1200, 1200, gCutsceneIndex, .main

; ============================================================
; Shared helpers
; ============================================================
.exit_cutscene:
    SET_U32_VALUE 0, var0
    SET_SPECIAL_BIT 0, gCutsceneCompletionFlags
    DEACTIVATE_SELF

.wait_loop:
    SET_WAIT_FRAMES 1
    EXECUTE_SUBROUTINE .wait_loop

.setup_message_box:
    SET_MESSAGE_INTERPOLATION -4, 0, 0
    SET_MESSAGE_BOX_ASSETS 0, 0, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 24, -64, 352
    RETURN_FROM_SUBROUTINE

.setup_player:
    SETUP_ENTITY 0, ENTITY_ASSET_PLAYER, 1
    SET_ENTITY_ANIMATIONS 0, 0, 8, 16, 24, 32, 40
    SET_BEHAVIOR_FLAGS CUTSCENE_ASSET_BEHAVIOR_TRACK_ENTITY
    RETURN_FROM_SUBROUTINE

.executor_6_wait_stub:
    SET_ASSET_ROTATION SOUTH
    EXECUTE_SUBROUTINE .wait_loop

; ============================================================
; Main setup - spawn NPCs and trigger the coin-cake ceremony
; ============================================================
.main:
    INIT_MAP_ADDITION 2, 0
    INIT_MAP_ADDITION 3, 0
    INIT_MAP_ADDITION 4, 0
    INIT_MAP_ADDITION 5, 0
    SPAWN_EXECUTOR 1, .maria_setup
    SPAWN_EXECUTOR 2, .popuri_setup
    SPAWN_EXECUTOR 4, .ann_setup
    BRANCH_ON_SPECIAL_BIT 15, lifeEventBits[1], .spawn_remaining_npcs
    SPAWN_EXECUTOR 5, .karen_setup
    BRANCH_ON_SPECIAL_BIT 14, lifeEventBits[1], .spawn_remaining_npcs
    BRANCH_U8_VAR_WITHIN_RANGE 100, 255, npcAffection[KAI], .spawn_kai_high_affection

.spawn_remaining_npcs:
    SPAWN_EXECUTOR 6, .mayor_setup
    SPAWN_EXECUTOR 7, .mayor_wife_setup
    SPAWN_EXECUTOR 8, .potion_shop_dealer_setup
    SPAWN_EXECUTOR 9, .may_setup
    SPAWN_EXECUTOR 10, .kent_setup
    SPAWN_EXECUTOR 11, .stu_setup
    SPAWN_EXECUTOR 12, .harris_setup
    BRANCH_U8_VAR_WITHIN_RANGE 100, 255, npcAffection[GRAY], .spawn_gray_high_affection
    SPAWN_EXECUTOR 14, .jeff_setup
    BRANCH_ON_SPECIAL_BIT 13, lifeEventBits[1], .spawn_decorations
    BRANCH_U8_VAR_WITHIN_RANGE 100, 255, npcAffection[CLIFF], .spawn_cliff_high_affection

.spawn_decorations:
    SPAWN_EXECUTOR 17, .assistant_carpenter_setup
    SPAWN_EXECUTOR 18, .shipper_setup
    SPAWN_EXECUTOR 19, .executor_19_setup
    SPAWN_EXECUTOR 20, .executor_20_setup
    SPAWN_EXECUTOR 21, .executor_21_setup
    SPAWN_EXECUTOR 22, .executor_22_setup
    SPAWN_EXECUTOR 23, .executor_23_setup
    SPAWN_EXECUTOR 24, .executor_24_setup
    SPAWN_EXECUTOR 25, .executor_25_setup
    SPAWN_EXECUTOR 26, .executor_26_setup
    SPAWN_EXECUTOR 27, .executor_27_setup
    SPAWN_EXECUTOR 28, .executor_28_setup
    SPAWN_EXECUTOR 29, .executor_29_setup
    SPAWN_EXECUTOR 30, .executor_30_setup
    SPAWN_EXECUTOR 31, .executor_31_setup
    SPAWN_EXECUTOR 32, .executor_32_setup
    SPAWN_EXECUTOR 33, .executor_33_setup
    SPAWN_EXECUTOR 34, .executor_34_setup
    EXECUTE_SUBROUTINE .setup_player
    SET_COORDINATES 128, 0, -32
    SET_ASSET_ROTATION NORTHWEST
    SET_WAIT_FRAMES 1
    UPDATE_GLOBAL_RGBA 255, 255, 255, 255, 8
    SET_WAIT_FRAMES 32
    SET_U16_VALUE 0, D_80189824
    SPAWN_EXECUTOR 41, .executor_41_roll_for_coin
    SET_ENTITY_MAP_SPACE_INDEPENDENT FALSE
    DEACTIVATE_SELF

.spawn_gray_high_affection:
    SPAWN_EXECUTOR 13, .gray_setup
    RETURN_FROM_SUBROUTINE

.spawn_cliff_high_affection:
    SPAWN_EXECUTOR 15, .cliff_setup
    RETURN_FROM_SUBROUTINE

.spawn_kai_high_affection:
    SPAWN_EXECUTOR 16, .kai_setup
    RETURN_FROM_SUBROUTINE

; ============================================================
; Executor 41 - random-number ticker that picks the Harvest King
; ============================================================
.executor_41_post_dance:
    SETUP_MAP_ASSET MAIN_MAP_INDEX
    SET_ASSET_ROTATION SOUTH
    SET_COORDINATES -32, 96, -32
    EXECUTE_SUBROUTINE .wait_loop

.executor_41_roll_for_coin:
    SET_WAIT_FRAMES 1
    BRANCH_ON_SPECIAL_BIT 6, var0, .executor_41_roll_for_coin
    UPDATE_U16_VALUE 1, 9999, D_80189824
    BRANCH_U16_VAR_WITHIN_RANGE 1000, 1000, D_80189824, .executor_41_trigger_cake_delivery
    EXECUTE_SUBROUTINE .executor_41_roll_for_coin

.executor_41_trigger_cake_delivery:
    SPAWN_EXECUTOR 3, .elli_setup
    DEACTIVATE_SELF

; ============================================================
; Executor 40 - cake / coin overlay spawned by Elli
; ============================================================
.executor_40_cake_on_ground:
    SETUP_ENTITY 22, ENTITY_ASSET_STATIC_ITEM, 1
    SET_ENTITY_ANIMATIONS 22, 0, 0, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_TRACKING_TARGET 3, 0, 14, 20, 255
    SET_ENTITY_ANIMATION 6
    EXECUTE_SUBROUTINE .wait_loop

.executor_40_coin_on_player:
    SETUP_ENTITY 22, ENTITY_ASSET_STATIC_ITEM, 1
    SET_ENTITY_ANIMATIONS 22, 0, 0, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_TRACKING_TARGET 0, -12, 52, 8, 0
    SET_ENTITY_ANIMATION 229
    EXECUTE_SUBROUTINE .wait_loop

.executor_40_coin_fade_out:
    SET_ENTITY_TRACKING_TARGET 0, 0, 14, 20, 255
    SET_WAIT_FRAMES 16
    SET_ENTITY_TRACKING_TARGET 0, 0, 32, 16, 255
    SET_WAIT_FRAMES 10
    DEACTIVATE_SELF

