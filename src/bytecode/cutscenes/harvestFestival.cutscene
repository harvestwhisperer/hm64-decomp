.kai_dialogue_dispatch:
    PAUSE_ENTITY 0
    FLIP_ENTITY_DIRECTION 0
    EXECUTE_SUBROUTINE .setup_message_box
    SET_SPECIAL_BIT 6, var0
    BRANCH_ON_SPECIAL_BIT 30, lifeEventBits[0], .kai_talk_drink_wine
    INIT_DIALOGUE_SESSION 0, DIALOGUE_TEXT_56, 24
    WAIT_FOR_DIALOGUE_INPUT 0
    TOGGLE_PAUSE_ENTITY 0
    CLEAR_SPECIAL_BIT 6, var0
    EXECUTE_SUBROUTINE .kai_wait

.kai_talk_drink_wine:
    INIT_MESSAGE_BOX_TYPE1 0, HARVEST_FESTIVAL_TEXT_INDEX, 71
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITY 0
    CLEAR_SPECIAL_BIT 6, var0
    EXECUTE_SUBROUTINE .kai_wait

; ============================================================
; Executor 17 - Assistant Carpenter
; ============================================================
.assistant_carpenter_setup:
    SETUP_ENTITY 17, ENTITY_ASSET_ASSISTANT_CARPENTER, 1
    SET_ENTITY_ANIMATIONS 17, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    SET_COORDINATES 192, 0, -144

.assistant_carpenter_wait:
    SET_ASSET_ROTATION NORTHWEST
    SET_CALLBACK_ROUTINE 0, 32768, .assistant_carpenter_on_interact
    EXECUTE_SUBROUTINE .wait_loop

.assistant_carpenter_on_interact:
    BRANCH_ON_SPECIAL_BIT 16, var1, .assistant_carpenter_talk
    UPDATE_U8_VALUE 2, 255, npcAffection[NPC_CARPENTER_1]
    SET_SPECIAL_BIT 16, var1

.assistant_carpenter_talk:
    PAUSE_ENTITY 0
    FLIP_ENTITY_DIRECTION 0
    EXECUTE_SUBROUTINE .setup_message_box
    SET_SPECIAL_BIT 6, var0
    INIT_MESSAGE_BOX_TYPE1 0, HARVEST_FESTIVAL_TEXT_INDEX, 73
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITY 0
    CLEAR_SPECIAL_BIT 6, var0
    EXECUTE_SUBROUTINE .assistant_carpenter_wait

; ============================================================
; Executor 18 - Shipper
; ============================================================
.shipper_setup:
    SETUP_ENTITY 18, ENTITY_ASSET_SHIPPER, 1
    SET_ENTITY_ANIMATIONS 18, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    SET_COORDINATES 192, 0, 112

.shipper_wait:
    SET_ASSET_ROTATION NORTHWEST
    SET_CALLBACK_ROUTINE 0, 32768, .shipper_on_interact
    EXECUTE_SUBROUTINE .wait_loop

.shipper_on_interact:
    BRANCH_ON_SPECIAL_BIT 17, var1, .shipper_talk
    UPDATE_U8_VALUE 2, 255, npcAffection[NPC_SHIPPER]
    SET_SPECIAL_BIT 17, var1

.shipper_talk:
    PAUSE_ENTITY 0
    FLIP_ENTITY_DIRECTION 0
    EXECUTE_SUBROUTINE .setup_message_box
    SET_SPECIAL_BIT 6, var0
    INIT_MESSAGE_BOX_TYPE1 0, HARVEST_FESTIVAL_TEXT_INDEX, 72
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITY 0
    CLEAR_SPECIAL_BIT 6, var0
    EXECUTE_SUBROUTINE .shipper_wait

; ============================================================
; Dance phase - entered when a bachelorette candidate accepts
; ============================================================
.start_dance_phase:
    SET_WAIT_FRAMES 20
    SET_AUDIO_SEQUENCE 0, _festivalDanceSegmentRomStart, _festivalDanceSegmentRomEnd
    SET_AUDIO_SEQUENCE_VOLUME 0, 128, 128
    SET_OTHER_EXECUTOR_PTR 0, .player_dance_sequence
    SET_WAIT_FRAMES 1
    SPAWN_EXECUTOR 33, .dance_finale_timer
    SET_OTHER_EXECUTOR_PTR 6, .mayor_dance_sequence
    SET_OTHER_EXECUTOR_PTR 7, .mayor_wife_dance_sequence
    SET_OTHER_EXECUTOR_PTR 9, .may_dance_sequence
    SET_OTHER_EXECUTOR_PTR 11, .stu_dance_sequence
    RETURN_FROM_SUBROUTINE

.deactivate_non_dancer_npcs:
    DEACTIVATE_EXECUTOR 8
    DEACTIVATE_EXECUTOR 10
    DEACTIVATE_EXECUTOR 12
    DEACTIVATE_EXECUTOR 13
    DEACTIVATE_EXECUTOR 14
    DEACTIVATE_EXECUTOR 15
    DEACTIVATE_EXECUTOR 16
    DEACTIVATE_EXECUTOR 17
    DEACTIVATE_EXECUTOR 18
    DEACTIVATE_EXECUTOR 19
    DEACTIVATE_EXECUTOR 20
    DEACTIVATE_EXECUTOR 21
    DEACTIVATE_EXECUTOR 22
    DEACTIVATE_EXECUTOR 23
    DEACTIVATE_EXECUTOR 24
    DEACTIVATE_EXECUTOR 25
    DEACTIVATE_EXECUTOR 26
    DEACTIVATE_EXECUTOR 27
    DEACTIVATE_EXECUTOR 28
    DEACTIVATE_EXECUTOR 29
    DEACTIVATE_EXECUTOR 30
    DEACTIVATE_EXECUTOR 31
    DEACTIVATE_EXECUTOR 32
    DEACTIVATE_EXECUTOR 33
    DEACTIVATE_EXECUTOR 34
    STOP_SEQUENCE_WITH_FADE 0, 1
    SET_WAIT_FRAMES 1
    IDLE_WHILE_SEQUENCE_PLAYING 0
    RETURN_FROM_SUBROUTINE

.restore_player_post_fade:
    TOGGLE_PAUSE_ENTITY 0
    SPAWN_EXECUTOR 0, .executor_0_post_dance
    SET_WAIT_FRAMES 1
    SET_OTHER_EXECUTOR_PTR 6, .executor_6_post_dance
    SET_OTHER_EXECUTOR_PTR 7, .executor_7_post_dance
    SET_OTHER_EXECUTOR_PTR 9, .executor_9_post_dance
    SET_OTHER_EXECUTOR_PTR 11, .executor_11_post_dance
    SPAWN_EXECUTOR 41, .executor_41_post_dance
    SET_COORDINATES 48, 0, -32
    SET_ASSET_ROTATION SOUTHWEST
    SET_WAIT_FRAMES 1
    UPDATE_GLOBAL_RGBA 255, 255, 255, 255, 8
    WAIT_RGBA_FINISHED
    RETURN_FROM_SUBROUTINE

