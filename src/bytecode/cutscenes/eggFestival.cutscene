.executor_37_post_hunt_exit:
    SET_WAIT_FRAMES 1
    BRANCH_U8_VAR_WITHIN_RANGE 1, 1, cutsceneLevelInteractionIndex, .post_hunt_fade_out
    BRANCH_U8_VAR_WITHIN_RANGE 9, 10, cutsceneLevelInteractionIndex, .post_hunt_fade_out
    BRANCH_U8_VAR_WITHIN_RANGE 2, 2, cutsceneLevelInteractionIndex, .post_hunt_fade_out
    BRANCH_U8_VAR_WITHIN_RANGE 11, 11, cutsceneLevelInteractionIndex, .post_hunt_fade_out
    EXECUTE_SUBROUTINE .executor_37_post_hunt_exit

.post_hunt_fade_out:
    PAUSE_ENTITIES
    SET_AUDIO_SEQUENCE_VOLUME 0, 0, 8
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    SET_WAIT_FRAMES 32
    STOP_SEQUENCE_WITH_FADE 0, 1
    IDLE_WHILE_SEQUENCE_PLAYING 0
    DEACTIVATE_EXECUTOR 1
    DEACTIVATE_EXECUTOR 2
    DEACTIVATE_EXECUTOR 3
    DEACTIVATE_EXECUTOR 4
    DEACTIVATE_EXECUTOR 5
    DEACTIVATE_EXECUTOR 6
    DEACTIVATE_EXECUTOR 7
    DEACTIVATE_EXECUTOR 8
    DEACTIVATE_EXECUTOR 9
    DEACTIVATE_EXECUTOR 10
    DEACTIVATE_EXECUTOR 11
    DEACTIVATE_EXECUTOR 12
    EXECUTE_SUBROUTINE .exit
