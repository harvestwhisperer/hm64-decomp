.executor_37_egg_dispatch:
    SET_WAIT_FRAMES 1
    BRANCH_ON_SPECIAL_BIT 9, var0, .executor_37_egg_dispatch
    BRANCH_ON_BUTTON_PRESSED 0, 32768, .on_egg_picked_up
    BRANCH_U8_VAR_WITHIN_RANGE 1, 1, cutsceneLevelInteractionIndex, .egg_interaction_1
    BRANCH_U8_VAR_WITHIN_RANGE 9, 10, cutsceneLevelInteractionIndex, .egg_interaction_9_or_10
    BRANCH_U8_VAR_WITHIN_RANGE 2, 2, cutsceneLevelInteractionIndex, .egg_interaction_2_or_11
    BRANCH_U8_VAR_WITHIN_RANGE 11, 11, cutsceneLevelInteractionIndex, .egg_interaction_2_or_11
    EXECUTE_SUBROUTINE .executor_37_egg_dispatch

.egg_interaction_1:
    PAUSE_ENTITIES
    SET_SPECIAL_BIT 9, var0
    EXECUTE_SUBROUTINE .setup_message_box
    INIT_MESSAGE_BOX_TYPE1 0, EGG_FESTIVAL_TEXT_INDEX, 61
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SPAWN_EXECUTOR 0, .executor_0_walk_nw_grab
    DEACTIVATE_SELF

.egg_interaction_2_or_11:
    PAUSE_ENTITIES
    SET_SPECIAL_BIT 9, var0
    EXECUTE_SUBROUTINE .setup_message_box
    INIT_MESSAGE_BOX_TYPE1 0, EGG_FESTIVAL_TEXT_INDEX, 61
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
