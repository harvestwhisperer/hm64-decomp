.executor_41_timer:
    SET_WAIT_FRAMES 1
    BRANCH_ON_SPECIAL_BIT 9, var0, .executor_41_timer
    BRANCH_U16_VAR_WITHIN_RANGE 900, 9999, D_80189824, .timer_expired
    UPDATE_U16_VALUE 1, 9999, D_80189824
    EXECUTE_SUBROUTINE .executor_41_timer

.timer_expired:
    SET_SPECIAL_BIT 31, var0
    PAUSE_ENTITIES
    SET_SPECIAL_BIT 9, var0
    INIT_MESSAGE_BOX_TYPE1 0, EGG_FESTIVAL_TEXT_INDEX, 6
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    CLEAR_SPECIAL_BIT 31, var0
    BRANCH_U16_VAR_WITHIN_RANGE 5, 999, D_80180710, .timer_restart_round
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    SET_WAIT_FRAMES 32
    TOGGLE_PAUSE_ENTITIES
    DEACTIVATE_EXECUTOR 32
    DEACTIVATE_EXECUTOR 33
    SPAWN_EXECUTOR 0, .executor_0_post_hunt_player_warp
    CLEAR_SPECIAL_BIT 9, var0
    DEACTIVATE_SELF

.timer_restart_round:
    SPAWN_EXECUTOR 40, .executor_40_post_hunt_fade
    DEACTIVATE_SELF

.executor_0_post_hunt_player_warp:
    TOGGLE_PAUSE_ENTITIES
    SET_U16_VALUE 0, playerIdleCounter
    EXECUTE_SUBROUTINE .setup_player
    SET_COORDINATES -384, 0, 32
    SET_ASSET_ROTATION NORTHWEST
    UPDATE_GLOBAL_RGBA 255, 255, 255, 255, 8
    WAIT_RGBA_FINISHED
    SET_ENTITY_MAP_SPACE_INDEPENDENT FALSE
    SET_OTHER_EXECUTOR_PTR 1, .executor_1_mayor_final
    DEACTIVATE_SELF

.executor_1_mayor_final:
    PAUSE_ENTITIES
    INIT_MESSAGE_BOX_TYPE1 0, EGG_FESTIVAL_TEXT_INDEX, 52
    EXECUTE_SUBROUTINE .mayor_correct_continue

