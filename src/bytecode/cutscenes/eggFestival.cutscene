; ============================================
; Bank 20 - Egg Festival
; ============================================

#include "entities.h"
#include "texts.h"
#include "dialogues.h"

.buffer 2

#define MAIN_MAP_INDEX 0

; Local variables
.local var0, u32, 0
.local var1, u32, 0

.array npcAffection, u8
.array lifeEventBits, u32
.array dailyEventBits, u32

.start:
    SET_SPECIAL_BIT 31, gCutsceneCompletionFlags
    SET_SPECIAL_BIT 9, gCutsceneCompletionFlags
    SET_SPECIAL_BIT 12, gCutsceneCompletionFlags
    SET_SPECIAL_BIT 13, gCutsceneCompletionFlags
    SET_SPECIAL_BIT 14, gCutsceneCompletionFlags
    SET_SPECIAL_BIT 15, gCutsceneCompletionFlags
    SET_SPECIAL_BIT 13, dailyEventBits[1]
    PAUSE_ENTITIES
    STOP_SEQUENCE_WITH_FADE 0, 8
    IDLE_WHILE_SEQUENCE_PLAYING 0
    SET_AUDIO_SEQUENCE 0, _sportsFestival2SegmentRomStart, _sportsFestival2SegmentRomEnd
    SET_AUDIO_SEQUENCE_VOLUME 0, 128, 8
    TOGGLE_PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .setup_message_box
    BRANCH_U16_VAR_WITHIN_RANGE 1250, 1250, gCutsceneIndex, .festival_setup

.exit:
    SET_U32_VALUE 0, var0
    SET_SPECIAL_BIT 0, gCutsceneCompletionFlags
    DEACTIVATE_SELF

.wait_loop:
    SET_WAIT_FRAMES 1
    EXECUTE_SUBROUTINE .wait_loop

.setup_message_box:
    SET_MESSAGE_INTERPOLATION -4, 0, 0
    SET_MESSAGE_BOX_ASSETS 0, 0, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 24, -64, 352
    RETURN_FROM_SUBROUTINE

.setup_player:
    SETUP_ENTITY 0, ENTITY_ASSET_PLAYER, 1
    SET_ENTITY_ANIMATIONS 0, 0, 8, 16, 24, 32, 40
    SET_BEHAVIOR_FLAGS CUTSCENE_ASSET_BEHAVIOR_TRACK_ENTITY
    RETURN_FROM_SUBROUTINE

.executor_0_exit:
    SET_ENTITY_MAP_SPACE_INDEPENDENT FALSE
    DEACTIVATE_SELF

.executor_1_post_hunt_idle:
    SET_ASSET_ROTATION SOUTHEAST
    EXECUTE_SUBROUTINE .wait_loop

.festival_setup:
    INIT_MAP_ADDITION 5, 0
    INIT_MAP_ADDITION 6, 0
    INIT_MAP_ADDITION 7, 0
    INIT_MAP_ADDITION 8, 0
    INIT_MAP_ADDITION 9, 0
    INIT_MAP_ADDITION 10, 0
    INIT_MAP_ADDITION 11, 0
    INIT_MAP_ADDITION 12, 0
    SET_SPECIAL_BIT 0, var0
    SET_U16_VALUE 0, D_801886D2
    SET_U16_VALUE 0, D_80180710
    SPAWN_EXECUTOR 1, .executor_1_mayor
    SPAWN_EXECUTOR 2, .executor_2_kent_pre
    SPAWN_EXECUTOR 3, .executor_3_stu_pre
    SPAWN_EXECUTOR 4, .executor_4_rick_pre
    SPAWN_EXECUTOR 5, .executor_5_maria_pre
    SPAWN_EXECUTOR 6, .executor_6_ann_pre
    SPAWN_EXECUTOR 7, .executor_7_harris_pre
    SPAWN_EXECUTOR 8, .executor_8_jeff_pre
    BRANCH_ON_SPECIAL_BIT 15, lifeEventBits[1], .after_maybe_karen
    SPAWN_EXECUTOR 9, .executor_9_karen_pre

.after_maybe_karen:
    BRANCH_ON_SPECIAL_BIT 14, lifeEventBits[1], .after_maybe_kai
    SPAWN_EXECUTOR 10, .executor_10_kai_pre

.after_maybe_kai:
    BRANCH_ON_SPECIAL_BIT 13, lifeEventBits[1], .after_maybe_cliff
    SPAWN_EXECUTOR 11, .executor_11_cliff_pre

.after_maybe_cliff:
    BRANCH_U8_VAR_WITHIN_RANGE 0, 100, npcAffection[GRAY], .spawn_doug_instead_of_gray
    SPAWN_EXECUTOR 12, .executor_12_gray_pre

.player_intro:
    EXECUTE_SUBROUTINE .setup_player
    SET_COORDINATES -384, 0, 32
    SET_ASSET_ROTATION NORTHWEST
    SET_WAIT_FRAMES 1
    UPDATE_GLOBAL_RGBA 255, 255, 255, 255, 8
    WAIT_RGBA_FINISHED
    INIT_MESSAGE_BOX_TYPE1 0, EGG_FESTIVAL_TEXT_INDEX, 0
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SPAWN_EXECUTOR 37, .executor_37_egg_dispatch
    SET_ENTITY_MAP_SPACE_INDEPENDENT FALSE
    DEACTIVATE_SELF

.spawn_doug_instead_of_gray:
    SPAWN_EXECUTOR 12, .executor_12_doug_pre
    EXECUTE_SUBROUTINE .player_intro

.executor_1_mayor:
    SETUP_ENTITY 1, ENTITY_ASSET_MAYOR, 1
    SET_ENTITY_ANIMATIONS 1, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_COORDINATES -448, 0, 32
    SET_ASSET_ROTATION SOUTHEAST

.mayor_wait:
    SET_CALLBACK_ROUTINE 0, 32768, .mayor_on_interact
    EXECUTE_SUBROUTINE .wait_loop

.mayor_on_interact:
    EXECUTE_SUBROUTINE .setup_message_box
    BRANCH_ON_SPECIAL_BIT 0, var1, .mayor_dispatch
    UPDATE_U8_VALUE 2, 255, npcAffection[NPC_MAYOR]
    SET_SPECIAL_BIT 0, var1

.mayor_dispatch:
    PAUSE_ENTITIES
    FLIP_ENTITY_DIRECTION 0
    INIT_DIALOGUE_SESSION 0, DIALOGUE_EGG_FESTIVAL, 1
    WAIT_FOR_DIALOGUE_INPUT 0
    BRANCH_ON_DIALOGUE 0, 0, .mayor_start_hunt
    BRANCH_ON_DIALOGUE 0, 1, .mayor_talk_explain

.mayor_start_hunt:
    SET_ASSET_ROTATION SOUTHEAST
    INIT_MESSAGE_BOX_TYPE1 0, EGG_FESTIVAL_TEXT_INDEX, 3
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_ENTITY_ANIMATION 22
    SET_WAIT_FRAMES 20
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SPAWN_EXECUTOR 32, .executor_32_mayor_holds_egg
    TOGGLE_PAUSE_ENTITIES
    SET_OTHER_EXECUTOR_PTR 2, .executor_2_kent_hunt
    SET_OTHER_EXECUTOR_PTR 3, .executor_3_stu_hunt
    SET_OTHER_EXECUTOR_PTR 4, .executor_4_rick_hunt
    SET_OTHER_EXECUTOR_PTR 5, .executor_5_maria_hunt
    SET_OTHER_EXECUTOR_PTR 6, .executor_6_ann_hunt
    SET_OTHER_EXECUTOR_PTR 7, .executor_7_harris_hunt
    SET_OTHER_EXECUTOR_PTR 8, .executor_8_jeff_hunt
    SET_OTHER_EXECUTOR_PTR 9, .executor_9_karen_hunt
    SET_OTHER_EXECUTOR_PTR 10, .executor_10_kai_hunt
    SET_OTHER_EXECUTOR_PTR 11, .executor_11_cliff_hunt
    SET_OTHER_EXECUTOR_PTR 12, .executor_12_gray_or_doug_hunt
    SET_U16_VALUE 0, D_80189824
    SPAWN_EXECUTOR 41, .executor_41_timer
    EXECUTE_SUBROUTINE .mayor_show_egg_wait

.mayor_talk_explain:
    INIT_MESSAGE_BOX_TYPE1 0, EGG_FESTIVAL_TEXT_INDEX, 51
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .mayor_wait

.mayor_show_egg_wait:
    SET_ASSET_ROTATION SOUTHEAST
    SET_CALLBACK_ROUTINE 0, 32768, .mayor_eval_choice
    EXECUTE_SUBROUTINE .wait_loop

.mayor_eval_choice:
    BRANCH_ON_SPECIAL_BIT 31, var0, .mayor_show_egg_wait
    EXECUTE_SUBROUTINE .setup_message_box
    SET_SPECIAL_BIT 9, var0
    SET_SPECIAL_BIT 8, var0
    PAUSE_ENTITY 0
    FLIP_ENTITY_DIRECTION 0
    BRANCH_ON_SPECIAL_BIT 20, var0, .mayor_check_color_0
    BRANCH_ON_SPECIAL_BIT 21, var0, .mayor_check_color_1
    BRANCH_ON_SPECIAL_BIT 22, var0, .mayor_check_color_2
    BRANCH_ON_SPECIAL_BIT 23, var0, .mayor_check_color_3
    BRANCH_ON_SPECIAL_BIT 24, var0, .mayor_check_color_4
    BRANCH_ON_SPECIAL_BIT 25, var0, .mayor_check_color_5
    INIT_MESSAGE_BOX_TYPE1 0, EGG_FESTIVAL_TEXT_INDEX, 53
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITIES
    CLEAR_SPECIAL_BIT 9, var0
    EXECUTE_SUBROUTINE .mayor_show_egg_wait

.mayor_check_color_0:
    BRANCH_ON_SPECIAL_BIT 1, var0, .mayor_correct_advance
    EXECUTE_SUBROUTINE .mayor_wrong

.mayor_check_color_1:
    BRANCH_ON_SPECIAL_BIT 2, var0, .mayor_correct_advance
    EXECUTE_SUBROUTINE .mayor_wrong

.mayor_check_color_2:
    BRANCH_ON_SPECIAL_BIT 3, var0, .mayor_correct_advance
    EXECUTE_SUBROUTINE .mayor_wrong

.mayor_check_color_3:
    BRANCH_ON_SPECIAL_BIT 4, var0, .mayor_correct_advance
    EXECUTE_SUBROUTINE .mayor_wrong

.mayor_check_color_4:
    BRANCH_ON_SPECIAL_BIT 5, var0, .mayor_correct_advance
    EXECUTE_SUBROUTINE .mayor_wrong

.mayor_check_color_5:
    BRANCH_ON_SPECIAL_BIT 6, var0, .mayor_correct_advance
    EXECUTE_SUBROUTINE .mayor_wrong

.mayor_correct_advance:
    UPDATE_U16_VALUE 1, 999, D_801886D2
    DEACTIVATE_EXECUTOR 32
    DEACTIVATE_EXECUTOR 33
    DEACTIVATE_EXECUTOR 41
    CLEAR_SPECIAL_BIT 13, dailyEventBits
    BRANCH_U16_VAR_WITHIN_RANGE 5, 999, D_80180710, .mayor_zero_points_ending
    INIT_MESSAGE_BOX_TYPE1 0, EGG_FESTIVAL_TEXT_INDEX, 4

.mayor_correct_continue:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    EXECUTE_SUBROUTINE .reset_round_state
    SET_ENTITY_ANIMATION 22
    SET_WAIT_FRAMES 20
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SPAWN_EXECUTOR 32, .executor_32_mayor_holds_egg
    TOGGLE_PAUSE_ENTITIES
    CLEAR_SPECIAL_BIT 9, var0
    CLEAR_SPECIAL_BIT 8, var0
    SET_U16_VALUE 0, D_80189824
    SPAWN_EXECUTOR 41, .executor_41_timer
    EXECUTE_SUBROUTINE .mayor_show_egg_wait

.mayor_wrong:
    DEACTIVATE_EXECUTOR 33
    CLEAR_SPECIAL_BIT 13, dailyEventBits
    INIT_MESSAGE_BOX_TYPE1 0, EGG_FESTIVAL_TEXT_INDEX, 5
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    EXECUTE_SUBROUTINE .reset_correct_color_bits
    TOGGLE_PAUSE_ENTITIES
    CLEAR_SPECIAL_BIT 9, var0
    CLEAR_SPECIAL_BIT 8, var0
    EXECUTE_SUBROUTINE .mayor_show_egg_wait

.reset_correct_color_bits:
    CLEAR_SPECIAL_BIT 20, var0
    CLEAR_SPECIAL_BIT 21, var0
    CLEAR_SPECIAL_BIT 22, var0
    CLEAR_SPECIAL_BIT 23, var0
    CLEAR_SPECIAL_BIT 24, var0
    CLEAR_SPECIAL_BIT 25, var0
    RETURN_FROM_SUBROUTINE

.reset_round_state:
    CLEAR_SPECIAL_BIT 1, var0
    CLEAR_SPECIAL_BIT 2, var0
    CLEAR_SPECIAL_BIT 3, var0
    CLEAR_SPECIAL_BIT 4, var0
    CLEAR_SPECIAL_BIT 5, var0
    CLEAR_SPECIAL_BIT 6, var0
    CLEAR_SPECIAL_BIT 10, var0
    CLEAR_SPECIAL_BIT 11, var0
    CLEAR_SPECIAL_BIT 12, var0
    CLEAR_SPECIAL_BIT 13, var0
    CLEAR_SPECIAL_BIT 14, var0
    CLEAR_SPECIAL_BIT 15, var0
    CLEAR_SPECIAL_BIT 16, var0
    CLEAR_SPECIAL_BIT 17, var0
    CLEAR_SPECIAL_BIT 18, var0
    CLEAR_SPECIAL_BIT 19, var0
    CLEAR_SPECIAL_BIT 20, var0
    CLEAR_SPECIAL_BIT 21, var0
    CLEAR_SPECIAL_BIT 22, var0
    CLEAR_SPECIAL_BIT 23, var0
    CLEAR_SPECIAL_BIT 24, var0
    CLEAR_SPECIAL_BIT 25, var0
    RETURN_FROM_SUBROUTINE

.mayor_post_hunt_wait:
    SET_CALLBACK_ROUTINE 0, 32768, .mayor_post_hunt_on_interact
    EXECUTE_SUBROUTINE .wait_loop

.mayor_post_hunt_on_interact:
    EXECUTE_SUBROUTINE .setup_message_box
    PAUSE_ENTITIES
    FLIP_ENTITY_DIRECTION 0
    INIT_MESSAGE_BOX_TYPE1 0, EGG_FESTIVAL_TEXT_INDEX, 60
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .mayor_post_hunt_wait

.mayor_zero_points_ending:
    INIT_MESSAGE_BOX_TYPE1 0, EGG_FESTIVAL_TEXT_INDEX, 7
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SPAWN_EXECUTOR 40, .executor_40_post_hunt_fade
    EXECUTE_SUBROUTINE .wait_loop

.executor_40_post_hunt_fade:
    SET_WAIT_FRAMES 10
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    SET_WAIT_FRAMES 32
    DEACTIVATE_EXECUTOR 32
    DEACTIVATE_EXECUTOR 33
    DEACTIVATE_EXECUTOR 2
    DEACTIVATE_EXECUTOR 3
    DEACTIVATE_EXECUTOR 4
    DEACTIVATE_EXECUTOR 5
    DEACTIVATE_EXECUTOR 6
    DEACTIVATE_EXECUTOR 7
    DEACTIVATE_EXECUTOR 8
    DEACTIVATE_EXECUTOR 9
    DEACTIVATE_EXECUTOR 10
    DEACTIVATE_EXECUTOR 11
    DEACTIVATE_EXECUTOR 12
    SET_WAIT_FRAMES 1
    TOGGLE_PAUSE_ENTITIES
    SPAWN_EXECUTOR 0, .executor_0_post_hunt_reset_player
    SET_OTHER_EXECUTOR_PTR 1, .executor_1_post_hunt_idle
    SPAWN_EXECUTOR 2, .executor_2_kent_post
    SPAWN_EXECUTOR 3, .executor_3_stu_post
    SPAWN_EXECUTOR 4, .executor_4_rick_post
    SPAWN_EXECUTOR 5, .executor_5_maria_post
    SPAWN_EXECUTOR 6, .executor_6_ann_post
    SPAWN_EXECUTOR 7, .executor_7_harris_post
    SPAWN_EXECUTOR 8, .executor_8_jeff_post
    BRANCH_ON_SPECIAL_BIT 15, lifeEventBits[1], .after_maybe_karen_post
    SPAWN_EXECUTOR 9, .executor_9_karen_post

.after_maybe_karen_post:
    BRANCH_ON_SPECIAL_BIT 14, lifeEventBits[1], .after_maybe_kai_post
    SPAWN_EXECUTOR 10, .executor_10_kai_post

.after_maybe_kai_post:
    BRANCH_ON_SPECIAL_BIT 13, lifeEventBits[1], .after_maybe_cliff_post
    SPAWN_EXECUTOR 11, .executor_11_cliff_post

.after_maybe_cliff_post:
    SPAWN_EXECUTOR 12, .executor_12_gray_or_doug_post
    DEACTIVATE_EXECUTOR 37
    SET_WAIT_FRAMES 1
    SET_OTHER_EXECUTOR_PTR 1, .mayor_post_hunt_wait
    CLEAR_SPECIAL_BIT 13, dailyEventBits
    UPDATE_GLOBAL_RGBA 255, 255, 255, 255, 8
    SET_WAIT_FRAMES 32
    INIT_MESSAGE_BOX_TYPE1 0, EGG_FESTIVAL_TEXT_INDEX, 8
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_WAIT_FRAMES 30
    SPAWN_EXECUTOR 37, .executor_37_post_hunt_exit
    BRANCH_U16_VAR_WITHIN_RANGE 3, 99, D_801886D2, .ending_player_wins
    BRANCH_ON_RANDOM 0, 20, .ending_harris_wins
    BRANCH_ON_RANDOM 21, 40, .ending_jeff_wins
    BRANCH_ON_RANDOM 41, 60, .ending_kai_wins
    BRANCH_ON_RANDOM 61, 80, .ending_cliff_wins
    EXECUTE_SUBROUTINE .ending_gray_or_doug_wins

.ending_common:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_WAIT_FRAMES 20
    SET_SFX 84, 128
    SET_WAIT_FRAMES 60
    BRANCH_U16_VAR_WITHIN_RANGE 0, 2, D_801886D2, .prize_random_branch
    BRANCH_ON_SPECIAL_BIT 8, acquiredPowerNutBits, .prize_check_turtle
    INIT_MESSAGE_BOX_TYPE1 0, EGG_FESTIVAL_TEXT_INDEX, 56
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 0, .executor_0_grab_power_nut
    DEACTIVATE_SELF

.executor_0_grab_power_nut:
    SET_ASSET_ROTATION SOUTHWEST
    SPAWN_EXECUTOR 32, .executor_32_power_nut_prop
    SET_ENTITY_DIRECTIONAL_ANIMATION 24
    SET_WAIT_FRAMES 30
    SET_ENTITY_ANIMATION 437
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SET_ASSET_ROTATION NORTHWEST
    SET_SPECIAL_BIT 8, acquiredPowerNutBits
    UPDATE_U8_VALUE 15, 250, gMaximumStamina
    UPDATE_U8_VALUE 2, 255, gHappiness
    SET_ENTITY_MAP_SPACE_INDEPENDENT FALSE
    DEACTIVATE_SELF

.executor_32_power_nut_prop:
    SETUP_ENTITY 28, ENTITY_ASSET_STATIC_ITEM, 1
    SET_ENTITY_ANIMATIONS 28, 0, 0, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_ANIMATION 210
    SET_ENTITY_TRACKING_TARGET 0, 0, 14, 20, 255
    SET_WAIT_FRAMES 30
    SET_ENTITY_TRACKING_TARGET 0, 0, 32, 16, 255
    SET_WAIT_FRAMES 10
    DEACTIVATE_SELF

.prize_check_turtle:
    BRANCH_ON_SPECIAL_BIT 6, lifeEventBits[2], .prize_random_branch
    SET_SPECIAL_BIT 6, lifeEventBits[2]
    INIT_MESSAGE_BOX_TYPE1 0, EGG_FESTIVAL_TEXT_INDEX, 57
    EXECUTE_SUBROUTINE .prize_message_close

.prize_random_branch:
    BRANCH_ON_RANDOM 0, 50, .prize_lumber_path
    BRANCH_U16_VAR_WITHIN_RANGE 0, 2, D_801886D2, .prize_fodder_message
    UPDATE_U16_VALUE 150, 999, fodderQuantity

.prize_fodder_message:
    INIT_MESSAGE_BOX_TYPE1 0, EGG_FESTIVAL_TEXT_INDEX, 58
    EXECUTE_SUBROUTINE .prize_message_close

.prize_lumber_path:
    BRANCH_U16_VAR_WITHIN_RANGE 0, 2, D_801886D2, .prize_lumber_message
    UPDATE_U16_VALUE 150, 999, gLumber

.prize_lumber_message:
    INIT_MESSAGE_BOX_TYPE1 0, EGG_FESTIVAL_TEXT_INDEX, 59
    EXECUTE_SUBROUTINE .prize_message_close

.prize_message_close:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 0, .executor_0_exit
    SET_OTHER_EXECUTOR_PTR 1, .mayor_post_hunt_wait
    DEACTIVATE_SELF

.ending_player_wins:
    UPDATE_U8_VALUE 5, 255, gHappiness
    INIT_MESSAGE_BOX_TYPE1 0, EGG_FESTIVAL_TEXT_INDEX, 9
    EXECUTE_SUBROUTINE .ending_common

.ending_harris_wins:
    SET_SPECIAL_BIT 26, var0
    INIT_MESSAGE_BOX_TYPE1 0, EGG_FESTIVAL_TEXT_INDEX, 11
    EXECUTE_SUBROUTINE .ending_common

.ending_jeff_wins:
    SET_SPECIAL_BIT 27, var0
    INIT_MESSAGE_BOX_TYPE1 0, EGG_FESTIVAL_TEXT_INDEX, 13
    EXECUTE_SUBROUTINE .ending_common

.ending_kai_wins:
    SET_SPECIAL_BIT 28, var0
    INIT_MESSAGE_BOX_TYPE1 0, EGG_FESTIVAL_TEXT_INDEX, 15
    EXECUTE_SUBROUTINE .ending_common

.ending_cliff_wins:
    SET_SPECIAL_BIT 29, var0
    INIT_MESSAGE_BOX_TYPE1 0, EGG_FESTIVAL_TEXT_INDEX, 14
    EXECUTE_SUBROUTINE .ending_common

.ending_gray_or_doug_wins:
    SET_SPECIAL_BIT 30, var0
    BRANCH_U8_VAR_WITHIN_RANGE 0, 100, npcAffection[GRAY], .ending_doug_wins
    INIT_MESSAGE_BOX_TYPE1 0, EGG_FESTIVAL_TEXT_INDEX, 12
    EXECUTE_SUBROUTINE .ending_common

.ending_doug_wins:
    INIT_MESSAGE_BOX_TYPE1 0, EGG_FESTIVAL_TEXT_INDEX, 10
    EXECUTE_SUBROUTINE .ending_common

.setup_kent:
    SETUP_ENTITY 2, ENTITY_ASSET_KENT, 1
    SET_ENTITY_ANIMATIONS 2, 0, 8, 16, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    RETURN_FROM_SUBROUTINE

.executor_2_kent_pre:
    EXECUTE_SUBROUTINE .setup_kent
    SET_COORDINATES -352, 0, -64

.kent_pre_wait:
    SET_ASSET_ROTATION WEST
    SET_CALLBACK_ROUTINE 0, 32768, .kent_pre_on_interact
    EXECUTE_SUBROUTINE .wait_loop

.kent_pre_on_interact:
    EXECUTE_SUBROUTINE .setup_message_box
    BRANCH_ON_SPECIAL_BIT 1, var1, .kent_pre_talk
    UPDATE_U8_VALUE 2, 255, npcAffection[NPC_KENT]
    SET_SPECIAL_BIT 1, var1

.kent_pre_talk:
    PAUSE_ENTITIES
    FLIP_ENTITY_DIRECTION 0
    INIT_MESSAGE_BOX_TYPE1 0, EGG_FESTIVAL_TEXT_INDEX, 16
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .kent_pre_wait

.setup_stu:
    SETUP_ENTITY 3, ENTITY_ASSET_STU, 1
    SET_ENTITY_ANIMATIONS 3, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    RETURN_FROM_SUBROUTINE

.executor_3_stu_pre:
    EXECUTE_SUBROUTINE .setup_stu
    SET_COORDINATES -320, 0, -32

.stu_pre_wait:
    SET_ASSET_ROTATION WEST
    SET_CALLBACK_ROUTINE 0, 32768, .stu_pre_on_interact
    EXECUTE_SUBROUTINE .wait_loop

.stu_pre_on_interact:
    EXECUTE_SUBROUTINE .setup_message_box
    BRANCH_ON_SPECIAL_BIT 2, var1, .stu_pre_talk
    UPDATE_U8_VALUE 2, 255, npcAffection[NPC_STU]
    SET_SPECIAL_BIT 2, var1

.stu_pre_talk:
    PAUSE_ENTITIES
    FLIP_ENTITY_DIRECTION 0
    INIT_MESSAGE_BOX_TYPE1 0, EGG_FESTIVAL_TEXT_INDEX, 19
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .stu_pre_wait

.setup_rick:
    SETUP_ENTITY 4, ENTITY_ASSET_RICK, 1
    SET_ENTITY_ANIMATIONS 4, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    RETURN_FROM_SUBROUTINE

.executor_4_rick_pre:
    EXECUTE_SUBROUTINE .setup_rick
    SET_COORDINATES -96, 0, 0

.rick_pre_wait:
    SET_ASSET_ROTATION NORTHWEST
    SET_CALLBACK_ROUTINE 0, 32768, .rick_pre_on_interact
    EXECUTE_SUBROUTINE .wait_loop

.rick_pre_on_interact:
    EXECUTE_SUBROUTINE .setup_message_box
    BRANCH_ON_SPECIAL_BIT 3, var1, .rick_pre_talk
    UPDATE_U8_VALUE 2, 255, npcAffection[NPC_RICK]
    SET_SPECIAL_BIT 3, var1

.rick_pre_talk:
    PAUSE_ENTITIES
    FLIP_ENTITY_DIRECTION 0
    INIT_MESSAGE_BOX_TYPE1 0, EGG_FESTIVAL_TEXT_INDEX, 22
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .rick_pre_wait

.setup_maria:
    SETUP_ENTITY 5, ENTITY_ASSET_MARIA, 1
    SET_ENTITY_ANIMATIONS 5, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    RETURN_FROM_SUBROUTINE

.executor_5_maria_pre:
    EXECUTE_SUBROUTINE .setup_maria
