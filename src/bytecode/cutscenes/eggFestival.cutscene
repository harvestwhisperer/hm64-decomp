    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SPAWN_EXECUTOR 0, .executor_0_walk_se_grab
    DEACTIVATE_SELF

.set_holding_flag_true:
    SET_HOLDING_ANIMATION_FLAG TRUE
    RETURN_FROM_SUBROUTINE

.set_holding_flag_false:
    SET_HOLDING_ANIMATION_FLAG FALSE
    RETURN_FROM_SUBROUTINE

.executor_0_walk_nw_grab:
    TOGGLE_PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .setup_player
    BRANCH_ON_SPECIAL_BIT 13, dailyEventBits, .set_holding_flag_true
    ENTITY_WALK 16, NORTHWEST, 2
    BRANCH_ON_SPECIAL_BIT 13, dailyEventBits, .set_holding_flag_false
    SPAWN_EXECUTOR 37, .executor_37_egg_dispatch
    CLEAR_SPECIAL_BIT 9, var0
    SET_ENTITY_MAP_SPACE_INDEPENDENT FALSE
    DEACTIVATE_SELF

.executor_0_walk_ne_grab:
    TOGGLE_PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .setup_player
    BRANCH_ON_SPECIAL_BIT 13, dailyEventBits, .set_holding_flag_true
    ENTITY_WALK 16, NORTHEAST, 2
    BRANCH_ON_SPECIAL_BIT 13, dailyEventBits, .set_holding_flag_false
    SPAWN_EXECUTOR 37, .executor_37_egg_dispatch
    CLEAR_SPECIAL_BIT 9, var0
    SET_ENTITY_MAP_SPACE_INDEPENDENT FALSE
    DEACTIVATE_SELF

.executor_0_walk_se_grab:
    TOGGLE_PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .setup_player
    BRANCH_ON_SPECIAL_BIT 13, dailyEventBits, .set_holding_flag_true
    ENTITY_WALK 16, SOUTHEAST, 2
    BRANCH_ON_SPECIAL_BIT 13, dailyEventBits, .set_holding_flag_false
    SPAWN_EXECUTOR 37, .executor_37_egg_dispatch
    CLEAR_SPECIAL_BIT 9, var0
    SET_ENTITY_MAP_SPACE_INDEPENDENT FALSE
    DEACTIVATE_SELF

