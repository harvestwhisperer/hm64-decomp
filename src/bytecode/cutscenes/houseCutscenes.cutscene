; Parallel of .cs_6. Dialogue 1 option 1 branch shows
; text 260 (remembered) else text 261 (forgot).
; Reinteract shows text 273.
; ====================================================
.cs_13:
    SET_SPECIAL_BIT 15, gCutsceneCompletionFlags
    SPAWN_EXECUTOR 1, .cs13_popuri_main
    SPAWN_EXECUTOR 2, .executor_2_dec_e43_anim_60
    SPAWN_EXECUTOR 3, .executor_3_dec_e44_anim_61
    SPAWN_EXECUTOR 4, .executor_4_dec_e45_anim_62
    SPAWN_EXECUTOR 5, .executor_5_dec_e46_anim_6
