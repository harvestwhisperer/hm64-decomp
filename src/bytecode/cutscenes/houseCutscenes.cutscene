.cs31_karen_close_if_wife4:
    BRANCH_U8_VAR_WITHIN_RANGE 4, 4, gWife, .cs31_karen_text10
    RETURN_FROM_SUBROUTINE

; ====================================================
; Cutscene 32 - Karen giving birth
; Parallel of .cs_4 with Sasha (e24) supporting. The
; interact dispatch uses texts 451 - 456 for the day /
; evening / night finale variants.
; ====================================================
.cs_32:
    SET_SPECIAL_BIT 10, gCutsceneCompletionFlags
    BRANCH_U8_VAR_WITHIN_RANGE 0, 5, gHour, .cs32_birth_night
    BRANCH_U8_VAR_WITHIN_RANGE 15, 23, gHour, .cs32_birth_evening
    BRANCH_U8_VAR_WITHIN_RANGE 6, 6, gHour, .cs32_birth_6am
