    UPDATE_U8_VALUE 5, 255, npcAffection[PASTOR]
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 385
    EXECUTE_SUBROUTINE .sub_birth_finale_exit

