; ====================================================
; Cutscene 37 - Karen baby-name confirmation
; Parallel of .cs_9. Dialogue 33 picks midwife / potion
; dealer / Sasha. Midwife uses text 476 - 211; potion
; dealer uses text 476 - 213; Sasha uses text 477, 476,
; 478.
; ====================================================
.cs_37:
    SET_SPECIAL_BIT 31, gCutsceneCompletionFlags
    UPDATE_U8_VALUE -5, 255, gHappiness
    UPDATE_U8_VALUE 8, 255, npcAffection[BABY]
    SET_SPECIAL_BIT 15, gCutsceneCompletionFlags
    SPAWN_EXECUTOR 1, .cs37_karen_naming_setup
    SPAWN_EXECUTOR 4, .executor_4_baby_e25_cradle
    SPAWN_EXECUTOR 5, .executor_5_player_naming_pos
