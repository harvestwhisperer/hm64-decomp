    EXECUTE_SUBROUTINE .sub_sasha_dialogue_return

; ====================================================
; Cutscene 34 - Karen birthday
; Parallel of .cs_6. Dialogue 4 option 1 branch shows
; text 459 else text 460. Reinteract shows text 470.
; ====================================================
.cs_34:
    SET_SPECIAL_BIT 15, gCutsceneCompletionFlags
    SPAWN_EXECUTOR 1, .cs34_karen_main
    SPAWN_EXECUTOR 2, .executor_2_dec_e43_anim_10
    SPAWN_EXECUTOR 3, .executor_3_dec_e44_anim_61
    SPAWN_EXECUTOR 4, .executor_4_dec_e45_anim_62
    SPAWN_EXECUTOR 5, .executor_5_dec_e46_anim_6
    SPAWN_EXECUTOR 32, .executor_32_karen_interact_watch
