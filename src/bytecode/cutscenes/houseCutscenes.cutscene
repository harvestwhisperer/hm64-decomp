.executor_3_pastor_approach:
    ENTITY_WALK 24, DIRECTION_W, 2
    SET_ASSET_ROTATION 4
    EXECUTE_SUBROUTINE .sub_pastor_wait_callback

.cs18_on_interact_dispatch:
    BRANCH_U8_VAR_WITHIN_RANGE 0, 254, gItemBeingHeld, .executor_41_elli_interact_watch
    PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .setup_msgbox_default
    BRANCH_U8_VAR_WITHIN_RANGE 6, 6, gHour, .cs18_interact_6am
    BRANCH_U8_VAR_WITHIN_RANGE 7, 14, gHour, .cs18_interact_day
    BRANCH_U8_VAR_WITHIN_RANGE 15, 23, gHour, .cs18_interact_evening_finale
    BRANCH_U8_VAR_WITHIN_RANGE 0, 5, gHour, .cs18_interact_night_finale
    DEACTIVATE_SELF

.cs18_interact_6am:
    EXECUTE_SUBROUTINE .setup_msgbox_default
    BRANCH_U8_VAR_WITHIN_RANGE 1, 255, gMinutes, .cs18_interact_day
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 328
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    BRANCH_ON_SPECIAL_BIT 2, var0, .cs18_interact_check_var2
    SET_SPECIAL_BIT 2, var0
    SET_OTHER_EXECUTOR_PTR 3, .executor_3_pastor_approach

.cs18_interact_check_var2:
    TOGGLE_PAUSE_ENTITIES
    SPAWN_EXECUTOR 41, .executor_41_elli_interact_watch
    EXECUTE_SUBROUTINE .wait_loop

