    BRANCH_U8_VAR_WITHIN_RANGE 7, 14, gHour, .cs32_interact_day
    BRANCH_U8_VAR_WITHIN_RANGE 15, 23, gHour, .cs32_interact_evening_finale
    BRANCH_U8_VAR_WITHIN_RANGE 0, 5, gHour, .cs32_interact_night_finale
    DEACTIVATE_SELF

