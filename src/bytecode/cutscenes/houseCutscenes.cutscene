; ====================================================
; Cutscene 9 - Maria baby-name confirmation
; Maria asks the player to pick who should confirm the
; name via dialogue 29 (three choices). Midwife path
; diagnoses measles (text 209) into text
; 210 and 211. Potion dealer path uses text 212, 210,
; 213. Mayor wife path uses text 214, 210, 215. Applies
; a +8 affection bump to whichever NPC is chosen.
; ====================================================
.cs_9:
    SET_SPECIAL_BIT 31, gCutsceneCompletionFlags
    UPDATE_U8_VALUE -5, 255, gHappiness
    UPDATE_U8_VALUE 8, 255, npcAffection[BABY]
    SET_SPECIAL_BIT 15, gCutsceneCompletionFlags
    SPAWN_EXECUTOR 1, .cs9_maria_naming_setup
    SPAWN_EXECUTOR 4, .executor_4_baby_e25_cradle
    SPAWN_EXECUTOR 5, .executor_5_player_naming_pos
    DEACTIVATE_SELF

.cs9_maria_naming_setup:
    EXECUTE_SUBROUTINE .setup_wife_maria_e22
    SET_COORDINATES -152, 0, -64
    SET_ASSET_ROTATION 6
    SET_WAIT_FRAMES 1
    UPDATE_GLOBAL_RGBA 255, 255, 255, 255, 8
    WAIT_RGBA_FINISHED
    INIT_DIALOGUE_SESSION 0, DIALOGUE_TEXT_65, 29
    WAIT_FOR_DIALOGUE_INPUT 0
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    SET_OTHER_EXECUTOR_PTR 4, .executor_4_baby_anim_13
    SET_OTHER_EXECUTOR_PTR 5, .executor_5_player_exit_naming
    SET_COORDINATES -152, 0, -32
    SET_ASSET_ROTATION 4
    BRANCH_ON_DIALOGUE 0, 0, .cs9_midwife_path
    BRANCH_ON_DIALOGUE 0, 1, .cs9_potion_dealer_path
    BRANCH_ON_DIALOGUE 0, 2, .cs9_mayor_wife_path

.cs9_midwife_path:
    UPDATE_U8_VALUE 8, 255, npcAffection[MIDWIFE]
    SPAWN_EXECUTOR 3, .cs9_midwife_naming
    EXECUTE_SUBROUTINE .wait_loop

.cs9_potion_dealer_path:
    UPDATE_U8_VALUE 8, 255, npcAffection[POTION_SHOP_DEALER]
    SPAWN_EXECUTOR 3, .cs9_potion_dealer_naming
    EXECUTE_SUBROUTINE .wait_loop

.cs9_mayor_wife_path:
    UPDATE_U8_VALUE 8, 255, npcAffection[MAYOR_WIFE]
    SPAWN_EXECUTOR 3, .cs9_mayor_wife_naming
    EXECUTE_SUBROUTINE .wait_loop

