; ====================================================
; Cutscene 51 - Player catches a cold
; Player enters lying down (anim 455). The map setup
; loads and the center-avatar message box shows text
; 0.
; Fades out audio and returns. This is the trigger
; that later leads into .cs_3 / .cs_10 / .cs_17 /
; .cs_24 / .cs_31 depending on marital state.
; ====================================================
.cs_51:
    UPDATE_U8_VALUE -8, 255, gHappiness
    SET_SPECIAL_BIT 15, gCutsceneCompletionFlags
    SPAWN_EXECUTOR 1, .executor_4_player_anim_455_pos
    SPAWN_EXECUTOR 16, .executor_16_cs0_map_setup
    SET_WAIT_FRAMES 50
    EXECUTE_SUBROUTINE .setup_msgbox_center_avatar
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 0
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_WAIT_FRAMES 30
    SET_AUDIO_SEQUENCE_VOLUME 0, 0, 4
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    SET_WAIT_FRAMES 40
    STOP_SEQUENCE_WITH_FADE 0, 1
    IDLE_WHILE_SEQUENCE_PLAYING 0
    DEACTIVATE_EXECUTOR 1
    DEACTIVATE_EXECUTOR 16
    EXECUTE_SUBROUTINE .cutscene_exit

; ====================================================
; Cutscene 52 - Maria cake tasting
; Maria waits until the player is holding an item,
; then speaks text 56 (Here you go, a vegetable
; cake, very healthy), serves the cake, and the
; player tastes (anim 437). Reinteract shows text 57
; Branches via gCutsceneIndex to .taste_to_maria et al for the
; +3 gHappiness and wait-tasted state.
; ====================================================
.cs_52:
    SET_SPECIAL_BIT 30, gCutsceneCompletionFlags
    SPAWN_EXECUTOR 1, .cs52_maria_cake_setup
    DEACTIVATE_SELF

.cs52_maria_cake_setup:
    EXECUTE_SUBROUTINE .setup_wife_maria_e22
    SET_COORDINATES -96, 0, -64
    SET_ASSET_ROTATION 6

.cs52_maria_wait:
    SET_CALLBACK_ROUTINE 0, 32768, .cs52_maria_serve_cake
    EXECUTE_SUBROUTINE .wait_loop

.cs52_maria_wait_tasted:
    SET_CALLBACK_ROUTINE 0, 32768, .cs52_maria_tasted_msg
    EXECUTE_SUBROUTINE .wait_loop

.executor_10_cake_item_anim_6:
    SETUP_ENTITY 47, ENTITY_ASSET_STATIC_ITEM, 1
    SET_ENTITY_ANIMATIONS 47, 0, 0, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_ANIMATION 6
    SET_ENTITY_TRACKING_TARGET 22, 0, 14, 20, 255
    EXECUTE_SUBROUTINE .wait_loop

.cs52_maria_serve_cake:
    BRANCH_U8_VAR_WITHIN_RANGE 0, 254, gItemBeingHeld, .cs52_maria_wait
    PAUSE_ENTITY 0
    FLIP_ENTITY_DIRECTION 0
    EXECUTE_SUBROUTINE .setup_msgbox_default
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 56
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_ENTITY_DIRECTIONAL_ANIMATION 16
    WAIT_ENTITY_ANIMATION
    SPAWN_EXECUTOR 10, .executor_10_cake_item_anim_6
    SET_WAIT_FRAMES 20
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    UPDATE_U8_VALUE 3, 255, gHappiness
    SPAWN_EXECUTOR 0, .exec_0_player_taste_and_dispatch
    EXECUTE_SUBROUTINE .wait_loop

.cs52_maria_tasted_msg:
    PAUSE_ENTITY 0
    FLIP_ENTITY_DIRECTION 0
    EXECUTE_SUBROUTINE .setup_msgbox_default
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 57
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITY 0
    EXECUTE_SUBROUTINE .cs52_maria_wait_tasted

.exec_0_player_taste_and_dispatch:
    TOGGLE_PAUSE_ENTITY 0
    EXECUTE_SUBROUTINE .setup_player_entity
    SET_ASSET_ROTATION 0
    SET_OTHER_EXECUTOR_PTR 10, .executor_10_tracking_finish
    SET_ENTITY_DIRECTIONAL_ANIMATION 24
    SET_WAIT_FRAMES 16
    SET_ENTITY_ANIMATION 437
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    FLIP_ENTITY_DIRECTION 22
    BRANCH_U16_VAR_WITHIN_RANGE 52, 52, gCutsceneIndex, .taste_to_maria
    BRANCH_U16_VAR_WITHIN_RANGE 53, 53, gCutsceneIndex, .taste_to_popuri
    BRANCH_U16_VAR_WITHIN_RANGE 54, 54, gCutsceneIndex, .taste_to_elli
    BRANCH_U16_VAR_WITHIN_RANGE 55, 55, gCutsceneIndex, .taste_to_ann
    BRANCH_U16_VAR_WITHIN_RANGE 56, 56, gCutsceneIndex, .taste_to_karen
    DEACTIVATE_SELF

.taste_to_maria:
    SET_OTHER_EXECUTOR_PTR 1, .cs52_maria_wait_tasted

.sub_taste_release_deactivate:
    SET_WAIT_FRAMES 1
    SET_ENTITY_MAP_SPACE_INDEPENDENT FALSE
    DEACTIVATE_SELF

.taste_to_popuri:
    SET_OTHER_EXECUTOR_PTR 1, .cs53_popuri_wait_tasted
    EXECUTE_SUBROUTINE .sub_taste_release_deactivate

.taste_to_elli:
    SET_OTHER_EXECUTOR_PTR 1, .cs54_elli_wait_tasted
    EXECUTE_SUBROUTINE .sub_taste_release_deactivate

.taste_to_ann:
    SET_OTHER_EXECUTOR_PTR 1, .cs55_ann_wait_tasted
    EXECUTE_SUBROUTINE .sub_taste_release_deactivate

.taste_to_karen:
    SET_OTHER_EXECUTOR_PTR 1, .cs56_karen_wait_tasted
    EXECUTE_SUBROUTINE .sub_taste_release_deactivate

