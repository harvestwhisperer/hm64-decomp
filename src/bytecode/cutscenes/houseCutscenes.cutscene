    SET_WAIT_FRAMES 8
    SET_ENTITY_DIRECTIONAL_ANIMATION 103
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_ANIMATION 1
    SET_WAIT_FRAMES 10
    SET_ASSET_ROTATION 2
    SET_ENTITY_ANIMATION 36
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_ANIMATION 40
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 525
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    ENTITY_WALK 16, DIRECTION_W, 2
    SET_ASSET_ROTATION 4
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 526
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 24, -64, 256
    ENTITY_WALK 120, DIRECTION_W, 2
    SET_OTHER_EXECUTOR_PTR 7, .executor_7_release_deactivate
    TOGGLE_PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .cutscene_exit

