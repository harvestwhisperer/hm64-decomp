    BRANCH_U8_VAR_WITHIN_RANGE 34, 34, interactedWithLevelInteractionIndex, .popuri_interact_trigger_1
    BRANCH_U8_VAR_WITHIN_RANGE 35, 35, interactedWithLevelInteractionIndex, .popuri_interact_trigger_2
    EXECUTE_SUBROUTINE .executor_32_popuri_interact_watch

.popuri_interact_trigger_0:
    BRANCH_U8_VAR_WITHIN_RANGE 0, 254, gItemBeingHeld, .executor_32_popuri_interact_watch
    BRANCH_ON_SPECIAL_BIT 0, var0, .executor_32_popuri_interact_watch
    SPAWN_EXECUTOR 0, .executor_0_popuri_gift_item_60
    SET_SPECIAL_BIT 0, var0
    EXECUTE_SUBROUTINE .executor_32_popuri_interact_watch

