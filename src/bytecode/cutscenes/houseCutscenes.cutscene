    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 215
    EXECUTE_SUBROUTINE .sub_naming_exit

; ====================================================
; Cutscene 10 - Popuri brings soup and medicine (cold)
; Popuri visits the bedridden player. NPC fallback
; uses text 246 / 248; if married to Popuri (gWife==1)
; the wife variants text 3 and text 4 are spoken.
; Parallel of .cs_3.
; ====================================================
.cs_10:
    SET_SPECIAL_BIT 31, gCutsceneCompletionFlags
    UPDATE_U8_VALUE 8, 255, gHappiness
    SET_SPECIAL_BIT 15, gCutsceneCompletionFlags
    SPAWN_EXECUTOR 1, .cs10_popuri_main
    DEACTIVATE_SELF

.setup_wife_popuri_e22:
    SETUP_ENTITY 22, ENTITY_ASSET_POPURI, 1
    SET_ENTITY_ANIMATIONS 22, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    RETURN_FROM_SUBROUTINE

.cs10_popuri_text3:
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 3
    EXECUTE_SUBROUTINE .cs10_popuri_serve_food

.cs10_popuri_text4:
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 4
    EXECUTE_SUBROUTINE .sub_wife_leave_fade_exit

.cs10_popuri_main:
    SPAWN_EXECUTOR 4, .executor_4_player_anim_455_pos
    SPAWN_EXECUTOR 16, .executor_16_cs0_map_setup
    SET_WAIT_FRAMES 1
    EXECUTE_SUBROUTINE .setup_wife_popuri_e22
    SET_COORDINATES -116, 0, -136
    SET_ASSET_ROTATION 2
    UPDATE_GLOBAL_RGBA 255, 255, 255, 255, 8
    WAIT_RGBA_FINISHED
    SET_WAIT_FRAMES 15
    BRANCH_ON_SPECIAL_BIT MARRIED, lifeEventBits[0], .cs10_popuri_if_wife1
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 246

.cs10_popuri_serve_food:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_ENTITY_DIRECTIONAL_ANIMATION 16
    WAIT_ENTITY_ANIMATION
    SPAWN_EXECUTOR 10, .executor_10_item_anim_34
    SET_WAIT_FRAMES 30
    DEACTIVATE_EXECUTOR 10
    BRANCH_ON_SPECIAL_BIT MARRIED, lifeEventBits[0], .cs10_popuri_close_if_wife1
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 248
    EXECUTE_SUBROUTINE .sub_wife_leave_fade_exit

.cs10_popuri_if_wife1:
    BRANCH_U8_VAR_WITHIN_RANGE 1, 1, gWife, .cs10_popuri_text3
    RETURN_FROM_SUBROUTINE

.cs10_popuri_close_if_wife1:
    BRANCH_U8_VAR_WITHIN_RANGE 1, 1, gWife, .cs10_popuri_text4
    RETURN_FROM_SUBROUTINE

; ====================================================
; Cutscene 11 - Popuri giving birth
; Parallel of .cs_4 with Lillia (e24) in the mayor-
; wife role. Time-of-day branches pick day / evening /
; night setups. Evening variant plays the push-and-
; delivery cinematic (texts 168 - 176, Popuri asking
; for a name via text 178). Interaction dispatch uses
; texts 251 - 257.
; ====================================================
.cs_11:
    SET_SPECIAL_BIT 10, gCutsceneCompletionFlags
    BRANCH_U8_VAR_WITHIN_RANGE 0, 5, gHour, .cs11_birth_night
    BRANCH_U8_VAR_WITHIN_RANGE 15, 23, gHour, .cs11_birth_evening
    BRANCH_U8_VAR_WITHIN_RANGE 6, 6, gHour, .cs11_birth_6am
    SPAWN_EXECUTOR 1, .cs11_popuri_exec_day
    SPAWN_EXECUTOR 2, .executor_2_midwife_wander
    SPAWN_EXECUTOR 3, .executor_3_lillia_day
    SPAWN_EXECUTOR 41, .executor_41_popuri_interact_watch
    DEACTIVATE_SELF

.audio_night_spring:
    SET_AUDIO_SEQUENCE 0, _nightAmbienceSpringSegmentRomStart, _nightAmbienceSpringSegmentRomEnd
    SET_AUDIO_SEQUENCE_VOLUME 0, 64, 4
    RETURN_FROM_SUBROUTINE

.audio_night_summer:
    SET_AUDIO_SEQUENCE 0, _nightAmbienceSummerSegmentRomStart, _nightAmbienceSummerSegmentRomEnd
    SET_AUDIO_SEQUENCE_VOLUME 0, 64, 4
    RETURN_FROM_SUBROUTINE

.audio_night_autumn:
    SET_AUDIO_SEQUENCE 0, _nightAmbienceAutumnSegmentRomStart, _nightAmbienceAutumnSegmentRomEnd
    SET_AUDIO_SEQUENCE_VOLUME 0, 64, 4
    RETURN_FROM_SUBROUTINE

.audio_starry_night:
    SET_AUDIO_SEQUENCE 0, _starryNightFestivalSegmentRomStart, _starryNightFestivalSegmentRomEnd
    SET_AUDIO_SEQUENCE_VOLUME 0, 64, 4
    RETURN_FROM_SUBROUTINE

; ====================================================
; Cutscene 12 - Popuri post-birth bedroom scene
; Parallel of .cs_5. Popuri sleeps, baby e25 lies
; nearby. Plays a seasonal night-ambience sequence
; (spring / summer / autumn / starry) then shows
; text 312 (Popuri saying thank you and goodnight).
; ====================================================
.cs_12:
    SET_SPECIAL_BIT 31, gCutsceneCompletionFlags
    SPAWN_EXECUTOR 1, .cs12_popuri_sleep_e22
    SPAWN_EXECUTOR 4, .executor_4_baby_e25_anim_13
    EXECUTE_SUBROUTINE .setup_player_entity
    SET_COORDINATES -128, 0, -144
    SET_ASSET_ROTATION 2
    BRANCH_U8_VAR_WITHIN_RANGE 1, 1, gSeason, .audio_night_spring
    BRANCH_U8_VAR_WITHIN_RANGE 2, 2, gSeason, .audio_night_summer
    BRANCH_U8_VAR_WITHIN_RANGE 3, 3, gSeason, .audio_night_autumn
    BRANCH_U8_VAR_WITHIN_RANGE 4, 4, gSeason, .audio_starry_night
    UPDATE_GLOBAL_RGBA 255, 255, 255, 255, 8
    WAIT_RGBA_FINISHED
    SET_WAIT_FRAMES 10
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 312
    EXECUTE_SUBROUTINE .sub_fade_out_exit

.cs12_popuri_sleep_e22:
    EXECUTE_SUBROUTINE .setup_wife_popuri_e22
    SET_ENTITY_PHYSICS_FLAGS 0
    SET_COORDINATES -194, 32, -172
    SET_ENTITY_ANIMATION 24
    EXECUTE_SUBROUTINE .wait_loop

.cs11_birth_6am:
    SPAWN_EXECUTOR 41, .executor_41_popuri_interact_watch
    SPAWN_EXECUTOR 1, .cs11_popuri_exec_day
    SPAWN_EXECUTOR 2, .executor_2_midwife_wander
    BRANCH_U8_VAR_WITHIN_RANGE 1, 99, gMinutes, .cs11_birth_6am_after_min
    SPAWN_EXECUTOR 3, .executor_3_lillia_6am
    DEACTIVATE_SELF

.cs11_birth_6am_after_min:
    SPAWN_EXECUTOR 3, .executor_3_lillia_day
    DEACTIVATE_SELF

.cs11_birth_evening:
    SPAWN_EXECUTOR 1, .cs11_popuri_exec_evening
    SPAWN_EXECUTOR 2, .executor_2_midwife_fixed_pos
    SPAWN_EXECUTOR 3, .executor_3_lillia_evening
    SPAWN_EXECUTOR 4, .executor_4_baby_e25_anim_13
    SPAWN_EXECUTOR 41, .executor_41_popuri_interact_watch
    DEACTIVATE_SELF

.cs11_birth_night:
    SPAWN_EXECUTOR 1, .cs11_popuri_exec_night
    SPAWN_EXECUTOR 4, .executor_4_baby_e25_anim_13
    SPAWN_EXECUTOR 41, .executor_41_popuri_interact_watch
    DEACTIVATE_SELF

.executor_41_popuri_interact_watch:
    SET_WAIT_FRAMES 1
    BRANCH_U8_VAR_WITHIN_RANGE 33, 33, interactedWithLevelInteractionIndex, .cs11_on_interact_trigger
    EXECUTE_SUBROUTINE .executor_41_popuri_interact_watch

.cs11_on_interact_trigger:
    SET_OTHER_EXECUTOR_PTR 1, .cs11_on_interact_dispatch
    DEACTIVATE_SELF

.cs11_popuri_exec_day:
    EXECUTE_SUBROUTINE .setup_wife_popuri_e22
    SET_COORDINATES -184, 0, -172
    SET_ENTITY_ANIMATION 24
    EXECUTE_SUBROUTINE .wait_loop

.cs11_popuri_exec_evening:
    EXECUTE_SUBROUTINE .setup_wife_popuri_e22
    SET_ENTITY_PHYSICS_FLAGS 0
    SET_COORDINATES -194, 32, -172
    SET_ENTITY_ANIMATION 24
    SET_WAIT_FRAMES 1
    BRANCH_ON_SPECIAL_BIT 11, D_80237A00, .wait_loop
    EXECUTE_SUBROUTINE .sub_birth_cinematic
    SET_SPECIAL_BIT 11, D_80237A00

.cs11_popuri_exec_night:
    EXECUTE_SUBROUTINE .setup_wife_popuri_e22
    SET_ENTITY_PHYSICS_FLAGS 0
    SET_COORDINATES -194, 32, -172
    SET_ENTITY_ANIMATION 24
    EXECUTE_SUBROUTINE .wait_loop

.setup_lillia_e24:
    SETUP_ENTITY 24, ENTITY_ASSET_LILLIA, 1
    SET_ENTITY_ANIMATIONS 24, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    RETURN_FROM_SUBROUTINE

.executor_3_lillia_6am:
    EXECUTE_SUBROUTINE .setup_lillia_e24
    SET_COORDINATES -48, 0, 112
    SET_ASSET_ROTATION 4
    UPDATE_RGBA 255, 255, 255, 255, 8
    WAIT_RGBA_FINISHED

.sub_lillia_wait_callback:
    SET_CALLBACK_ROUTINE 0, 32768, .cs11_lillia_on_interact
    EXECUTE_SUBROUTINE .wait_loop

.executor_3_lillia_evening:
    EXECUTE_SUBROUTINE .setup_lillia_e24
    SET_COORDINATES -80, 0, -112
    SET_ASSET_ROTATION 2
    EXECUTE_SUBROUTINE .sub_lillia_wait_callback

.executor_3_lillia_day:
    EXECUTE_SUBROUTINE .setup_lillia_e24
    SET_COORDINATES -112, 0, 80
    SET_ASSET_ROTATION 4
    EXECUTE_SUBROUTINE .sub_lillia_wait_callback

.executor_3_lillia_approach:
    ENTITY_WALK 24, DIRECTION_W, 2
    SET_ASSET_ROTATION 4
    EXECUTE_SUBROUTINE .sub_lillia_wait_callback

.cs11_on_interact_dispatch:
    BRANCH_U8_VAR_WITHIN_RANGE 0, 254, gItemBeingHeld, .executor_41_popuri_interact_watch
    PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .setup_msgbox_default
    BRANCH_U8_VAR_WITHIN_RANGE 6, 6, gHour, .cs11_interact_6am
    BRANCH_U8_VAR_WITHIN_RANGE 7, 14, gHour, .cs11_interact_day
    BRANCH_U8_VAR_WITHIN_RANGE 15, 23, gHour, .cs11_interact_evening_finale
    BRANCH_U8_VAR_WITHIN_RANGE 0, 5, gHour, .cs11_interact_night_finale
    DEACTIVATE_SELF

.cs11_interact_6am:
    EXECUTE_SUBROUTINE .setup_msgbox_default
    BRANCH_U8_VAR_WITHIN_RANGE 1, 99, gMinutes, .cs11_interact_day
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 251
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    BRANCH_ON_SPECIAL_BIT 1, var0, .cs11_interact_check_var1
    SET_SPECIAL_BIT 1, var0
    SET_OTHER_EXECUTOR_PTR 3, .executor_3_lillia_approach

.cs11_interact_check_var1:
    TOGGLE_PAUSE_ENTITIES
    SPAWN_EXECUTOR 41, .executor_41_popuri_interact_watch
    EXECUTE_SUBROUTINE .wait_loop

.cs11_interact_day:
    EXECUTE_SUBROUTINE .setup_msgbox_center_avatar
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 166
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    EXECUTE_SUBROUTINE .setup_msgbox_default
    TOGGLE_PAUSE_ENTITIES
    SPAWN_EXECUTOR 41, .executor_41_popuri_interact_watch
    EXECUTE_SUBROUTINE .wait_loop

.cs11_interact_evening_finale:
    EXECUTE_SUBROUTINE .setup_msgbox_default
    UPDATE_U8_VALUE 8, 255, npcAffection[POPURI]
    UPDATE_U8_VALUE 5, 255, npcAffection[LILLIA]
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 254
    EXECUTE_SUBROUTINE .sub_birth_finale_exit

.cs11_interact_night_finale:
    EXECUTE_SUBROUTINE .setup_msgbox_default
    UPDATE_U8_VALUE -5, 255, npcAffection[POPURI]
    UPDATE_U8_VALUE 5, 255, npcAffection[LILLIA]
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 257
    EXECUTE_SUBROUTINE .sub_birth_finale_exit

.cs11_lillia_on_interact:
    FLIP_ENTITY_DIRECTION 0
    PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .setup_msgbox_default
    BRANCH_U8_VAR_WITHIN_RANGE 6, 6, gHour, .cs11_lillia_6am
    BRANCH_U8_VAR_WITHIN_RANGE 1, 14, gHour, .cs11_lillia_day
    BRANCH_U8_VAR_WITHIN_RANGE 15, 23, gHour, .cs11_lillia_evening
    DEACTIVATE_SELF

.cs11_lillia_6am:
    BRANCH_U8_VAR_WITHIN_RANGE 1, 255, gMinutes, .cs11_lillia_day
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 252

.sub_lillia_dialogue_return:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .sub_lillia_wait_callback

