    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 354
    WAIT_MESSAGE_BOX_CLOSED 0
    SET_ASSET_ROTATION 0
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 213
    EXECUTE_SUBROUTINE .sub_naming_exit

; ====================================================
; Cutscene 24 - Ann brings soup and medicine (cold)
; Ann visits the bedridden player. NPC fallback uses
; text 374 / 376; if married to Ann (gWife==3) the
; wife variants text 7 and text 8 are spoken.
; Parallel of .cs_3.
; ====================================================
.cs_24:
    SET_SPECIAL_BIT 31, gCutsceneCompletionFlags
    UPDATE_U8_VALUE 8, 255, gHappiness
    SET_SPECIAL_BIT 15, gCutsceneCompletionFlags
    SPAWN_EXECUTOR 1, .cs24_ann_main
    DEACTIVATE_SELF

.setup_wife_ann_e22:
    SETUP_ENTITY 22, ENTITY_ASSET_ANN, 1
    SET_ENTITY_ANIMATIONS 22, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    RETURN_FROM_SUBROUTINE

.cs24_ann_text7:
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 7
    EXECUTE_SUBROUTINE .cs24_ann_serve_food

.cs24_ann_text8:
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 8
    EXECUTE_SUBROUTINE .sub_wife_leave_fade_exit

.cs24_ann_main:
    SPAWN_EXECUTOR 4, .executor_4_player_anim_455_pos
    SPAWN_EXECUTOR 16, .executor_16_cs0_map_setup
    SET_WAIT_FRAMES 1
    EXECUTE_SUBROUTINE .setup_wife_ann_e22
    SET_COORDINATES -116, 0, -136
    SET_ASSET_ROTATION 2
    UPDATE_GLOBAL_RGBA 255, 255, 255, 255, 8
    WAIT_RGBA_FINISHED
    SET_WAIT_FRAMES 15
    BRANCH_ON_SPECIAL_BIT MARRIED, lifeEventBits[0], .cs24_ann_if_wife3
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 374

.cs24_ann_serve_food:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_ENTITY_DIRECTIONAL_ANIMATION 16
    WAIT_ENTITY_ANIMATION
    SPAWN_EXECUTOR 10, .executor_10_item_anim_62
    SET_WAIT_FRAMES 30
    DEACTIVATE_EXECUTOR 10
    BRANCH_ON_SPECIAL_BIT MARRIED, lifeEventBits[0], .cs24_ann_close_if_wife3
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 376
    EXECUTE_SUBROUTINE .sub_wife_leave_fade_exit

.cs24_ann_if_wife3:
    BRANCH_U8_VAR_WITHIN_RANGE 3, 3, gWife, .cs24_ann_text7
    RETURN_FROM_SUBROUTINE

.cs24_ann_close_if_wife3:
    BRANCH_U8_VAR_WITHIN_RANGE 3, 3, gWife, .cs24_ann_text8
    RETURN_FROM_SUBROUTINE

; ====================================================
; Cutscene 25 - Ann giving birth
; Parallel of .cs_4 with Doug (e24) supporting. The
; interact dispatch uses texts 379 - 385 for the day /
; evening / night finale variants.
; ====================================================
.cs_25:
    SET_SPECIAL_BIT 10, gCutsceneCompletionFlags
    BRANCH_U8_VAR_WITHIN_RANGE 0, 5, gHour, .cs25_birth_night
    BRANCH_U8_VAR_WITHIN_RANGE 15, 23, gHour, .cs25_birth_evening
    BRANCH_U8_VAR_WITHIN_RANGE 6, 6, gHour, .cs25_birth_6am
    SPAWN_EXECUTOR 1, .cs25_ann_exec_day
    SPAWN_EXECUTOR 2, .executor_2_midwife_wander
    SPAWN_EXECUTOR 3, .executor_3_doug_day
    SPAWN_EXECUTOR 41, .executor_41_ann_interact_watch
    DEACTIVATE_SELF

; ====================================================
; Cutscene 26 - Ann post-birth bedroom scene
; Parallel of .cs_5. Shows text 314 (Ann saying she
; feels like she has finished a big job and then
; saying goodnight).
; ====================================================
.cs_26:
    SET_SPECIAL_BIT 31, gCutsceneCompletionFlags
    SPAWN_EXECUTOR 1, .cs26_ann_sleep_e22
    SPAWN_EXECUTOR 4, .executor_4_baby_e25_anim_13
    EXECUTE_SUBROUTINE .setup_player_entity
    SET_COORDINATES -128, 0, -144
    SET_ASSET_ROTATION 2
    UPDATE_GLOBAL_RGBA 255, 255, 255, 255, 8
    WAIT_RGBA_FINISHED
    SET_WAIT_FRAMES 10
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 314
    EXECUTE_SUBROUTINE .sub_fade_out_exit

.cs26_ann_sleep_e22:
    EXECUTE_SUBROUTINE .setup_wife_ann_e22
    SET_ENTITY_PHYSICS_FLAGS 0
    SET_COORDINATES -194, 32, -172
    SET_ENTITY_ANIMATION 24
    SPAWN_EXECUTOR 41, .executor_41_ann_interact_watch
    EXECUTE_SUBROUTINE .wait_loop

.cs25_birth_6am:
    SPAWN_EXECUTOR 41, .executor_41_ann_interact_watch
    SPAWN_EXECUTOR 1, .cs25_ann_exec_day
    SPAWN_EXECUTOR 2, .executor_2_midwife_wander
    BRANCH_U8_VAR_WITHIN_RANGE 1, 99, gMinutes, .cs25_birth_6am_after_min
    SPAWN_EXECUTOR 3, .executor_3_doug_6am
    DEACTIVATE_SELF

.cs25_birth_6am_after_min:
    SPAWN_EXECUTOR 3, .executor_3_doug_day
    DEACTIVATE_SELF

.cs25_birth_evening:
    SPAWN_EXECUTOR 1, .cs25_ann_exec_evening
    SPAWN_EXECUTOR 2, .executor_2_midwife_fixed_pos
    SPAWN_EXECUTOR 3, .executor_3_doug_evening
    SPAWN_EXECUTOR 4, .executor_4_baby_e25_anim_13
    SPAWN_EXECUTOR 41, .executor_41_ann_interact_watch
    DEACTIVATE_SELF

.cs25_birth_night:
    SPAWN_EXECUTOR 1, .cs25_ann_exec_night
    SPAWN_EXECUTOR 4, .executor_4_baby_e25_anim_13
    SPAWN_EXECUTOR 41, .executor_41_ann_interact_watch
    DEACTIVATE_SELF

.executor_41_ann_interact_watch:
    SET_WAIT_FRAMES 1
    BRANCH_U8_VAR_WITHIN_RANGE 33, 33, interactedWithLevelInteractionIndex, .cs25_on_interact_trigger
    EXECUTE_SUBROUTINE .executor_41_ann_interact_watch

.cs25_on_interact_trigger:
    SET_OTHER_EXECUTOR_PTR 1, .cs25_on_interact_dispatch
    DEACTIVATE_SELF

.cs25_ann_exec_day:
