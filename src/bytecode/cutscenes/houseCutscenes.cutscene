    SET_WAIT_FRAMES 1
    BRANCH_U8_VAR_WITHIN_RANGE 33, 33, interactedWithLevelInteractionIndex, .maria_interact_trigger_0
    BRANCH_U8_VAR_WITHIN_RANGE 34, 34, interactedWithLevelInteractionIndex, .maria_interact_trigger_1
