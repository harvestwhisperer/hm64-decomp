.cs_43:
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 255
    SET_WAIT_FRAMES 1
    PAUSE_ENTITIES
    SET_WAIT_FRAMES 30
    SET_MESSAGE_INTERPOLATION -4, 0, 0
    SET_MESSAGE_BOX_ASSETS 0, 1, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 0, -64, 256
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 288
    EXECUTE_SUBROUTINE .sub_single_msg_exit

; ====================================================
; Cutscene 44 - Dream flashback
; Same frame as .cs_41 showing text 359 (narrator
; recalling a girl excitedly watching baby birds in a
; tree and then falling).
; ====================================================
.cs_44:
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 255
    SET_WAIT_FRAMES 1
    PAUSE_ENTITIES
    SET_WAIT_FRAMES 30
    SET_MESSAGE_INTERPOLATION -4, 0, 0
    SET_MESSAGE_BOX_ASSETS 0, 1, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 0, -64, 256
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 359
    EXECUTE_SUBROUTINE .sub_single_msg_exit

; ====================================================
; Cutscene 45 - Dream flashback
; Same frame as .cs_41 showing text 425 (narrator
; recalling a crying girl locked out after getting in
; trouble, walked home hand in hand).
; ====================================================
.cs_45:
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 255
    SET_WAIT_FRAMES 1
    PAUSE_ENTITIES
    SET_WAIT_FRAMES 30
    SET_MESSAGE_INTERPOLATION -4, 0, 0
    SET_MESSAGE_BOX_ASSETS 0, 1, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 0, -64, 256
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 425
    EXECUTE_SUBROUTINE .sub_single_msg_exit

; ====================================================
; Cutscene 46 - Wife note (Maria leaves for home)
; Triggered when player affection with the wife drops
; too low. UPDATE_U8_VALUE -50 on npcAffection[MARIA],
; an item spawns at the table (anim 211), and an
; interaction dispatches to a wife-specific farewell
; note. Maria uses text 216 . Popuri / Elli / Ann /
; Karen variants share the same setup via cs_47..50.
; ====================================================
.cs_46:
    UPDATE_U8_VALUE -50, 255, npcAffection[MARIA]
    SPAWN_EXECUTOR 1, .cs46_setup_item_e46_anim_211
    SPAWN_EXECUTOR 32, .executor_32_watch_interact_32
    DEACTIVATE_SELF

.cs46_setup_item_e46_anim_211:
    SETUP_ENTITY 46, ENTITY_ASSET_STATIC_ITEM, 1
    SET_ENTITY_ANIMATIONS 46, 0, 0, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_COORDINATES -56, 0, 16
    SET_ENTITY_ANIMATION 211
    EXECUTE_SUBROUTINE .wait_loop

.executor_32_watch_interact_32:
    SET_WAIT_FRAMES 1
    BRANCH_U8_VAR_WITHIN_RANGE 32, 32, interactedWithLevelInteractionIndex, .cs46_on_interact_wife_dispatch
    EXECUTE_SUBROUTINE .executor_32_watch_interact_32

.cs46_on_interact_wife_dispatch:
    PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .setup_msgbox_center_avatar
    BRANCH_U8_VAR_WITHIN_RANGE 0, 0, gWife, .cs46_angry_maria
    BRANCH_U8_VAR_WITHIN_RANGE 1, 1, gWife, .cs46_angry_popuri
    BRANCH_U8_VAR_WITHIN_RANGE 2, 2, gWife, .cs46_angry_elli
    BRANCH_U8_VAR_WITHIN_RANGE 3, 3, gWife, .cs46_angry_ann
    BRANCH_U8_VAR_WITHIN_RANGE 4, 4, gWife, .cs46_angry_karen

.sub_angry_return:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    EXECUTE_SUBROUTINE .setup_msgbox_default
    TOGGLE_PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .executor_32_watch_interact_32

.cs46_angry_maria:
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 216
    EXECUTE_SUBROUTINE .sub_angry_return

.cs46_angry_popuri:
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 283
    EXECUTE_SUBROUTINE .sub_angry_return

.cs46_angry_elli:
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 355
    EXECUTE_SUBROUTINE .sub_angry_return

.cs46_angry_ann:
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 411
    EXECUTE_SUBROUTINE .sub_angry_return

.cs46_angry_karen:
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 479
    EXECUTE_SUBROUTINE .sub_angry_return

