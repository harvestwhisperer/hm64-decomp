    BRANCH_ON_SPECIAL_BIT 1, var0, .executor_32_karen_interact_watch
    SPAWN_EXECUTOR 0, .executor_0_player_gift_item_6
    SET_SPECIAL_BIT 1, var0
    EXECUTE_SUBROUTINE .executor_32_karen_interact_watch

