; ====================================================
; Cutscene 38 - Cliff delivers morning fish
; Cliff walks up to the player, says he caught lots of
; fish and came to share (text 521), hands something
; over, apologises for the early hour (text 522), and
; leaves. Text 523 plays afterward while the player
; walks off. +5 affection for Cliff.
; ====================================================
.cs_38:
    SET_SPECIAL_BIT 31, gCutsceneCompletionFlags
    SET_SPECIAL_BIT 15, gCutsceneCompletionFlags
    UPDATE_U8_VALUE 5, 255, npcAffection[CLIFF]
    SPAWN_EXECUTOR 7, .cs38_cliff_entrance
    DEACTIVATE_SELF

; ====================================================
; Cutscene 39 - Ann bumps into Cliff (introduction)
; The player walks up and Cliff apologises. Ann reacts
; (text 525), asks if Cliff is a traveller and catches
; his name (text 526). Cliff then walks off NW.
; ====================================================
.cs_39:
    SPAWN_EXECUTOR 7, .cs39_cliff_ann_setup
    DEACTIVATE_SELF

.cs38_cliff_entrance:
    EXECUTE_SUBROUTINE .setup_player_entity
    SET_COORDINATES -48, 0, -48
    SET_ASSET_ROTATION 0
    UPDATE_GLOBAL_RGBA 255, 255, 255, 255, 8
    WAIT_RGBA_FINISHED
    SET_WAIT_FRAMES 15
    SET_SFX 42, 128
    SET_WAIT_FRAMES 10
    SET_SFX 42, 128
    SET_WAIT_FRAMES 20
    SPAWN_EXECUTOR 1, .cs38_cliff_walks_to_player
    ENTITY_WALK 24, DIRECTION_E, 2
    ENTITY_WALK 32, DIRECTION_S, 2
    EXECUTE_SUBROUTINE .wait_loop

.setup_cliff_e37:
    SETUP_ENTITY 37, ENTITY_ASSET_CLIFF, 1
    SET_ENTITY_ANIMATIONS 37, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    RETURN_FROM_SUBROUTINE

.cs38_cliff_walks_to_player:
    EXECUTE_SUBROUTINE .setup_cliff_e37
    SET_RGBA 255, 255, 255, 255
    SET_COORDINATES -32, 0, 160
    SET_ASSET_ROTATION 4
    ENTITY_WALK 50, DIRECTION_N, 2
    ENTITY_WALK 16, DIRECTION_E, 2
    SET_ASSET_ROTATION 4
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 521
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_ENTITY_ANIMATION 21
    WAIT_ENTITY_ANIMATION
    SPAWN_EXECUTOR 10, .executor_10_item_e37_anim_37
    SET_WAIT_FRAMES 30
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SET_OTHER_EXECUTOR_PTR 7, .cs38_cliff_gives_item
    EXECUTE_SUBROUTINE .wait_loop

.cs38_cliff_gives_item:
    EXECUTE_SUBROUTINE .sub_player_react_anim_437
    FLIP_ENTITY_DIRECTION 37
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 522
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 1, .cs38_cliff_leaves_step1
    DEACTIVATE_SELF

.cs38_cliff_leaves_step1:
    TOGGLE_PAUSE_ENTITY 37
    ENTITY_WALK 16, DIRECTION_W, 2
    ENTITY_WALK 42, DIRECTION_S, 2
    SPAWN_EXECUTOR 7, .cs38_cliff_leaves_fade_out
    DEACTIVATE_SELF

.cs38_cliff_leaves_fade_out:
    SET_SFX 50, 128
    SET_WAIT_FRAMES 30
    SET_SFX 14, 128
    SET_WAIT_FRAMES 10
    EXECUTE_SUBROUTINE .setup_msgbox_center_avatar
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 523
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    EXECUTE_SUBROUTINE .setup_msgbox_default
    EXECUTE_SUBROUTINE .setup_player_entity
    SET_RGBA 255, 255, 255, 255
    TOGGLE_PAUSE_ENTITIES
    ENTITY_WALK 16, DIRECTION_S, 2
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    ENTITY_WALK 16, DIRECTION_W, 2
    ENTITY_WALK 32, DIRECTION_S, 2
    WAIT_RGBA_FINISHED
    SET_SPECIAL_BIT 1, gCutsceneCompletionFlags
    SET_ENTITY_MAP_SPACE_INDEPENDENT FALSE
    EXECUTE_SUBROUTINE .cutscene_exit

.cs39_cliff_ann_setup:
    SPAWN_EXECUTOR 1, .cs39_cliff_spawn
    SPAWN_EXECUTOR 2, .cs39_ann_spawn
    EXECUTE_SUBROUTINE .setup_player_entity
    SET_COORDINATES -372, 0, 112
    SET_WAIT_FRAMES 1
    UPDATE_GLOBAL_RGBA 254, 254, 254, 254, 0
    WAIT_RGBA_FINISHED
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 524
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 1, .cs39_cliff_walk_off
    SET_OTHER_EXECUTOR_PTR 2, .cs39_ann_dialogue
    EXECUTE_SUBROUTINE .wait_loop

.cs39_cliff_walk_off:
    ENTITY_WALK 120, DIRECTION_W, 2
    DEACTIVATE_SELF

.cs39_cliff_spawn:
