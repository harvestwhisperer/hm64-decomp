    SET_ASSET_ROTATION 2
    UPDATE_GLOBAL_RGBA 255, 255, 255, 255, 8
    WAIT_RGBA_FINISHED
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 353
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_AUDIO_SEQUENCE_VOLUME 0, 0, 4
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    STOP_SEQUENCE_WITH_FADE 0, 1
    IDLE_WHILE_SEQUENCE_PLAYING 0
    DEACTIVATE_EXECUTOR 4
    EXECUTE_SUBROUTINE .cutscene_exit

.cs23_executor_5_player_exit:
    EXECUTE_SUBROUTINE .setup_player_entity
    SET_COORDINATES -152, 0, -32
    SET_ASSET_ROTATION 2
    SET_ENTITY_MAP_SPACE_INDEPENDENT FALSE
    PAUSE_ENTITIES
    DEACTIVATE_SELF

.cs23_midwife_naming:
    EXECUTE_SUBROUTINE .setup_midwife_msg_209
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 354
    WAIT_MESSAGE_BOX_CLOSED 0
    SET_ENTITY_ANIMATION 16
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 211
    EXECUTE_SUBROUTINE .sub_naming_exit

.cs23_potion_dealer_naming:
