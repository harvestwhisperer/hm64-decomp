    BRANCH_ON_DIALOGUE 0, 2, .cs23_elli_fallback_path

.cs23_midwife_path:
    UPDATE_U8_VALUE 8, 255, npcAffection[MIDWIFE]
    SPAWN_EXECUTOR 3, .cs23_midwife_naming
    EXECUTE_SUBROUTINE .wait_loop

.cs23_potion_dealer_path:
    UPDATE_U8_VALUE 8, 255, npcAffection[POTION_SHOP_DEALER]
    SPAWN_EXECUTOR 3, .cs23_potion_dealer_naming
    EXECUTE_SUBROUTINE .wait_loop

.cs23_elli_fallback_path:
    UPDATE_U8_VALUE 8, 255, npcAffection[ELLI]
