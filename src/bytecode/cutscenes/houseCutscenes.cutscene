    SET_COORDINATES -342, 0, 152
    SET_ASSET_ROTATION 0
    SET_ENTITY_ANIMATION 33
    EXECUTE_SUBROUTINE .wait_loop

; ====================================================
; Cutscene 40 - Harvest Goddess grape blessing
; Player stands with anim 482 (asleep / head bowed),
; the map fades to a dim tint, Harvest Goddess (e22,
; ENTITY_ASSET_HARVEST_GODDESS) appears elevated in
; front. She speaks text 567 (message from the grape
; spirit; Kief fairies have arrived; harvest will be
; wonderful). Fade out and exit.
; ====================================================
.cs_40:
    SET_SPECIAL_BIT 15, gCutsceneCompletionFlags
    SET_SPECIAL_BIT 31, gCutsceneCompletionFlags
    EXECUTE_SUBROUTINE .setup_player_entity
    SET_BEHAVIOR_FLAGS 0
    SET_WAIT_FRAMES 1
    SPAWN_EXECUTOR 41, .cs40_map_fade_in
    SET_ENTITY_ANIMATION 482
    SET_COORDINATES -180, 0, -156
    EXECUTE_SUBROUTINE .wait_loop

.cs40_map_fade_in:
    SETUP_MAP_ASSET MAIN_MAP_INDEX
    SET_ASSET_ROTATION 7
    SET_COORDINATES -180, 0, -164
    SET_WAIT_FRAMES 1
    UPDATE_GLOBAL_RGBA 64, 64, 64, 64, 8
    WAIT_RGBA_FINISHED
    SPAWN_EXECUTOR 1, .cs40_goddess_talk
    EXECUTE_SUBROUTINE .wait_loop

.cs40_goddess_talk:
    SETUP_ENTITY 22, ENTITY_ASSET_HARVEST_GODDESS, 1
    SET_ENTITY_ANIMATIONS 22, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_PHYSICS_FLAGS 0
    SET_ENTITY_ANIMATION 3
    SET_COORDINATES -192, 64, -160
    UPDATE_RGBA 255, 255, 255, 255, 6
    WAIT_RGBA_FINISHED
    SET_WAIT_FRAMES 30
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 567
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_WAIT_FRAMES 30
    UPDATE_RGBA 0, 0, 0, 0, 6
    WAIT_RGBA_FINISHED
    SET_OTHER_EXECUTOR_PTR 41, .cs40_fade_out_exit
    DEACTIVATE_SELF

.cs40_fade_out_exit:
    SET_WAIT_FRAMES 30
    SET_AUDIO_SEQUENCE_VOLUME 0, 0, 4
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    STOP_SEQUENCE_WITH_FADE 0, 1
    IDLE_WHILE_SEQUENCE_PLAYING 0
    DEACTIVATE_EXECUTOR 0
    EXECUTE_SUBROUTINE .cutscene_exit

; ====================================================
; Cutscene 41 - Dream flashback
; Black screen, player paused, a large-avatar message
; box reads text 144 (narrator recalling a girl being
; shown a fairy-tale book, waving goodbye as the
; narrator promises to visit next summer). Fade-out
; audio and exit via .sub_single_msg_exit.
; ====================================================
.cs_41:
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 255
    SET_WAIT_FRAMES 1
    PAUSE_ENTITIES
    SET_WAIT_FRAMES 30
    SET_MESSAGE_INTERPOLATION -4, 0, 0
    SET_MESSAGE_BOX_ASSETS 0, 1, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 0, -64, 256
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 144

.sub_single_msg_exit:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_MESSAGE_BOX_ASSETS 0, 0, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 24, -64, 256
    SET_AUDIO_SEQUENCE_VOLUME 0, 0, 8
    SET_WAIT_FRAMES 30
    STOP_SEQUENCE_WITH_FADE 0, 1
    IDLE_WHILE_SEQUENCE_PLAYING 0
    TOGGLE_PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .cutscene_exit

; ====================================================
; Cutscene 42 - Dream flashback
; Same frame as .cs_41 showing text 223 (narrator
; recalling a girl slipping while reaching for a
; flower under the cliff and saying she found a
; flower).
