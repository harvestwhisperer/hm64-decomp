    SPAWN_EXECUTOR 1, .cs18_elli_exec_day
    SPAWN_EXECUTOR 2, .executor_2_midwife_wander
    BRANCH_U8_VAR_WITHIN_RANGE 1, 99, gMinutes, .cs18_birth_6am_after_min
    SPAWN_EXECUTOR 3, .executor_3_pastor_6am
    DEACTIVATE_SELF

.cs18_birth_6am_after_min:
    SPAWN_EXECUTOR 3, .executor_3_pastor_day
    DEACTIVATE_SELF

.cs18_birth_evening:
    SPAWN_EXECUTOR 1, .cs18_elli_exec_evening
    SPAWN_EXECUTOR 2, .executor_2_midwife_fixed_pos
    SPAWN_EXECUTOR 3, .executor_3_pastor_evening
    SPAWN_EXECUTOR 4, .executor_4_baby_e25_anim_13
    SPAWN_EXECUTOR 41, .executor_41_elli_interact_watch
    DEACTIVATE_SELF

.cs18_birth_night:
    SPAWN_EXECUTOR 1, .cs18_elli_exec_night
    SPAWN_EXECUTOR 4, .executor_4_baby_e25_anim_13
    SPAWN_EXECUTOR 41, .executor_41_elli_interact_watch
    DEACTIVATE_SELF

