    EXECUTE_SUBROUTINE .sub_lillia_dialogue_return

.cs11_lillia_evening:
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 256
    EXECUTE_SUBROUTINE .sub_lillia_dialogue_return

; ====================================================
