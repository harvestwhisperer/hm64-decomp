; ============================================================
; Bank 10 - House Cutscenes
; ============================================================

#include "entities.h"
#include "texts.h"
#include "dialogues.h"
#include "maps.h"

#define MAIN_MAP_INDEX 0

#define MAYOR_WIFE 12
#define LILLIA 13
#define SASHA 18
#define POTION_SHOP_DEALER 19
#define KENT 20
#define MIDWIFE 22
#define PASTOR 25

.buffer 2

; Local variables
.local var0, u32, 0

.array npcAffection, u8
.array lifeEventBits, u32

; lifeEventBits[0] bit positions
#define MARRIED 0
#define HAVE_BABY 1

.dispatch:
    TOGGLE_PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .setup_msgbox_default
    BRANCH_U16_VAR_WITHIN_RANGE 0, 0, gCutsceneIndex, .cs_0
    BRANCH_U16_VAR_WITHIN_RANGE 1, 1, gCutsceneIndex, .cs_1
    BRANCH_U16_VAR_WITHIN_RANGE 2, 2, gCutsceneIndex, .cs_2
    BRANCH_U16_VAR_WITHIN_RANGE 3, 3, gCutsceneIndex, .cs_3
    BRANCH_U16_VAR_WITHIN_RANGE 4, 4, gCutsceneIndex, .cs_4
    BRANCH_U16_VAR_WITHIN_RANGE 5, 5, gCutsceneIndex, .cs_5
    BRANCH_U16_VAR_WITHIN_RANGE 6, 6, gCutsceneIndex, .cs_6
    BRANCH_U16_VAR_WITHIN_RANGE 7, 7, gCutsceneIndex, .cs_7
    BRANCH_U16_VAR_WITHIN_RANGE 8, 8, gCutsceneIndex, .cs_8
    BRANCH_U16_VAR_WITHIN_RANGE 9, 9, gCutsceneIndex, .cs_9
    BRANCH_U16_VAR_WITHIN_RANGE 10, 10, gCutsceneIndex, .cs_10
    BRANCH_U16_VAR_WITHIN_RANGE 11, 11, gCutsceneIndex, .cs_11
    BRANCH_U16_VAR_WITHIN_RANGE 12, 12, gCutsceneIndex, .cs_12
    BRANCH_U16_VAR_WITHIN_RANGE 13, 13, gCutsceneIndex, .cs_13
    BRANCH_U16_VAR_WITHIN_RANGE 14, 14, gCutsceneIndex, .cs_14
    BRANCH_U16_VAR_WITHIN_RANGE 15, 15, gCutsceneIndex, .cs_15
    BRANCH_U16_VAR_WITHIN_RANGE 16, 16, gCutsceneIndex, .cs_16
    BRANCH_U16_VAR_WITHIN_RANGE 17, 17, gCutsceneIndex, .cs_17
    BRANCH_U16_VAR_WITHIN_RANGE 18, 18, gCutsceneIndex, .cs_18
    BRANCH_U16_VAR_WITHIN_RANGE 19, 19, gCutsceneIndex, .cs_19
    BRANCH_U16_VAR_WITHIN_RANGE 20, 20, gCutsceneIndex, .cs_20
    BRANCH_U16_VAR_WITHIN_RANGE 21, 21, gCutsceneIndex, .cs_21
    BRANCH_U16_VAR_WITHIN_RANGE 22, 22, gCutsceneIndex, .cs_22
    BRANCH_U16_VAR_WITHIN_RANGE 23, 23, gCutsceneIndex, .cs_23
    BRANCH_U16_VAR_WITHIN_RANGE 24, 24, gCutsceneIndex, .cs_24
    BRANCH_U16_VAR_WITHIN_RANGE 25, 25, gCutsceneIndex, .cs_25
    BRANCH_U16_VAR_WITHIN_RANGE 26, 26, gCutsceneIndex, .cs_26
    BRANCH_U16_VAR_WITHIN_RANGE 27, 27, gCutsceneIndex, .cs_27
    BRANCH_U16_VAR_WITHIN_RANGE 28, 28, gCutsceneIndex, .cs_28
    BRANCH_U16_VAR_WITHIN_RANGE 29, 29, gCutsceneIndex, .cs_29
    BRANCH_U16_VAR_WITHIN_RANGE 30, 30, gCutsceneIndex, .cs_30
    BRANCH_U16_VAR_WITHIN_RANGE 31, 31, gCutsceneIndex, .cs_31
    BRANCH_U16_VAR_WITHIN_RANGE 32, 32, gCutsceneIndex, .cs_32
    BRANCH_U16_VAR_WITHIN_RANGE 33, 33, gCutsceneIndex, .cs_33
    BRANCH_U16_VAR_WITHIN_RANGE 34, 34, gCutsceneIndex, .cs_34
    BRANCH_U16_VAR_WITHIN_RANGE 35, 35, gCutsceneIndex, .cs_35
    BRANCH_U16_VAR_WITHIN_RANGE 36, 36, gCutsceneIndex, .cs_36
    BRANCH_U16_VAR_WITHIN_RANGE 37, 37, gCutsceneIndex, .cs_37
    BRANCH_U16_VAR_WITHIN_RANGE 38, 38, gCutsceneIndex, .cs_38
    BRANCH_U16_VAR_WITHIN_RANGE 39, 39, gCutsceneIndex, .cs_39
    BRANCH_U16_VAR_WITHIN_RANGE 40, 40, gCutsceneIndex, .cs_40
    BRANCH_U16_VAR_WITHIN_RANGE 41, 41, gCutsceneIndex, .cs_41
    BRANCH_U16_VAR_WITHIN_RANGE 42, 42, gCutsceneIndex, .cs_42
    BRANCH_U16_VAR_WITHIN_RANGE 43, 43, gCutsceneIndex, .cs_43
    BRANCH_U16_VAR_WITHIN_RANGE 44, 44, gCutsceneIndex, .cs_44
    BRANCH_U16_VAR_WITHIN_RANGE 45, 45, gCutsceneIndex, .cs_45
    BRANCH_U16_VAR_WITHIN_RANGE 46, 46, gCutsceneIndex, .cs_46
    BRANCH_U16_VAR_WITHIN_RANGE 47, 47, gCutsceneIndex, .cs_47
    BRANCH_U16_VAR_WITHIN_RANGE 48, 48, gCutsceneIndex, .cs_48
    BRANCH_U16_VAR_WITHIN_RANGE 49, 49, gCutsceneIndex, .cs_49
    BRANCH_U16_VAR_WITHIN_RANGE 50, 50, gCutsceneIndex, .cs_50
    BRANCH_U16_VAR_WITHIN_RANGE 51, 51, gCutsceneIndex, .cs_51
    BRANCH_U16_VAR_WITHIN_RANGE 52, 52, gCutsceneIndex, .cs_52
    BRANCH_U16_VAR_WITHIN_RANGE 53, 53, gCutsceneIndex, .cs_53
    BRANCH_U16_VAR_WITHIN_RANGE 54, 54, gCutsceneIndex, .cs_54
    BRANCH_U16_VAR_WITHIN_RANGE 55, 55, gCutsceneIndex, .cs_55
    BRANCH_U16_VAR_WITHIN_RANGE 56, 56, gCutsceneIndex, .cs_56

.cutscene_exit:
    SET_U32_VALUE 0, var0
    SET_SPECIAL_BIT 0, gCutsceneCompletionFlags
    DEACTIVATE_SELF

.wait_loop:
    SET_WAIT_FRAMES 1
    EXECUTE_SUBROUTINE .wait_loop

.setup_msgbox_default:
    SET_MESSAGE_INTERPOLATION -4, 0, 0
    SET_MESSAGE_BOX_ASSETS 0, 0, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 24, -64, 352
    RETURN_FROM_SUBROUTINE

.setup_msgbox_center_avatar:
    SET_MESSAGE_INTERPOLATION -4, 0, 0
    SET_MESSAGE_BOX_ASSETS 0, 1, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 0, -64, 352
    RETURN_FROM_SUBROUTINE

.sub_item_e39_track_e22:
    SETUP_ENTITY 39, ENTITY_ASSET_STATIC_ITEM, 1
    SET_ENTITY_ANIMATIONS 39, 0, 0, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_RGBA 255, 255, 255, 255
    SET_ENTITY_TRACKING_TARGET 22, 0, 14, 22, 255
    RETURN_FROM_SUBROUTINE

.executor_10_item_e40_anim_57:
    SETUP_ENTITY 40, ENTITY_ASSET_STATIC_ITEM, 1
    SET_ENTITY_ANIMATIONS 40, 0, 0, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_RGBA 255, 255, 255, 255
    SET_ENTITY_TRACKING_TARGET 23, 0, 14, 20, 255
    SET_ENTITY_ANIMATION 57
    EXECUTE_SUBROUTINE .wait_loop

.executor_11_item_anim_111:
    EXECUTE_SUBROUTINE .sub_item_e39_track_e22
    SET_ENTITY_ANIMATION 111
    EXECUTE_SUBROUTINE .wait_loop

.executor_10_item_anim_110:
    EXECUTE_SUBROUTINE .sub_item_e39_track_e22
    SET_ENTITY_ANIMATION 110
    EXECUTE_SUBROUTINE .wait_loop

.executor_10_item_e37_anim_37:
    EXECUTE_SUBROUTINE .sub_item_e39_track_e22
    SET_ENTITY_TRACKING_TARGET 37, 0, 14, 22, 255
    SET_ENTITY_ANIMATION 37
    EXECUTE_SUBROUTINE .wait_loop

.executor_10_item_anim_62:
    EXECUTE_SUBROUTINE .sub_item_e39_track_e22
    SET_ENTITY_ANIMATION 62
    EXECUTE_SUBROUTINE .wait_loop

.executor_10_item_anim_34:
    EXECUTE_SUBROUTINE .sub_item_e39_track_e22
    SET_ENTITY_ANIMATION 34
    EXECUTE_SUBROUTINE .wait_loop

.executor_10_tracking_finish:
    SET_ENTITY_TRACKING_TARGET 0, 0, 14, 20, 255
    SET_WAIT_FRAMES 16
    SET_ENTITY_TRACKING_TARGET 0, 0, 32, 16, 255
    SET_WAIT_FRAMES 10
    DEACTIVATE_SELF

.setup_player_entity:
    SETUP_ENTITY 0, ENTITY_ASSET_PLAYER, 1
    SET_ENTITY_ANIMATIONS 0, 0, 8, 16, 24, 32, 40
    SET_BEHAVIOR_FLAGS CUTSCENE_ASSET_BEHAVIOR_TRACK_ENTITY
    RETURN_FROM_SUBROUTINE

.executor_4_player_pos_nw:
    EXECUTE_SUBROUTINE .setup_player_entity
    SET_RGBA 255, 255, 255, 255
    SET_ASSET_ROTATION 2
    SET_ENTITY_MAP_SPACE_INDEPENDENT FALSE
    PAUSE_ENTITIES
    DEACTIVATE_SELF

.sub_player_react_anim_437:
    SET_ASSET_ROTATION 0
    SET_OTHER_EXECUTOR_PTR 10, .executor_10_tracking_finish
    SET_ENTITY_DIRECTIONAL_ANIMATION 24
    SET_WAIT_FRAMES 16
    SET_ENTITY_ANIMATION 437
    WAIT_ENTITY_ANIMATION
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    FLIP_ENTITY_DIRECTION 22
    SET_ENTITY_MAP_SPACE_INDEPENDENT FALSE
    PAUSE_ENTITIES
    RETURN_FROM_SUBROUTINE

.executor_4_player_anim_455_pos:
    EXECUTE_SUBROUTINE .setup_player_entity
    SET_BEHAVIOR_FLAGS 0
    SET_WAIT_FRAMES 1
    SET_ENTITY_ANIMATION 455
    SET_COORDINATES -180, 0, -164
    EXECUTE_SUBROUTINE .wait_loop

.executor_7_release_deactivate:
    SET_ENTITY_MAP_SPACE_INDEPENDENT FALSE
    DEACTIVATE_SELF

.executor_4_release_deactivate:
    SET_BEHAVIOR_FLAGS CUTSCENE_ASSET_BEHAVIOR_TRACK_ENTITY
    SET_WAIT_FRAMES 1
    SET_ENTITY_MAP_SPACE_INDEPENDENT FALSE
    DEACTIVATE_SELF

.executor_2_face_and_wait:
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    EXECUTE_SUBROUTINE .wait_loop

.executor_1_face_sw_wait:
    SET_ASSET_ROTATION 0
    EXECUTE_SUBROUTINE .wait_loop

; ====================================================
; Cutscene 0 - Kent and Stu deliver cold medicine
; Kent enters with younger brother Stu, hands the
; bedridden player a potion (texts 17 - 23), then the
; two leave with a fade-out. Bumps gHappiness +8.
; ====================================================
.cs_0:
    UPDATE_U8_VALUE 8, 255, gHappiness
    SET_SPECIAL_BIT 15, gCutsceneCompletionFlags
    SET_SPECIAL_BIT 31, gCutsceneCompletionFlags
    SPAWN_EXECUTOR 1, .cs0_main_kent_opening
    DEACTIVATE_SELF

.setup_kent_e22:
    SETUP_ENTITY 22, ENTITY_ASSET_KENT, 1
    SET_ENTITY_ANIMATIONS 22, 0, 8, 16, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    RETURN_FROM_SUBROUTINE

.setup_stu_e23:
    SETUP_ENTITY 23, ENTITY_ASSET_STU, 1
    SET_ENTITY_ANIMATIONS 23, 0, 8, 16, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    RETURN_FROM_SUBROUTINE

.executor_16_cs0_map_setup:
    SETUP_MAP_ASSET MAIN_MAP_INDEX
    SET_ASSET_ROTATION 7
    SET_COORDINATES -140, 0, -152
    EXECUTE_SUBROUTINE .wait_loop

.cs0_main_kent_opening:
    SPAWN_EXECUTOR 2, .cs0_stu_initial_pos
    SPAWN_EXECUTOR 4, .executor_4_player_anim_455_pos
    SPAWN_EXECUTOR 16, .executor_16_cs0_map_setup
    SET_WAIT_FRAMES 1
    EXECUTE_SUBROUTINE .setup_kent_e22
    SET_ASSET_ROTATION 2
    SET_COORDINATES -118, 0, -116
    UPDATE_GLOBAL_RGBA 255, 255, 255, 255, 8
    WAIT_RGBA_FINISHED
    SET_WAIT_FRAMES 15
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 17
    WAIT_MESSAGE_BOX_CLOSED 0
    SET_OTHER_EXECUTOR_PTR 2, .cs0_stu_rice_balls
    EXECUTE_SUBROUTINE .wait_loop

.cs0_stu_initial_pos:
    EXECUTE_SUBROUTINE .setup_stu_e23
    SET_COORDINATES -118, 0, -140
    SET_ASSET_ROTATION 2
    EXECUTE_SUBROUTINE .wait_loop

.cs0_stu_rice_balls:
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 18
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_ENTITY_DIRECTIONAL_ANIMATION 16
    WAIT_ENTITY_ANIMATION
    SPAWN_EXECUTOR 10, .executor_10_item_e40_anim_57
    SET_ENTITY_DIRECTIONAL_ANIMATION 24
    WAIT_ENTITY_ANIMATION
    SET_WAIT_FRAMES 15
    SET_OTHER_EXECUTOR_PTR 1, .cs0_kent_medicine_speech
    EXECUTE_SUBROUTINE .wait_loop

.cs0_kent_medicine_speech:
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 19
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_ENTITY_DIRECTIONAL_ANIMATION 28
    WAIT_ENTITY_ANIMATION
    SPAWN_EXECUTOR 11, .executor_11_item_anim_111
    SET_ENTITY_DIRECTIONAL_ANIMATION 36
    WAIT_ENTITY_ANIMATION
    SET_WAIT_FRAMES 30
    DEACTIVATE_EXECUTOR 10
    DEACTIVATE_EXECUTOR 11
    SET_OTHER_EXECUTOR_PTR 2, .executor_2_face_and_wait
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 20
    WAIT_MESSAGE_BOX_CLOSED 0
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 21
    WAIT_MESSAGE_BOX_CLOSED 0
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 22
    WAIT_MESSAGE_BOX_CLOSED 0
    TOGGLE_PAUSE_ENTITY 22
    SET_OTHER_EXECUTOR_PTR 2, .cs0_stu_goodbye
    ENTITY_WALK 128, DIRECTION_S, 2
    DEACTIVATE_SELF

.cs0_stu_goodbye:
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 23
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITY 23
    ENTITY_WALK 64, DIRECTION_S, 2
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    ENTITY_WALK 64, DIRECTION_S, 2
    WAIT_RGBA_FINISHED
    TOGGLE_PAUSE_ENTITIES
    SET_OTHER_EXECUTOR_PTR 4, .executor_4_release_deactivate
    DEACTIVATE_EXECUTOR 16
    EXECUTE_SUBROUTINE .cutscene_exit

; ====================================================
; Cutscene 1 - Kent runaway and sick-grandpa flashback
; Kent (younger) asks the player if he can stay the
; night after fighting with his grandfather. Stu runs
; in saying grandpa collapsed; the scene fades to the
; potion-shop bedroom where the midwife reports grandpa
; is resting. Texts 30, 34, 35, 39 - 53.
; NOTE: labels in this block still reference "wedding"
; / "ceremony" from an earlier guess and should be
; revisited.
; ====================================================
.cs_1:
    SET_SPECIAL_BIT 15, gCutsceneCompletionFlags
    SPAWN_EXECUTOR 1, .cs1_kent_ask_marriage
    DEACTIVATE_SELF

.cs1_kent_ask_marriage:
    SET_WAIT_FRAMES 32
    PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .setup_kent_e22
    SET_RGBA 255, 255, 255, 255
    SET_COORDINATES -112, 0, 112
    TOGGLE_PAUSE_ENTITY 22
    ENTITY_WALK 80, DIRECTION_N, 2
    SET_ASSET_ROTATION 6
    SPAWN_EXECUTOR 4, .executor_4_player_pos_nw
    EXECUTE_SUBROUTINE .setup_msgbox_default
    INIT_DIALOGUE_SESSION 0, DIALOGUE_TEXT_65, 27
    WAIT_FOR_DIALOGUE_INPUT 0
    BRANCH_ON_DIALOGUE 0, 0, .cs1_kent_answered_yes
    BRANCH_ON_DIALOGUE 0, 1, .cs1_kent_answered_no

.cs1_kent_answered_no:
    UPDATE_U8_VALUE -5, 255, npcAffection[KENT]
    TOGGLE_PAUSE_ENTITY 22
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 35
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    ENTITY_RUN 56, DIRECTION_S, 4
    TOGGLE_PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .cutscene_exit

.cs1_kent_answered_yes:
    UPDATE_U8_VALUE 5, 255, npcAffection[KENT]
    INIT_DIALOGUE_SESSION 0, DIALOGUE_TEXT_65, 28
    WAIT_FOR_DIALOGUE_INPUT 0
    BRANCH_ON_DIALOGUE 0, 0, .cs1_ring_no
    BRANCH_ON_DIALOGUE 0, 1, .cs1_ring_yes

.cs1_ring_no:
    UPDATE_U8_VALUE -3, 255, npcAffection[KENT]
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 39
    EXECUTE_SUBROUTINE .cs1_wedding_sequence

.cs1_ring_yes:
    UPDATE_U8_VALUE 3, 255, npcAffection[KENT]
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 40

.cs1_wedding_sequence:
    WAIT_MESSAGE_BOX_CLOSED 0
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 41
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    UPDATE_U8_VALUE 5, 255, gHappiness
    SET_WAIT_FRAMES 30
    SPAWN_EXECUTOR 2, .cs1_exec_wife_approach
    EXECUTE_SUBROUTINE .wait_loop

.cs1_exec_wife_approach:
    EXECUTE_SUBROUTINE .setup_stu_e23
    SET_RGBA 255, 255, 255, 255
    TOGGLE_PAUSE_ENTITY 23
    SET_COORDINATES -112, 0, 112
    SET_ASSET_ROTATION 4
    ENTITY_WALK 32, DIRECTION_N, 4
    SET_OTHER_EXECUTOR_PTR 1, .executor_1_face_sw_wait
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 44
    WAIT_MESSAGE_BOX_CLOSED 0
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 45
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SPAWN_EXECUTOR 4, .cs1_ceremony_arrive_church
    EXECUTE_SUBROUTINE .wait_loop
    ENTITY_RUN 26, DIRECTION_S, 4
    DEACTIVATE_SELF

.cs1_ceremony_arrive_church:
    TOGGLE_PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .setup_player_entity
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    SET_SPECIAL_BIT 29, gCutsceneCompletionFlags
    SET_OTHER_EXECUTOR_PTR 1, .cs1_player_ceremony_walk
    SET_OTHER_EXECUTOR_PTR 2, .cs1_wife_ceremony_walk
    SPAWN_EXECUTOR 3, .cs1_exec_potion_dealer_pos
    SPAWN_EXECUTOR 5, .cs1_exec_midwife_pos
    SPAWN_EXECUTOR 8, .cs1_load_church_map
    SET_COORDINATES 72, 0, 32
    SET_ASSET_ROTATION 2
    SET_WAIT_FRAMES 1
    UPDATE_GLOBAL_RGBA 255, 255, 255, 255, 8
    SET_WAIT_FRAMES 4
    ENTITY_RUN 22, DIRECTION_W, 4
    ENTITY_RUN 9, DIRECTION_N, 4
    ENTITY_RUN 12, DIRECTION_W, 4
    WAIT_RGBA_FINISHED
    SET_ASSET_ROTATION 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 24, -64, 256
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 47
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 5, .cs1_ceremony_vows
    EXECUTE_SUBROUTINE .wait_loop

.cs1_ceremony_vows:
    ENTITY_WALK 24, DIRECTION_W, 2
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 48
    WAIT_MESSAGE_BOX_CLOSED 0
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 49
    WAIT_MESSAGE_BOX_CLOSED 0
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 50
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    ENTITY_WALK 16, DIRECTION_S, 2
    ENTITY_WALK 36, DIRECTION_E, 2
    SET_OTHER_EXECUTOR_PTR 4, .cs1_ceremony_end
    DEACTIVATE_SELF
    EXECUTE_SUBROUTINE .setup_player_entity
    SET_COORDINATES -116, 0, -136
    SET_ASSET_ROTATION 2
    EXECUTE_SUBROUTINE .wait_loop
    SET_COORDINATES -96, 0, 0
    SET_ASSET_ROTATION 6
    EXECUTE_SUBROUTINE .wait_loop

.cs1_ceremony_end:
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 52
    WAIT_MESSAGE_BOX_CLOSED 0
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 53
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    DEACTIVATE_EXECUTOR 1
    DEACTIVATE_EXECUTOR 2
    DEACTIVATE_EXECUTOR 3
    DEACTIVATE_EXECUTOR 8
    SET_ENTITY_MAP_SPACE_INDEPENDENT FALSE
    TOGGLE_PAUSE_ENTITIES
    SET_SPECIAL_BIT 1, gCutsceneCompletionFlags
    EXECUTE_SUBROUTINE .cutscene_exit

.setup_potion_dealer_e24:
    SETUP_ENTITY 24, ENTITY_ASSET_POTION_SHOP_DEALER, 1
    SET_ENTITY_ANIMATIONS 24, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    RETURN_FROM_SUBROUTINE

.cs1_exec_potion_dealer_pos:
    EXECUTE_SUBROUTINE .setup_potion_dealer_e24
    SET_COORDINATES -100, 0, 64
    SET_ENTITY_ANIMATION 16
    EXECUTE_SUBROUTINE .wait_loop

.cs1_exec_midwife_pos:
    SETUP_ENTITY 25, ENTITY_ASSET_MIDWIFE, 1
    SET_ENTITY_ANIMATIONS 25, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_PHYSICS_FLAGS 0
    SET_COORDINATES 16, 0, 0
    SET_ASSET_ROTATION 0
    SET_WAIT_FRAMES 30
    SET_ASSET_ROTATION 2
    EXECUTE_SUBROUTINE .wait_loop

.cs1_player_ceremony_walk:
    SET_ENTITY_PHYSICS_FLAGS 0
    SET_COORDINATES 0, 0, 32
    ENTITY_RUN 8, DIRECTION_W, 4
    ENTITY_RUN 9, DIRECTION_N, 4
    ENTITY_RUN 20, DIRECTION_W, 4
    SET_ASSET_ROTATION 0
    EXECUTE_SUBROUTINE .wait_loop

.cs1_wife_ceremony_walk:
    SET_ENTITY_PHYSICS_FLAGS 0
    SET_COORDINATES 32, 0, 32
    ENTITY_WALK 16, DIRECTION_W, 4
    ENTITY_WALK 9, DIRECTION_N, 4
    ENTITY_WALK 16, DIRECTION_W, 4
    SET_ASSET_ROTATION 0
    EXECUTE_SUBROUTINE .wait_loop

.cs1_load_church_map:
    DEACTIVATE_MAP_OBJECTS 0
    LOAD_MAP MAIN_MAP_INDEX, POTION_SHOP_BEDROOM
    SETUP_MAP_ASSET MAIN_MAP_INDEX
    SET_COORDINATES 0, 96, 0
    SET_ASSET_ROTATION 7
    EXECUTE_SUBROUTINE .wait_loop

; ====================================================
; Cutscene 2 - Kent drops by to check in on the player
; Kent stands SE of the player and, on interaction,
; delivers text 55 (I am OK now, you are pretty busy
; huh). The dispatch also tints the global RGBA by
; time-of-day and weather (snow tiers at gWeather == 2)
; via .sub_rgba_by_time_weather, then shows text 54.
; ====================================================
.cs_2:
    SPAWN_EXECUTOR 1, .cs2_kent_setup_pos
    SPAWN_EXECUTOR 7, .cs2_player_setup
    DEACTIVATE_SELF

.cs2_kent_setup_pos:
    EXECUTE_SUBROUTINE .setup_kent_e22
    SET_COORDINATES 352, 0, -64

.cs2_kent_wait:
    SET_ASSET_ROTATION 6
    SET_CALLBACK_ROUTINE 0, 32768, .cs2_kent_on_interact
    EXECUTE_SUBROUTINE .wait_loop

.cs2_kent_on_interact:
    EXECUTE_SUBROUTINE .setup_msgbox_default
    FLIP_ENTITY_DIRECTION 0
    PAUSE_ENTITIES
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 55
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .cs2_kent_wait

.sub_rgba_by_time_weather:
    BRANCH_U8_VAR_WITHIN_RANGE 2, 2, gWeather, .rgba_snow_dispatch
    BRANCH_U8_VAR_WITHIN_RANGE 0, 4, gHour, .rgba_tier_20_23_or_0_4
    BRANCH_U8_VAR_WITHIN_RANGE 5, 5, gHour, .rgba_tier_5_or_18_19
    BRANCH_U8_VAR_WITHIN_RANGE 6, 7, gHour, .rgba_tier_6_7
    BRANCH_U8_VAR_WITHIN_RANGE 8, 11, gHour, .rgba_tier_8_11
    BRANCH_U8_VAR_WITHIN_RANGE 12, 15, gHour, .rgba_tier_12_15
    BRANCH_U8_VAR_WITHIN_RANGE 16, 16, gHour, .rgba_tier_16
    BRANCH_U8_VAR_WITHIN_RANGE 17, 17, gHour, .rgba_tier_17
    BRANCH_U8_VAR_WITHIN_RANGE 18, 19, gHour, .rgba_tier_5_or_18_19
    BRANCH_U8_VAR_WITHIN_RANGE 20, 23, gHour, .rgba_tier_20_23_or_0_4
    EXECUTE_SUBROUTINE .cs2_finalize_msg_54

.rgba_tier_20_23_or_0_4:
    UPDATE_GLOBAL_RGBA 80, 80, 80, 80, 8
    EXECUTE_SUBROUTINE .cs2_finalize_msg_54

.rgba_tier_5_or_18_19:
    UPDATE_GLOBAL_RGBA 128, 128, 128, 128, 8
    EXECUTE_SUBROUTINE .cs2_finalize_msg_54

.rgba_tier_6_7:
    UPDATE_GLOBAL_RGBA 192, 192, 192, 192, 8
    EXECUTE_SUBROUTINE .cs2_finalize_msg_54

.rgba_tier_8_11:
    UPDATE_GLOBAL_RGBA 224, 224, 224, 224, 8
    EXECUTE_SUBROUTINE .cs2_finalize_msg_54

.rgba_tier_12_15:
    UPDATE_GLOBAL_RGBA 255, 255, 255, 255, 8
    EXECUTE_SUBROUTINE .cs2_finalize_msg_54

.rgba_tier_16:
    UPDATE_GLOBAL_RGBA 255, 224, 224, 224, 8
    EXECUTE_SUBROUTINE .cs2_finalize_msg_54

.rgba_tier_17:
    BRANCH_U8_VAR_WITHIN_RANGE 3, 3, gWeather, .rgba_tier_17_weather3
    UPDATE_GLOBAL_RGBA 255, 192, 192, 192, 8
    EXECUTE_SUBROUTINE .cs2_finalize_msg_54

.rgba_tier_17_weather3:
    UPDATE_GLOBAL_RGBA 255, 192, 192, 192, 8
    EXECUTE_SUBROUTINE .cs2_finalize_msg_54

.rgba_snow_dispatch:
    BRANCH_U8_VAR_WITHIN_RANGE 0, 4, gHour, .rgba_snow_night
    BRANCH_U8_VAR_WITHIN_RANGE 5, 7, gHour, .rgba_snow_dawn_dusk
    BRANCH_U8_VAR_WITHIN_RANGE 8, 11, gHour, .rgba_snow_morning_afternoon
    BRANCH_U8_VAR_WITHIN_RANGE 12, 15, gHour, .rgba_snow_midday
    BRANCH_U8_VAR_WITHIN_RANGE 16, 17, gHour, .rgba_snow_morning_afternoon
    BRANCH_U8_VAR_WITHIN_RANGE 18, 19, gHour, .rgba_snow_dawn_dusk
    BRANCH_U8_VAR_WITHIN_RANGE 20, 23, gHour, .rgba_snow_night
    EXECUTE_SUBROUTINE .cs2_finalize_msg_54

.rgba_snow_night:
    UPDATE_GLOBAL_RGBA 80, 80, 128, 80, 8
    EXECUTE_SUBROUTINE .cs2_finalize_msg_54

.rgba_snow_dawn_dusk:
    UPDATE_GLOBAL_RGBA 112, 112, 192, 112, 8
    EXECUTE_SUBROUTINE .cs2_finalize_msg_54

.rgba_snow_morning_afternoon:
    UPDATE_GLOBAL_RGBA 128, 128, 208, 128, 8
    EXECUTE_SUBROUTINE .cs2_finalize_msg_54

.rgba_snow_midday:
    UPDATE_GLOBAL_RGBA 144, 144, 255, 144, 8
    EXECUTE_SUBROUTINE .cs2_finalize_msg_54

.cs2_player_setup:
    EXECUTE_SUBROUTINE .setup_player_entity
    SET_COORDINATES 384, 0, -64
    SET_ASSET_ROTATION 2
    SET_WAIT_FRAMES 1
    EXECUTE_SUBROUTINE .sub_rgba_by_time_weather

.cs2_finalize_msg_54:
    WAIT_RGBA_FINISHED
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 54
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_ENTITY_MAP_SPACE_INDEPENDENT FALSE
    TOGGLE_PAUSE_ENTITIES
    DEACTIVATE_SELF

; ====================================================
; Cutscene 3 - Maria brings soup and medicine (cold)
; If the player is not married, Maria visits as an NPC
; with soup and potion-shop medicine (text 158, then
; text 160 closing). If married to Maria (gWife == 0),
; she speaks the wife variants text 1 and text 2
; instead. Pairs with .cs_51 (player catches cold).
; ====================================================
.cs_3:
    SET_SPECIAL_BIT 31, gCutsceneCompletionFlags
    UPDATE_U8_VALUE 8, 255, gHappiness
    SET_SPECIAL_BIT 15, gCutsceneCompletionFlags
    SPAWN_EXECUTOR 1, .cs3_maria_main
    DEACTIVATE_SELF

.setup_wife_maria_e22:
    SETUP_ENTITY 22, ENTITY_ASSET_MARIA, 1
    SET_ENTITY_ANIMATIONS 22, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    RETURN_FROM_SUBROUTINE

.cs3_maria_text1:
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 1
    EXECUTE_SUBROUTINE .cs3_maria_serve_food

.cs3_maria_text2:
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 2
    EXECUTE_SUBROUTINE .sub_wife_leave_fade_exit

.cs3_maria_main:
    SPAWN_EXECUTOR 4, .executor_4_player_anim_455_pos
    SPAWN_EXECUTOR 16, .executor_16_cs0_map_setup
    SET_WAIT_FRAMES 1
    EXECUTE_SUBROUTINE .setup_wife_maria_e22
    SET_COORDINATES -116, 0, -136
    SET_ASSET_ROTATION 2
    UPDATE_GLOBAL_RGBA 255, 255, 255, 255, 8
    WAIT_RGBA_FINISHED
    SET_WAIT_FRAMES 15
    BRANCH_ON_SPECIAL_BIT MARRIED, lifeEventBits[0], .cs3_maria_if_wife0
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 158

.cs3_maria_serve_food:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_ENTITY_DIRECTIONAL_ANIMATION 16
    WAIT_ENTITY_ANIMATION
    SPAWN_EXECUTOR 10, .executor_10_item_anim_62
    SET_WAIT_FRAMES 30
    DEACTIVATE_EXECUTOR 10
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    SET_WAIT_FRAMES 1
    SET_ENTITY_DIRECTIONAL_ANIMATION 16
    WAIT_ENTITY_ANIMATION
    SPAWN_EXECUTOR 10, .executor_11_item_anim_111
    SET_WAIT_FRAMES 30
    DEACTIVATE_EXECUTOR 10
    BRANCH_ON_SPECIAL_BIT MARRIED, lifeEventBits[0], .cs3_maria_close_if_wife0
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 160

.sub_wife_leave_fade_exit:
    SET_ENTITY_DIRECTIONAL_ANIMATION 0
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITY 22
    ENTITY_WALK 64, DIRECTION_S, 2
    SET_AUDIO_SEQUENCE_VOLUME 0, 0, 4
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    ENTITY_WALK 64, DIRECTION_S, 2
    WAIT_RGBA_FINISHED
    STOP_SEQUENCE_WITH_FADE 0, 1
    IDLE_WHILE_SEQUENCE_PLAYING 0
    DEACTIVATE_EXECUTOR 4
    DEACTIVATE_EXECUTOR 16
    EXECUTE_SUBROUTINE .cutscene_exit

.cs3_maria_if_wife0:
    BRANCH_U8_VAR_WITHIN_RANGE 0, 0, gWife, .cs3_maria_text1
    RETURN_FROM_SUBROUTINE

.cs3_maria_close_if_wife0:
    BRANCH_U8_VAR_WITHIN_RANGE 0, 0, gWife, .cs3_maria_text2
    RETURN_FROM_SUBROUTINE

; ====================================================
; Cutscene 4 - Maria giving birth (wife)
; Time-of-day routes to 6am / day / evening / night
; variants. Midwife (e23) works on Maria (e22) while
; Mayor Wife (e24) supports. Evening variant plays the
; push-and-delivery cinematic (texts 168 - 176, then
; 178 for Maria asking the player to name the baby).
; Interacting with the bed drives texts 164 - 181 and
; applies affection + happiness rewards on success.
; ====================================================
.cs_4:
    SET_SPECIAL_BIT 10, gCutsceneCompletionFlags
    BRANCH_U8_VAR_WITHIN_RANGE 0, 5, gHour, .cs4_birth_night
    BRANCH_U8_VAR_WITHIN_RANGE 15, 23, gHour, .cs4_birth_evening
    BRANCH_U8_VAR_WITHIN_RANGE 6, 6, gHour, .cs4_birth_6am
    SPAWN_EXECUTOR 1, .cs4_maria_exec_day
    SPAWN_EXECUTOR 2, .executor_2_midwife_wander
    SPAWN_EXECUTOR 3, .executor_3_mayor_wife_day
    SPAWN_EXECUTOR 41, .executor_41_cs4_interact_watch
    DEACTIVATE_SELF

; ====================================================
; Cutscene 5 - Maria post-birth bedroom scene
; Maria sleeps in bed (anim 24), baby e25 in the
; cradle. Player stands NW of bed; text 311 (Maria
; thanking the player for the name, then saying
; goodnight). Fade to black and exit.
; ====================================================
.cs_5:
    SET_SPECIAL_BIT 31, gCutsceneCompletionFlags
    SPAWN_EXECUTOR 1, .cs5_maria_sleep_e22
    SPAWN_EXECUTOR 4, .executor_4_baby_e25_anim_13
    EXECUTE_SUBROUTINE .setup_player_entity
    SET_COORDINATES -128, 0, -144
    SET_ASSET_ROTATION 2
    UPDATE_GLOBAL_RGBA 255, 255, 255, 255, 8
    WAIT_RGBA_FINISHED
    SET_WAIT_FRAMES 10
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 311

.sub_fade_out_exit:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_WAIT_FRAMES 10
    SET_AUDIO_SEQUENCE_VOLUME 0, 0, 8
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    STOP_SEQUENCE_WITH_FADE 0, 1
    IDLE_WHILE_SEQUENCE_PLAYING 0
    EXECUTE_SUBROUTINE .cutscene_exit

.cs5_maria_sleep_e22:
    EXECUTE_SUBROUTINE .setup_wife_maria_e22
    SET_ENTITY_PHYSICS_FLAGS 0
    SET_COORDINATES -194, 32, -172
    SET_ENTITY_ANIMATION 24
    EXECUTE_SUBROUTINE .wait_loop

.cs4_birth_6am:
    SPAWN_EXECUTOR 41, .executor_41_cs4_interact_watch
    SPAWN_EXECUTOR 1, .cs4_maria_exec_day
    SPAWN_EXECUTOR 2, .executor_2_midwife_wander
    BRANCH_U8_VAR_WITHIN_RANGE 1, 99, gMinutes, .cs4_birth_6am_after_min
    SPAWN_EXECUTOR 3, .executor_3_mayor_wife_6am
    DEACTIVATE_SELF

.cs4_birth_6am_after_min:
    SPAWN_EXECUTOR 3, .executor_3_mayor_wife_day
    DEACTIVATE_SELF

.cs4_birth_evening:
    SPAWN_EXECUTOR 1, .cs4_maria_exec_evening
    SPAWN_EXECUTOR 2, .executor_2_midwife_fixed_pos
    SPAWN_EXECUTOR 3, .executor_3_mayor_wife_evening
    SPAWN_EXECUTOR 4, .executor_4_baby_e25_anim_13
    SPAWN_EXECUTOR 41, .executor_41_cs4_interact_watch
    DEACTIVATE_SELF

.cs4_birth_night:
    SPAWN_EXECUTOR 1, .cs4_maria_exec_night
    SPAWN_EXECUTOR 4, .executor_4_baby_e25_anim_13
    DEACTIVATE_SELF

.cs4_maria_exec_day:
    EXECUTE_SUBROUTINE .setup_wife_maria_e22
    SET_COORDINATES -184, 0, -172
    SET_ENTITY_ANIMATION 24
    EXECUTE_SUBROUTINE .wait_loop

.cs4_maria_exec_evening:
    EXECUTE_SUBROUTINE .setup_wife_maria_e22
    SET_ENTITY_PHYSICS_FLAGS 0
    SET_COORDINATES -194, 32, -172
    SET_ENTITY_ANIMATION 24
    SET_WAIT_FRAMES 1
    BRANCH_ON_SPECIAL_BIT 11, D_80237A00, .wait_loop
    EXECUTE_SUBROUTINE .sub_birth_cinematic
    SET_SPECIAL_BIT 11, D_80237A00
    EXECUTE_SUBROUTINE .wait_loop

.cs4_maria_exec_night:
    EXECUTE_SUBROUTINE .setup_wife_maria_e22
    SET_ENTITY_PHYSICS_FLAGS 0
    SET_COORDINATES -194, 32, -172
    SET_ENTITY_ANIMATION 24
    SET_WAIT_FRAMES 1
    UPDATE_GLOBAL_RGBA 255, 255, 255, 255, 8
    WAIT_RGBA_FINISHED
    EXECUTE_SUBROUTINE .wait_loop

.sub_birth_cinematic:
    PAUSE_ENTITIES
    UPDATE_GLOBAL_RGBA 255, 255, 255, 255, 8
    WAIT_RGBA_FINISHED
    SET_MESSAGE_INTERPOLATION -4, 0, 0
    SET_MESSAGE_BOX_ASSETS 0, 1, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 0, -64, 256
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 168
    WAIT_MESSAGE_BOX_CLOSED 0
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 169
    WAIT_MESSAGE_BOX_CLOSED 0
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 170
    WAIT_MESSAGE_BOX_CLOSED 0
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 171
    WAIT_MESSAGE_BOX_CLOSED 0
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 172
    WAIT_MESSAGE_BOX_CLOSED 0
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 173
    WAIT_MESSAGE_BOX_CLOSED 0
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 174
    WAIT_MESSAGE_BOX_CLOSED 0
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 175
    WAIT_MESSAGE_BOX_CLOSED 0
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 176
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_MESSAGE_BOX_ASSETS 0, 0, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 24, -64, 256
    TOGGLE_PAUSE_ENTITIES
    RETURN_FROM_SUBROUTINE

.executor_41_cs4_interact_watch:
    SET_WAIT_FRAMES 1
    BRANCH_U8_VAR_WITHIN_RANGE 33, 33, interactedWithLevelInteractionIndex, .cs4_on_interact_trigger
    EXECUTE_SUBROUTINE .executor_41_cs4_interact_watch

.cs4_on_interact_trigger:
    SET_OTHER_EXECUTOR_PTR 1, .cs4_on_interact_dispatch
    DEACTIVATE_SELF

.cs4_on_interact_dispatch:
    BRANCH_U8_VAR_WITHIN_RANGE 0, 254, gItemBeingHeld, .executor_41_cs4_interact_watch
    PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .setup_msgbox_default
    BRANCH_U8_VAR_WITHIN_RANGE 6, 6, gHour, .cs4_interact_6am
    BRANCH_U8_VAR_WITHIN_RANGE 7, 14, gHour, .cs4_interact_day
    BRANCH_U8_VAR_WITHIN_RANGE 15, 23, gHour, .cs4_interact_evening_finale
    BRANCH_U8_VAR_WITHIN_RANGE 0, 5, gHour, .cs4_interact_night_finale
    DEACTIVATE_SELF

.cs4_interact_6am:
    EXECUTE_SUBROUTINE .setup_msgbox_center_avatar
    BRANCH_U8_VAR_WITHIN_RANGE 1, 99, gMinutes, .cs4_interact_day
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 166
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    EXECUTE_SUBROUTINE .setup_msgbox_default
    BRANCH_ON_SPECIAL_BIT 0, var0, .cs4_interact_check_var0
    SET_SPECIAL_BIT 0, var0
    SET_OTHER_EXECUTOR_PTR 3, .executor_3_mayor_wife_approach

.cs4_interact_check_var0:
    TOGGLE_PAUSE_ENTITIES
    SPAWN_EXECUTOR 41, .executor_41_cs4_interact_watch
    EXECUTE_SUBROUTINE .wait_loop

.cs4_interact_day:
    EXECUTE_SUBROUTINE .setup_msgbox_center_avatar
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 166
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    EXECUTE_SUBROUTINE .setup_msgbox_default
    TOGGLE_PAUSE_ENTITIES
    SPAWN_EXECUTOR 41, .executor_41_cs4_interact_watch
    EXECUTE_SUBROUTINE .wait_loop

.cs4_interact_evening_finale:
    EXECUTE_SUBROUTINE .setup_msgbox_default
    UPDATE_U8_VALUE 8, 255, npcAffection[MARIA]
    UPDATE_U8_VALUE 5, 255, npcAffection[MAYOR_WIFE]
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 178

.sub_birth_finale_exit:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    UPDATE_U8_VALUE 30, 255, gHappiness
    UPDATE_U8_VALUE 5, 255, npcAffection[MIDWIFE]
    SET_WAIT_FRAMES 10
    SET_AUDIO_SEQUENCE_VOLUME 0, 0, 8
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    STOP_SEQUENCE_WITH_FADE 0, 1
    DEACTIVATE_EXECUTOR 2
    DEACTIVATE_EXECUTOR 3
    DEACTIVATE_EXECUTOR 4
    IDLE_WHILE_SEQUENCE_PLAYING 0
    EXECUTE_SUBROUTINE .cutscene_exit

.cs4_interact_night_finale:
    EXECUTE_SUBROUTINE .setup_msgbox_default
    UPDATE_U8_VALUE -5, 255, npcAffection[MARIA]
    UPDATE_U8_VALUE 8, 255, npcAffection[MAYOR_WIFE]
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 181
    EXECUTE_SUBROUTINE .sub_birth_finale_exit

