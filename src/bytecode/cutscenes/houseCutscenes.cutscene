.cs_42:
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 255
    SET_WAIT_FRAMES 1
    PAUSE_ENTITIES
    SET_WAIT_FRAMES 30
    SET_MESSAGE_INTERPOLATION -4, 0, 0
    SET_MESSAGE_BOX_ASSETS 0, 1, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 0, -64, 256
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 223
    EXECUTE_SUBROUTINE .sub_single_msg_exit

; ====================================================
; Cutscene 43 - Dream flashback
; Same frame as .cs_41 showing text 288 (narrator
; recalling a playing-house scene with mud cookies and
; a stomach ache).
