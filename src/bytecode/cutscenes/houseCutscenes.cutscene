    SET_ASSET_ROTATION 4
    EXECUTE_SUBROUTINE .sub_doug_wait_callback

.cs25_on_interact_dispatch:
    BRANCH_U8_VAR_WITHIN_RANGE 0, 254, gItemBeingHeld, .executor_41_ann_interact_watch
    PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .setup_msgbox_default
    BRANCH_U8_VAR_WITHIN_RANGE 6, 6, gHour, .cs25_interact_6am
    BRANCH_U8_VAR_WITHIN_RANGE 7, 14, gHour, .cs25_interact_day
    BRANCH_U8_VAR_WITHIN_RANGE 15, 23, gHour, .cs25_interact_evening_finale
    BRANCH_U8_VAR_WITHIN_RANGE 0, 5, gHour, .cs25_interact_night_finale
    DEACTIVATE_SELF

.cs25_interact_6am:
    EXECUTE_SUBROUTINE .setup_msgbox_default
    BRANCH_U8_VAR_WITHIN_RANGE 1, 255, gMinutes, .cs25_interact_day
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 379
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    BRANCH_ON_SPECIAL_BIT 3, var0, .cs25_interact_check_var3
    SET_SPECIAL_BIT 3, var0
    SET_OTHER_EXECUTOR_PTR 3, .executor_3_doug_approach

.cs25_interact_check_var3:
    TOGGLE_PAUSE_ENTITIES
    SPAWN_EXECUTOR 41, .executor_41_ann_interact_watch
    EXECUTE_SUBROUTINE .wait_loop

.cs25_interact_day:
    EXECUTE_SUBROUTINE .setup_msgbox_center_avatar
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 166
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    EXECUTE_SUBROUTINE .setup_msgbox_default
    TOGGLE_PAUSE_ENTITIES
    SPAWN_EXECUTOR 41, .executor_41_ann_interact_watch
    EXECUTE_SUBROUTINE .wait_loop

.cs25_interact_evening_finale:
