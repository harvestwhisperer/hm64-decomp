    BRANCH_U8_VAR_WITHIN_RANGE 34, 34, interactedWithLevelInteractionIndex, .karen_interact_trigger_1
    BRANCH_U8_VAR_WITHIN_RANGE 35, 35, interactedWithLevelInteractionIndex, .karen_interact_trigger_2
