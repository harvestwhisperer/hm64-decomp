    WAIT_RGBA_FINISHED
    SET_OTHER_EXECUTOR_PTR 4, .executor_4_baby_anim_13
    SET_OTHER_EXECUTOR_PTR 5, .executor_5_player_exit_naming
    SET_COORDINATES -152, 0, -32
    SET_ASSET_ROTATION 4
    BRANCH_ON_DIALOGUE 0, 0, .cs16_midwife_path
    BRANCH_ON_DIALOGUE 0, 1, .cs16_potion_dealer_path
    BRANCH_ON_DIALOGUE 0, 2, .cs16_lillia_path

