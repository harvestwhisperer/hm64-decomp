    EXECUTE_SUBROUTINE .cs29_ann_reinteract_wait

; ====================================================
; Cutscene 30 - Ann baby-name confirmation
; Parallel of .cs_9. Dialogue 32 picks midwife / potion
; dealer / Gray. Midwife uses text 408 - 211; potion
; dealer uses text 408 - 213; Gray uses text 409, 408,
; 410.
; ====================================================
.cs_30:
    SET_SPECIAL_BIT 31, gCutsceneCompletionFlags
    UPDATE_U8_VALUE -5, 255, gHappiness
    UPDATE_U8_VALUE 8, 255, npcAffection[BABY]
    SET_SPECIAL_BIT 15, gCutsceneCompletionFlags
    SPAWN_EXECUTOR 1, .cs30_ann_naming_setup
    SPAWN_EXECUTOR 4, .executor_4_baby_e25_cradle
    SPAWN_EXECUTOR 5, .executor_5_player_naming_pos
    DEACTIVATE_SELF

