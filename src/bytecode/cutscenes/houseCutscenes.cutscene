    WAIT_MESSAGE_BOX_CLOSED 0
    SET_ASSET_ROTATION 0
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 410
    EXECUTE_SUBROUTINE .sub_naming_exit

; ====================================================
; Cutscene 31 - Karen brings soup and medicine (cold)
; Karen visits the bedridden player. NPC fallback uses
; text 445 / 447; if married to Karen (gWife==4) the
; wife variants text 9 and text 10 are spoken.
; Parallel of .cs_3.
; ====================================================
.cs_31:
    SET_SPECIAL_BIT 31, gCutsceneCompletionFlags
    UPDATE_U8_VALUE 8, 255, gHappiness
    SET_SPECIAL_BIT 15, gCutsceneCompletionFlags
    SPAWN_EXECUTOR 1, .cs31_karen_main
    DEACTIVATE_SELF

.setup_wife_karen_e22:
    SETUP_ENTITY 22, ENTITY_ASSET_KAREN, 1
    SET_ENTITY_ANIMATIONS 22, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    RETURN_FROM_SUBROUTINE

.cs31_karen_text9:
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 9
    EXECUTE_SUBROUTINE .cs31_karen_serve_food

.cs31_karen_text10:
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 10
    EXECUTE_SUBROUTINE .sub_wife_leave_fade_exit

.cs31_karen_main:
    SPAWN_EXECUTOR 4, .executor_4_player_anim_455_pos
    SPAWN_EXECUTOR 16, .executor_16_cs0_map_setup
    SET_WAIT_FRAMES 1
    EXECUTE_SUBROUTINE .setup_wife_karen_e22
    SET_COORDINATES -116, 0, -136
    SET_ASSET_ROTATION 2
    UPDATE_GLOBAL_RGBA 255, 255, 255, 255, 8
    WAIT_RGBA_FINISHED
    SET_WAIT_FRAMES 15
    BRANCH_ON_SPECIAL_BIT MARRIED, lifeEventBits[0], .cs31_karen_if_wife4
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 445

