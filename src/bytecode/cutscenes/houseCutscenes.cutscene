    SPAWN_EXECUTOR 2, .executor_2_midwife_wander
    SPAWN_EXECUTOR 3, .executor_3_sasha_day
    SPAWN_EXECUTOR 41, .executor_41_karen_interact_watch
    DEACTIVATE_SELF

; ====================================================
; Cutscene 33 - Karen post-birth bedroom scene
; Parallel of .cs_5. Shows text 315 (Karen saying
; there are three of us now, work hard daddy, then
; saying goodnight).
