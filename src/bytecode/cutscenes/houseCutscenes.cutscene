; ====================================================
; Cutscene 17 - Elli brings soup and medicine (cold)
; Elli visits the bedridden player. NPC fallback uses
; text 308 / 310; if married to Elli (gWife==2) the
; wife variants text 5 and text 6 are spoken.
; Parallel of .cs_3.
; ====================================================
.cs_17:
    SET_SPECIAL_BIT 31, gCutsceneCompletionFlags
    UPDATE_U8_VALUE 8, 255, gHappiness
    SET_SPECIAL_BIT 15, gCutsceneCompletionFlags
    SPAWN_EXECUTOR 1, .cs17_elli_main
    DEACTIVATE_SELF

.setup_wife_elli_e22:
    SETUP_ENTITY 22, ENTITY_ASSET_ELLI, 1
    SET_ENTITY_ANIMATIONS 22, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_ENTITY_NON_COLLIDABLE
    RETURN_FROM_SUBROUTINE

.cs17_elli_text5:
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 5
    EXECUTE_SUBROUTINE .cs17_elli_serve_food

.cs17_elli_text6:
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 6
    EXECUTE_SUBROUTINE .sub_wife_leave_fade_exit

.cs17_elli_main:
    SPAWN_EXECUTOR 4, .executor_4_player_anim_455_pos
    SPAWN_EXECUTOR 16, .executor_16_cs0_map_setup
    SET_WAIT_FRAMES 1
    EXECUTE_SUBROUTINE .setup_wife_elli_e22
    SET_COORDINATES -116, 0, -136
    SET_ASSET_ROTATION 2
    UPDATE_GLOBAL_RGBA 255, 255, 255, 255, 8
    WAIT_RGBA_FINISHED
    SET_WAIT_FRAMES 15
    BRANCH_ON_SPECIAL_BIT MARRIED, lifeEventBits[0], .cs17_elli_if_wife2
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 308

.cs17_elli_serve_food:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_ENTITY_DIRECTIONAL_ANIMATION 16
    WAIT_ENTITY_ANIMATION
    SPAWN_EXECUTOR 10, .executor_10_item_anim_110
    SET_WAIT_FRAMES 30
    DEACTIVATE_EXECUTOR 10
    BRANCH_ON_SPECIAL_BIT MARRIED, lifeEventBits[0], .cs17_elli_close_if_wife2
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 310
    EXECUTE_SUBROUTINE .sub_wife_leave_fade_exit

.cs17_elli_if_wife2:
    BRANCH_U8_VAR_WITHIN_RANGE 2, 2, gWife, .cs17_elli_text5
    RETURN_FROM_SUBROUTINE

.cs17_elli_close_if_wife2:
    BRANCH_U8_VAR_WITHIN_RANGE 2, 2, gWife, .cs17_elli_text6
    RETURN_FROM_SUBROUTINE

; ====================================================
; Cutscene 18 - Elli giving birth
; Parallel of .cs_4 with the Pastor (e24) supporting
; instead of Mayor Wife. Interaction dispatch uses
; texts 328 - 333 for the evening / night finales.
; ====================================================
.cs_18:
    SET_SPECIAL_BIT 10, gCutsceneCompletionFlags
    BRANCH_U8_VAR_WITHIN_RANGE 0, 5, gHour, .cs18_birth_night
    BRANCH_U8_VAR_WITHIN_RANGE 15, 23, gHour, .cs18_birth_evening
    BRANCH_U8_VAR_WITHIN_RANGE 6, 6, gHour, .cs18_birth_6am
    SPAWN_EXECUTOR 1, .cs18_elli_exec_day
    SPAWN_EXECUTOR 2, .executor_2_midwife_wander
    SPAWN_EXECUTOR 3, .executor_3_pastor_day
    SPAWN_EXECUTOR 41, .executor_41_elli_interact_watch
    DEACTIVATE_SELF

; ====================================================
; Cutscene 19 - Elli post-birth bedroom scene
; Parallel of .cs_5. Shows text 313 (Elli thanking the
; player for the name, then saying goodnight).
; ====================================================
.cs_19:
    SET_SPECIAL_BIT 31, gCutsceneCompletionFlags
    SPAWN_EXECUTOR 1, .cs19_elli_sleep_e22
    SPAWN_EXECUTOR 4, .executor_4_baby_e25_anim_13
    EXECUTE_SUBROUTINE .setup_player_entity
    SET_COORDINATES -128, 0, -144
    SET_ASSET_ROTATION 2
    UPDATE_GLOBAL_RGBA 255, 255, 255, 255, 8
    WAIT_RGBA_FINISHED
    SET_WAIT_FRAMES 10
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 313
    EXECUTE_SUBROUTINE .sub_fade_out_exit

.cs19_elli_sleep_e22:
    EXECUTE_SUBROUTINE .setup_wife_elli_e22
    SET_ENTITY_PHYSICS_FLAGS 0
    SET_COORDINATES -194, 32, -172
    SET_ENTITY_ANIMATION 24
    SPAWN_EXECUTOR 41, .executor_41_elli_interact_watch
    EXECUTE_SUBROUTINE .wait_loop

.cs18_birth_6am:
