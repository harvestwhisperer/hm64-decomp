    WAIT_MESSAGE_BOX_CLOSED 0
    SET_ASSET_ROTATION 0
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 213
    EXECUTE_SUBROUTINE .sub_naming_exit

