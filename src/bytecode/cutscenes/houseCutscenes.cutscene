    FLIP_ENTITY_DIRECTION 0
    PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .setup_msgbox_default
    BRANCH_U8_VAR_WITHIN_RANGE 1, 14, gHour, .cs25_doug_day
    BRANCH_U8_VAR_WITHIN_RANGE 15, 23, gHour, .cs25_doug_evening
    BRANCH_U8_VAR_WITHIN_RANGE 0, 0, gHour, .cs25_doug_evening
    DEACTIVATE_SELF

.cs25_doug_day:
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 380
    WAIT_MESSAGE_BOX_CLOSED 0
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 381

