    SET_ENTITY_DIRECTIONAL_ANIMATION 122
    EXECUTE_SUBROUTINE .cs13_popuri_wait

.cs13_popuri_main:
    EXECUTE_SUBROUTINE .setup_wife_popuri_e22
    BRANCH_ON_SPECIAL_BIT HAVE_BABY, lifeEventBits[0], .cs13_popuri_with_baby_pose
