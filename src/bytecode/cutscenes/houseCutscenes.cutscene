    SET_ENTITY_ANIMATION 11
    EXECUTE_SUBROUTINE .wait_loop

.baby_cradle_anim_47:
    SET_ENTITY_ANIMATION 47
    EXECUTE_SUBROUTINE .wait_loop

.executor_4_baby_anim_13:
