    RESET_MESSAGE_BOX_AVATAR 0
    SET_ENTITY_DIRECTIONAL_ANIMATION 16
    WAIT_ENTITY_ANIMATION
    SPAWN_EXECUTOR 10, .executor_10_item_anim_110
    SET_WAIT_FRAMES 30
    DEACTIVATE_EXECUTOR 10
    BRANCH_ON_SPECIAL_BIT MARRIED, lifeEventBits[0], .cs31_karen_close_if_wife4
    INIT_MESSAGE_BOX_TYPE1 0, HOUSE_CUTSCENES_TEXT_INDEX, 447
    EXECUTE_SUBROUTINE .sub_wife_leave_fade_exit

.cs31_karen_if_wife4:
    BRANCH_U8_VAR_WITHIN_RANGE 4, 4, gWife, .cs31_karen_text9
