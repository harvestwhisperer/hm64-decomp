; ------------------------------------------------------------
; Dog setups (slots 1-6)
; ------------------------------------------------------------
; Each dog DMAs its sprite, picks a palette (coloring), positions
; itself at the starting line, and fades in. Dog 1 has a special
; path (.dog1_setup_player_owned) when bit 5 is set (player dog in
; race): it skips the fade-in and uses palette 0 instead of 6. Dog
; 2 similarly has .dog2_setup_alt_palette for bit 6.

.dog1_setup:
    DMA_SPRITE 136, 1, _dogTextureSegmentRomStart, _dogTextureSegmentRomEnd, _dogAssetsIndexSegmentRomStart, _dogAssetsIndexSegmentRomEnd, _dogSpritesheetIndexSegmentRomStart, _dogSpritesheetIndexSegmentRomEnd, 0x8027C400, 0x8027CD08, 0x8027D610, 0x8027D810, 0x8027F400, 0x8027F600
    SET_ANIM_DATA_PTR_WITH_FLAG .anim_14495C
    SET_SPRITE_PALETTE 6
    BRANCH_ON_SPECIAL_BIT 5, D_801C3F78, .dog1_setup_player_owned
    SET_COORDINATES 96, 24, 0
    SET_RGBA 0, 0, 0, 0
    SET_WAIT_FRAMES 1
    UPDATE_RGBA 255, 255, 255, 255, 8
    WAIT_RGBA_FINISHED
    SET_U16_VALUE 128, dog1Progress
    EXECUTE_SUBROUTINE .wait_loop

.dog1_setup_player_owned:
    SET_SPRITE_PALETTE 0
    RETURN_FROM_SUBROUTINE

.dog2_setup:
    DMA_SPRITE 137, 1, _dogTextureSegmentRomStart, _dogTextureSegmentRomEnd, _dogAssetsIndexSegmentRomStart, _dogAssetsIndexSegmentRomEnd, _dogSpritesheetIndexSegmentRomStart, _dogSpritesheetIndexSegmentRomEnd, 0x8027FC00, 0x80280508, 0x80280E10, 0x80281010, 0x80282C00, 0x80282E00
    SET_ANIM_DATA_PTR_WITH_FLAG .anim_14495C
    SET_SPRITE_PALETTE 4
    BRANCH_ON_SPECIAL_BIT 6, D_801C3F78, .dog2_setup_alt_palette
    SET_COORDINATES 96, 0, 5
    SET_RGBA 0, 0, 0, 0
    SET_WAIT_FRAMES 1
    UPDATE_RGBA 255, 255, 255, 255, 8
    WAIT_RGBA_FINISHED
    SET_U16_VALUE 128, dog2Progress
    EXECUTE_SUBROUTINE .wait_loop

.dog2_setup_alt_palette:
    SET_SPRITE_PALETTE 2
    RETURN_FROM_SUBROUTINE

.dog3_setup:
    DMA_SPRITE 138, 1, _dogTextureSegmentRomStart, _dogTextureSegmentRomEnd, _dogAssetsIndexSegmentRomStart, _dogAssetsIndexSegmentRomEnd, _dogSpritesheetIndexSegmentRomStart, _dogSpritesheetIndexSegmentRomEnd, 0x80283400, 0x80283D08, 0x80284610, 0x80284810, 0x80286400, 0x80286600
    SET_ANIM_DATA_PTR_WITH_FLAG .anim_14495C
    SET_SPRITE_PALETTE 2
    SET_COORDINATES 96, -24, 10
    SET_RGBA 0, 0, 0, 0
    SET_WAIT_FRAMES 1
    UPDATE_RGBA 255, 255, 255, 255, 8
    WAIT_RGBA_FINISHED
    SET_U16_VALUE 128, dog3Progress
    EXECUTE_SUBROUTINE .wait_loop

.dog4_setup:
    DMA_SPRITE 139, 1, _dogTextureSegmentRomStart, _dogTextureSegmentRomEnd, _dogAssetsIndexSegmentRomStart, _dogAssetsIndexSegmentRomEnd, _dogSpritesheetIndexSegmentRomStart, _dogSpritesheetIndexSegmentRomEnd, 0x80286C00, 0x80287508, 0x80287E10, 0x80288010, 0x80289C00, 0x80289E00
    SET_ANIM_DATA_PTR_WITH_FLAG .anim_14495C
    SET_SPRITE_PALETTE 5
    SET_COORDINATES 96, -48, 15
    SET_RGBA 0, 0, 0, 0
    SET_WAIT_FRAMES 1
    UPDATE_RGBA 255, 255, 255, 255, 8
