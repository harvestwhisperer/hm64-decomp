; ============================================================
; CUTSCENE 1303 - Post-Race / Exit
; ============================================================
; The closing scene after all 3 races are run. Mayor greets the
; player; dialogue depends on whether the player dog finished 1st
; (bit 1 of D_801C3F78). If so, the winner celebration subsystem
; below is triggered from inside .cs_race (not here).
;   mayor default ................. text 43
;   post-race + 1st place ......... text 44 (bit 1)

.cs_post_race:
    SPAWN_EXECUTOR 1, .post_race_mayor_setup
    EXECUTE_SUBROUTINE .setup_player
    SET_COORDINATES -256, 0, 96
    SET_ASSET_ROTATION EAST
    SET_WAIT_FRAMES 1
    UPDATE_GLOBAL_RGBA 254, 254, 254, 254, 0
    WAIT_RGBA_FINISHED
    INIT_MESSAGE_BOX_TYPE1 0, DOG_RACE_TEXT_INDEX, 43
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_ENTITY_MAP_SPACE_INDEPENDENT FALSE
    DEACTIVATE_SELF

.post_race_mayor_setup:
    SETUP_ENTITY 1, ENTITY_ASSET_MAYOR, 1
    SET_ENTITY_ANIMATIONS 1, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_COORDINATES -224, 0, 64
    SET_ASSET_ROTATION WEST

.post_race_mayor_wait:
    SET_CALLBACK_ROUTINE 0, 32768, .post_race_mayor_on_interact
    EXECUTE_SUBROUTINE .wait_loop

.post_race_mayor_on_interact:
    PAUSE_ENTITIES
    FLIP_ENTITY_DIRECTION 0
    EXECUTE_SUBROUTINE .setup_message_box
    BRANCH_ON_SPECIAL_BIT 1, D_801C3F78, .post_race_mayor_talk_rest
    INIT_MESSAGE_BOX_TYPE1 0, DOG_RACE_TEXT_INDEX, 43

.post_race_mayor_talk_done:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .post_race_mayor_wait

.post_race_mayor_talk_rest:
    INIT_MESSAGE_BOX_TYPE1 0, DOG_RACE_TEXT_INDEX, 44
    EXECUTE_SUBROUTINE .post_race_mayor_talk_done

; ============================================================
; Winner Celebration (spawned from .race_player_first)
; ============================================================
; Foreground sprite sequence when the player dog finishes 1st:
;   slot 1 (.winner_player_setup)   player walks in, idles
;   slot 2 (.winner_dog_setup)      dog enters
;   slot 3 (.winner_mayor_setup)    Mayor walks up, texts 40
;   slot 4 (.winner_doug_setup)     Doug enters, texts 39
;   slot 5 (.winner_photographer)   Photographer walks up
;                                   texts 41 (say cheese) + 42
;   slot 6 (.winner_medal_setup)    medal item appears
;   slot 33 (.winner_camera_flash)  funeral-intro flash texture,
;                                   scaled 20x, fades out
; Finally sets lifeEventBits[2] bit 21 and dailyEventBits[1] bit 25
; (1st-place flags, consumed elsewhere), then tears down executors.

.winner_player_setup:
    DMA_SPRITE 135, 1, _playerTextureSegmentRomStart, _playerTextureSegmentRomEnd, _playerAssetsIndexSegmentRomStart, _playerAssetsIndexSegmentRomEnd, _playerSpritesheetIndexSegmentRomStart, _playerSpritesheetIndexSegmentRomEnd, 0x80240B00, 0x80243B00, 0x80246B00, 0x8024AB00, 0x80252300, 0x80252B00
    SET_ANIM_DATA_PTR_WITH_FLAG .anim_144E5C
    SET_COORDINATES -80, -8, 30
    SET_RGBA 0, 0, 0, 0
    SET_WAIT_FRAMES 1
    UPDATE_RGBA 255, 255, 255, 255, 8
    SET_FRAME_DELTA 2, 0, 0, 32
    WAIT_RGBA_FINISHED
    SET_ANIM_DATA_PTR .anim_144E50
    SET_WAIT_FRAMES 10
    SET_ANIM_DATA_PTR .anim_144E68
    SPAWN_EXECUTOR 3, .winner_mayor_setup
    EXECUTE_SUBROUTINE .wait_loop

.winner_player_after_mayor:
    SET_ANIM_DATA_PTR .anim_144E7C
    SET_WAIT_FRAMES 30
    EXECUTE_SUBROUTINE .setup_message_box
    INIT_MESSAGE_BOX_TYPE1 0, DOG_RACE_TEXT_INDEX, 40
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SPAWN_EXECUTOR 4, .winner_doug_setup
    SET_WAIT_FRAMES 30
    SPAWN_EXECUTOR 5, .winner_photographer_setup
    EXECUTE_SUBROUTINE .wait_loop

.winner_player_after_doug:
    SET_ANIM_DATA_PTR .anim_144E44
    EXECUTE_SUBROUTINE .wait_loop

.winner_player_hold_medal:
    SET_ANIM_DATA_PTR .anim_144E98
    SET_OTHER_EXECUTOR_PTR 2, .winner_dog_after_medal
    SET_WAIT_FRAMES 10
    DEACTIVATE_EXECUTOR 2
    SPAWN_EXECUTOR 6, .winner_medal_setup
    SET_WAIT_FRAMES 30
    SET_OTHER_EXECUTOR_PTR 5, .winner_photographer_take_photo
    EXECUTE_SUBROUTINE .wait_loop

.winner_dog_setup:
    DMA_SPRITE 136, 1, _dogTextureSegmentRomStart, _dogTextureSegmentRomEnd, _dogAssetsIndexSegmentRomStart, _dogAssetsIndexSegmentRomEnd, _dogSpritesheetIndexSegmentRomStart, _dogSpritesheetIndexSegmentRomEnd, 0x8027C400, 0x8027CD08, 0x8027D610, 0x8027D810, 0x8027F400, 0x8027F600
    SET_ANIM_DATA_PTR_WITH_FLAG .anim_144EBC
    SET_COORDINATES 24, -8, 40
    SET_RGBA 0, 0, 0, 0
    SET_WAIT_FRAMES 1
    UPDATE_RGBA 255, 255, 255, 255, 8
    WAIT_RGBA_FINISHED
    EXECUTE_SUBROUTINE .wait_loop

.winner_dog_after_medal:
    SET_ANIM_DATA_PTR .anim_144EC8
    EXECUTE_SUBROUTINE .wait_loop

.winner_medal_setup:
    DMA_SPRITE 147, 1, _holdableItemsTextureSegmentRomStart, _holdableItemsTextureSegmentRomEnd, _holdableItemsAssetsIndexSegmentRomStart, _holdableItemsAssetsIndexSegmentRomEnd, _holdableItemsSpritesheetIndexSegmentRomStart, _holdableItemsSpritesheetIndexSegmentRomEnd, 0x802C6250, 0x802C6650, 0x802C8650, 0x802CAE50, 0x802CE350, 0x802CE550
    SET_COORDINATES 6, 0, 50
    SET_ANIM_DATA_PTR_WITH_FLAG .anim_144ED4
    SET_RGBA 255, 255, 255, 255
    EXECUTE_SUBROUTINE .wait_loop

.winner_mayor_setup:
    DMA_SPRITE 145, 1, _mayorTextureSegmentRomStart, _mayorTextureSegmentRomEnd, _mayorAssetsIndexSegmentRomStart, _mayorAssetsIndexSegmentRomEnd, _mayorSpritesheetIndexSegmentRomStart, _mayorSpritesheetIndexSegmentRomEnd, 0x80272500, 0x80273180, 0x80273E00, 0x80274880, 0x80275680, 0x80275780
    SET_ANIM_DATA_PTR_WITH_FLAG .anim_144F08
    SET_RGBA 255, 255, 255, 255
    SET_COORDINATES -208, -160, 20
    SET_FRAME_DELTA 1, 1, 0, 168
    SET_ANIM_DATA_PTR .anim_144EFC
    SET_OTHER_EXECUTOR_PTR 1, .winner_player_after_mayor
    EXECUTE_SUBROUTINE .wait_loop

.winner_mayor_final_anim:
    SET_ANIM_DATA_PTR .anim_144EF0
    EXECUTE_SUBROUTINE .wait_loop

.winner_doug_setup:
    DMA_SPRITE 144, 1, _dougTextureSegmentRomStart, _dougTextureSegmentRomEnd, _dougAssetsIndexSegmentRomStart, _dougAssetsIndexSegmentRomEnd, _dougSpritesheetIndexSegmentRomStart, _dougSpritesheetIndexSegmentRomEnd, 0x8026F000, 0x8026FC80, 0x80270900, 0x80271380, 0x80272180, 0x80272280
    SET_ANIM_DATA_PTR_WITH_FLAG .anim_144F2C
    SET_RGBA 255, 255, 255, 255
    SET_COORDINATES 184, -160, 20
    SET_FRAME_DELTA -1, 1, 0, 128
    SET_ANIM_DATA_PTR .anim_144F14
    SET_OTHER_EXECUTOR_PTR 1, .winner_player_after_doug
    INIT_MESSAGE_BOX_TYPE1 0, DOG_RACE_TEXT_INDEX, 39
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_OTHER_EXECUTOR_PTR 1, .winner_player_hold_medal
    EXECUTE_SUBROUTINE .wait_loop

.winner_doug_final_anim:
    SET_ANIM_DATA_PTR .anim_144F20
    EXECUTE_SUBROUTINE .wait_loop

.winner_photographer_setup:
    DMA_SPRITE 146, 1, _photographerTextureSegmentRomStart, _photographerTextureSegmentRomEnd, _photographerAssetsIndexSegmentRomStart, _photographerAssetsIndexSegmentRomEnd, _photographerSpritesheetIndexSegmentRomStart, _photographerSpritesheetIndexSegmentRomEnd, 0x80275A00, 0x80276680, 0x80277300, 0x80277D80, 0x80278B80, 0x80278C80
    SET_ANIM_DATA_PTR_WITH_FLAG .anim_144F44
    SET_COORDINATES -188, -160, 50
    SET_RGBA 255, 255, 255, 255
    SET_FRAME_DELTA 1, 1, 0, 112
    SET_ANIM_DATA_PTR .anim_144F38
    EXECUTE_SUBROUTINE .wait_loop

.winner_photographer_take_photo:
    SET_OTHER_EXECUTOR_PTR 3, .winner_mayor_final_anim
    SET_OTHER_EXECUTOR_PTR 4, .winner_doug_final_anim
    SET_ANIM_DATA_PTR .anim_144F50
    INIT_MESSAGE_BOX_TYPE1 0, DOG_RACE_TEXT_INDEX, 41
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_WAIT_FRAMES 20
    SET_SFX 94, 128
    SPAWN_EXECUTOR 33, .winner_camera_flash_setup
    SET_WAIT_FRAMES 40
    INIT_MESSAGE_BOX_TYPE1 0, DOG_RACE_TEXT_INDEX, 42
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_WAIT_FRAMES 20
    SET_SPECIAL_BIT 25, dailyEventBits[1]
    ; set WON_DOG_RACE
    SET_SPECIAL_BIT 21, lifeEventBits[2]
    SET_OTHER_EXECUTOR_PTR 1, .race_end_fade_black_exit
    SET_OTHER_EXECUTOR_PTR 3, .race_end_fade_black_exit
    SET_OTHER_EXECUTOR_PTR 4, .race_end_fade_black_exit
    SET_OTHER_EXECUTOR_PTR 6, .race_end_fade_black_exit
    SET_OTHER_EXECUTOR_PTR 30, .race_end_fade_black_exit
    SET_OTHER_EXECUTOR_PTR 31, .race_end_fade_black_exit
    SET_OTHER_EXECUTOR_PTR 36, .race_end_fade_black_exit
    SET_OTHER_EXECUTOR_PTR 37, .race_end_fade_black_exit
    SET_OTHER_EXECUTOR_PTR 39, .race_end_fade_black_exit
    SET_OTHER_EXECUTOR_PTR 40, .race_end_fade_black_exit
    EXECUTE_SUBROUTINE .race_final_cleanup

.winner_camera_flash_setup:
    DMA_SPRITE 127, 0, _funeralIntroTextureSegmentRomStart, _funeralIntroTextureSegmentRomEnd, _funeralIntroAssetsIndexSegmentRomStart, _funeralIntroAssetsIndexSegmentRomEnd, 0, 0, 0x80284C00, 0, 0x80284610, 0x80284810, 0x80286400, 0x80286600
    SET_ANIM_DATA_PTR_WITH_FLAG .anim_144E2C
    SET_COORDINATES 0, 0, 254
    SET_SPRITE_SCALE 20, 20, 0
    SET_RGBA 255, 255, 255, 255
    SET_WAIT_FRAMES 2
    SET_SPRITE_RENDERING_LAYER 2
    UPDATE_RGBA 255, 255, 255, 0, 64
    WAIT_RGBA_FINISHED
    DEACTIVATE_SELF

