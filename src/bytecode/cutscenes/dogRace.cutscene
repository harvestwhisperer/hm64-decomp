; ============================================================
; CUTSCENE 1302 - The Race
; ============================================================
; Orchestrates one race:
;   1. Clear gRaceFinishOrder, spawn map, player stub, 6 dogs, and
;      9 extra sprite slots (30, 31, 35-41). Only the trees on slots
;      30/31 actually render in-game; the other 7 slots DMA sprites
;      that are never drawn (see the sprite-setups banner below).
;   2. Show the Get ready text 50, start SFX 85, hand the dog and
;      extra-slot executors over to their race-tick handlers for a
;      240-frame race.
;   3. Spawn .race_track_finishers (slot 33) to watch dog counters;
;      spawn .race_sfx_loop (slot 26) to play SFX 84 repeatedly.
;   4. After 40 more frames, stop dogs, show the finish-line message
;      (text 51), spawn .race_resolve_finish_order (slot 24).
;   5. Wait for resolver to finish, show results (text 52), fan out
;      to .race_player_first / .race_player_second / .race_end_cleanup.

.cs_race:
    CLEAR_SPECIAL_BIT 0, D_801C3F78
    CLEAR_SPECIAL_BIT 3, D_801C3F78
    SET_U8_VALUE 0, gRaceFinishOrder
    SET_U8_VALUE 0, gRaceFinishOrder[1]
    SET_U8_VALUE 0, gRaceFinishOrder[2]
    SET_U8_VALUE 0, gRaceFinishOrder[3]
    SET_U8_VALUE 0, gRaceFinishOrder[4]
    SET_U8_VALUE 0, gRaceFinishOrder[5]
    SPAWN_EXECUTOR 32, .race_setup_map_stub
    SPAWN_EXECUTOR 16, .race_setup_player_stub
    SET_WAIT_FRAMES 2
    SPAWN_EXECUTOR 1, .dog1_setup
    SPAWN_EXECUTOR 2, .dog2_setup
    SPAWN_EXECUTOR 3, .dog3_setup
    SPAWN_EXECUTOR 4, .dog4_setup
    SPAWN_EXECUTOR 5, .dog5_setup
    SPAWN_EXECUTOR 6, .dog6_setup
    SPAWN_EXECUTOR 30, .executor_30_14477C
    SPAWN_EXECUTOR 31, .executor_31_1445D0
    SPAWN_EXECUTOR 35, .executor_35_144850
    SPAWN_EXECUTOR 36, .executor_36_1446A4
    SPAWN_EXECUTOR 37, .executor_37_144710
    SPAWN_EXECUTOR 38, .executor_38_1447E4
    SPAWN_EXECUTOR 39, .executor_39_1444F8
    SPAWN_EXECUTOR 40, .executor_40_144564
    SPAWN_EXECUTOR 41, .executor_41_144638
    SET_WAIT_FRAMES 32
    SET_MESSAGE_BOX_ASSETS 0, 1, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 0, -64, 352
    INIT_MESSAGE_BOX_TYPE2 0, DOG_RACE_TEXT_INDEX, 50
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_WAIT_FRAMES 20
    SET_SFX 85, 128
    SET_WAIT_FRAMES 10
    SET_OTHER_EXECUTOR_PTR 1, .dog1_race_tick
    SET_OTHER_EXECUTOR_PTR 2, .dog2_race_tick
    SET_OTHER_EXECUTOR_PTR 3, .dog3_race_tick
    SET_OTHER_EXECUTOR_PTR 4, .dog4_race_tick
    SET_OTHER_EXECUTOR_PTR 5, .dog5_race_tick
    SET_OTHER_EXECUTOR_PTR 6, .dog6_race_tick
    SET_OTHER_EXECUTOR_PTR 30, .executor_30_140C58
    SET_OTHER_EXECUTOR_PTR 31, .executor_31_140CA8
    SET_OTHER_EXECUTOR_PTR 35, .executor_35_140C34
    SET_OTHER_EXECUTOR_PTR 36, .executor_36_140C40
    SET_OTHER_EXECUTOR_PTR 37, .executor_37_140C4C
    SET_OTHER_EXECUTOR_PTR 38, .executor_38_140C64
    SET_OTHER_EXECUTOR_PTR 39, .executor_39_140C70
    SET_OTHER_EXECUTOR_PTR 40, .executor_40_140C8C
    SET_OTHER_EXECUTOR_PTR 41, .executor_41_140CC4
    SET_WAIT_FRAMES 240
    SPAWN_EXECUTOR 26, .race_sfx_loop
    SET_WAIT_FRAMES 60
    SPAWN_EXECUTOR 32, .executor_32_1448BC
    SPAWN_EXECUTOR 33, .race_track_finishers
    SET_WAIT_FRAMES 40
    SET_OTHER_EXECUTOR_PTR 1, .dog_slowdown_after_finish
    SET_OTHER_EXECUTOR_PTR 2, .dog_slowdown_after_finish
    SET_OTHER_EXECUTOR_PTR 3, .dog_slowdown_after_finish
    SET_OTHER_EXECUTOR_PTR 4, .dog_slowdown_after_finish
    SET_OTHER_EXECUTOR_PTR 5, .dog_slowdown_after_finish
    SET_OTHER_EXECUTOR_PTR 6, .dog_slowdown_after_finish
    SET_OTHER_EXECUTOR_PTR 30, .wait_loop
    SET_OTHER_EXECUTOR_PTR 31, .wait_loop
    SET_OTHER_EXECUTOR_PTR 36, .wait_loop
    SET_OTHER_EXECUTOR_PTR 37, .wait_loop
    SET_OTHER_EXECUTOR_PTR 38, .wait_loop
    SET_OTHER_EXECUTOR_PTR 39, .wait_loop
    SET_OTHER_EXECUTOR_PTR 40, .wait_loop
    SET_OTHER_EXECUTOR_PTR 41, .wait_loop
    INIT_MESSAGE_BOX_TYPE2 0, DOG_RACE_TEXT_INDEX, 51
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SPAWN_EXECUTOR 24, .race_resolve_finish_order
    SET_WAIT_FRAMES 60
    SET_SPECIAL_BIT 2, gCutsceneCompletionFlags

.race_wait_resolver:
    SET_WAIT_FRAMES 1
    BRANCH_ON_SPECIAL_BIT 2, gCutsceneCompletionFlags, .race_wait_resolver
    SET_WAIT_FRAMES 1
    INIT_MESSAGE_BOX_TYPE1 0, DOG_RACE_TEXT_INDEX, 52
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    DEACTIVATE_EXECUTOR 26
    SET_WAIT_FRAMES 20
    BRANCH_ON_SPECIAL_BIT 5, D_801C3F78, .race_player_entered_check_placement
    EXECUTE_SUBROUTINE .race_check_second_place

.race_end_cleanup:
    SET_OTHER_EXECUTOR_PTR 32, .race_end_fade_black_exit
    SET_OTHER_EXECUTOR_PTR 30, .race_end_fade_black_exit
    SET_OTHER_EXECUTOR_PTR 31, .race_end_fade_black_exit
    SET_OTHER_EXECUTOR_PTR 36, .race_end_fade_black_exit
    SET_OTHER_EXECUTOR_PTR 37, .race_end_fade_black_exit
    SET_OTHER_EXECUTOR_PTR 38, .race_end_fade_black_exit
    SET_OTHER_EXECUTOR_PTR 39, .race_end_fade_black_exit
    SET_OTHER_EXECUTOR_PTR 40, .race_end_fade_black_exit
    SET_OTHER_EXECUTOR_PTR 41, .race_final_cleanup
    DEACTIVATE_SELF

.race_sfx_loop:
    SET_SFX 84, 128
    SET_WAIT_FRAMES 35
    EXECUTE_SUBROUTINE .race_sfx_loop

.race_player_entered_check_placement:
    SET_SPECIAL_BIT 0, D_801C3F78
    BRANCH_U8_VAR_WITHIN_RANGE 1, 1, gRaceFinishOrder, .race_player_first
    EXECUTE_SUBROUTINE .race_check_second_place

.race_check_second_place:
    BRANCH_U8_VAR_WITHIN_RANGE 2, 2, gRaceFinishOrder, .race_player_second
    EXECUTE_SUBROUTINE .race_end_cleanup

.race_player_second:
    SET_SPECIAL_BIT 3, D_801C3F78
    EXECUTE_SUBROUTINE .race_end_cleanup

.race_player_first:
    SET_SPECIAL_BIT 1, D_801C3F78
    SET_OTHER_EXECUTOR_PTR 32, .race_end_fade_black_exit
    SET_OTHER_EXECUTOR_PTR 30, .race_end_fade_black
    SET_OTHER_EXECUTOR_PTR 31, .race_end_fade_black
    SET_OTHER_EXECUTOR_PTR 36, .race_end_fade_black
    SET_OTHER_EXECUTOR_PTR 37, .race_end_fade_black
    SET_OTHER_EXECUTOR_PTR 38, .race_end_fade_black_exit
    SET_OTHER_EXECUTOR_PTR 39, .race_end_fade_black
    SET_OTHER_EXECUTOR_PTR 40, .race_end_fade_black
    SET_OTHER_EXECUTOR_PTR 41, .race_end_fade_black_exit
    SET_WAIT_FRAMES 40
    SPAWN_EXECUTOR 1, .winner_player_setup
    SPAWN_EXECUTOR 2, .winner_dog_setup
    SET_WAIT_FRAMES 1
    SET_OTHER_EXECUTOR_PTR 30, .race_end_fade_white
    SET_OTHER_EXECUTOR_PTR 31, .race_end_fade_white
    SET_OTHER_EXECUTOR_PTR 36, .race_end_fade_white
    SET_OTHER_EXECUTOR_PTR 37, .race_end_fade_white
    SET_OTHER_EXECUTOR_PTR 39, .race_end_fade_white
    SET_OTHER_EXECUTOR_PTR 40, .race_end_fade_white
    DEACTIVATE_SELF

; ------------------------------------------------------------
; Race-end fade handlers
; ------------------------------------------------------------
; Installed onto race executor slots via SET_OTHER_EXECUTOR_PTR to
; fade sprites to white/black and tear down the scene.

.race_end_fade_white:
    UPDATE_RGBA 255, 255, 255, 255, 8
    WAIT_RGBA_FINISHED
    EXECUTE_SUBROUTINE .wait_loop

.race_end_fade_black:
    UPDATE_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    EXECUTE_SUBROUTINE .wait_loop

.race_end_fade_black_exit:
    UPDATE_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    DEACTIVATE_SELF

.race_final_cleanup:
    SET_AUDIO_SEQUENCE_VOLUME 0, 0, 4
    UPDATE_RGBA 0, 0, 0, 0, 8
    WAIT_RGBA_FINISHED
    STOP_SEQUENCE_WITH_FADE 0, 1
    IDLE_WHILE_SEQUENCE_PLAYING 0
    SET_U8_VALUE 1, gMinutes
    SET_SPECIAL_BIT 2, D_801C3F78
    SET_SPECIAL_BIT 1, gCutsceneCompletionFlags
    EXECUTE_SUBROUTINE .exit_cutscene

; ------------------------------------------------------------
; Race setup stubs and extra-slot scroll handlers
; ------------------------------------------------------------
; .race_setup_player_stub / .race_setup_map_stub run once at
; race start then deactivate. The .executor_NN_140CXX handlers
; below are SET_OTHER_EXECUTOR_PTR targets for the 9 extra sprite
; slots (30, 31, 35-41) during the race -- each handler loops its
; sprite across the screen with SET_FRAME_DELTA. Only the trees
; on slots 30/31 render in-game; the horse icons and green dots
; on the other slots DMA their sprites but never get drawn.

.race_setup_player_stub:
    EXECUTE_SUBROUTINE .setup_player
    DEACTIVATE_SELF

.race_setup_map_stub:
    SETUP_MAP_ASSET MAIN_MAP_INDEX
    SET_WAIT_FRAMES 1
    DEACTIVATE_SELF

.executor_35_140C34:
    SET_FRAME_DELTA 8, 0, 0, 60
    DEACTIVATE_SELF

.executor_36_140C40:
    SET_FRAME_DELTA 8, 0, 0, 60
    EXECUTE_SUBROUTINE .sub_140C78

.executor_37_140C4C:
    SET_FRAME_DELTA 8, 0, 0, 60
    EXECUTE_SUBROUTINE .sub_140C94

.executor_30_140C58:
    SET_FRAME_DELTA 8, 0, 0, 60
    EXECUTE_SUBROUTINE .sub_140CB0

.executor_38_140C64:
    SET_FRAME_DELTA 16, 0, 0, 30
    EXECUTE_SUBROUTINE .sub_140CCC

.executor_39_140C70:
    SET_FRAME_DELTA 8, 0, 0, 20

.sub_140C78:
