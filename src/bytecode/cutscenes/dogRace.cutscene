; ------------------------------------------------------------
; Trackside sprite setups (horse-race effect spritesheet)
; ------------------------------------------------------------
; All slots DMA from _horseRaceTextureSegment, which holds the
; horse-race effect sheet. Each setup picks one anim that maps
; to a texture index in assets/sprites/effects/horseRace/textures/:
;   0 = horse icon (focused)        3 = green dot
;   1 = horse icon (neutral)        4 = yellow dot  (unused here)
;   2 = horse icon (tired)          5 = red dot     (unused here)
;   6 = ground                      8, 10 = fence/railing
;   7 = background trees            9 = finish line (unused here)
; Note: these 10 executor slots are set up and DMA their
; sprites, but the horse icon and green-dot textures (0-3) do
; not render during the dog race in-game. They appear to be
; vestigial from the shared spritesheet -- horseRace uses the
; same slot layout and does render them. Slot layout here:
;   30/31 trees (anim 7), 36/39 anim-0, 37/40 anim-1,
;   38/41 anim-2, 35 centered green dot, 32 green dot at X=-320.
; See the horseRace banner for coordinates.

.executor_39_1444F8:
    DMA_SPRITE 160, 0, _horseRaceTextureSegmentRomStart, _horseRaceTextureSegmentRomEnd, _horseRaceAssetsIndexSegmentRomStart, _horseRaceAssetsIndexSegmentRomEnd, 0, 0, 0x80299500, 0, 0x8029DF00, 0x8029E200, 0x8029E400, 0x00000000
    SET_ANIM_DATA_PTR_WITH_FLAG .anim_144920
    SET_SPRITE_PALETTE 2
    SET_COORDINATES 160, 0, -100
    SET_SPRITE_SCALE 2, 2, 0
    SET_RGBA 0, 0, 0, 0
    SET_WAIT_FRAMES 1
    UPDATE_RGBA 255, 255, 255, 255, 8
    WAIT_RGBA_FINISHED
    EXECUTE_SUBROUTINE .wait_loop

.executor_40_144564:
    DMA_SPRITE 161, 0, _horseRaceTextureSegmentRomStart, _horseRaceTextureSegmentRomEnd, _horseRaceAssetsIndexSegmentRomStart, _horseRaceAssetsIndexSegmentRomEnd, 0, 0, 0x80299500, 0, 0x8029DF00, 0x8029E200, 0x8029E400, 0x00000000
    SET_ANIM_DATA_PTR_WITH_FLAG .anim_14492C
    SET_SPRITE_PALETTE 6
    SET_COORDINATES 160, 0, -50
    SET_SPRITE_SCALE 2, 2, 0
    SET_RGBA 0, 0, 0, 0
    SET_WAIT_FRAMES 1
    UPDATE_RGBA 255, 255, 255, 255, 8
    WAIT_RGBA_FINISHED
    EXECUTE_SUBROUTINE .wait_loop

