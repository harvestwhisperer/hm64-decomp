; ============================================
; Bank 21 - Dog Race
; ============================================
;
; Four cutscenes, dispatched by gCutsceneIndex at .dispatch:
;   1300: ticket stand        -> .cs_ticket_stand
;   1301: festival crowd      -> .cs_festival_crowd
;   1302: the race itself     -> .cs_race
;   1303: post-race / exit    -> .cs_post_race
;
; D_801C3F78 race-state bits (inferred from bytecode usage):
;   bit 1: player dog finished 1st    (set at .race_player_first)
;   bit 2: race has completed         (post-race gate in every NPC dispatcher)
;   bit 3: player dog finished 2nd    (set at .race_player_second)
;   bit 5: player dog is in the race  (unlocks Rick betting dialogue,
;                                      dog-entered variants for several NPCs)
; Bits 0, 4, 6 are touched but their semantics are not verified.
;
; gRaceFinishOrder[0..5]: dogs ranked 1st..6th, as u8 placement codes 1..6.
; dog1Progress..dog6Progress: per-dog race position counters used by the race tick machines.
; finishLine, progressCeiling: scratch for .race_track_finishers.

#include "entities.h"
#include "texts.h"
#include "dialogues.h"

#define MAIN_MAP_INDEX 0

.buffer 2

; 0x802F5000
.local var0, u32, 0
; 0x802F5004
.local dog1Progress, u16, 0
; 0x802F5006
.local dog2Progress, u16, 0
; 0x802F5008
.local dog3Progress, u16, 0
; 0x802F500A
.local dog4Progress, u16, 0
; 0x802F500C
.local dog5Progress, u16, 0
; 0x802F500E
.local dog6Progress, u16, 0
; 0x802F5010
.local finishLine, u16, 0
; 0x802F5012
.local progressCeiling, u16, 999

.array npcAffection, u8
.array lifeEventBits, u32
.array dailyEventBits, u32
.array gRaceFinishOrder, u8

.struct dogInfo, Dog
.struct gRacingContext, RacingContext

#define MARRIED 0

#define MARIA 0

.dispatch:
    SET_SPECIAL_BIT 13, gCutsceneCompletionFlags
    SET_SPECIAL_BIT 14, gCutsceneCompletionFlags
    SET_SPECIAL_BIT 15, gCutsceneCompletionFlags
    EXECUTE_SUBROUTINE .setup_message_box
    TOGGLE_PAUSE_ENTITIES
    BRANCH_U16_VAR_WITHIN_RANGE 1300, 1300, gCutsceneIndex, .cs_ticket_stand
    BRANCH_U16_VAR_WITHIN_RANGE 1301, 1301, gCutsceneIndex, .cs_festival_crowd
    BRANCH_U16_VAR_WITHIN_RANGE 1302, 1302, gCutsceneIndex, .cs_race
    BRANCH_U16_VAR_WITHIN_RANGE 1303, 1303, gCutsceneIndex, .cs_post_race

; ============================================================
; SHARED HELPERS
; ============================================================

.exit_cutscene:
    CLEAR_SPECIAL_BIT 0, var0
    CLEAR_SPECIAL_BIT 1, var0
    CLEAR_SPECIAL_BIT 2, var0
    SET_SPECIAL_BIT 0, gCutsceneCompletionFlags
    DEACTIVATE_SELF

.wait_loop:
    SET_WAIT_FRAMES 1
    EXECUTE_SUBROUTINE .wait_loop

.setup_message_box:
    SET_MESSAGE_INTERPOLATION -4, 0, 0
    SET_MESSAGE_BOX_ASSETS 0, 0, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 24, -64, 352
    RETURN_FROM_SUBROUTINE

.setup_player:
    SETUP_ENTITY 0, ENTITY_ASSET_PLAYER, 1
    SET_ENTITY_ANIMATIONS 0, 0, 8, 16, 24, 32, 40
    SET_BEHAVIOR_FLAGS CUTSCENE_ASSET_BEHAVIOR_TRACK_ENTITY
    RETURN_FROM_SUBROUTINE

; ============================================================
; CUTSCENE 1300 - Ticket Stand
; ============================================================
; Entered when the player visits the ticket booth.
; Mayor (text 45) and Mayor Wife (text 46) staff the counter.
; Also spawns the time announcer to gate entering the festival proper.

.cs_ticket_stand:
    SET_SPECIAL_BIT 12, gCutsceneCompletionFlags
    STOP_SEQUENCE_WITH_FADE 0, 8
    IDLE_WHILE_SEQUENCE_PLAYING 0
    SET_AUDIO_SEQUENCE 0, _racingFestivalSegmentRomStart, _racingFestivalSegmentRomEnd
    SET_AUDIO_SEQUENCE_VOLUME 0, 128, 8
    INIT_MAP_ADDITION 1, 0
    SPAWN_EXECUTOR 1, .ticket_mayor_setup
    SPAWN_EXECUTOR 2, .ticket_wife_setup
    SET_WAIT_FRAMES 1
    UPDATE_GLOBAL_RGBA 254, 254, 254, 254, 0
    SET_WAIT_FRAMES 32
    CLEAR_SPECIAL_BIT 12, gCutsceneCompletionFlags
    SPAWN_EXECUTOR 41, .announcer_tick
    DEACTIVATE_SELF

.ticket_mayor_setup:
    SETUP_ENTITY 1, ENTITY_ASSET_MAYOR, 1
    SET_ENTITY_ANIMATIONS 1, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_COORDINATES -192, 0, -32
    SET_ASSET_ROTATION SOUTHEAST

.ticket_mayor_wait:
    SET_CALLBACK_ROUTINE 0, 32768, .ticket_mayor_talk
    EXECUTE_SUBROUTINE .wait_loop

.ticket_mayor_talk:
    PAUSE_ENTITIES
    FLIP_ENTITY_DIRECTION 0
    EXECUTE_SUBROUTINE .setup_message_box
    INIT_MESSAGE_BOX_TYPE1 0, DOG_RACE_TEXT_INDEX, 45
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .ticket_mayor_wait

.ticket_wife_setup:
    SETUP_ENTITY 2, ENTITY_ASSET_MAYOR_WIFE, 1
    SET_ENTITY_ANIMATIONS 2, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_COORDINATES -192, 0, 16
    SET_ASSET_ROTATION SOUTHEAST

.ticket_wife_wait:
    SET_CALLBACK_ROUTINE 0, 32768, .ticket_wife_talk
    EXECUTE_SUBROUTINE .wait_loop

.ticket_wife_talk:
    PAUSE_ENTITIES
    FLIP_ENTITY_DIRECTION 0
    EXECUTE_SUBROUTINE .setup_message_box
    INIT_MESSAGE_BOX_TYPE1 0, DOG_RACE_TEXT_INDEX, 46
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .ticket_wife_wait

; ============================================================
; CUTSCENE 1301 - Festival Crowd
; ============================================================
; Main festival view. Spawns 13 base NPC executors (Kent, Stu, Potion
; Dealer, Rick, Popuri, Ann, Jeff, Elli, three Festival Girls, Old Man,
; Old Woman), optionally Maria (executor 14) and/or Karen (executor 15)
; based on marital state + affection, and the hour-gated time announcer.

.cs_festival_crowd:
    SET_SPECIAL_BIT 12, gCutsceneCompletionFlags
    STOP_SEQUENCE_WITH_FADE 0, 8
    IDLE_WHILE_SEQUENCE_PLAYING 0
    SET_AUDIO_SEQUENCE 0, _racingFestivalSegmentRomStart, _racingFestivalSegmentRomEnd
    SET_AUDIO_SEQUENCE_VOLUME 0, 128, 8
    SPAWN_EXECUTOR 1, .kent_setup
    SPAWN_EXECUTOR 2, .stu_setup
    SPAWN_EXECUTOR 3, .potion_dealer_setup
    SPAWN_EXECUTOR 4, .rick_setup
    SPAWN_EXECUTOR 5, .popuri_setup
    SPAWN_EXECUTOR 6, .ann_setup
    SPAWN_EXECUTOR 7, .jeff_setup
    SPAWN_EXECUTOR 8, .elli_setup
    SPAWN_EXECUTOR 9, .festival_girl1_setup
    SPAWN_EXECUTOR 10, .festival_girl2_setup
    SPAWN_EXECUTOR 11, .festival_girl3_setup
    SPAWN_EXECUTOR 12, .old_man_setup
    SPAWN_EXECUTOR 13, .old_woman_setup
    ; Decide whether to spawn Maria (slot 14) and/or Karen (slot 15):
    ;   - Married: spawn the wife if she is Maria or Karen.
    ;   - Single with high Maria affection AND dog in race: spawn Maria.
    ;   - Otherwise: no extra spawn.
    BRANCH_ON_SPECIAL_BIT MARRIED, lifeEventBits[0], .check_wife_is_maria
    BRANCH_U8_VAR_WITHIN_RANGE 0, 79, npcAffection[MARIA], .check_married_karen
    BRANCH_ON_SPECIAL_BIT 5, D_801C3F78, .spawn_maria_crowd
    EXECUTE_SUBROUTINE .check_married_karen

.spawn_maria_crowd:
    SPAWN_EXECUTOR 14, .maria_setup

.check_married_karen:
    BRANCH_ON_SPECIAL_BIT 0, lifeEventBits[0], .check_wife_is_karen

.fade_in_start_announcer:
    SET_WAIT_FRAMES 1
    UPDATE_GLOBAL_RGBA 254, 254, 254, 254, 0
    SET_WAIT_FRAMES 32
    CLEAR_SPECIAL_BIT 12, gCutsceneCompletionFlags
    SPAWN_EXECUTOR 41, .announcer_tick
    DEACTIVATE_SELF

.spawn_karen_crowd:
    SPAWN_EXECUTOR 15, .karen_setup
    EXECUTE_SUBROUTINE .fade_in_start_announcer

.check_wife_is_maria:
    BRANCH_U8_VAR_WITHIN_RANGE 0, 0, gWife, .spawn_maria_crowd
    RETURN_FROM_SUBROUTINE

.check_wife_is_karen:
    BRANCH_U8_VAR_WITHIN_RANGE 4, 4, gWife, .spawn_karen_crowd
    RETURN_FROM_SUBROUTINE

; ------------------------------------------------------------
; Time announcer (executor 41 during cutscenes 1300/1301)
; ------------------------------------------------------------
; Polls gHour each frame. At 10h/13h/16h the next race begins (texts
; 47/48/49). Between races, text 53 plays once (gated by bit 4 of
; D_801C3F78). At 18h the festival ends and all executors shut down.

.announcer_tick:
    SET_WAIT_FRAMES 1
    BRANCH_U8_VAR_WITHIN_RANGE 10, 10, gHour, .announcer_race1_start
    BRANCH_U8_VAR_WITHIN_RANGE 13, 13, gHour, .announcer_race2_start
    BRANCH_U8_VAR_WITHIN_RANGE 16, 16, gHour, .announcer_race3_start
    BRANCH_U8_VAR_WITHIN_RANGE 18, 18, gHour, .announcer_end_day
    EXECUTE_SUBROUTINE .announcer_tick

.announcer_between_races:
    BRANCH_ON_SPECIAL_BIT 4, D_801C3F78, .announcer_tick
    PAUSE_ENTITIES
    SET_MESSAGE_INTERPOLATION -4, 0, 0
    SET_MESSAGE_BOX_ASSETS 0, 1, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 0, -64, 352
    INIT_MESSAGE_BOX_TYPE1 0, DOG_RACE_TEXT_INDEX, 53
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    SET_MESSAGE_BOX_ASSETS 0, 0, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 24, -64, 352
    TOGGLE_PAUSE_ENTITIES
    SET_SPECIAL_BIT 4, D_801C3F78
    EXECUTE_SUBROUTINE .announcer_tick

.announcer_race1_start:
    BRANCH_U8_VAR_WITHIN_RANGE 1, 255, gMinutes, .announcer_tick
    PAUSE_ENTITIES
    SET_MESSAGE_INTERPOLATION -4, 0, 0
    SET_MESSAGE_BOX_ASSETS 0, 1, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 0, -64, 352
    INIT_MESSAGE_BOX_TYPE1 0, DOG_RACE_TEXT_INDEX, 47
    EXECUTE_SUBROUTINE .announcer_race_cleanup

.announcer_race2_start:
    BRANCH_U8_VAR_WITHIN_RANGE 1, 255, gMinutes, .announcer_tick
    PAUSE_ENTITIES
    SET_MESSAGE_INTERPOLATION -4, 0, 0
    SET_MESSAGE_BOX_ASSETS 0, 1, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 0, -64, 352
    INIT_MESSAGE_BOX_TYPE1 0, DOG_RACE_TEXT_INDEX, 48
    EXECUTE_SUBROUTINE .announcer_race_cleanup

.announcer_race3_start:
    BRANCH_U8_VAR_WITHIN_RANGE 1, 255, gMinutes, .announcer_between_races
    PAUSE_ENTITIES
    SET_MESSAGE_INTERPOLATION -4, 0, 0
    SET_MESSAGE_BOX_ASSETS 0, 1, 0, 0
    SET_MESSAGE_BOX_VIEW_POSITION 0, 0, -64, 352
    INIT_MESSAGE_BOX_TYPE1 0, DOG_RACE_TEXT_INDEX, 49
    EXECUTE_SUBROUTINE .announcer_race_cleanup

.announcer_end_day:
    PAUSE_ENTITIES
    SET_AUDIO_SEQUENCE_VOLUME 0, 0, 8
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    SET_WAIT_FRAMES 32
    STOP_SEQUENCE_WITH_FADE 0, 1
    DEACTIVATE_EXECUTOR 1
    DEACTIVATE_EXECUTOR 2
    DEACTIVATE_EXECUTOR 3
    DEACTIVATE_EXECUTOR 4
    DEACTIVATE_EXECUTOR 5
    DEACTIVATE_EXECUTOR 6
    DEACTIVATE_EXECUTOR 7
    DEACTIVATE_EXECUTOR 8
    DEACTIVATE_EXECUTOR 9
    DEACTIVATE_EXECUTOR 10
    DEACTIVATE_EXECUTOR 11
    DEACTIVATE_EXECUTOR 12
    DEACTIVATE_EXECUTOR 13
    DEACTIVATE_EXECUTOR 14
    DEACTIVATE_EXECUTOR 15
    IDLE_WHILE_SEQUENCE_PLAYING 0
    SET_SPECIAL_BIT 1, gCutsceneCompletionFlags
    EXECUTE_SUBROUTINE .exit_cutscene

.announcer_race_cleanup:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    UPDATE_GLOBAL_RGBA 0, 0, 0, 0, 8
    SET_WAIT_FRAMES 32
    DEACTIVATE_EXECUTOR 1
    DEACTIVATE_EXECUTOR 2
    DEACTIVATE_EXECUTOR 3
    DEACTIVATE_EXECUTOR 4
    DEACTIVATE_EXECUTOR 5
    DEACTIVATE_EXECUTOR 6
    DEACTIVATE_EXECUTOR 7
    DEACTIVATE_EXECUTOR 8
    DEACTIVATE_EXECUTOR 9
    DEACTIVATE_EXECUTOR 10
    DEACTIVATE_EXECUTOR 11
    DEACTIVATE_EXECUTOR 12
    DEACTIVATE_EXECUTOR 13
    DEACTIVATE_EXECUTOR 14
    DEACTIVATE_EXECUTOR 15
    TOGGLE_PAUSE_ENTITIES
    SET_SPECIAL_BIT 1, gCutsceneCompletionFlags
    EXECUTE_SUBROUTINE .exit_cutscene

; ------------------------------------------------------------
; NPC executors (cutscene 1301). Each follows the same pattern:
;   _setup       -- place NPC and fall through to _wait
;   _wait        -- install interaction callback, then idle
;   _on_interact -- dispatcher: post-race? dog-entered? married?
;   _talk_*      -- leaf handler, shows one INIT_MESSAGE_BOX
;   _talk_done   -- shared close: wait box closed, resume _wait
; ------------------------------------------------------------

; Kent - family of Taro. Taro is the Kent family racing dog (see texts 6, 7, 8).
;   pre-race default ............. text 5
;   player dog also in race ...... text 6  (bit 5)
;   post-race generic ............ text 7  (bit 2)
;   Kent family won .............. text 8  (bit 2 + bit 6)
.kent_setup:
    SETUP_ENTITY 1, ENTITY_ASSET_KENT, 1
    SET_ENTITY_ANIMATIONS 1, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_COORDINATES -64, 0, 144
    SET_ASSET_ROTATION SOUTHWEST

.kent_wait:
    SET_CALLBACK_ROUTINE 0, 32768, .kent_on_interact
    EXECUTE_SUBROUTINE .wait_loop

.kent_on_interact:
    PAUSE_ENTITIES
    FLIP_ENTITY_DIRECTION 0
    EXECUTE_SUBROUTINE .setup_message_box
    BRANCH_ON_SPECIAL_BIT 2, D_801C3F78, .kent_post_race
    BRANCH_ON_SPECIAL_BIT 5, D_801C3F78, .kent_talk_dog_entered
    INIT_MESSAGE_BOX_TYPE1 0, DOG_RACE_TEXT_INDEX, 5

.kent_talk_done:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .kent_wait

.kent_talk_dog_entered:
    INIT_MESSAGE_BOX_TYPE1 0, DOG_RACE_TEXT_INDEX, 6
    EXECUTE_SUBROUTINE .kent_talk_done

.kent_post_race:
    BRANCH_ON_SPECIAL_BIT 6, D_801C3F78, .kent_check_taro_won

.kent_talk_post_race:
    INIT_MESSAGE_BOX_TYPE1 0, DOG_RACE_TEXT_INDEX, 7
    EXECUTE_SUBROUTINE .kent_talk_done

.kent_check_taro_won:
    BRANCH_ON_SPECIAL_BIT 3, D_801C3F78, .kent_talk_taro_won
    EXECUTE_SUBROUTINE .kent_talk_post_race

.kent_talk_taro_won:
    INIT_MESSAGE_BOX_TYPE1 0, DOG_RACE_TEXT_INDEX, 8
    EXECUTE_SUBROUTINE .kent_talk_done

; Stu - younger brother of Kent; also cheers for Taro.
;   pre-race default ............. text 9
;   post-race generic ............ text 10 (bit 2)
;   Kent family won .............. text 11 (bit 2 + bit 6)
.stu_setup:
    SETUP_ENTITY 2, ENTITY_ASSET_STU, 1
    SET_ENTITY_ANIMATIONS 2, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_COORDINATES -96, 0, 144
    SET_ASSET_ROTATION SOUTHWEST

.stu_wait:
    SET_CALLBACK_ROUTINE 0, 32768, .stu_on_interact
    EXECUTE_SUBROUTINE .wait_loop

.stu_on_interact:
    PAUSE_ENTITIES
    FLIP_ENTITY_DIRECTION 0
    EXECUTE_SUBROUTINE .setup_message_box
    BRANCH_ON_SPECIAL_BIT 2, D_801C3F78, .stu_post_race
    INIT_MESSAGE_BOX_TYPE1 0, DOG_RACE_TEXT_INDEX, 9

.stu_talk_done:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .stu_wait

.stu_post_race:
    BRANCH_ON_SPECIAL_BIT 6, D_801C3F78, .stu_check_taro_won

.stu_talk_post_race:
    INIT_MESSAGE_BOX_TYPE1 0, DOG_RACE_TEXT_INDEX, 10
    EXECUTE_SUBROUTINE .stu_talk_done

.stu_check_taro_won:
    BRANCH_ON_SPECIAL_BIT 3, D_801C3F78, .stu_talk_taro_won
    EXECUTE_SUBROUTINE .stu_talk_post_race

.stu_talk_taro_won:
    INIT_MESSAGE_BOX_TYPE1 0, DOG_RACE_TEXT_INDEX, 11
    EXECUTE_SUBROUTINE .stu_talk_done

; Potion Shop Dealer - the owner of Taro.
;   pre-race default ............. text 2
;   post-race, lost .............. text 3  (bit 2)
;   post-race, Taro won .......... text 4  (bit 2 + bit 6)
.potion_dealer_setup:
    SETUP_ENTITY 3, ENTITY_ASSET_POTION_SHOP_DEALER, 1
    SET_ENTITY_ANIMATIONS 3, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_COORDINATES -16, 0, 144
    SET_ASSET_ROTATION SOUTHWEST

.potion_dealer_wait:
    SET_CALLBACK_ROUTINE 0, 32768, .potion_dealer_on_interact
    EXECUTE_SUBROUTINE .wait_loop

.potion_dealer_on_interact:
    PAUSE_ENTITIES
    FLIP_ENTITY_DIRECTION 0
    EXECUTE_SUBROUTINE .setup_message_box
    BRANCH_ON_SPECIAL_BIT 2, D_801C3F78, .potion_dealer_post_race
    INIT_MESSAGE_BOX_TYPE1 0, DOG_RACE_TEXT_INDEX, 2

.potion_dealer_talk_done:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .potion_dealer_wait

.potion_dealer_post_race:
    BRANCH_ON_SPECIAL_BIT 6, D_801C3F78, .potion_dealer_check_taro_won

.potion_dealer_talk_lost:
    INIT_MESSAGE_BOX_TYPE1 0, DOG_RACE_TEXT_INDEX, 3
    EXECUTE_SUBROUTINE .potion_dealer_talk_done

.potion_dealer_check_taro_won:
    BRANCH_ON_SPECIAL_BIT 3, D_801C3F78, .potion_dealer_talk_taro_won
    EXECUTE_SUBROUTINE .potion_dealer_talk_lost

.potion_dealer_talk_taro_won:
    INIT_MESSAGE_BOX_TYPE1 0, DOG_RACE_TEXT_INDEX, 4
    EXECUTE_SUBROUTINE .potion_dealer_talk_done

; Rick - runs the betting counter.
;   pre-race default ............. text 55
;   player dog in race ........... opens DIALOGUE_DOG_RACE betting UI (bit 5)
;   post-race .................... text 14 (bit 2)
.rick_setup:
    SETUP_ENTITY 4, ENTITY_ASSET_RICK, 1
    SET_ENTITY_ANIMATIONS 4, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_COORDINATES 160, 0, 24
    SET_ASSET_ROTATION SOUTHWEST

.rick_wait:
    SET_CALLBACK_ROUTINE 0, 32768, .rick_on_interact
    EXECUTE_SUBROUTINE .wait_loop

.rick_on_interact:
    PAUSE_ENTITIES
    FLIP_ENTITY_DIRECTION 0
    EXECUTE_SUBROUTINE .setup_message_box
    BRANCH_ON_SPECIAL_BIT 2, D_801C3F78, .rick_talk_lost_bet
    BRANCH_ON_SPECIAL_BIT 5, D_801C3F78, .rick_betting_dialogue
    INIT_MESSAGE_BOX_TYPE1 0, DOG_RACE_TEXT_INDEX, 55

.rick_talk_done:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .rick_wait

.rick_betting_dialogue:
    INIT_DIALOGUE_SESSION 0, DIALOGUE_DOG_RACE, 1
    WAIT_FOR_DIALOGUE_INPUT 0
    TOGGLE_PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .rick_wait

.rick_talk_lost_bet:
    INIT_MESSAGE_BOX_TYPE1 0, DOG_RACE_TEXT_INDEX, 14
    EXECUTE_SUBROUTINE .rick_talk_done

; Popuri (bachelorette, NPC index 1).
;   pre-race default ............. text 16
;   player dog in race ........... text 15 (bit 5)
;   wife == Popuri ............... text 17
;   post-race .................... text 18 (bit 2)
.popuri_setup:
    SETUP_ENTITY 5, ENTITY_ASSET_POPURI, 1
    SET_ENTITY_ANIMATIONS 5, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_COORDINATES -128, 0, 48
    SET_ASSET_ROTATION SOUTHWEST

.popuri_wait:
    SET_CALLBACK_ROUTINE 0, 32768, .popuri_on_interact
    EXECUTE_SUBROUTINE .wait_loop

.popuri_on_interact:
    PAUSE_ENTITIES
    FLIP_ENTITY_DIRECTION 0
    EXECUTE_SUBROUTINE .setup_message_box
    BRANCH_ON_SPECIAL_BIT 2, D_801C3F78, .popuri_talk_running_hard
    BRANCH_ON_SPECIAL_BIT 0, lifeEventBits[0], .popuri_check_wife
    BRANCH_ON_SPECIAL_BIT 5, D_801C3F78, .popuri_talk_good_luck
    INIT_MESSAGE_BOX_TYPE1 0, DOG_RACE_TEXT_INDEX, 16

.popuri_talk_done:
    WAIT_MESSAGE_BOX_CLOSED 0
    RESET_MESSAGE_BOX_AVATAR 0
    TOGGLE_PAUSE_ENTITIES
    EXECUTE_SUBROUTINE .popuri_wait

.popuri_check_wife:
    BRANCH_U8_VAR_WITHIN_RANGE 1, 1, gWife, .popuri_wife_talk_chick_race
    RETURN_FROM_SUBROUTINE

.popuri_talk_good_luck:
    INIT_MESSAGE_BOX_TYPE1 0, DOG_RACE_TEXT_INDEX, 15
    EXECUTE_SUBROUTINE .popuri_talk_done

.popuri_wife_talk_chick_race:
    INIT_MESSAGE_BOX_TYPE1 0, DOG_RACE_TEXT_INDEX, 17
    EXECUTE_SUBROUTINE .popuri_talk_done

.popuri_talk_running_hard:
    INIT_MESSAGE_BOX_TYPE1 0, DOG_RACE_TEXT_INDEX, 18
    EXECUTE_SUBROUTINE .popuri_talk_done

; Ann (bachelorette, NPC index 3).
;   pre-race default ............. text 23
;   player dog in race ........... text 24 (bit 5)
;   wife == Ann, no dog .......... text 27
;   wife == Ann, dog in race ..... text 26 (bit 5)
;   post-race .................... text 25 (bit 2)
.ann_setup:
    SETUP_ENTITY 6, ENTITY_ASSET_ANN, 1
    SET_ENTITY_ANIMATIONS 6, 0, 8, 0, 0, 0, 0
    SET_BEHAVIOR_FLAGS 0
    SET_COORDINATES 64, 0, -8
    SET_ASSET_ROTATION SOUTHWEST

.ann_wait:
    SET_CALLBACK_ROUTINE 0, 32768, .ann_on_interact
    EXECUTE_SUBROUTINE .wait_loop

.ann_on_interact:
    PAUSE_ENTITIES
    FLIP_ENTITY_DIRECTION 0
    EXECUTE_SUBROUTINE .setup_message_box
    BRANCH_ON_SPECIAL_BIT 2, D_801C3F78, .ann_talk_affection
    BRANCH_ON_SPECIAL_BIT 0, lifeEventBits[0], .ann_check_wife
    BRANCH_ON_SPECIAL_BIT 5, D_801C3F78, .ann_talk_pray
    INIT_MESSAGE_BOX_TYPE1 0, DOG_RACE_TEXT_INDEX, 23

.ann_talk_done:
    WAIT_MESSAGE_BOX_CLOSED 0
